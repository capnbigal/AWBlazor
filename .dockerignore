# Build output
**/bin/
**/obj/
**/out/
**/publish/

# IDE
.vs/
.vscode/
.idea/
**/*.user

# OS cruft
.DS_Store
Thumbs.db

# Git metadata
.git/
.gitignore
.gitattributes

# Tests + related — not shipped in the image
AWBlazorApp.Tests/
export/
docs/

# Dev/local files
*.md
# UserGuide markdown content is read at runtime by MarkdownBlogService and copied to publish
# output via the .csproj <Content Include=...> rules. Re-include it after the *.md exclude.
!src/AWBlazorApp/Features/UserGuide/Content/_posts/**
!src/AWBlazorApp/Features/UserGuide/Content/_pages/**
!src/AWBlazorApp/Features/UserGuide/Content/_includes/**
!src/AWBlazorApp/Features/UserGuide/Content/_videos/**

# Secrets (never in image)
.env
.env.*
!.env.template
**/secrets.json
**/appsettings.Development.json

# Scripts that aren't baked into the app
scripts/
deployment/

# CI configs
.github/
