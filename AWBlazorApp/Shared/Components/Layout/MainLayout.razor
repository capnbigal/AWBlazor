@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject PersistentComponentState AppState

<MudThemeProvider @rendermode="InteractiveServer" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<NotificationListener />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2 app-bar-title">AWBlazor</MudText>
        <MudSpacer />
        <GlobalSearch />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleDarkMode" />
        <AuthorizeView>
            <Authorized>
                @{
                    var userName = context.User.Identity?.Name ?? "";
                    var initials = string.Join("", userName.Split('@')[0]
                        .Split(new[] { '.', '_', '-' }, StringSplitOptions.RemoveEmptyEntries)
                        .Take(2)
                        .Select(p => char.ToUpper(p[0])));
                    if (initials.Length == 0) initials = "?";
                }
                <MudAvatar Color="Color.Secondary" Size="Size.Small" Class="mr-2">@initials</MudAvatar>
                <MudText Class="mr-3 app-bar-username" Typo="Typo.body2">@userName</MudText>
                <form action="Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="" />
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Text" Color="Color.Inherit">
                        Sign out
                    </MudButton>
                </form>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="Account/Login" Variant="Variant.Text" Color="Color.Inherit">Sign in</MudButton>
                <MudButton Href="Account/Register" Variant="Variant.Text" Color="Color.Inherit">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode;
    private bool _drawerOpen = true;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private PersistingComponentStateSubscription? _persistingSubscription;
    private const string StateKey = "theme.isDarkMode";

    // Dark-mode handoff across prerender → interactive render:
    //   1. On the SSR (prerender) pass HttpContext is available, so we read the "darkMode"
    //      cookie and seed _isDarkMode. MudThemeProvider paints dark immediately.
    //   2. We persist that value via PersistentComponentState so the subsequent interactive
    //      render picks it up on its first pass instead of defaulting to false and causing
    //      the brief light-mode flash.
    //   3. OnAfterRenderAsync still reads the cookie via JS as a final safety net for
    //      environments where prerendering is disabled.
    protected override void OnInitialized()
    {
        _persistingSubscription = AppState.RegisterOnPersisting(PersistThemeState);

        if (AppState.TryTakeFromJson<bool>(StateKey, out var persisted))
        {
            _isDarkMode = persisted;
            return;
        }

        if (HttpContext is not null
            && HttpContext.Request.Cookies.TryGetValue("darkMode", out var raw)
            && bool.TryParse(raw, out var isDark))
        {
            _isDarkMode = isDark;
        }
    }

    private Task PersistThemeState()
    {
        AppState.PersistAsJson(StateKey, _isDarkMode);
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var fromCookie = await JS.InvokeAsync<bool>("getDarkModeCookie");
            if (fromCookie != _isDarkMode)
            {
                _isDarkMode = fromCookie;
                StateHasChanged();
            }
        }
        catch (JSException)
        {
            // JS not ready yet — the inline <head> script handles the visual state,
            // so light mode is a safe default until the user toggles.
        }
    }

    public void Dispose() => _persistingSubscription?.Dispose();

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("setDarkModeCookie", _isDarkMode);
    }
}
