@*
    Searchable checkbox list of distinct values for <TEntity>.<PropertyName>. Backed by
    IDistinctValuesProvider which builds a SELECT DISTINCT against the property via reflection.
    On Apply, the selected values are written into the shared ColumnFilterState; on Clear,
    the selection for that column is removed. Either outcome closes with Ok so the parent
    triggers a grid reload.
*@
@typeparam TEntity where TEntity : class
@inject IDistinctValuesProvider Provider

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Filter: @Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField T="string"
                          @bind-Value="search"
                          @bind-Value:after="ReloadAsync"
                          Placeholder="Search..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300" />

            @if (loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (values.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No values match.</MudText>
            }
            else
            {
                <MudStack Row="true" Spacing="2">
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="SelectAll">Select all</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="SelectNone">Select none</MudButton>
                </MudStack>
                <div style="max-height: 320px; overflow-y: auto;">
                    @foreach (var value in values)
                    {
                        var label = value?.ToString() ?? "(null)";
                        var key = KeyFor(value);
                        <MudCheckBox T="bool"
                                     Value="@(selection.Contains(key))"
                                     ValueChanged="@(checked_ => Toggle(value, checked_))"
                                     Label="@label"
                                     Dense="true" />
                    }
                </div>
                @if (truncated)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Showing first @values.Count values — refine the search to narrow further.
                    </MudText>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="ClearAndClose">Clear filter</MudButton>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Apply">Apply</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter, EditorRequired] public string PropertyName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public ColumnFilterState State { get; set; } = null!;

    private const int PageSize = 200;

    private string? search;
    private bool loading;
    private bool truncated;
    private List<object?> values = new();
    // Keys mirror the value's stringified form — HashSet<object?> equality is finicky for
    // boxed ints, so we use a string-keyed working copy and rebuild the state on Apply.
    private HashSet<string> selection = new(StringComparer.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        // Seed the working set from existing filter state.
        foreach (var v in State.GetOrCreate(PropertyName))
            selection.Add(KeyFor(v));
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        loading = true;
        try
        {
            // Ask for one more than the page size to detect truncation.
            var fetched = await Provider.GetDistinctValuesAsync<TEntity>(PropertyName, search, PageSize + 1, CancellationToken.None);
            truncated = fetched.Count > PageSize;
            values = fetched.Take(PageSize).ToList();
        }
        finally
        {
            loading = false;
        }
    }

    private static string KeyFor(object? value) => value?.ToString() ?? "\0null\0";

    private void Toggle(object? value, bool on)
    {
        var key = KeyFor(value);
        if (on) selection.Add(key);
        else selection.Remove(key);
    }

    private void SelectAll()
    {
        foreach (var v in values) selection.Add(KeyFor(v));
    }

    private void SelectNone() => selection.Clear();

    private void Apply()
    {
        var set = State.GetOrCreate(PropertyName);
        set.Clear();
        foreach (var v in values)
        {
            if (selection.Contains(KeyFor(v)))
                set.Add(v);
        }
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void ClearAndClose()
    {
        State.Clear(PropertyName);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
