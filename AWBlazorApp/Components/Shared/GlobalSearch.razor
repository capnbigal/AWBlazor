        new("Permissions", "admin/permissions", "Admin", Icons.Material.Filled.Security),
    ];

    private Task<IEnumerable<SearchItem>> SearchAsync(string? value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(allItems.Take(10));

        var results = allItems
            .Where(i => i.Name.Contains(value, StringComparison.OrdinalIgnoreCase)
                     || i.Category.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(15);

        return Task.FromResult(results);
    }

    private void OnItemSelected(SearchItem? item)
    {
        selectedItem = item;
        if (item is not null)
        {
            selectedItem = null;
            Navigation.NavigateTo(item.Url);
        }
    }

    public sealed record SearchItem(string Name, string Url, string Category, string Icon);
}
