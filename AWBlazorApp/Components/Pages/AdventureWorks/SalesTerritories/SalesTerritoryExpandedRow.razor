@using AWBlazorApp.Data.Entities.AdventureWorks
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="my-2" />
}
else
{
    <div class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Revenue</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Sales YTD: <strong>@(territory?.SalesYtd.ToString("C0") ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Sales last year: <strong>@(territory?.SalesLastYear.ToString("C0") ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Cost YTD: <strong>@(territory?.CostYtd.ToString("C0") ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Cost last year: <strong>@(territory?.CostLastYear.ToString("C0") ?? "—")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Coverage</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Country: <strong>@(territory?.CountryRegionCode ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Customers: <strong>@customerCount.ToString("N0")</strong></MudText>
                    <MudText Typo="Typo.body2">Salespeople: <strong>@salespeople.Count</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Order summary</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Total orders: <strong>@orderCount.ToString("N0")</strong></MudText>
                    <MudText Typo="Typo.body2">Total revenue: <strong>@totalRevenue.ToString("C0")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Margin</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    @if (territory is not null && territory.SalesYtd > 0)
                    {
                        var margin = (1 - territory.CostYtd / territory.SalesYtd) * 100;
                        <MudText Typo="Typo.body2">YTD margin: <strong>@margin.ToString("N1")%</strong></MudText>
                    }
                </MudStack>
            </MudItem>
        </MudGrid>

        @if (salespeople.Count > 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-1">Assigned salespeople</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead><tr><th>ID</th><th style="text-align:right">Quota</th><th style="text-align:right">Sales YTD</th><th style="text-align:right">Last year</th><th style="text-align:right">Bonus</th></tr></thead>
                <tbody>
                    @foreach (var sp in salespeople)
                    {
                        <tr>
                            <td><MudLink Href="aw/sales-persons" Color="Color.Primary">@sp.Id</MudLink></td>
                            <td style="text-align:right">@(sp.SalesQuota?.ToString("C0") ?? "—")</td>
                            <td style="text-align:right">@sp.SalesYtd.ToString("C0")</td>
                            <td style="text-align:right">@sp.SalesLastYear.ToString("C0")</td>
                            <td style="text-align:right">@sp.Bonus.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </div>
}

@code {
    [Parameter] public int TerritoryId { get; set; }

    private bool loading = true;
    private SalesTerritory? territory;
    private int customerCount;
    private int orderCount;
    private decimal totalRevenue;
    private List<SalesPerson> salespeople = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        territory = await db.SalesTerritories.AsNoTracking().FirstOrDefaultAsync(t => t.Id == TerritoryId);

        customerCount = await db.Customers.AsNoTracking().Where(c => c.TerritoryId == TerritoryId).CountAsync();

        var orders = await db.SalesOrderHeaders.AsNoTracking()
            .Where(o => o.TerritoryId == TerritoryId)
            .ToListAsync();
        orderCount = orders.Count;
        totalRevenue = orders.Sum(o => o.TotalDue);

        salespeople = await db.SalesPersons.AsNoTracking()
            .Where(sp => sp.TerritoryId == TerritoryId)
            .OrderByDescending(sp => sp.SalesYtd)
            .ToListAsync();

        loading = false;
    }
}
