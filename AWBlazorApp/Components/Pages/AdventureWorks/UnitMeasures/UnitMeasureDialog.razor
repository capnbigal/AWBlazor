@using AWBlazorApp.Data.Entities.AdventureWorks
@using AWBlazorApp.Models.AdventureWorks
@using AWBlazorApp.Services.AdventureWorksAudit
@using AWBlazorApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateUnitMeasureRequest> CreateValidator
@inject MudFormValidator<UpdateUnitMeasureRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create unit of measure" : $"Edit {Model!.UnitMeasureCode}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@createModel.UnitMeasureCode" ValueChanged="@((string? v) => createModel = createModel with { UnitMeasureCode = v })" Label="Code" Variant="Variant.Outlined" Required="true" MaxLength="3" HelperText="Up to 3 characters — primary key" />
                    </MudItem>
                    <MudItem xs="12" sm="8">
                        <MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4"><MudTextField Value="@Model!.UnitMeasureCode" Label="Code" Variant="Variant.Outlined" Disabled="true" HelperText="Code is the primary key and cannot be changed" /></MudItem>
                    <MudItem xs="12" sm="8">
                        <MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public UnitMeasureDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateUnitMeasureRequest createModel = new();
    private UpdateUnitMeasureRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null) updateModel = new UpdateUnitMeasureRequest { Name = Model.Name };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var code = (createModel.UnitMeasureCode ?? string.Empty).Trim();
                if (await db.UnitMeasures.AnyAsync(t => t.UnitMeasureCode == code))
                {
                    Snackbar.Add($"Code '{code}' already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                db.UnitMeasures.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.UnitMeasureAuditLogs.Add(UnitMeasureAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.UnitMeasureCode));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.UnitMeasures.FirstOrDefaultAsync(t => t.UnitMeasureCode == Model!.UnitMeasureCode);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = UnitMeasureAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.UnitMeasureAuditLogs.Add(UnitMeasureAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.UnitMeasureCode));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
