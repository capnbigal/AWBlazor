@* Placeholder dialog so the Components.Pages.AdventureWorks.BusinessEntities folder has the
   same shape as every other entity folder. BusinessEntity has no editable data of its own;
   the Index page handles create/delete via simple confirmation message boxes instead. *@
@using AWBlazorApp.Models.AdventureWorks

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">Business entity</MudText></TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2">
            BusinessEntity has no editable data of its own — it's just a surrogate key. Use
            the "New business entity" button on the index page to allocate a new id.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public BusinessEntityDto? Model { get; set; }

    private void Close() => MudDialog.Close();
}
