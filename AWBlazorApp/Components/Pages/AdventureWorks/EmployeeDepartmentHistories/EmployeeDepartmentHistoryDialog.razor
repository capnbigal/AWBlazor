@using AWBlazorApp.Data.Entities.AdventureWorks
@using AWBlazorApp.Models.AdventureWorks
@using AWBlazorApp.Services.AdventureWorksAudit
@using AWBlazorApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateEmployeeDepartmentHistoryRequest> CreateValidator
@inject MudFormValidator<UpdateEmployeeDepartmentHistoryRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create assignment" : $"Edit assignment ({Model!.BusinessEntityId}/{Model.DepartmentId}/{Model.ShiftId}/{Model.StartDate:yyyy-MM-dd})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.BusinessEntityId" ValueChanged="@((int v) => createModel = createModel with { BusinessEntityId = v })" Label="Employee" Required="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="short" Value="@createModel.DepartmentId" ValueChanged="@((short v) => createModel = createModel with { DepartmentId = v })" Label="Department" Required="true" Items="_departments" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="byte" Value="@createModel.ShiftId" ValueChanged="@((byte v) => createModel = createModel with { ShiftId = v })" Label="Shift" Required="true" Items="_shifts" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@createModel.StartDate" DateChanged="@((DateTime? v) => createModel = createModel with { StartDate = v ?? DateTime.UtcNow.Date })" Label="Start date" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudDatePicker Date="@createModel.EndDate" DateChanged="@((DateTime? v) => createModel = createModel with { EndDate = v })" Label="End date" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudDatePicker Date="@updateModel.EndDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { EndDate = v })" Label="End date" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public EmployeeDepartmentHistoryDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateEmployeeDepartmentHistoryRequest createModel = new() { StartDate = DateTime.UtcNow.Date };
    private UpdateEmployeeDepartmentHistoryRequest updateModel = new();
    private bool saving;
    private List<LookupItem<short>> _departments = [];
    private List<LookupItem<byte>> _shifts = [];

    protected override async Task OnInitializedAsync()
    {
        _departments = await Lookup.GetDepartmentsAsync();
        _shifts = await Lookup.GetShiftsAsync();

        if (Model is not null)
        {
            updateModel = new UpdateEmployeeDepartmentHistoryRequest { EndDate = Model.EndDate };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var startDate = createModel.StartDate.Date;
                if (await db.EmployeeDepartmentHistories.AnyAsync(x =>
                        x.BusinessEntityId == createModel.BusinessEntityId
                        && x.DepartmentId == createModel.DepartmentId
                        && x.ShiftId == createModel.ShiftId
                        && x.StartDate == startDate))
                {
                    Snackbar.Add("Assignment with that key already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                db.EmployeeDepartmentHistories.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.EmployeeDepartmentHistoryAuditLogs.Add(EmployeeDepartmentHistoryAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.EmployeeDepartmentHistories
                    .FirstOrDefaultAsync(t => t.BusinessEntityId == Model!.BusinessEntityId
                        && t.DepartmentId == Model.DepartmentId
                        && t.ShiftId == Model.ShiftId
                        && t.StartDate == Model.StartDate);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = EmployeeDepartmentHistoryAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.EmployeeDepartmentHistoryAuditLogs.Add(EmployeeDepartmentHistoryAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
