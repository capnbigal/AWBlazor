@using AWBlazorApp.Data.Entities.AdventureWorks
@using AWBlazorApp.Models.AdventureWorks
@using AWBlazorApp.Services.AdventureWorksAudit
@using AWBlazorApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateProductProductPhotoRequest> CreateValidator
@inject MudFormValidator<UpdateProductProductPhotoRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Link a photo to a product" : $"Edit link ({Model!.ProductId}, {Model.ProductPhotoId})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.ProductId" ValueChanged="@((int v) => createModel = createModel with { ProductId = v })" Label="Product" SearchFunc="Lookup.SearchProductsAsync" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" Value="@createModel.ProductPhotoId" ValueChanged="@((int v) => createModel = createModel with { ProductPhotoId = v })" Label="Photo id" Variant="Variant.Outlined" Required="true" Min="1" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch T="bool" Value="@createModel.Primary" ValueChanged="@((bool v) => createModel = createModel with { Primary = v })" Label="Primary photo for product" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudSwitch T="bool" Value="@(updateModel.Primary ?? false)" ValueChanged="@((bool v) => updateModel = updateModel with { Primary = v })" Label="Primary photo for product" Color="Color.Primary" />
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ProductProductPhotoDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateProductProductPhotoRequest createModel = new();
    private UpdateProductProductPhotoRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateProductProductPhotoRequest { Primary = Model.Primary };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.ProductProductPhotos.AnyAsync(x =>
                        x.ProductId == createModel.ProductId && x.ProductPhotoId == createModel.ProductPhotoId))
                {
                    Snackbar.Add("Link already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.ProductProductPhotos.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.ProductProductPhotoAuditLogs.Add(ProductProductPhotoAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.ProductProductPhotos.FirstOrDefaultAsync(t =>
                    t.ProductId == Model!.ProductId && t.ProductPhotoId == Model.ProductPhotoId);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = ProductProductPhotoAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.ProductProductPhotoAuditLogs.Add(ProductProductPhotoAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
