@using AWBlazorApp.Data.Entities.AdventureWorks
@using AWBlazorApp.Models.AdventureWorks
@using AWBlazorApp.Services.AdventureWorksAudit
@using AWBlazorApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateWorkOrderRequest> CreateValidator
@inject MudFormValidator<UpdateWorkOrderRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create work order" : $"Edit work order #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.ProductId" ValueChanged="@((int v) => createModel = createModel with { ProductId = v })" SearchFunc="SearchProductsAsync" Label="Product" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" Value="@createModel.OrderQty" ValueChanged="@((int v) => createModel = createModel with { OrderQty = v })" Label="Order qty" Variant="Variant.Outlined" Required="true" Min="1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="short" Value="@createModel.ScrappedQty" ValueChanged="@((short v) => createModel = createModel with { ScrappedQty = v })" Label="Scrapped qty" Variant="Variant.Outlined" Min="0" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="short" Value="@(createModel.ScrapReasonId ?? 0)" ValueChanged="@((short v) => createModel = createModel with { ScrapReasonId = v == 0 ? null : v })" Label="Scrap reason" Items="_scrapReasons" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.StartDate" DateChanged="@((DateTime? v) => createModel = createModel with { StartDate = v ?? DateTime.UtcNow.Date })" Label="Start" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.DueDate" DateChanged="@((DateTime? v) => createModel = createModel with { DueDate = v ?? DateTime.UtcNow.Date })" Label="Due" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.EndDate" DateChanged="@((DateTime? v) => createModel = createModel with { EndDate = v })" Label="End" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@(updateModel.ProductId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { ProductId = v == 0 ? null : v })" SearchFunc="SearchProductsAsync" Label="Product" InitialDisplayText="@_productDisplay" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int?" Value="@updateModel.OrderQty" ValueChanged="@((int? v) => updateModel = updateModel with { OrderQty = v })" Label="Order qty" Variant="Variant.Outlined" Clearable="true" Min="1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="short?" Value="@updateModel.ScrappedQty" ValueChanged="@((short? v) => updateModel = updateModel with { ScrappedQty = v })" Label="Scrapped qty" Variant="Variant.Outlined" Clearable="true" Min="0" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="short" Value="@(updateModel.ScrapReasonId ?? 0)" ValueChanged="@((short v) => updateModel = updateModel with { ScrapReasonId = v == 0 ? null : v })" Label="Scrap reason" Items="_scrapReasons" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.StartDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { StartDate = v })" Label="Start" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.DueDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { DueDate = v })" Label="Due" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.EndDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { EndDate = v })" Label="End" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public WorkOrderDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateWorkOrderRequest createModel = new() { StartDate = DateTime.UtcNow.Date, DueDate = DateTime.UtcNow.Date };
    private UpdateWorkOrderRequest updateModel = new();
    private bool saving;
    private List<LookupItem<short>> _scrapReasons = [];
    private string? _productDisplay;

    protected override async Task OnInitializedAsync()
    {
        _scrapReasons = await Lookup.GetScrapReasonsAsync();

        if (Model is not null)
        {
            updateModel = new UpdateWorkOrderRequest
            {
                ProductId = Model.ProductId,
                OrderQty = Model.OrderQty,
                ScrappedQty = Model.ScrappedQty,
                StartDate = Model.StartDate,
                EndDate = Model.EndDate,
                DueDate = Model.DueDate,
                ScrapReasonId = Model.ScrapReasonId,
            };
            _productDisplay = await Lookup.GetProductNameAsync(Model.ProductId);
        }
    }

    private Task<IEnumerable<LookupItem<int>>> SearchProductsAsync(string query) => Lookup.SearchProductsAsync(query);

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate required FK
                if (!await db.Products.AnyAsync(x => x.Id == createModel.ProductId))
                { Snackbar.Add($"Product #{createModel.ProductId} does not exist.", Severity.Error); return; }
                // Validate optional FK
                if (createModel.ScrapReasonId.HasValue && !await db.ScrapReasons.AnyAsync(x => x.Id == createModel.ScrapReasonId.Value))
                { Snackbar.Add($"Scrap reason #{createModel.ScrapReasonId.Value} does not exist.", Severity.Error); return; }

                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.WorkOrders.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                var reloaded = await db.WorkOrders.AsNoTracking().FirstAsync(x => x.Id == entity.Id);
                db.WorkOrderAuditLogs.Add(WorkOrderAuditService.RecordCreate(reloaded, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.WorkOrders.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = WorkOrderAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FKs on update
                if (updateModel.ProductId.HasValue && !await db.Products.AnyAsync(x => x.Id == updateModel.ProductId.Value))
                { Snackbar.Add($"Product #{updateModel.ProductId.Value} does not exist.", Severity.Error); return; }
                if (updateModel.ScrapReasonId.HasValue && !await db.ScrapReasons.AnyAsync(x => x.Id == updateModel.ScrapReasonId.Value))
                { Snackbar.Add($"Scrap reason #{updateModel.ScrapReasonId.Value} does not exist.", Severity.Error); return; }
                db.WorkOrderAuditLogs.Add(WorkOrderAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
