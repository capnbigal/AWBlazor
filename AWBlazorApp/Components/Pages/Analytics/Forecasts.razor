@page "/analytics/forecasts"
@attribute [Authorize]
@using AWBlazorApp.Features.Forecasting.Domain
@using AWBlazorApp.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AnalyticsCacheService Cache

<PageTitle>Forecast analytics</PageTitle>

<MudStack Spacing="4">
    <MudText Typo="Typo.h4">Forecast analytics</MudText>

    @if (loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">Loading forecast data...</MudText>
    }
    else
    {
        @* ── KPI row ────────────────────────────────────────────────────────── *@
        <MudGrid>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Primary"
                         Value="@data.ActiveForecasts.ToString("N0")" Label="Active forecasts" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.GppGood" Color="Color.Success"
                         Value="@($"{data.AvgAccuracy:N1}%")" Label="Avg accuracy" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.Schedule" Color="Color.Info"
                         Value="@data.UpcomingEvaluations.ToString("N0")" Label="Upcoming evaluations" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Warning"
                         Value="@data.TotalEvaluated.ToString("N0")" Label="Total evaluated" />
            </MudItem>
        </MudGrid>

        @* ── Accuracy by method ─────────────────────────────────────────────── *@
        @if (data.AccuracyByMethodLabels.Length > 0)
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Forecast accuracy by method</MudText>
                <MudChart T="double" ChartType="ChartType.Bar"
                          ChartSeries="@data.AccuracyByMethodSeries"
                          XAxisLabels="@data.AccuracyByMethodLabels"
                          Width="100%" Height="320px" />
            </MudPaper>
        }

        @* ── Recently evaluated ─────────────────────────────────────────────── *@
        @if (data.RecentlyEvaluated.Count > 0)
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Recently evaluated</MudText>
                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Forecast</th>
                            <th>Period</th>
                            <th style="text-align:right">Forecasted</th>
                            <th style="text-align:right">Actual</th>
                            <th style="text-align:right">Variance %</th>
                            <th>Evaluated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in data.RecentlyEvaluated)
                        {
                            <tr>
                                <td><strong>@row.ForecastName</strong></td>
                                <td>@row.PeriodDate.ToString("yyyy-MM")</td>
                                <td style="text-align:right">@row.ForecastedValue.ToString("N2")</td>
                                <td style="text-align:right">@row.ActualValue.ToString("N2")</td>
                                <td style="text-align:right">
                                    <MudText Color="@VarianceColor(row.VariancePercent)">@($"{row.VariancePercent:N1}%")</MudText>
                                </td>
                                <td>@row.EvaluatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }

        @* ── Upcoming evaluations ───────────────────────────────────────────── *@
        @if (data.UpcomingPoints.Count > 0)
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Upcoming evaluations</MudText>
                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Forecast</th>
                            <th>Data source</th>
                            <th>Period</th>
                            <th style="text-align:right">Forecasted value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in data.UpcomingPoints)
                        {
                            <tr>
                                <td><strong>@row.ForecastName</strong></td>
                                <td>@row.DataSource</td>
                                <td>@row.PeriodDate.ToString("yyyy-MM")</td>
                                <td style="text-align:right">@row.ForecastedValue.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }
    }
</MudStack>

@code {
    private bool loading = true;
    private ForecastAnalyticsData data = new();

    protected override async Task OnInitializedAsync()
    {
        data = await Cache.GetOrCreateAsync(Cache.Key("forecasts-analytics", "all"), LoadDataAsync);
        loading = false;
    }

    private async Task<ForecastAnalyticsData> LoadDataAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var result = new ForecastAnalyticsData();

        var now = DateTime.UtcNow;
        var in30Days = now.AddDays(30);
        var in90Days = now.AddDays(90);

        // KPIs
        result.ActiveForecasts = await db.ForecastDefinitions.AsNoTracking()
            .CountAsync(f => f.Status == ForecastStatus.Active && f.DeletedDate == null);

        var allEvaluated = await db.ForecastDataPoints.AsNoTracking()
            .Where(dp => dp.ActualValue != null)
            .Select(dp => new { dp.VariancePercent })
            .ToListAsync();

        result.TotalEvaluated = allEvaluated.Count;
        if (allEvaluated.Count > 0)
        {
            var meanAbsVariance = allEvaluated.Average(dp => (double)Math.Abs(dp.VariancePercent ?? 0));
            result.AvgAccuracy = 100 - meanAbsVariance;
        }

        result.UpcomingEvaluations = await db.ForecastDataPoints.AsNoTracking()
            .CountAsync(dp => dp.PeriodDate <= in30Days && dp.PeriodDate >= now && dp.ActualValue == null);

        // Accuracy by method
        var methodAccuracy = await db.ForecastDataPoints.AsNoTracking()
            .Where(dp => dp.ActualValue != null)
            .Join(db.ForecastDefinitions.AsNoTracking().Where(f => f.DeletedDate == null),
                dp => dp.ForecastDefinitionId, f => f.Id,
                (dp, f) => new { f.Method, dp.VariancePercent })
            .GroupBy(x => x.Method)
            .Select(g => new { Method = g.Key, AvgAbsVariance = g.Average(x => (double)Math.Abs(x.VariancePercent ?? 0)) })
            .OrderBy(x => x.Method)
            .ToListAsync();

        if (methodAccuracy.Count > 0)
        {
            result.AccuracyByMethodLabels = methodAccuracy.Select(x => x.Method.ToString()).ToArray();
            result.AccuracyByMethodSeries =
            [
                new ChartSeries<double> { Name = "Avg |Variance %|", Data = methodAccuracy.Select(x => x.AvgAbsVariance).ToArray() },
            ];
        }

        // Recently evaluated (last 15)
        result.RecentlyEvaluated = await db.ForecastDataPoints.AsNoTracking()
            .Where(dp => dp.ActualValue != null)
            .OrderByDescending(dp => dp.EvaluatedDate)
            .Take(15)
            .Join(db.ForecastDefinitions.AsNoTracking(),
                dp => dp.ForecastDefinitionId, f => f.Id,
                (dp, f) => new EvaluatedRow
                {
                    ForecastName = f.Name,
                    PeriodDate = dp.PeriodDate,
                    ForecastedValue = dp.ForecastedValue,
                    ActualValue = dp.ActualValue!.Value,
                    VariancePercent = dp.VariancePercent ?? 0,
                    EvaluatedDate = dp.EvaluatedDate!.Value,
                })
            .ToListAsync();

        // Upcoming evaluations (next 15 within 90 days)
        result.UpcomingPoints = await db.ForecastDataPoints.AsNoTracking()
            .Where(dp => dp.ActualValue == null && dp.PeriodDate >= now && dp.PeriodDate <= in90Days)
            .OrderBy(dp => dp.PeriodDate)
            .Take(15)
            .Join(db.ForecastDefinitions.AsNoTracking().Where(f => f.DeletedDate == null),
                dp => dp.ForecastDefinitionId, f => f.Id,
                (dp, f) => new UpcomingRow
                {
                    ForecastName = f.Name,
                    DataSource = f.DataSource.ToString(),
                    PeriodDate = dp.PeriodDate,
                    ForecastedValue = dp.ForecastedValue,
                })
            .ToListAsync();

        return result;
    }

    private static Color VarianceColor(decimal variancePercent)
    {
        var abs = Math.Abs(variancePercent);
        return abs <= 10 ? Color.Success : abs <= 25 ? Color.Warning : Color.Error;
    }

    private sealed class ForecastAnalyticsData
    {
        public int ActiveForecasts { get; set; }
        public double AvgAccuracy { get; set; }
        public int UpcomingEvaluations { get; set; }
        public int TotalEvaluated { get; set; }
        public string[] AccuracyByMethodLabels { get; set; } = [];
        public List<ChartSeries<double>> AccuracyByMethodSeries { get; set; } = [];
        public List<EvaluatedRow> RecentlyEvaluated { get; set; } = [];
        public List<UpcomingRow> UpcomingPoints { get; set; } = [];
    }

    private sealed class EvaluatedRow
    {
        public string ForecastName { get; init; } = "";
        public DateTime PeriodDate { get; init; }
        public decimal ForecastedValue { get; init; }
        public decimal ActualValue { get; init; }
        public decimal VariancePercent { get; init; }
        public DateTime EvaluatedDate { get; init; }
    }

    private sealed class UpcomingRow
    {
        public string ForecastName { get; init; } = "";
        public string DataSource { get; init; } = "";
        public DateTime PeriodDate { get; init; }
        public decimal ForecastedValue { get; init; }
    }
}
