@page "/processes/{ProcessId:int}/timeline"
@attribute [Authorize]
@using AWBlazorApp.Data.Entities.ProcessManagement
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Process timeline</PageTitle>

<MudStack Spacing="4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="processes" />
        <MudText Typo="Typo.h4">@(processName ?? "Process") — Timeline</MudText>
    </MudStack>

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudDatePicker @bind-Date="filterStart" Label="From" Variant="Variant.Outlined" Clearable="true" />
        <MudDatePicker @bind-Date="filterEnd" Label="To" Variant="Variant.Outlined" Clearable="true" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDataAsync">Filter</MudButton>
    </MudStack>

    @if (loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (executions.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No executions found for the selected date range.</MudAlert>
    }
    else
    {
        <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelineAlign="TimelineAlign.Start">
            @foreach (var exec in executions)
            {
                <MudTimelineItem Color="@ExecColor(exec.Status)" Icon="@ExecIcon(exec.Status)" Size="Size.Medium">
                    <ItemOpposite>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @exec.ExecutionDate.ToString("MMM dd, yyyy HH:mm")
                        </MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudPaper Class="pa-3" Elevation="1">
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudChip T="string" Color="@ExecColor(exec.Status)" Size="Size.Small">@exec.Status</MudChip>
                                    <MudText Typo="Typo.body2">@exec.CompletedStepCount / @exec.TotalStepCount steps completed</MudText>
                                </MudStack>
                                @if (!string.IsNullOrEmpty(exec.AssignedUserId))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned: @exec.AssignedUserId</MudText>
                                }

                                @if (stepExecutionMap.TryGetValue(exec.Id, out var stepExecs) && stepExecs.Count > 0)
                                {
                                    var firstPendingId = GetFirstPendingStepId(exec, stepExecs);
                                    <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="mt-2">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>Step</th>
                                                <th>Status</th>
                                                <th>Completed by</th>
                                                <th>Completed</th>
                                                @if (firstPendingId.HasValue)
                                                {
                                                    <th>Actions</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var se in stepExecs)
                                            {
                                                <tr>
                                                    <td>@se.SequenceNumber</td>
                                                    <td>@se.StepName</td>
                                                    <td>
                                                        <MudChip T="string" Color="@StepStatusColor(se.Status)" Size="Size.Small">@se.Status</MudChip>
                                                    </td>
                                                    <td>@(se.CompletedByUserId ?? "—")</td>
                                                    <td>@(se.CompletedDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                                    @if (firstPendingId.HasValue)
                                                    {
                                                        <td>
                                                            @if (se.Id == firstPendingId.Value)
                                                            {
                                                                <MudStack Row="true" Spacing="1">
                                                                    <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                                               OnClick="@(() => CompleteStepAsync(se.Id, ProcessStepExecutionStatus.Completed))">
                                                                        Complete
                                                                    </MudButton>
                                                                    <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                                                                               OnClick="@(() => CompleteStepAsync(se.Id, ProcessStepExecutionStatus.Skipped))">
                                                                        Skip
                                                                    </MudButton>
                                                                </MudStack>
                                                            }
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                            </MudStack>
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudStack>

@code {
    [Parameter] public int ProcessId { get; set; }

    private List<BreadcrumbItem> _breadcrumbs = [
        new("Home", "/", icon: Icons.Material.Filled.Home),
        new("Processes", "/processes"),
        new("Timeline", null, disabled: true),
    ];

    private bool loading = true;
    private string? processName;
    private DateTime? filterStart;
    private DateTime? filterEnd;
    private List<ProcessExecutionDto> executions = [];
    private Dictionary<int, List<ProcessStepExecutionDto>> stepExecutionMap = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        processName = await db.Processes.AsNoTracking()
            .Where(p => p.Id == ProcessId)
            .Select(p => p.Name)
            .FirstOrDefaultAsync();

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        loading = true;
        StateHasChanged();

        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.ProcessExecutions.AsNoTracking()
            .Include(e => e.StepExecutions).ThenInclude(se => se.ProcessStep)
            .Where(e => e.ProcessId == ProcessId);

        if (filterStart.HasValue)
            query = query.Where(e => e.ExecutionDate >= filterStart.Value);
        if (filterEnd.HasValue)
            query = query.Where(e => e.ExecutionDate <= filterEnd.Value.AddDays(1));

        var rawExecutions = await query
            .OrderByDescending(e => e.ExecutionDate)
            .ToListAsync();

        executions = rawExecutions.Select(e => e.ToDto()).ToList();

        stepExecutionMap = rawExecutions.ToDictionary(
            e => e.Id,
            e => e.StepExecutions
                .OrderBy(se => se.ProcessStep.SequenceNumber)
                .Select(se => se.ToDto())
                .ToList());

        loading = false;
    }

    private static Color ExecColor(ProcessExecutionStatus status) => status switch
    {
        ProcessExecutionStatus.Completed  => Color.Success,
        ProcessExecutionStatus.InProgress => Color.Warning,
        ProcessExecutionStatus.Overdue    => Color.Error,
        ProcessExecutionStatus.Pending    => Color.Info,
        ProcessExecutionStatus.Cancelled  => Color.Default,
        _                                 => Color.Default,
    };

    private static string ExecIcon(ProcessExecutionStatus status) => status switch
    {
        ProcessExecutionStatus.Completed  => Icons.Material.Filled.CheckCircle,
        ProcessExecutionStatus.InProgress => Icons.Material.Filled.HourglassTop,
        ProcessExecutionStatus.Overdue    => Icons.Material.Filled.Warning,
        ProcessExecutionStatus.Pending    => Icons.Material.Filled.Schedule,
        ProcessExecutionStatus.Cancelled  => Icons.Material.Filled.Cancel,
        _                                 => Icons.Material.Filled.Info,
    };

    private static int? GetFirstPendingStepId(ProcessExecutionDto exec, List<ProcessStepExecutionDto> stepExecs)
    {
        if (exec.Status is not (ProcessExecutionStatus.Pending or ProcessExecutionStatus.InProgress))
            return null;
        return stepExecs.FirstOrDefault(s => s.Status == ProcessStepExecutionStatus.Pending)?.Id;
    }

    private static Color StepStatusColor(ProcessStepExecutionStatus status) => status switch
    {
        ProcessStepExecutionStatus.Completed  => Color.Success,
        ProcessStepExecutionStatus.InProgress => Color.Warning,
        ProcessStepExecutionStatus.Skipped    => Color.Default,
        ProcessStepExecutionStatus.Pending    => Color.Info,
        _                                     => Color.Default,
    };

    private async Task CompleteStepAsync(int stepExecutionId, ProcessStepExecutionStatus newStatus)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var stepExec = await db.ProcessStepExecutions
                .Include(se => se.ProcessExecution).ThenInclude(pe => pe.StepExecutions)
                .FirstOrDefaultAsync(se => se.Id == stepExecutionId);

            if (stepExec is null)
            {
                Snackbar.Add("Step execution not found.", Severity.Warning);
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.IsAuthenticated == true ? authState.User.Identity.Name : null;

            stepExec.Status = newStatus;
            stepExec.CompletedByUserId = userId;
            stepExec.CompletedDate = DateTime.UtcNow;

            var allSteps = stepExec.ProcessExecution.StepExecutions;
            var allDone = allSteps.All(s => s.Id == stepExecutionId
                || s.Status is ProcessStepExecutionStatus.Completed or ProcessStepExecutionStatus.Skipped);

            if (allDone)
            {
                stepExec.ProcessExecution.Status = ProcessExecutionStatus.Completed;
                stepExec.ProcessExecution.CompletedDate = DateTime.UtcNow;
            }
            else if (stepExec.ProcessExecution.Status == ProcessExecutionStatus.Pending)
            {
                stepExec.ProcessExecution.Status = ProcessExecutionStatus.InProgress;
            }

            await db.SaveChangesAsync();

            Snackbar.Add($"Step {(newStatus == ProcessStepExecutionStatus.Completed ? "completed" : "skipped")}.", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
    }
}
