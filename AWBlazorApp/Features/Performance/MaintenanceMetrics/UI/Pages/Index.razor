@page "/performance/maintenance-metrics"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IMaintenanceMetricsService Svc
@inject ISnackbar Snackbar

<PageTitle>Maintenance metrics</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Maintenance metrics</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Per-asset monthly MTBF / MTTR / availability / PM compliance</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Calculate" OnClick="OpenCompute">Compute month</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterAsset" Label="Asset ID" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterYear" Label="Year" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="MaintenanceMonthlyMetricDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.AssetId" Title="Asset" />
            <TemplateColumn Title="Period" Sortable="false"><CellTemplate>@context.Item.Year-@context.Item.Month.ToString("D2")</CellTemplate></TemplateColumn>
            <PropertyColumn Property="x => x.WorkOrderCount" Title="WOs" />
            <PropertyColumn Property="x => x.BreakdownCount" Title="Breakdowns" />
            <TemplateColumn Title="MTBF (h)" Sortable="false"><CellTemplate>@(context.Item.MtbfHours?.ToString("F1") ?? "—")</CellTemplate></TemplateColumn>
            <TemplateColumn Title="MTTR (h)" Sortable="false"><CellTemplate>@(context.Item.MttrHours?.ToString("F1") ?? "—")</CellTemplate></TemplateColumn>
            <TemplateColumn Title="Availability" Sortable="false"><CellTemplate>@(context.Item.AvailabilityFraction.HasValue ? $"{context.Item.AvailabilityFraction.Value * 100m:F1}%" : "—")</CellTemplate></TemplateColumn>
            <TemplateColumn Title="PM compliance" Sortable="false"><CellTemplate>@(context.Item.PmComplianceFraction.HasValue ? $"{context.Item.PmComplianceFraction.Value * 100m:F1}%" : "—")</CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="MaintenanceMonthlyMetricDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Compute maintenance metric</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="compute.AssetId" Label="Asset ID" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int" @bind-Value="compute.Year" Label="Year" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int" @bind-Value="compute.Month" Label="Month (1-12)" Required="true" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ComputeAsync" Disabled="computing">@(computing ? "Computing…" : "Compute")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<MaintenanceMonthlyMetricDto> grid = null!;
    private bool _loading = true;
    private int? filterAsset, filterYear;

    private bool dialogOpen, computing;
    private ComputeMaintenanceMetricRequest compute = new();

    private async Task<GridData<MaintenanceMonthlyMetricDto>> LoadAsync(GridState<MaintenanceMonthlyMetricDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.MaintenanceMonthlyMetrics.AsNoTracking();
            if (filterAsset.HasValue) q = q.Where(x => x.AssetId == filterAsset.Value);
            if (filterYear.HasValue) q = q.Where(x => x.Year == filterYear.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.Year).ThenByDescending(x => x.Month)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<MaintenanceMonthlyMetricDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCompute()
    {
        var now = DateTime.UtcNow;
        compute = new ComputeMaintenanceMetricRequest { Year = now.Year, Month = now.Month };
        dialogOpen = true;
    }

    private async Task ComputeAsync()
    {
        computing = true;
        try
        {
            var m = await Svc.ComputeMonthlyAsync(compute.AssetId, compute.Year, compute.Month, default);
            Snackbar.Add($"{m.WorkOrderCount} WOs, {m.BreakdownCount} breakdowns.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Compute failed: {ex.Message}", Severity.Error); }
        finally { computing = false; }
    }
}
