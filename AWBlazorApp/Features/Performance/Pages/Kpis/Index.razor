@page "/performance/kpis"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IKpiEvaluationService EvalService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>KPIs</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">KPIs</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Named, re-usable KPIs with enum-based aggregations over OEE / production / maintenance metrics</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New KPI</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="KpiSource?" @bind-Value="filterSource" Label="Source" Variant="Variant.Outlined" Clearable="true" Style="max-width: 260px">
                <MudSelectItem T="KpiSource?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<KpiSource>()) { <MudSelectItem T="KpiSource?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudCheckBox T="bool" @bind-Value="activeOnly" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="KpiDefinitionDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Source" Title="Source" />
            <PropertyColumn Property="x => x.Aggregation" Title="Agg" />
            <PropertyColumn Property="x => x.TargetValue" Title="Target" />
            <PropertyColumn Property="x => x.Unit" Title="Unit" />
            <PropertyColumn Property="x => x.Direction" Title="Dir" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate>@(context.Item.IsActive ? "✓" : "")</CellTemplate></TemplateColumn>
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@(() => OpenEvaluate(context.Item.Id))">Evaluate</MudButton>
                    </AuthorizeView>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="KpiDefinitionDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New KPI</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newKpi.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newKpi.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newKpi.Description" Label="Description" Variant="Variant.Outlined" Lines="2" />
            <MudSelect T="KpiSource" @bind-Value="newKpi.Source" Label="Source metric" Variant="Variant.Outlined">
                @foreach (var s in Enum.GetValues<KpiSource>()) { <MudSelectItem T="KpiSource" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudSelect T="KpiAggregation" @bind-Value="newKpi.Aggregation" Label="Aggregation" Variant="Variant.Outlined">
                @foreach (var a in Enum.GetValues<KpiAggregation>()) { <MudSelectItem T="KpiAggregation" Value="@a">@a</MudSelectItem> }
            </MudSelect>
            <MudTextField @bind-Value="newKpi.Unit" Label="Unit (e.g. %, hrs, units)" Variant="Variant.Outlined" />
            <MudNumericField T="decimal?" @bind-Value="newKpi.TargetValue" Label="Target value (optional)" Variant="Variant.Outlined" />
            <MudNumericField T="decimal?" @bind-Value="newKpi.WarningThreshold" Label="Warning threshold" Variant="Variant.Outlined" />
            <MudNumericField T="decimal?" @bind-Value="newKpi.CriticalThreshold" Label="Critical threshold" Variant="Variant.Outlined" />
            <MudSelect T="KpiDirection" @bind-Value="newKpi.Direction" Label="Direction" Variant="Variant.Outlined">
                @foreach (var d in Enum.GetValues<KpiDirection>()) { <MudSelectItem T="KpiDirection" Value="@d">@d</MudSelectItem> }
            </MudSelect>
            <MudCheckBox T="bool" @bind-Value="newKpi.IsActive" Label="Active" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="evaluateOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Evaluate KPI</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudSelect T="PerformancePeriodKind" @bind-Value="evalReq.PeriodKind" Label="Period kind" Variant="Variant.Outlined">
                @foreach (var p in Enum.GetValues<PerformancePeriodKind>()) { <MudSelectItem T="PerformancePeriodKind" Value="@p">@p</MudSelectItem> }
            </MudSelect>
            <MudDatePicker @bind-Date="evalStart" Label="Period start" Required="true" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="evalEnd" Label="Period end" Required="true" Variant="Variant.Outlined" />
            @if (evalResult is not null)
            {
                <MudAlert Severity="@ToMudSeverity(evalResult.Status)">
                    @evalResult.Status — Value = @(evalResult.Value?.ToString("F3") ?? "—") (target @(evalResult.TargetAtPeriod?.ToString("F3") ?? "—"))
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => evaluateOpen = false">Close</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="DoEvaluate" Disabled="evaluating">@(evaluating ? "Running…" : "Evaluate")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<KpiDefinitionDto> grid = null!;
    private bool _loading = true;
    private KpiSource? filterSource;
    private bool activeOnly = true;

    private bool dialogOpen, saving;
    private CreateKpiDefinitionRequest newKpi = new();

    private bool evaluateOpen, evaluating;
    private int evalKpiId;
    private EvaluateKpiRequest evalReq = new();
    private DateTime? evalStart, evalEnd;
    private KpiValueDto? evalResult;

    private static Severity ToMudSeverity(KpiStatus s) => s switch
    {
        KpiStatus.OnTarget => Severity.Success,
        KpiStatus.Warning => Severity.Warning,
        KpiStatus.Critical => Severity.Error,
        _ => Severity.Info,
    };

    private async Task<GridData<KpiDefinitionDto>> LoadAsync(GridState<KpiDefinitionDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.KpiDefinitions.AsNoTracking();
            if (filterSource.HasValue) q = q.Where(x => x.Source == filterSource.Value);
            if (activeOnly) q = q.Where(x => x.IsActive);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.Code)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<KpiDefinitionDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newKpi = new CreateKpiDefinitionRequest { Source = KpiSource.OeeOverall, Aggregation = KpiAggregation.Average, Direction = KpiDirection.HigherIsBetter, IsActive = true }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newKpi.ToEntity();
            var by = await GetUserNameAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            db.KpiDefinitions.Add(entity);
            await db.SaveChangesAsync();
            db.KpiDefinitionAuditLogs.Add(KpiDefinitionAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.Code}.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private void OpenEvaluate(int id)
    {
        evalKpiId = id;
        evalReq = new EvaluateKpiRequest { KpiDefinitionId = id, PeriodKind = PerformancePeriodKind.Day };
        evalStart = DateTime.UtcNow.Date.AddDays(-7);
        evalEnd = DateTime.UtcNow.Date;
        evalResult = null;
        evaluateOpen = true;
    }

    private async Task DoEvaluate()
    {
        evaluating = true;
        try
        {
            if (evalStart.HasValue) evalReq.PeriodStart = DateTime.SpecifyKind(evalStart.Value, DateTimeKind.Utc);
            if (evalEnd.HasValue) evalReq.PeriodEnd = DateTime.SpecifyKind(evalEnd.Value, DateTimeKind.Utc);
            var v = await EvalService.EvaluateAsync(evalKpiId, evalReq.PeriodKind, evalReq.PeriodStart, evalReq.PeriodEnd, default);
            evalResult = v.ToDto();
        }
        catch (Exception ex) { Snackbar.Add($"Evaluate failed: {ex.Message}", Severity.Error); }
        finally { evaluating = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
