@page "/workforce"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Workforce</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Workforce</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Training, qualifications, attendance, leave, shift communication</MudText>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.NotificationsActive" Color="Color.Error" Value="@openAlerts.ToString("N0")" Label="Open qual alerts" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.AccessTime" Color="Color.Warning" Value="@expiringQuals.ToString("N0")" Label="Quals expiring ≤30d" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.EventBusy" Color="Color.Info" Value="@pendingLeaves.ToString("N0")" Label="Pending leave" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.EditNote" Color="Color.Primary" Value="@unackHandovers.ToString("N0")" Label="Unack handover notes" /></MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        @foreach (var card in Cards)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@card.Icon" Color="Color.Primary" Size="Size.Large" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6">@card.Title</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@card.Subtitle</MudText>
                        </MudStack>
                        <MudSpacer />
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.List" Href="@card.Href">Open</MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudStack>

@code {
    private int openAlerts, expiringQuals, pendingLeaves, unackHandovers;

    private record NavCard(string Title, string Subtitle, string Href, string Icon);

    private static readonly NavCard[] Cards =
    [
        new("Alert inbox", "Operator qualification issues from clock-in", "workforce/qualification-alerts", Icons.Material.Filled.NotificationsActive),
        new("Training courses", "wf.TrainingCourse — recurring cert tracking", "workforce/training-courses", Icons.Material.Filled.School),
        new("Qualifications", "wf.Qualification — skills, certs, safety, compliance", "workforce/qualifications", Icons.Material.Filled.Badge),
        new("Employee quals", "Per-employee grant, expiry, evidence", "workforce/employee-qualifications", Icons.Material.Filled.CardMembership),
        new("Station requirements", "Required quals per station", "workforce/station-qualifications", Icons.Material.Filled.WorkspacePremium),
        new("Leave requests", "Pending → Approved/Rejected workflow", "workforce/leave-requests", Icons.Material.Filled.EventBusy),
        new("Attendance", "Per-shift clock in / out, status", "workforce/attendance", Icons.Material.Filled.HowToReg),
        new("Shift handover", "Per-station handover notes", "workforce/handover-notes", Icons.Material.Filled.EditNote),
        new("Announcements", "Broadcast messages across org / org unit", "workforce/announcements", Icons.Material.Filled.Campaign),
    ];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        openAlerts = await db.QualificationAlerts.CountAsync(a => a.Status == QualificationAlertStatus.Open);
        var cutoff = DateTime.UtcNow.AddDays(30);
        expiringQuals = await db.EmployeeQualifications.CountAsync(q => q.ExpiresOn != null && q.ExpiresOn <= cutoff);
        pendingLeaves = await db.LeaveRequests.CountAsync(l => l.Status == LeaveStatus.Pending);
        unackHandovers = await db.ShiftHandoverNotes.CountAsync(h => h.RequiresAcknowledgment && h.AcknowledgedAt == null);
    }
}
