@page "/workforce/attendance"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Attendance</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Attendance</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">wf.AttendanceEvent — per-shift payroll / HR view (distinct from MES OperatorClockEvent)</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Log event</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterEmployee" Label="Employee" Variant="Variant.Outlined" Clearable="true" />
            <MudDatePicker @bind-Date="filterFrom" Label="From" Variant="Variant.Outlined" Clearable="true" />
            <MudDatePicker @bind-Date="filterTo" Label="To" Variant="Variant.Outlined" Clearable="true" />
            <MudSelect T="AttendanceStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 180px">
                <MudSelectItem T="AttendanceStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<AttendanceStatus>()) { <MudSelectItem T="AttendanceStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="AttendanceEventDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="#" />
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Employee" />
            <PropertyColumn Property="x => x.ShiftDate" Title="Shift date" />
            <PropertyColumn Property="x => x.ShiftId" Title="Shift" />
            <PropertyColumn Property="x => x.ClockInAt" Title="Clock in" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.ClockOutAt" Title="Clock out" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.Status" Title="Status" />
        </Columns>
        <PagerContent><MudDataGridPager T="AttendanceEventDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Log attendance event</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newRow.BusinessEntityId" Label="Employee (BusinessEntityId)" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRow.ShiftId" Label="Shift ID (optional)" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="shiftDate" Label="Shift date" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="AttendanceStatus" @bind-Value="newRow.Status" Label="Status" Variant="Variant.Outlined">
                @foreach (var s in Enum.GetValues<AttendanceStatus>()) { <MudSelectItem T="AttendanceStatus" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudTextField @bind-Value="newRow.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Log")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<AttendanceEventDto> grid = null!;
    private bool _loading = true;
    private int? filterEmployee;
    private DateTime? filterFrom, filterTo;
    private AttendanceStatus? filterStatus;

    private bool dialogOpen, saving;
    private CreateAttendanceEventRequest newRow = new();
    private DateTime? shiftDate = DateTime.UtcNow.Date;

    private async Task<GridData<AttendanceEventDto>> LoadAsync(GridState<AttendanceEventDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.AttendanceEvents.AsNoTracking();
            if (filterEmployee.HasValue) q = q.Where(x => x.BusinessEntityId == filterEmployee.Value);
            if (filterFrom.HasValue) { var from = DateOnly.FromDateTime(filterFrom.Value); q = q.Where(x => x.ShiftDate >= from); }
            if (filterTo.HasValue) { var to = DateOnly.FromDateTime(filterTo.Value); q = q.Where(x => x.ShiftDate <= to); }
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.ShiftDate).ThenByDescending(x => x.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<AttendanceEventDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateAttendanceEventRequest { Status = AttendanceStatus.Present }; shiftDate = DateTime.UtcNow.Date; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (shiftDate.HasValue) newRow.ShiftDate = DateOnly.FromDateTime(shiftDate.Value);
            var entity = newRow.ToEntity();
            db.AttendanceEvents.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add("Logged.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }
}
