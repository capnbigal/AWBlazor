@page "/workforce/station-qualifications"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Station qualifications</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Station qualifications</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Required quals per station — checked at operator clock-in, raises alert inbox entries (does not block)</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Assign qualification</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterStation" Label="Station" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterQual" Label="Qualification" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="StationQualificationDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.StationId" Title="Station" />
            <PropertyColumn Property="x => x.QualificationId" Title="Qualification" />
            <TemplateColumn Title="Required" Sortable="false"><CellTemplate>@(context.Item.IsRequired ? "✓" : "")</CellTemplate></TemplateColumn>
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context.Item.Id))" />
                    </AuthorizeView>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="StationQualificationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Assign qualification to station</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newRow.StationId" Label="Station ID" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int" @bind-Value="newRow.QualificationId" Label="Qualification ID" Required="true" Variant="Variant.Outlined" />
            <MudCheckBox T="bool" @bind-Value="newRow.IsRequired" Label="Required (otherwise advisory)" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Assign")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<StationQualificationDto> grid = null!;
    private bool _loading = true;
    private int? filterStation;
    private int? filterQual;

    private bool dialogOpen, saving;
    private CreateStationQualificationRequest newRow = new();

    private async Task<GridData<StationQualificationDto>> LoadAsync(GridState<StationQualificationDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.StationQualifications.AsNoTracking();
            if (filterStation.HasValue) q = q.Where(x => x.StationId == filterStation.Value);
            if (filterQual.HasValue) q = q.Where(x => x.QualificationId == filterQual.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.StationId).ThenBy(x => x.QualificationId)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<StationQualificationDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateStationQualificationRequest { IsRequired = true }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.StationQualifications.AnyAsync(x => x.StationId == newRow.StationId && x.QualificationId == newRow.QualificationId))
            {
                Snackbar.Add("Station already has this qualification.", Severity.Error);
                return;
            }
            var entity = newRow.ToEntity();
            var by = await GetUserNameAsync();
            db.StationQualifications.Add(entity);
            await db.SaveChangesAsync();
            db.StationQualificationAuditLogs.Add(StationQualificationAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            Snackbar.Add("Assigned.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Assign failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task Delete(int id)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.StationQualifications.FirstOrDefaultAsync(x => x.Id == id);
            if (entity is null) return;
            var by = await GetUserNameAsync();
            db.StationQualifications.Remove(entity);
            db.StationQualificationAuditLogs.Add(StationQualificationAuditService.RecordDelete(entity, by));
            await db.SaveChangesAsync();
            Snackbar.Add("Removed.", Severity.Success);
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Remove failed: {ex.Message}", Severity.Error); }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
