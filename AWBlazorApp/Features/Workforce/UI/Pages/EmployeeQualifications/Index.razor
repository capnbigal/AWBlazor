@page "/workforce/employee-qualifications"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IQualificationService Qualifications
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Employee qualifications</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Employee qualifications</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">wf.EmployeeQualification — per-employee grants, expiry tracked</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenGrant">Grant qualification</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterEmployee" Label="Employee (BusinessEntityId)" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterQual" Label="Qualification ID" Variant="Variant.Outlined" Clearable="true" />
            <MudCheckBox T="bool" @bind-Value="expiringOnly" Label="Expiring ≤30d only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="EmployeeQualificationDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="#" />
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Employee" />
            <PropertyColumn Property="x => x.QualificationId" Title="Qualification" />
            <PropertyColumn Property="x => x.EarnedDate" Title="Earned" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.ExpiresOn" Title="Expires" Format="yyyy-MM-dd" />
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    @{
                        var e = context.Item;
                        var now = DateTime.UtcNow;
                        if (e.ExpiresOn is null) {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">No expiry</MudChip>
                        }
                        else if (e.ExpiresOn < now) {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Expired</MudChip>
                        }
                        else if (e.ExpiresOn <= now.AddDays(30)) {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Soon</MudChip>
                        }
                        else {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Current</MudChip>
                        }
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Revoke(context.Item.Id))" />
                    </AuthorizeView>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="EmployeeQualificationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Grant qualification</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="req.BusinessEntityId" Label="Employee (BusinessEntityId)" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int" @bind-Value="req.QualificationId" Label="Qualification ID" Required="true" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="earnedDate" Label="Earned date" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="expiresDate" Label="Expires (optional)" Variant="Variant.Outlined" Clearable="true" />
            <MudTextField @bind-Value="req.EvidenceUrl" Label="Evidence URL (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="req.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="GrantAsync" Disabled="saving">@(saving ? "Saving..." : "Grant")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<EmployeeQualificationDto> grid = null!;
    private bool _loading = true;
    private int? filterEmployee;
    private int? filterQual;
    private bool expiringOnly;

    private bool dialogOpen, saving;
    private GrantEmployeeQualificationRequest req = new();
    private DateTime? earnedDate = DateTime.UtcNow.Date;
    private DateTime? expiresDate;

    private async Task<GridData<EmployeeQualificationDto>> LoadAsync(GridState<EmployeeQualificationDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.EmployeeQualifications.AsNoTracking();
            if (filterEmployee.HasValue) q = q.Where(x => x.BusinessEntityId == filterEmployee.Value);
            if (filterQual.HasValue) q = q.Where(x => x.QualificationId == filterQual.Value);
            if (expiringOnly)
            {
                var cutoff = DateTime.UtcNow.AddDays(30);
                q = q.Where(x => x.ExpiresOn != null && x.ExpiresOn <= cutoff);
            }
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.EarnedDate)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<EmployeeQualificationDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenGrant() { req = new GrantEmployeeQualificationRequest(); earnedDate = DateTime.UtcNow.Date; expiresDate = null; dialogOpen = true; }

    private async Task GrantAsync()
    {
        saving = true;
        try
        {
            var by = await GetUserNameAsync();
            await Qualifications.GrantAsync(
                req.BusinessEntityId, req.QualificationId,
                earnedDate ?? DateTime.UtcNow, expiresDate,
                string.IsNullOrWhiteSpace(req.EvidenceUrl) ? null : req.EvidenceUrl.Trim(),
                string.IsNullOrWhiteSpace(req.Notes) ? null : req.Notes.Trim(),
                by, default);
            Snackbar.Add("Granted.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Grant failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task Revoke(int id)
    {
        try
        {
            var by = await GetUserNameAsync();
            await Qualifications.RevokeAsync(id, by, default);
            Snackbar.Add("Revoked.", Severity.Success);
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Revoke failed: {ex.Message}", Severity.Error); }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
