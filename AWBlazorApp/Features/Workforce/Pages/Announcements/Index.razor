@page "/workforce/announcements"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Announcements</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Announcements</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Broadcasts scoped to org / org unit / all — auto-expiring</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Publish</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="AnnouncementSeverity?" @bind-Value="filterSeverity" Label="Severity" Variant="Variant.Outlined" Clearable="true" Style="max-width: 180px">
                <MudSelectItem T="AnnouncementSeverity?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<AnnouncementSeverity>()) { <MudSelectItem T="AnnouncementSeverity?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterOrg" Label="Organization" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterOrgUnit" Label="Org unit" Variant="Variant.Outlined" Clearable="true" />
            <MudCheckBox T="bool" @bind-Value="activeOnly" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="AnnouncementDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="#" />
            <PropertyColumn Property="x => x.Title" Title="Title" />
            <TemplateColumn Title="Severity" Sortable="false">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@SevColor(context.Item.Severity)" Variant="Variant.Filled">@context.Item.Severity</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.OrganizationId" Title="Org" />
            <PropertyColumn Property="x => x.OrgUnitId" Title="Unit" />
            <PropertyColumn Property="x => x.PublishedAt" Title="Published" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.ExpiresAt" Title="Expires" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate>@(context.Item.IsActive ? "✓" : "")</CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="AnnouncementDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>Publish announcement</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newRow.Title" Label="Title" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Body" Label="Body (markdown supported)" Required="true" Variant="Variant.Outlined" Lines="6" />
            <MudSelect T="AnnouncementSeverity" @bind-Value="newRow.Severity" Label="Severity" Variant="Variant.Outlined">
                @foreach (var s in Enum.GetValues<AnnouncementSeverity>()) { <MudSelectItem T="AnnouncementSeverity" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="newRow.OrganizationId" Label="Organization (optional)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRow.OrgUnitId" Label="Org unit (optional)" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="expiresDate" Label="Expires (optional)" Variant="Variant.Outlined" Clearable="true" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Publish")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<AnnouncementDto> grid = null!;
    private bool _loading = true;
    private AnnouncementSeverity? filterSeverity;
    private int? filterOrg, filterOrgUnit;
    private bool activeOnly = true;

    private bool dialogOpen, saving;
    private CreateAnnouncementRequest newRow = new();
    private DateTime? expiresDate;

    private static Color SevColor(AnnouncementSeverity s) => s switch
    {
        AnnouncementSeverity.Critical => Color.Error,
        AnnouncementSeverity.Important => Color.Warning,
        AnnouncementSeverity.Info => Color.Info,
        _ => Color.Default,
    };

    private async Task<GridData<AnnouncementDto>> LoadAsync(GridState<AnnouncementDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.Announcements.AsNoTracking();
            if (filterSeverity.HasValue) q = q.Where(x => x.Severity == filterSeverity.Value);
            if (filterOrg.HasValue) q = q.Where(x => x.OrganizationId == filterOrg.Value);
            if (filterOrgUnit.HasValue) q = q.Where(x => x.OrgUnitId == filterOrgUnit.Value);
            if (activeOnly)
            {
                var now = DateTime.UtcNow;
                q = q.Where(x => x.IsActive && (x.ExpiresAt == null || x.ExpiresAt > now));
            }
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.PublishedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<AnnouncementDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateAnnouncementRequest { Severity = AnnouncementSeverity.Info }; expiresDate = null; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            newRow.ExpiresAt = expiresDate;
            var by = await GetUserNameAsync();
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRow.ToEntity(by);
            await using var tx = await db.Database.BeginTransactionAsync();
            db.Announcements.Add(entity);
            await db.SaveChangesAsync();
            db.AnnouncementAuditLogs.Add(AnnouncementAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add("Published.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Publish failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
