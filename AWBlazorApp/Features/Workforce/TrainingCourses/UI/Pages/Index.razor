@page "/workforce/training-courses"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Training courses</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Training courses</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">wf.TrainingCourse — with optional recurrence for recurring certifications</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New course</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="search" Label="Search code / name" Variant="Variant.Outlined" Clearable="true" />
            <MudCheckBox T="bool" @bind-Value="filterActive" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="TrainingCourseDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.DurationMinutes" Title="Min" />
            <PropertyColumn Property="x => x.RecurrenceMonths" Title="Recur (mo)" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate>@(context.Item.IsActive ? "✓" : "")</CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="TrainingCourseDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New training course</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newCourse.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newCourse.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newCourse.Description" Label="Description" Variant="Variant.Outlined" Lines="2" />
            <MudNumericField T="int?" @bind-Value="newCourse.DurationMinutes" Label="Duration (minutes)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newCourse.RecurrenceMonths" Label="Recurrence (months)" HelperText="Optional — if set, TrainingRecord.ExpiresOn auto-computed" Variant="Variant.Outlined" />
            <MudCheckBox T="bool" @bind-Value="newCourse.IsActive" Label="Active" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<TrainingCourseDto> grid = null!;
    private bool _loading = true;
    private string? search;
    private bool filterActive = true;

    private bool dialogOpen, saving;
    private CreateTrainingCourseRequest newCourse = new();

    private async Task<GridData<TrainingCourseDto>> LoadAsync(GridState<TrainingCourseDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.TrainingCourses.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(x => x.Code.Contains(s) || x.Name.Contains(s));
            }
            if (filterActive) q = q.Where(x => x.IsActive);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.Code)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<TrainingCourseDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newCourse = new CreateTrainingCourseRequest { IsActive = true }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newCourse.ToEntity();
            var by = await GetUserNameAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            db.TrainingCourses.Add(entity);
            await db.SaveChangesAsync();
            db.TrainingCourseAuditLogs.Add(TrainingCourseAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.Code}.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
