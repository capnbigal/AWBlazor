@page "/aw/special-offer-products/history"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Dtos
@using AWBlazorApp.Features.Sales.CreditCards.Dtos
@using AWBlazorApp.Features.Sales.Currencies.Dtos
@using AWBlazorApp.Features.Sales.CurrencyRates.Dtos
@using AWBlazorApp.Features.Sales.Customers.Dtos
@using AWBlazorApp.Features.Sales.PersonCreditCards.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesPeople.Dtos
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Dtos
@using AWBlazorApp.Features.Sales.SalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesTaxRates.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritories.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Dtos
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Dtos
@using AWBlazorApp.Features.Sales.SpecialOffers.Dtos
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Dtos
@using AWBlazorApp.Features.Sales.Stores.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Special offer ↔ product audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/special-offer-products"))" />
        <MudText Typo="Typo.h4">Special offer ↔ product audit</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="SpecialOfferId" Label="Special offer id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="ProductId" Label="Product id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="SpecialOfferProductAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferProductAuditLog" PropertyName="@nameof(SpecialOfferProductAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SpecialOfferId" Title="Special offer">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferProductAuditLog" PropertyName="@nameof(SpecialOfferProductAuditLogDto.SpecialOfferId)" Title="Special offer" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductId" Title="Product">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferProductAuditLog" PropertyName="@nameof(SpecialOfferProductAuditLogDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferProductAuditLog" PropertyName="@nameof(SpecialOfferProductAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferProductAuditLog" PropertyName="@nameof(SpecialOfferProductAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SpecialOfferProductAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? SpecialOfferId { get; set; }
    [SupplyParameterFromQuery] public int? ProductId { get; set; }

    private MudDataGrid<SpecialOfferProductAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SpecialOfferProductAuditLogDto>> LoadServerDataAsync(GridState<SpecialOfferProductAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SpecialOfferProductAuditLogs.AsNoTracking();

        if (SpecialOfferId.HasValue) query = query.Where(a => a.SpecialOfferId == SpecialOfferId.Value);
        if (ProductId.HasValue) query = query.Where(a => a.ProductId == ProductId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SpecialOfferProductAuditLogDto.ChangedDate) => sort.Descending ? query.OrderByDescending(a => a.ChangedDate) : query.OrderBy(a => a.ChangedDate),
            nameof(SpecialOfferProductAuditLogDto.SpecialOfferId) => sort.Descending ? query.OrderByDescending(a => a.SpecialOfferId) : query.OrderBy(a => a.SpecialOfferId),
            nameof(SpecialOfferProductAuditLogDto.ProductId) => sort.Descending ? query.OrderByDescending(a => a.ProductId) : query.OrderBy(a => a.ProductId),
            nameof(SpecialOfferProductAuditLogDto.ChangedBy) => sort.Descending ? query.OrderByDescending(a => a.ChangedBy) : query.OrderBy(a => a.ChangedBy),
            nameof(SpecialOfferProductAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _ => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<SpecialOfferProductAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
