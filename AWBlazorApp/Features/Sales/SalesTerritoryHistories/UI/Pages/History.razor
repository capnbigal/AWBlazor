@page "/aw/sales-territory-histories/history"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Dtos
@using AWBlazorApp.Features.Sales.CreditCards.Dtos
@using AWBlazorApp.Features.Sales.Currencies.Dtos
@using AWBlazorApp.Features.Sales.CurrencyRates.Dtos
@using AWBlazorApp.Features.Sales.Customers.Dtos
@using AWBlazorApp.Features.Sales.PersonCreditCards.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesPeople.Dtos
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Dtos
@using AWBlazorApp.Features.Sales.SalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesTaxRates.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritories.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Dtos
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Dtos
@using AWBlazorApp.Features.Sales.SpecialOffers.Dtos
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Dtos
@using AWBlazorApp.Features.Sales.Stores.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Sales territory history audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/sales-territory-histories"))" />
        <MudText Typo="Typo.h4">Sales territory history audit</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="BusinessEntityId" Label="Business entity id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="TerritoryId" Label="Territory id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="SalesTerritoryHistoryAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="SalesTerritoryHistoryAuditLog" PropertyName="@nameof(SalesTerritoryHistoryAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Business entity">
                <HeaderTemplate><GridColumnHeader TEntity="SalesTerritoryHistoryAuditLog" PropertyName="@nameof(SalesTerritoryHistoryAuditLogDto.BusinessEntityId)" Title="Business entity" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.TerritoryId" Title="Territory">
                <HeaderTemplate><GridColumnHeader TEntity="SalesTerritoryHistoryAuditLog" PropertyName="@nameof(SalesTerritoryHistoryAuditLogDto.TerritoryId)" Title="Territory" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="SalesTerritoryHistoryAuditLog" PropertyName="@nameof(SalesTerritoryHistoryAuditLogDto.StartDate)" Title="Start" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="SalesTerritoryHistoryAuditLog" PropertyName="@nameof(SalesTerritoryHistoryAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.EndDate" Title="End" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="SalesTerritoryHistoryAuditLog" PropertyName="@nameof(SalesTerritoryHistoryAuditLogDto.EndDate)" Title="End" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="SalesTerritoryHistoryAuditLog" PropertyName="@nameof(SalesTerritoryHistoryAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SalesTerritoryHistoryAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? BusinessEntityId { get; set; }
    [SupplyParameterFromQuery] public int? TerritoryId { get; set; }

    private MudDataGrid<SalesTerritoryHistoryAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SalesTerritoryHistoryAuditLogDto>> LoadServerDataAsync(GridState<SalesTerritoryHistoryAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesTerritoryHistoryAuditLogs.AsNoTracking();

        if (BusinessEntityId.HasValue) query = query.Where(a => a.BusinessEntityId == BusinessEntityId.Value);
        if (TerritoryId.HasValue) query = query.Where(a => a.TerritoryId == TerritoryId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SalesTerritoryHistoryAuditLogDto.ChangedDate) => sort.Descending ? query.OrderByDescending(a => a.ChangedDate) : query.OrderBy(a => a.ChangedDate),
            nameof(SalesTerritoryHistoryAuditLogDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(a => a.BusinessEntityId) : query.OrderBy(a => a.BusinessEntityId),
            nameof(SalesTerritoryHistoryAuditLogDto.TerritoryId) => sort.Descending ? query.OrderByDescending(a => a.TerritoryId) : query.OrderBy(a => a.TerritoryId),
            nameof(SalesTerritoryHistoryAuditLogDto.StartDate) => sort.Descending ? query.OrderByDescending(a => a.StartDate) : query.OrderBy(a => a.StartDate),
            nameof(SalesTerritoryHistoryAuditLogDto.ChangedBy) => sort.Descending ? query.OrderByDescending(a => a.ChangedBy) : query.OrderBy(a => a.ChangedBy),
            nameof(SalesTerritoryHistoryAuditLogDto.EndDate) => sort.Descending ? query.OrderByDescending(a => a.EndDate) : query.OrderBy(a => a.EndDate),
            nameof(SalesTerritoryHistoryAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _ => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<SalesTerritoryHistoryAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
