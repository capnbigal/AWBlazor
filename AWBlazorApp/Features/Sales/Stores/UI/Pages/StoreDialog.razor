@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateStoreRequest> CreateValidator
@inject MudFormValidator<UpdateStoreRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create store" : $"Edit store #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@createModel.Id" ValueChanged="@((int v) => createModel = createModel with { Id = v })" SearchFunc="@(q => Lookup.SearchPersonsAsync(q))" Label="Business entity (person)" Required="true" /></MudItem>
                    <MudItem xs="12" sm="6"><MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" /></MudItem>
                    <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(createModel.SalesPersonId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { SalesPersonId = v == 0 ? null : v })" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" Label="Sales person" Clearable="true" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" MaxLength="50" /></MudItem>
                    <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(updateModel.SalesPersonId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { SalesPersonId = v == 0 ? null : v })" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" Label="Sales person" Clearable="true" InitialDisplayText="@_salesPersonDisplay" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public StoreDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateStoreRequest createModel = new();
    private UpdateStoreRequest updateModel = new();
    private bool saving;
    private string? _salesPersonDisplay;

    protected override async Task OnInitializedAsync()
    {
        if (Model is not null)
        {
            updateModel = new UpdateStoreRequest { Name = Model.Name, SalesPersonId = Model.SalesPersonId };
            if (Model.SalesPersonId.HasValue)
                _salesPersonDisplay = await Lookup.GetSalesPersonDisplayAsync(Model.SalesPersonId.Value);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.Stores.AnyAsync(x => x.Id == createModel.Id)) { Snackbar.Add($"Store #{createModel.Id} already exists.", Severity.Error); return; }
                // Validate optional FK
                if (createModel.SalesPersonId.HasValue && !await db.SalesPersons.AnyAsync(x => x.Id == createModel.SalesPersonId.Value))
                { Snackbar.Add($"Sales person #{createModel.SalesPersonId.Value} does not exist.", Severity.Error); return; }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.Stores.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.StoreAuditLogs.Add(StoreAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Stores.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = StoreAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FK on update
                if (updateModel.SalesPersonId.HasValue && !await db.SalesPersons.AnyAsync(x => x.Id == updateModel.SalesPersonId.Value))
                { Snackbar.Add($"Sales person #{updateModel.SalesPersonId.Value} does not exist.", Severity.Error); return; }
                db.StoreAuditLogs.Add(StoreAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
