@page "/analytics/sales"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Domain
@using AWBlazorApp.Shared.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AnalyticsCacheService Cache

<PageTitle>Sales analytics</PageTitle>

<MudStack Spacing="4">
    <MudText Typo="Typo.h4">Sales analytics</MudText>

    @if (loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">Loading sales data...</MudText>
    }
    else
    {
        @* ── KPI row ────────────────────────────────────────────────────────── *@
        <MudGrid>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary"
                         Value="@totalOrders.ToString("N0")" Label="Total orders"
                         Trend="@orderTrend" TrendDirection="@orderTrendDir" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success"
                         Value="@NumberFormat.CompactCurrency(totalRevenue)" Label="Total revenue"
                         ValueTitle="@totalRevenue.ToString("C0")"
                         Trend="@revenueTrend" TrendDirection="@revenueTrendDir" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Info"
                         Value="@NumberFormat.CompactCurrency(avgOrderValue)"
                         ValueTitle="@avgOrderValue.ToString("C0")" Label="Avg order value" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Warning"
                         Value="@($"{avgLeadTimeDays:N1} days")" Label="Avg lead time (order to ship)" />
            </MudItem>
        </MudGrid>

        @* ── Revenue over time ──────────────────────────────────────────────── *@
        <TimeSeriesChart Title="Revenue over time"
                         ChartType="ChartType.Line"
                         Labels="@revenueLabels"
                         Series="@revenueSeries"
                         Periods="@(new[] { "12M", "24M", "36M", "All" })"
                         ShowGranularity="false"
                         YAxisToStringFunc="@(v => NumberFormat.CompactCurrency(v, 0))" />

        @* ── Orders & shipments over time ───────────────────────────────────── *@
        <TimeSeriesChart Title="Orders placed vs. shipped per month"
                         ChartType="ChartType.Bar"
                         Labels="@ordersLabels"
                         Series="@ordersSeries"
                         Periods="@(new[] { "12M", "24M", "All" })"
                         ShowGranularity="false" />

        <MudGrid>
            @* ── Revenue by territory ──────────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Revenue by territory</MudText>
                    @if (territoryLabels.Length > 0)
                    {
                        <MudChart T="double" ChartType="ChartType.Donut"
                                  InputData="@territoryData"
                                  InputLabels="@territoryLabels"
                                  ChartOptions="@AWBlazorApp.Shared.Theming.ChartPalettes.BlueOptions"
                                  Width="100%" Height="280px" />
                    }
                </MudPaper>
            </MudItem>

            @* ── Online vs. reseller ──────────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Online vs. reseller orders</MudText>
                    @if (channelLabels.Length > 0)
                    {
                        <MudChart T="double" ChartType="ChartType.Pie"
                                  InputData="@channelData"
                                  InputLabels="@channelLabels"
                                  ChartOptions="@AWBlazorApp.Shared.Theming.ChartPalettes.BlueOptions"
                                  Width="100%" Height="280px" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ── Top 10 products by revenue ─────────────────────────────────────── *@
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Top 10 products by revenue</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th style="text-align:right">Revenue</th>
                        <th style="text-align:right">Qty sold</th>
                        <th>Share</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var rank = 0; }
                    @foreach (var p in topProducts)
                    {
                        rank++;
                        var pct = topProductsTotal > 0 ? (double)p.Revenue / (double)topProductsTotal * 100 : 0;
                        <tr>
                            <td>@rank</td>
                            <td><strong>@p.Name</strong></td>
                            <td style="text-align:right">@p.Revenue.ToString("C0")</td>
                            <td style="text-align:right">@p.Qty.ToString("N0")</td>
                            <td style="min-width:150px">
                                <MudProgressLinear Value="@pct" Color="Color.Success" Rounded="true" Size="Size.Small" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>

        @* ── Quota vs. actual per salesperson ───────────────────────────────── *@
        @if (quotaLabels.Length > 0)
        {
            <TimeSeriesChart Title="Quota vs. actual revenue (by quarter)"
                             ChartType="ChartType.Bar"
                             Labels="@quotaLabels"
                             Series="@quotaSeries"
                             Periods="@(new[] { "12M", "All" })"
                             ShowGranularity="false"
                             YAxisToStringFunc="@(v => NumberFormat.CompactCurrency(v, 0))" />
        }
    }
</MudStack>

@code {
    private bool loading = true;

    // KPIs
    private int totalOrders;
    private decimal totalRevenue;
    private decimal avgOrderValue;
    private double avgLeadTimeDays;
    private string orderTrend = "";
    private TrendDirection orderTrendDir;
    private string revenueTrend = "";
    private TrendDirection revenueTrendDir;

    // Revenue over time
    private string[] revenueLabels = [];
    private List<ChartSeries<double>> revenueSeries = [];

    // Orders & shipments
    private string[] ordersLabels = [];
    private List<ChartSeries<double>> ordersSeries = [];

    // Territory
    private string[] territoryLabels = [];
    private double[] territoryData = [];

    // Online vs reseller
    private string[] channelLabels = [];
    private double[] channelData = [];

    // Top products
    private List<ProductRevenue> topProducts = [];
    private decimal topProductsTotal;

    // Quota vs actual
    private string[] quotaLabels = [];
    private List<ChartSeries<double>> quotaSeries = [];

    protected override async Task OnInitializedAsync()
    {
        var data = await Cache.GetOrCreateAsync(Cache.Key("sales", "all"), LoadDataAsync);
        totalOrders = data.TotalOrders;
        totalRevenue = data.TotalRevenue;
        avgOrderValue = data.AvgOrderValue;
        avgLeadTimeDays = data.AvgLeadTimeDays;
        orderTrend = data.OrderTrend;
        orderTrendDir = data.OrderTrendDir;
        revenueTrend = data.RevenueTrend;
        revenueTrendDir = data.RevenueTrendDir;
        revenueLabels = data.RevenueLabels;
        revenueSeries = data.RevenueSeries;
        ordersLabels = data.OrdersLabels;
        ordersSeries = data.OrdersSeries;
        territoryLabels = data.TerritoryLabels;
        territoryData = data.TerritoryData;
        channelLabels = data.ChannelLabels;
        channelData = data.ChannelData;
        topProducts = data.TopProducts;
        topProductsTotal = data.TopProductsTotal;
        quotaLabels = data.QuotaLabels;
        quotaSeries = data.QuotaSeries;
        loading = false;
    }

    private async Task<SalesData> LoadDataAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var result = new SalesData();

        // ── KPIs (SQL-side aggregation) ──────────────────────────────────────
        result.TotalOrders = await db.SalesOrderHeaders.CountAsync();
        result.TotalRevenue = await db.SalesOrderHeaders.SumAsync(o => o.TotalDue);
        result.AvgOrderValue = result.TotalOrders > 0 ? result.TotalRevenue / result.TotalOrders : 0;

        result.AvgLeadTimeDays = await db.SalesOrderHeaders
            .Where(o => o.ShipDate != null)
            .AverageAsync(o => (double)EF.Functions.DateDiffDay(o.OrderDate, o.ShipDate!.Value));

        // Trend: SQL-side counts for last 12mo vs prior 12mo
        var maxDate = await db.SalesOrderHeaders.MaxAsync(o => o.OrderDate);
        var cutoff12 = maxDate.AddMonths(-12);
        var cutoff24 = maxDate.AddMonths(-24);

        var recentCount = await db.SalesOrderHeaders.CountAsync(o => o.OrderDate > cutoff12);
        var priorCount = await db.SalesOrderHeaders.CountAsync(o => o.OrderDate > cutoff24 && o.OrderDate <= cutoff12);
        if (priorCount > 0)
        {
            var pctChange = ((double)recentCount / priorCount - 1) * 100;
            result.OrderTrend = $"{pctChange:+0.0;-0.0}% vs prior 12mo";
            result.OrderTrendDir = pctChange >= 0 ? TrendDirection.Up : TrendDirection.Down;
        }

        var recentRev = await db.SalesOrderHeaders.Where(o => o.OrderDate > cutoff12).SumAsync(o => o.TotalDue);
        var priorRev = await db.SalesOrderHeaders.Where(o => o.OrderDate > cutoff24 && o.OrderDate <= cutoff12).SumAsync(o => o.TotalDue);
        if (priorRev > 0)
        {
            var revPct = ((double)(recentRev / priorRev) - 1) * 100;
            result.RevenueTrend = $"{revPct:+0.0;-0.0}% vs prior 12mo";
            result.RevenueTrendDir = revPct >= 0 ? TrendDirection.Up : TrendDirection.Down;
        }

        // ── Revenue over time (SQL GroupBy) ──────────────────────────────────
        var byMonth = await db.SalesOrderHeaders.AsNoTracking()
            .GroupBy(o => new { o.OrderDate.Year, o.OrderDate.Month })
            .Select(g => new { g.Key.Year, g.Key.Month, Revenue = (double)g.Sum(o => o.TotalDue), Count = g.Count() })
            .OrderBy(x => x.Year).ThenBy(x => x.Month)
            .ToListAsync();

        result.RevenueLabels = byMonth.Select(x => $"{x.Year}-{x.Month:D2}").ToArray();
        result.RevenueSeries = [new ChartSeries<double> { Name = "Revenue", Data = byMonth.Select(x => x.Revenue).ToArray() }];

        // ── Orders placed vs shipped ─────────────────────────────────────────
        var placedByMonth = byMonth.ToDictionary(x => $"{x.Year}-{x.Month:D2}", x => (double)x.Count);

        var shippedByMonth = await db.SalesOrderHeaders.AsNoTracking()
            .Where(o => o.ShipDate != null)
            .GroupBy(o => new { o.ShipDate!.Value.Year, o.ShipDate.Value.Month })
            .Select(g => new { g.Key.Year, g.Key.Month, Count = g.Count() })
            .ToListAsync();
        var shippedDict = shippedByMonth.ToDictionary(x => $"{x.Year}-{x.Month:D2}", x => (double)x.Count);

        var allMonths = placedByMonth.Keys.Union(shippedDict.Keys).OrderBy(k => k).ToArray();
        result.OrdersLabels = allMonths;
        result.OrdersSeries =
        [
            new ChartSeries<double> { Name = "Placed", Data = allMonths.Select(m => placedByMonth.GetValueOrDefault(m)).ToArray() },
            new ChartSeries<double> { Name = "Shipped", Data = allMonths.Select(m => shippedDict.GetValueOrDefault(m)).ToArray() },
        ];

        // ── Revenue by territory (SQL GroupBy) ───────────────────────────────
        var territories = await db.SalesTerritories.AsNoTracking().ToDictionaryAsync(t => t.Id, t => t.Name);
        var byTerritory = await db.SalesOrderHeaders.AsNoTracking()
            .Where(o => o.TerritoryId != null)
            .GroupBy(o => o.TerritoryId!.Value)
            .Select(g => new { TerritoryId = g.Key, Revenue = (double)g.Sum(o => o.TotalDue) })
            .OrderByDescending(x => x.Revenue)
            .ToListAsync();

        result.TerritoryLabels = byTerritory.Select(x => territories.GetValueOrDefault(x.TerritoryId, $"Territory {x.TerritoryId}")).ToArray();
        result.TerritoryData = byTerritory.Select(x => x.Revenue).ToArray();

        // ── Online vs. reseller (SQL-side) ───────────────────────────────────
        var onlineCount = await db.SalesOrderHeaders.CountAsync(o => o.OnlineOrderFlag);
        result.ChannelLabels = ["Online", "Reseller"];
        result.ChannelData = [(double)onlineCount, (double)(result.TotalOrders - onlineCount)];

        // ── Top 10 products (SQL GroupBy) ────────────────────────────────────
        var productNames = await db.Products.AsNoTracking()
            .Select(p => new { p.Id, p.Name })
            .ToDictionaryAsync(p => p.Id, p => p.Name);

        var topProductData = await db.SalesOrderDetails.AsNoTracking()
            .GroupBy(d => d.ProductId)
            .Select(g => new { ProductId = g.Key, Revenue = g.Sum(d => d.LineTotal), Qty = g.Sum(d => (int)d.OrderQty) })
            .OrderByDescending(x => x.Revenue)
            .Take(10)
            .ToListAsync();

        result.TopProducts = topProductData.Select(x => new ProductRevenue
        {
            Name = productNames.GetValueOrDefault(x.ProductId, $"Product {x.ProductId}"),
            Revenue = x.Revenue,
            Qty = x.Qty,
        }).ToList();
        result.TopProductsTotal = result.TopProducts.Sum(p => p.Revenue);

        // ── Quota vs actual (SQL GroupBy, quarterly) ─────────────────────────
        var quotas = await db.SalesPersonQuotaHistories.AsNoTracking()
            .GroupBy(q => new { q.QuotaDate.Year, Quarter = (q.QuotaDate.Month - 1) / 3 + 1 })
            .Select(g => new { g.Key.Year, g.Key.Quarter, Total = (double)g.Sum(q => q.SalesQuota) })
            .ToListAsync();

        if (quotas.Count > 0)
        {
            var quotaByQ = quotas.ToDictionary(x => $"{x.Year}-Q{x.Quarter}", x => x.Total);

            var actualByQ = await db.SalesOrderHeaders.AsNoTracking()
                .Where(o => o.SalesPersonId != null)
                .GroupBy(o => new { o.OrderDate.Year, Quarter = (o.OrderDate.Month - 1) / 3 + 1 })
                .Select(g => new { g.Key.Year, g.Key.Quarter, Total = (double)g.Sum(o => o.TotalDue) })
                .ToListAsync();
            var actualDict = actualByQ.ToDictionary(x => $"{x.Year}-Q{x.Quarter}", x => x.Total);

            var quarters = quotaByQ.Keys.Union(actualDict.Keys).OrderBy(k => k).ToArray();
            result.QuotaLabels = quarters;
            result.QuotaSeries =
            [
                new ChartSeries<double> { Name = "Quota", Data = quarters.Select(q => quotaByQ.GetValueOrDefault(q)).ToArray() },
                new ChartSeries<double> { Name = "Actual", Data = quarters.Select(q => actualDict.GetValueOrDefault(q)).ToArray() },
            ];
        }

        return result;
    }

    private sealed class SalesData
    {
        public int TotalOrders { get; set; }
        public decimal TotalRevenue { get; set; }
        public decimal AvgOrderValue { get; set; }
        public double AvgLeadTimeDays { get; set; }
        public string OrderTrend { get; set; } = "";
        public TrendDirection OrderTrendDir { get; set; }
        public string RevenueTrend { get; set; } = "";
        public TrendDirection RevenueTrendDir { get; set; }
        public string[] RevenueLabels { get; set; } = [];
        public List<ChartSeries<double>> RevenueSeries { get; set; } = [];
        public string[] OrdersLabels { get; set; } = [];
        public List<ChartSeries<double>> OrdersSeries { get; set; } = [];
        public string[] TerritoryLabels { get; set; } = [];
        public double[] TerritoryData { get; set; } = [];
        public string[] ChannelLabels { get; set; } = [];
        public double[] ChannelData { get; set; } = [];
        public List<ProductRevenue> TopProducts { get; set; } = [];
        public decimal TopProductsTotal { get; set; }
        public string[] QuotaLabels { get; set; } = [];
        public List<ChartSeries<double>> QuotaSeries { get; set; } = [];
    }

    private sealed class ProductRevenue
    {
        public string Name { get; init; } = "";
        public decimal Revenue { get; init; }
        public int Qty { get; init; }
    }
}
