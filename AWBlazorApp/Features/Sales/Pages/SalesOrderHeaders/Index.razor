@page "/aw/sales-order-headers"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Domain
@using AWBlazorApp.Features.Sales.Models
@using AWBlazorApp.Features.Sales.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Sales order headers</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Sales order headers</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.SalesOrderHeader</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/sales-order-headers/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New order</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4"><FkAutocomplete TValue="int" Value="@(filterCustomerId ?? 0)" ValueChanged="@(v => { filterCustomerId = v == 0 ? null : v; })" Label="Customer" SearchFunc="@(q => Lookup.SearchCustomersAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="byte?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="byte?" Value="@((byte?)null)">(any)</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte)1)">1 — In process</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte)2)">2 — Approved</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte)3)">3 — Backordered</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte)4)">4 — Rejected</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte)5)">5 — Shipped</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte)6)">6 — Cancelled</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="SalesOrderHeaderDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" Virtualize="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <HierarchyColumn T="SalesOrderHeaderDto" />
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SalesOrderNumber" Title="Order #">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.SalesOrderNumber)" Title="Order #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.OrderDate" Title="Order date" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.OrderDate)" Title="Order date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    @{ var (label, color) = StatusHelper.SalesOrderStatus(context.Item.Status); }
                    <MudChip T="string" Size="Size.Small" Color="@color" Variant="Variant.Filled">@label</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.CustomerId" Title="Customer">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.CustomerId)" Title="Customer" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SubTotal" Title="Subtotal" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.SubTotal)" Title="Subtotal" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.TotalDue" Title="Total due" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.TotalDue)" Title="Total due" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent>
            <SalesOrderHeaderExpandedRow OrderId="@context.Item.Id" />
        </ChildRowContent>
        <PagerContent><MudDataGridPager T="SalesOrderHeaderDto" /></PagerContent>
        <NoRecordsContent>
            <EmptyState />
        </NoRecordsContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<SalesOrderHeaderDto> grid = null!;
    private bool _loading = true;
    private int? filterCustomerId;
    private byte? filterStatus;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SalesOrderHeaderDto>> LoadServerDataAsync(GridState<SalesOrderHeaderDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.SalesOrderHeaders.AsNoTracking();
            if (filterCustomerId.HasValue) query = query.Where(x => x.CustomerId == filterCustomerId.Value);
            if (filterStatus.HasValue) query = query.Where(x => x.Status == filterStatus.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(SalesOrderHeaderDto.Id)                => sort.Descending ? query.OrderByDescending(x => x.Id)                : query.OrderBy(x => x.Id),
                nameof(SalesOrderHeaderDto.SalesOrderNumber)  => sort.Descending ? query.OrderByDescending(x => x.SalesOrderNumber)  : query.OrderBy(x => x.SalesOrderNumber),
                nameof(SalesOrderHeaderDto.OrderDate)         => sort.Descending ? query.OrderByDescending(x => x.OrderDate)         : query.OrderBy(x => x.OrderDate),
                nameof(SalesOrderHeaderDto.SubTotal)          => sort.Descending ? query.OrderByDescending(x => x.SubTotal)          : query.OrderBy(x => x.SubTotal),
                nameof(SalesOrderHeaderDto.TotalDue)          => sort.Descending ? query.OrderByDescending(x => x.TotalDue)          : query.OrderBy(x => x.TotalDue),
                nameof(SalesOrderHeaderDto.CustomerId)        => sort.Descending ? query.OrderByDescending(x => x.CustomerId)        : query.OrderBy(x => x.CustomerId),
                nameof(SalesOrderHeaderDto.ModifiedDate)      => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)      : query.OrderBy(x => x.ModifiedDate),
                _                                             => query.OrderByDescending(x => x.OrderDate).ThenBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<SalesOrderHeaderDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesOrderHeaderDialog>("New sales order", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Sales order created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(SalesOrderHeaderDto row)
    {
        var parameters = new DialogParameters<SalesOrderHeaderDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesOrderHeaderDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Sales order updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(SalesOrderHeaderDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete sales order?", $"Permanently delete order #{row.Id} ({row.SalesOrderNumber})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesOrderHeaders.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Order no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.SalesOrderHeaderAuditLogs.Add(SalesOrderHeaderAuditService.RecordDelete(entity, changedBy));
        db.SalesOrderHeaders.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Sales order deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(SalesOrderHeaderDto row) => Navigation.NavigateTo($"aw/sales-order-headers/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
