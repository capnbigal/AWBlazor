@page "/aw/credit-cards/history"
@page "/aw/credit-cards/history/{SlotId:int}"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Credit card history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/credit-cards"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Credit card history" : $"History for credit card #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.List" Href="aw/credit-cards/history">All history</MudButton>
        }
    </MudStack>

    @if (SlotId is null)
    {
        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                        <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudNumericField T="int?" @bind-Value="filterRowId" Label="Credit card id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudDataGrid T="CreditCardAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CreditCardId" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.CreditCardId)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CardType" Title="Card type">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.CardType)" Title="Card type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CardNumber" Title="Card number">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.CardNumber)" Title="Card number" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ExpMonth" Title="Exp month">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.ExpMonth)" Title="Exp month" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ExpYear" Title="Exp year">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.ExpYear)" Title="Exp year" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="CreditCardAuditLog" PropertyName="@nameof(CreditCardAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="CreditCardAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }

    private MudDataGrid<CreditCardAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private int? filterRowId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<CreditCardAuditLogDto>> LoadServerDataAsync(GridState<CreditCardAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CreditCardAuditLogs.AsNoTracking();

        var scopedId = SlotId ?? filterRowId;
        if (scopedId.HasValue) query = query.Where(a => a.CreditCardId == scopedId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CreditCardAuditLogDto.ChangedDate) => sort.Descending ? query.OrderByDescending(a => a.ChangedDate) : query.OrderBy(a => a.ChangedDate),
            nameof(CreditCardAuditLogDto.CreditCardId) => sort.Descending ? query.OrderByDescending(a => a.CreditCardId) : query.OrderBy(a => a.CreditCardId),
            nameof(CreditCardAuditLogDto.ChangedBy) => sort.Descending ? query.OrderByDescending(a => a.ChangedBy) : query.OrderBy(a => a.ChangedBy),
            nameof(CreditCardAuditLogDto.CardType) => sort.Descending ? query.OrderByDescending(a => a.CardType) : query.OrderBy(a => a.CardType),
            nameof(CreditCardAuditLogDto.CardNumber) => sort.Descending ? query.OrderByDescending(a => a.CardNumber) : query.OrderBy(a => a.CardNumber),
            nameof(CreditCardAuditLogDto.ExpMonth) => sort.Descending ? query.OrderByDescending(a => a.ExpMonth) : query.OrderBy(a => a.ExpMonth),
            nameof(CreditCardAuditLogDto.ExpYear) => sort.Descending ? query.OrderByDescending(a => a.ExpYear) : query.OrderBy(a => a.ExpYear),
            nameof(CreditCardAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _ => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<CreditCardAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
