@page "/aw/credit-cards"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Domain
@using AWBlazorApp.Features.Sales.Models
@using AWBlazorApp.Features.Sales.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Credit cards</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Credit cards</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.CreditCard</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/credit-cards/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New credit card</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudTextField @bind-Value="filterCardType" Label="Card type" Variant="Variant.Outlined" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="CreditCardDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25" FilterMode="DataGridFilterMode.ColumnFilterMenu">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id">
                <FilterTemplate><ColumnFilterButton TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CardType" Title="Card type">
                <FilterTemplate><ColumnFilterButton TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.CardType)" Title="Card type" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CardNumber" Title="Card number">
                <FilterTemplate><ColumnFilterButton TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.CardNumber)" Title="Card number" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ExpMonth" Title="Exp month">
                <FilterTemplate><ColumnFilterButton TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.ExpMonth)" Title="Exp month" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ExpYear" Title="Exp year">
                <FilterTemplate><ColumnFilterButton TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.ExpYear)" Title="Exp year" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <FilterTemplate><ColumnFilterButton TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="CreditCardDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<CreditCardDto> grid = null!;
    private string? filterCardType;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<CreditCardDto>> LoadServerDataAsync(GridState<CreditCardDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CreditCards.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCardType)) query = query.Where(x => x.CardType == filterCardType.Trim());
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CreditCardDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(CreditCardDto.CardType)     => sort.Descending ? query.OrderByDescending(x => x.CardType)     : query.OrderBy(x => x.CardType),
            nameof(CreditCardDto.CardNumber)   => sort.Descending ? query.OrderByDescending(x => x.CardNumber)   : query.OrderBy(x => x.CardNumber),
            nameof(CreditCardDto.ExpMonth)     => sort.Descending ? query.OrderByDescending(x => x.ExpMonth)     : query.OrderBy(x => x.ExpMonth),
            nameof(CreditCardDto.ExpYear)      => sort.Descending ? query.OrderByDescending(x => x.ExpYear)      : query.OrderBy(x => x.ExpYear),
            nameof(CreditCardDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                  => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CreditCardDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CreditCardDialog>("New credit card", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Credit card created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(CreditCardDto row)
    {
        var parameters = new DialogParameters<CreditCardDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CreditCardDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Credit card updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(CreditCardDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete credit card?", $"Permanently delete credit card #{row.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CreditCards.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Credit card no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.CreditCardAuditLogs.Add(CreditCardAuditService.RecordDelete(entity, changedBy));
        db.CreditCards.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Credit card deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(CreditCardDto row) => Navigation.NavigateTo($"aw/credit-cards/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
