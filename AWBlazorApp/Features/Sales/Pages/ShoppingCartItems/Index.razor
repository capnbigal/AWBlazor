@page "/aw/shopping-cart-items"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Domain
@using AWBlazorApp.Features.Sales.Models
@using AWBlazorApp.Features.Sales.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Shopping cart items</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Shopping cart items</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.ShoppingCartItem</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/shopping-cart-items/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New cart item</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudTextField @bind-Value="filterCartId" Label="Shopping cart id" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="ShoppingCartItemDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ShoppingCartId" Title="Cart id">
                <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.ShoppingCartId)" Title="Cart id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductId" Title="Product">
                <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Quantity" Title="Qty">
                <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.Quantity)" Title="Qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.DateCreated" Title="Created" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.DateCreated)" Title="Created" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History">
                            <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" />
                        </MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ShoppingCartItemDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<ShoppingCartItemDto> grid = null!;
    private bool _loading = true;
    private string? filterCartId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ShoppingCartItemDto>> LoadServerDataAsync(GridState<ShoppingCartItemDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.ShoppingCartItems.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterCartId))
            {
                var needle = filterCartId.Trim();
                query = query.Where(x => x.ShoppingCartId == needle);
            }
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(ShoppingCartItemDto.Id)             => sort.Descending ? query.OrderByDescending(x => x.Id)             : query.OrderBy(x => x.Id),
                nameof(ShoppingCartItemDto.ShoppingCartId) => sort.Descending ? query.OrderByDescending(x => x.ShoppingCartId) : query.OrderBy(x => x.ShoppingCartId),
                nameof(ShoppingCartItemDto.ProductId)      => sort.Descending ? query.OrderByDescending(x => x.ProductId)      : query.OrderBy(x => x.ProductId),
                nameof(ShoppingCartItemDto.Quantity)       => sort.Descending ? query.OrderByDescending(x => x.Quantity)       : query.OrderBy(x => x.Quantity),
                nameof(ShoppingCartItemDto.DateCreated)    => sort.Descending ? query.OrderByDescending(x => x.DateCreated)    : query.OrderBy(x => x.DateCreated),
                nameof(ShoppingCartItemDto.ModifiedDate)   => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)   : query.OrderBy(x => x.ModifiedDate),
                _                                          => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ShoppingCartItemDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ShoppingCartItemDialog>("New cart item", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Cart item created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(ShoppingCartItemDto row)
    {
        var parameters = new DialogParameters<ShoppingCartItemDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ShoppingCartItemDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Cart item updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(ShoppingCartItemDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete cart item?", $"Permanently delete cart item #{row.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ShoppingCartItems.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Cart item no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.ShoppingCartItemAuditLogs.Add(ShoppingCartItemAuditService.RecordDelete(entity, changedBy));
        db.ShoppingCartItems.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Cart item deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(ShoppingCartItemDto row) => Navigation.NavigateTo($"aw/shopping-cart-items/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
