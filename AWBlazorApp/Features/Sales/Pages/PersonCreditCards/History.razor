@page "/aw/person-credit-cards/history"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Person ↔ credit card audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/person-credit-cards"))" />
        <MudText Typo="Typo.h4">Person ↔ credit card audit</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="BusinessEntityId" Label="Business entity id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="CreditCardId" Label="Credit card id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="PersonCreditCardAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Business entity" />
            <PropertyColumn Property="x => x.CreditCardId" Title="Credit card" />
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By" />
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary" />
        </Columns>
        <PagerContent><MudDataGridPager T="PersonCreditCardAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? BusinessEntityId { get; set; }
    [SupplyParameterFromQuery] public int? CreditCardId { get; set; }

    private MudDataGrid<PersonCreditCardAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;

    private async Task<GridData<PersonCreditCardAuditLogDto>> LoadServerDataAsync(GridState<PersonCreditCardAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.PersonCreditCardAuditLogs.AsNoTracking();

        if (BusinessEntityId.HasValue) query = query.Where(a => a.BusinessEntityId == BusinessEntityId.Value);
        if (CreditCardId.HasValue) query = query.Where(a => a.CreditCardId == CreditCardId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(PersonCreditCardAuditLogDto.ChangedDate) => sort.Descending ? query.OrderByDescending(a => a.ChangedDate) : query.OrderBy(a => a.ChangedDate),
            nameof(PersonCreditCardAuditLogDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(a => a.BusinessEntityId) : query.OrderBy(a => a.BusinessEntityId),
            nameof(PersonCreditCardAuditLogDto.CreditCardId) => sort.Descending ? query.OrderByDescending(a => a.CreditCardId) : query.OrderBy(a => a.CreditCardId),
            nameof(PersonCreditCardAuditLogDto.ChangedBy) => sort.Descending ? query.OrderByDescending(a => a.ChangedBy) : query.OrderBy(a => a.ChangedBy),
            nameof(PersonCreditCardAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _ => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<PersonCreditCardAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
