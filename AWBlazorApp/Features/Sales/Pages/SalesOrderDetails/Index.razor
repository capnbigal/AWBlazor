@page "/aw/sales-order-details"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Domain
@using AWBlazorApp.Features.Sales.Models
@using AWBlazorApp.Features.Sales.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Sales order details</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Sales order details</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.SalesOrderDetail · composite PK (SalesOrderID, SalesOrderDetailID)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/sales-order-details/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New detail</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterSalesOrderId ?? 0)" ValueChanged="@(v => { filterSalesOrderId = v == 0 ? null : v; })" Label="Sales order" SearchFunc="@(q => Lookup.SearchSalesOrdersAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => { filterProductId = v == 0 ? null : v; })" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="SalesOrderDetailDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" Virtualize="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.SalesOrderId" Title="Order id">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderDetail" PropertyName="@nameof(SalesOrderDetailDto.SalesOrderId)" Title="Order id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SalesOrderDetailId" Title="Detail id">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderDetail" PropertyName="@nameof(SalesOrderDetailDto.SalesOrderDetailId)" Title="Detail id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductId" Title="Product">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderDetail" PropertyName="@nameof(SalesOrderDetailDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.OrderQty" Title="Qty">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderDetail" PropertyName="@nameof(SalesOrderDetailDto.OrderQty)" Title="Qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.UnitPrice" Title="Unit price" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderDetail" PropertyName="@nameof(SalesOrderDetailDto.UnitPrice)" Title="Unit price" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.LineTotal" Title="Line total" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderDetail" PropertyName="@nameof(SalesOrderDetailDto.LineTotal)" Title="Line total" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderDetail" PropertyName="@nameof(SalesOrderDetailDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SalesOrderDetailDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<SalesOrderDetailDto> grid = null!;
    private bool _loading = true;
    private int? filterSalesOrderId;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SalesOrderDetailDto>> LoadServerDataAsync(GridState<SalesOrderDetailDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.SalesOrderDetails.AsNoTracking();
            if (filterSalesOrderId.HasValue) query = query.Where(x => x.SalesOrderId == filterSalesOrderId.Value);
            if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);

            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(SalesOrderDetailDto.SalesOrderId)       => sort.Descending ? query.OrderByDescending(x => x.SalesOrderId)       : query.OrderBy(x => x.SalesOrderId),
                nameof(SalesOrderDetailDto.SalesOrderDetailId) => sort.Descending ? query.OrderByDescending(x => x.SalesOrderDetailId) : query.OrderBy(x => x.SalesOrderDetailId),
                nameof(SalesOrderDetailDto.ProductId)          => sort.Descending ? query.OrderByDescending(x => x.ProductId)          : query.OrderBy(x => x.ProductId),
                nameof(SalesOrderDetailDto.OrderQty)           => sort.Descending ? query.OrderByDescending(x => x.OrderQty)           : query.OrderBy(x => x.OrderQty),
                nameof(SalesOrderDetailDto.UnitPrice)          => sort.Descending ? query.OrderByDescending(x => x.UnitPrice)          : query.OrderBy(x => x.UnitPrice),
                nameof(SalesOrderDetailDto.LineTotal)          => sort.Descending ? query.OrderByDescending(x => x.LineTotal)          : query.OrderBy(x => x.LineTotal),
                nameof(SalesOrderDetailDto.ModifiedDate)       => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)       : query.OrderBy(x => x.ModifiedDate),
                _                                              => query.OrderBy(x => x.SalesOrderId).ThenBy(x => x.SalesOrderDetailId),
            };

            var rows = await query
                .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<SalesOrderDetailDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesOrderDetailDialog>("New order detail", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Detail created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(SalesOrderDetailDto row)
    {
        var parameters = new DialogParameters<SalesOrderDetailDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesOrderDetailDialog>($"Edit detail ({row.SalesOrderId}, {row.SalesOrderDetailId})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Detail updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(SalesOrderDetailDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete detail?", $"Permanently delete detail ({row.SalesOrderId}, {row.SalesOrderDetailId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesOrderDetails.FirstOrDefaultAsync(t => t.SalesOrderId == row.SalesOrderId && t.SalesOrderDetailId == row.SalesOrderDetailId);
        if (entity is null) { Snackbar.Add("Detail no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.SalesOrderDetailAuditLogs.Add(SalesOrderDetailAuditService.RecordDelete(entity, changedBy));
        db.SalesOrderDetails.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Detail deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(SalesOrderDetailDto row) => Navigation.NavigateTo($"aw/sales-order-details/history?salesOrderId={row.SalesOrderId}&salesOrderDetailId={row.SalesOrderDetailId}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
