@page "/aw/currencies/history"
@page "/aw/currencies/history/{Code}"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Currency history@(string.IsNullOrEmpty(Code) ? "" : $" — {Code}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/currencies"))" />
        <MudText Typo="Typo.h4">@(string.IsNullOrEmpty(Code) ? "Currency history" : $"History for currency {Code}")</MudText>
        <MudSpacer />
        @if (!string.IsNullOrEmpty(Code))
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.List" Href="aw/currencies/history">All history</MudButton>
        }
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">Every create, update, and delete of a <code>Sales.Currency</code> row is recorded here.</MudText>

    @if (string.IsNullOrEmpty(Code))
    {
        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                        <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterCode" Label="Code" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudDataGrid T="CurrencyAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.CurrencyCode" Title="Code" />
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary" />
        </Columns>
        <PagerContent><MudDataGridPager T="CurrencyAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public string? Code { get; set; }

    private MudDataGrid<CurrencyAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private string? filterCode;

    private async Task<GridData<CurrencyAuditLogDto>> LoadServerDataAsync(GridState<CurrencyAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CurrencyAuditLogs.AsNoTracking();

        var scopedCode = !string.IsNullOrEmpty(Code) ? Code : filterCode?.Trim();
        if (!string.IsNullOrEmpty(scopedCode)) query = query.Where(a => a.CurrencyCode == scopedCode);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CurrencyAuditLogDto.ChangedDate)  => sort.Descending ? query.OrderByDescending(a => a.ChangedDate)  : query.OrderBy(a => a.ChangedDate),
            nameof(CurrencyAuditLogDto.CurrencyCode) => sort.Descending ? query.OrderByDescending(a => a.CurrencyCode) : query.OrderBy(a => a.CurrencyCode),
            nameof(CurrencyAuditLogDto.ChangedBy)    => sort.Descending ? query.OrderByDescending(a => a.ChangedBy)    : query.OrderBy(a => a.ChangedBy),
            nameof(CurrencyAuditLogDto.Name)         => sort.Descending ? query.OrderByDescending(a => a.Name)         : query.OrderBy(a => a.Name),
            _                                        => query.OrderByDescending(a => a.ChangedDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<CurrencyAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
