@page "/aw/sales-person-quota-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Domain
@using AWBlazorApp.Features.Sales.Models
@using AWBlazorApp.Features.Sales.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Sales person quota history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Sales person quota history</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.SalesPersonQuotaHistory · composite PK (BusinessEntityID, QuotaDate)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/sales-person-quota-histories/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New quota row</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => { filterBusinessEntityId = v == 0 ? null : v; })" Label="Sales person" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="SalesPersonQuotaHistoryDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25" FilterMode="DataGridFilterMode.ColumnFilterMenu">
        <Columns>
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Sales person id">
                <FilterTemplate><ColumnFilterButton TEntity="SalesPersonQuotaHistory" PropertyName="@nameof(SalesPersonQuotaHistoryDto.BusinessEntityId)" Title="Sales person id" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.QuotaDate" Title="Quota date" Format="yyyy-MM-dd">
                <FilterTemplate><ColumnFilterButton TEntity="SalesPersonQuotaHistory" PropertyName="@nameof(SalesPersonQuotaHistoryDto.QuotaDate)" Title="Quota date" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SalesQuota" Title="Quota" Format="C0">
                <FilterTemplate><ColumnFilterButton TEntity="SalesPersonQuotaHistory" PropertyName="@nameof(SalesPersonQuotaHistoryDto.SalesQuota)" Title="Quota" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <FilterTemplate><ColumnFilterButton TEntity="SalesPersonQuotaHistory" PropertyName="@nameof(SalesPersonQuotaHistoryDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SalesPersonQuotaHistoryDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<SalesPersonQuotaHistoryDto> grid = null!;
    private int? filterBusinessEntityId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SalesPersonQuotaHistoryDto>> LoadServerDataAsync(GridState<SalesPersonQuotaHistoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesPersonQuotaHistories.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SalesPersonQuotaHistoryDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(SalesPersonQuotaHistoryDto.QuotaDate)        => sort.Descending ? query.OrderByDescending(x => x.QuotaDate)        : query.OrderBy(x => x.QuotaDate),
            nameof(SalesPersonQuotaHistoryDto.SalesQuota)       => sort.Descending ? query.OrderByDescending(x => x.SalesQuota)       : query.OrderBy(x => x.SalesQuota),
            nameof(SalesPersonQuotaHistoryDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _                                                   => query.OrderBy(x => x.BusinessEntityId).ThenByDescending(x => x.QuotaDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SalesPersonQuotaHistoryDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesPersonQuotaHistoryDialog>("New quota row", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Quota row created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(SalesPersonQuotaHistoryDto row)
    {
        var parameters = new DialogParameters<SalesPersonQuotaHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesPersonQuotaHistoryDialog>($"Edit ({row.BusinessEntityId}, {row.QuotaDate:yyyy-MM-dd})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Quota row updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(SalesPersonQuotaHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete quota row?", $"Permanently delete quota row ({row.BusinessEntityId}, {row.QuotaDate:yyyy-MM-dd})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesPersonQuotaHistories
            .FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.QuotaDate == row.QuotaDate);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.SalesPersonQuotaHistoryAuditLogs.Add(SalesPersonQuotaHistoryAuditService.RecordDelete(entity, changedBy));
        db.SalesPersonQuotaHistories.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Quota row deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(SalesPersonQuotaHistoryDto row)
        => Navigation.NavigateTo($"aw/sales-person-quota-histories/history?businessEntityId={row.BusinessEntityId}&quotaDate={row.QuotaDate:yyyy-MM-dd}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
