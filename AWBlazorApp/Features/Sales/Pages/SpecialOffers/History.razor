@page "/aw/special-offers/history"
@page "/aw/special-offers/history/{SlotId:int}"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Special offer history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/special-offers"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Special offer history" : $"History for special offer #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.List" Href="aw/special-offers/history">All history</MudButton>
        }
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">Every create, update, and delete of a <code>Sales.SpecialOffer</code> row is recorded here.</MudText>

    @if (SlotId is null)
    {
        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                        <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudNumericField T="int?" @bind-Value="filterRowId" Label="Offer id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudDataGrid T="SpecialOfferAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferAuditLog" PropertyName="@nameof(SpecialOfferAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SpecialOfferId" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferAuditLog" PropertyName="@nameof(SpecialOfferAuditLogDto.SpecialOfferId)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferAuditLog" PropertyName="@nameof(SpecialOfferAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Description" Title="Description">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferAuditLog" PropertyName="@nameof(SpecialOfferAuditLogDto.Description)" Title="Description" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.DiscountPct" Title="Discount" Format="P2">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferAuditLog" PropertyName="@nameof(SpecialOfferAuditLogDto.DiscountPct)" Title="Discount" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.OfferType" Title="Type">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferAuditLog" PropertyName="@nameof(SpecialOfferAuditLogDto.OfferType)" Title="Type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="SpecialOfferAuditLog" PropertyName="@nameof(SpecialOfferAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SpecialOfferAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }

    private MudDataGrid<SpecialOfferAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private int? filterRowId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SpecialOfferAuditLogDto>> LoadServerDataAsync(GridState<SpecialOfferAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SpecialOfferAuditLogs.AsNoTracking();

        var scopedId = SlotId ?? filterRowId;
        if (scopedId.HasValue) query = query.Where(a => a.SpecialOfferId == scopedId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SpecialOfferAuditLogDto.ChangedDate)    => sort.Descending ? query.OrderByDescending(a => a.ChangedDate)    : query.OrderBy(a => a.ChangedDate),
            nameof(SpecialOfferAuditLogDto.SpecialOfferId) => sort.Descending ? query.OrderByDescending(a => a.SpecialOfferId) : query.OrderBy(a => a.SpecialOfferId),
            nameof(SpecialOfferAuditLogDto.ChangedBy)      => sort.Descending ? query.OrderByDescending(a => a.ChangedBy)      : query.OrderBy(a => a.ChangedBy),
            nameof(SpecialOfferAuditLogDto.Description)    => sort.Descending ? query.OrderByDescending(a => a.Description)    : query.OrderBy(a => a.Description),
            nameof(SpecialOfferAuditLogDto.DiscountPct)    => sort.Descending ? query.OrderByDescending(a => a.DiscountPct)    : query.OrderBy(a => a.DiscountPct),
            nameof(SpecialOfferAuditLogDto.OfferType)      => sort.Descending ? query.OrderByDescending(a => a.OfferType)      : query.OrderBy(a => a.OfferType),
            nameof(SpecialOfferAuditLogDto.ChangeSummary)  => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary)  : query.OrderBy(a => a.ChangeSummary),
            _                                              => query.OrderByDescending(a => a.ChangedDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<SpecialOfferAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
