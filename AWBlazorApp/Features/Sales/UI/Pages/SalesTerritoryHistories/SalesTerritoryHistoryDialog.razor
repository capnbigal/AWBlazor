@using AWBlazorApp.Features.Sales.Domain
@using AWBlazorApp.Features.Sales.Dtos
@using AWBlazorApp.Features.Sales.Audit
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateSalesTerritoryHistoryRequest> CreateValidator
@inject MudFormValidator<UpdateSalesTerritoryHistoryRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create assignment" : "Edit assignment")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4"><FkAutocomplete TValue="int" Value="@createModel.BusinessEntityId" ValueChanged="@((int v) => createModel = createModel with { BusinessEntityId = v })" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" Label="Sales person" Required="true" /></MudItem>
                    <MudItem xs="12" sm="4"><FkSelect TValue="int" Value="@createModel.TerritoryId" ValueChanged="@((int v) => createModel = createModel with { TerritoryId = v })" Label="Territory" Required="true" Items="_territories" /></MudItem>
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@createModel.StartDate" DateChanged="@((DateTime? v) => createModel = createModel with { StartDate = v ?? DateTime.UtcNow.Date })" Label="Start date" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="12"><MudDatePicker Date="@createModel.EndDate" DateChanged="@((DateTime? v) => createModel = createModel with { EndDate = v })" Label="End date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12"><MudDatePicker Date="@updateModel.EndDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { EndDate = v })" Label="End date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SalesTerritoryHistoryDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateSalesTerritoryHistoryRequest createModel = new() { StartDate = DateTime.UtcNow.Date };
    private UpdateSalesTerritoryHistoryRequest updateModel = new();
    private bool saving;
    private List<LookupItem<int>> _territories = [];

    protected override async Task OnInitializedAsync()
    {
        _territories = await Lookup.GetSalesTerritoriesAsync();

        if (Model is not null) updateModel = new UpdateSalesTerritoryHistoryRequest { EndDate = Model.EndDate };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.SalesTerritoryHistories.AnyAsync(x => x.BusinessEntityId == createModel.BusinessEntityId && x.StartDate == createModel.StartDate && x.TerritoryId == createModel.TerritoryId))
                { Snackbar.Add("Assignment already exists.", Severity.Error); return; }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.SalesTerritoryHistories.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.SalesTerritoryHistoryAuditLogs.Add(SalesTerritoryHistoryAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.SalesTerritoryHistories.FirstOrDefaultAsync(t => t.BusinessEntityId == Model!.BusinessEntityId && t.StartDate == Model.StartDate && t.TerritoryId == Model.TerritoryId);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = SalesTerritoryHistoryAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.SalesTerritoryHistoryAuditLogs.Add(SalesTerritoryHistoryAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
