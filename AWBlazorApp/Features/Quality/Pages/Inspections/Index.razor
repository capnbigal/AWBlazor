@page "/quality/inspections"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Inspections</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Inspections</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">qa.Inspection — record results, complete to Pass/Fail (Fail auto-opens NCR)</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="InspectionStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="InspectionStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<InspectionStatus>()) { <MudSelectItem T="InspectionStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudSelect T="InspectionSourceKind?" @bind-Value="filterSource" Label="Source" Variant="Variant.Outlined" Clearable="true" Style="max-width: 220px">
                <MudSelectItem T="InspectionSourceKind?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<InspectionSourceKind>()) { <MudSelectItem T="InspectionSourceKind?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="InspectionDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.InspectionNumber" Title="Number" />
            <PropertyColumn Property="x => x.Status" Title="Status" />
            <PropertyColumn Property="x => x.SourceKind" Title="Source" />
            <PropertyColumn Property="x => x.SourceId" Title="Src id" />
            <PropertyColumn Property="x => x.InspectionPlanId" Title="Plan" />
            <PropertyColumn Property="x => x.InventoryItemId" Title="Item" />
            <PropertyColumn Property="x => x.Quantity" Title="Qty" Format="N4" />
            <PropertyColumn Property="x => x.InspectedAt" Title="When" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate><MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"quality/inspections/{context.Item.Id}"))" /></CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="InspectionDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<InspectionDto> grid = null!;
    private bool _loading = true;
    private InspectionStatus? filterStatus = InspectionStatus.Pending;
    private InspectionSourceKind? filterSource;

    private async Task<GridData<InspectionDto>> LoadAsync(GridState<InspectionDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.Inspections.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            if (filterSource.HasValue) q = q.Where(x => x.SourceKind == filterSource.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.ModifiedDate).ThenByDescending(x => x.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<InspectionDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();
}
