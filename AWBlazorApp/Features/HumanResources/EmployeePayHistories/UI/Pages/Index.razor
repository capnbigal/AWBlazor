@page "/aw/employee-pay-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.HumanResources.Departments.Domain
@using AWBlazorApp.Features.HumanResources.Employees.Domain
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Domain
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Domain
@using AWBlazorApp.Features.HumanResources.JobCandidates.Domain
@using AWBlazorApp.Features.HumanResources.Shifts.Domain
@using AWBlazorApp.Features.HumanResources.Departments.Dtos
@using AWBlazorApp.Features.HumanResources.Employees.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Dtos
@using AWBlazorApp.Features.HumanResources.JobCandidates.Dtos
@using AWBlazorApp.Features.HumanResources.Shifts.Dtos
@using AWBlazorApp.Features.HumanResources.Departments.Application.Services
@using AWBlazorApp.Features.HumanResources.Employees.Application.Services
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Application.Services
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Application.Services
@using AWBlazorApp.Features.HumanResources.JobCandidates.Application.Services
@using AWBlazorApp.Features.HumanResources.Shifts.Application.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Employee pay history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Employee pay history</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">HumanResources.EmployeePayHistory · composite PK (BusinessEntityID, RateChangeDate)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/employee-pay-histories/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New pay row</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => { filterBusinessEntityId = v == 0 ? null : v; })" Label="Employee" Clearable="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" OnSelectionChanged="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="EmployeePayHistoryDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Employee">
                <HeaderTemplate><GridColumnHeader TEntity="EmployeePayHistory" PropertyName="@nameof(EmployeePayHistoryDto.BusinessEntityId)" Title="Employee" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.RateChangeDate" Title="Rate change date" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="EmployeePayHistory" PropertyName="@nameof(EmployeePayHistoryDto.RateChangeDate)" Title="Rate change date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Rate" Title="Rate" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="EmployeePayHistory" PropertyName="@nameof(EmployeePayHistoryDto.Rate)" Title="Rate" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PayFrequency" Title="Frequency">
                <HeaderTemplate><GridColumnHeader TEntity="EmployeePayHistory" PropertyName="@nameof(EmployeePayHistoryDto.PayFrequency)" Title="Frequency" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="EmployeePayHistory" PropertyName="@nameof(EmployeePayHistoryDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="EmployeePayHistoryDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<EmployeePayHistoryDto> grid = null!;
    private bool _loading = true;
    private int? filterBusinessEntityId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<EmployeePayHistoryDto>> LoadServerDataAsync(GridState<EmployeePayHistoryDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.EmployeePayHistories.AsNoTracking();
            if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);

            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(EmployeePayHistoryDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
                nameof(EmployeePayHistoryDto.RateChangeDate) => sort.Descending ? query.OrderByDescending(x => x.RateChangeDate) : query.OrderBy(x => x.RateChangeDate),
                nameof(EmployeePayHistoryDto.Rate) => sort.Descending ? query.OrderByDescending(x => x.Rate) : query.OrderBy(x => x.Rate),
                nameof(EmployeePayHistoryDto.PayFrequency) => sort.Descending ? query.OrderByDescending(x => x.PayFrequency) : query.OrderBy(x => x.PayFrequency),
                nameof(EmployeePayHistoryDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _ => query.OrderBy(x => x.BusinessEntityId).ThenByDescending(x => x.RateChangeDate),
            };

            var rows = await query
                .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<EmployeePayHistoryDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<EmployeePayHistoryDialog>("New pay row", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Pay row created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(EmployeePayHistoryDto row)
    {
        var parameters = new DialogParameters<EmployeePayHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<EmployeePayHistoryDialog>($"Edit ({row.BusinessEntityId}, {row.RateChangeDate:yyyy-MM-dd})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Pay row updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(EmployeePayHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete pay row?", $"Permanently delete pay row ({row.BusinessEntityId}, {row.RateChangeDate:yyyy-MM-dd})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.EmployeePayHistories.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.RateChangeDate == row.RateChangeDate);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.EmployeePayHistoryAuditLogs.Add(EmployeePayHistoryAuditService.RecordDelete(entity, changedBy));
        db.EmployeePayHistories.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Pay row deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(EmployeePayHistoryDto row)
        => Navigation.NavigateTo($"aw/employee-pay-histories/history?businessEntityId={row.BusinessEntityId}&rateChangeDate={row.RateChangeDate:yyyy-MM-dd}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
