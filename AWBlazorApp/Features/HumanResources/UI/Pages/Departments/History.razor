@page "/aw/departments/history"
@page "/aw/departments/history/{SlotId:int}"
@attribute [Authorize]
@using AWBlazorApp.Features.HumanResources.Domain
@using AWBlazorApp.Features.HumanResources.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Department history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/departments"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Department history" : $"History for department #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.List" Href="aw/departments/history">All history</MudButton>
        }
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">Every create, update, and delete of a <code>HumanResources.Department</code> row is recorded here.</MudText>

    @if (SlotId is null)
    {
        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                        <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudNumericField T="int?" @bind-Value="filterRowId" Label="Department id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudDataGrid T="DepartmentAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="DepartmentAuditLog" PropertyName="@nameof(DepartmentAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.DepartmentId" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="DepartmentAuditLog" PropertyName="@nameof(DepartmentAuditLogDto.DepartmentId)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="DepartmentAuditLog" PropertyName="@nameof(DepartmentAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <HeaderTemplate><GridColumnHeader TEntity="DepartmentAuditLog" PropertyName="@nameof(DepartmentAuditLogDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.GroupName" Title="Group">
                <HeaderTemplate><GridColumnHeader TEntity="DepartmentAuditLog" PropertyName="@nameof(DepartmentAuditLogDto.GroupName)" Title="Group" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="DepartmentAuditLog" PropertyName="@nameof(DepartmentAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="DepartmentAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }

    private MudDataGrid<DepartmentAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private int? filterRowId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<DepartmentAuditLogDto>> LoadServerDataAsync(GridState<DepartmentAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.DepartmentAuditLogs.AsNoTracking();

        var scopedId = SlotId ?? filterRowId;
        if (scopedId.HasValue)
        {
            var key = (short)scopedId.Value;
            query = query.Where(a => a.DepartmentId == key);
        }
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(DepartmentAuditLogDto.ChangedDate)   => sort.Descending ? query.OrderByDescending(a => a.ChangedDate)   : query.OrderBy(a => a.ChangedDate),
            nameof(DepartmentAuditLogDto.DepartmentId)  => sort.Descending ? query.OrderByDescending(a => a.DepartmentId)  : query.OrderBy(a => a.DepartmentId),
            nameof(DepartmentAuditLogDto.ChangedBy)     => sort.Descending ? query.OrderByDescending(a => a.ChangedBy)     : query.OrderBy(a => a.ChangedBy),
            nameof(DepartmentAuditLogDto.Name)          => sort.Descending ? query.OrderByDescending(a => a.Name)          : query.OrderBy(a => a.Name),
            nameof(DepartmentAuditLogDto.GroupName)     => sort.Descending ? query.OrderByDescending(a => a.GroupName)     : query.OrderBy(a => a.GroupName),
            nameof(DepartmentAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _                                           => query.OrderByDescending(a => a.ChangedDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<DepartmentAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
