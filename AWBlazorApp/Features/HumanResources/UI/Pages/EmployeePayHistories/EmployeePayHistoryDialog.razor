@using AWBlazorApp.Features.HumanResources.Domain
@using AWBlazorApp.Features.HumanResources.Dtos
@using AWBlazorApp.Features.HumanResources.Audit
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateEmployeePayHistoryRequest> CreateValidator
@inject MudFormValidator<UpdateEmployeePayHistoryRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create pay row" : $"Edit pay ({Model!.BusinessEntityId}, {Model.RateChangeDate:yyyy-MM-dd})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@createModel.BusinessEntityId" ValueChanged="@((int v) => createModel = createModel with { BusinessEntityId = v })" Label="Employee" Required="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" /></MudItem>
                    <MudItem xs="12" sm="6"><MudDatePicker Date="@createModel.RateChangeDate" DateChanged="@((DateTime? v) => createModel = createModel with { RateChangeDate = v ?? DateTime.UtcNow.Date })" Label="Rate change date" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="12" sm="6"><MudNumericField T="decimal" Value="@createModel.Rate" ValueChanged="@((decimal v) => createModel = createModel with { Rate = v })" Label="Rate" Variant="Variant.Outlined" Required="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="byte" Value="@createModel.PayFrequency" ValueChanged="@((byte v) => createModel = createModel with { PayFrequency = v })" Label="Pay frequency" Variant="Variant.Outlined">
                            <MudSelectItem T="byte" Value="1">1 - Monthly</MudSelectItem>
                            <MudSelectItem T="byte" Value="2">2 - Biweekly</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><MudNumericField T="decimal?" Value="@updateModel.Rate" ValueChanged="@((decimal? v) => updateModel = updateModel with { Rate = v })" Label="Rate" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="byte?" Value="@updateModel.PayFrequency" ValueChanged="@((byte? v) => updateModel = updateModel with { PayFrequency = v })" Label="Pay frequency" Variant="Variant.Outlined" Clearable="true">
                            <MudSelectItem T="byte?" Value="1">1 - Monthly</MudSelectItem>
                            <MudSelectItem T="byte?" Value="2">2 - Biweekly</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public EmployeePayHistoryDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateEmployeePayHistoryRequest createModel = new() { RateChangeDate = DateTime.UtcNow.Date, PayFrequency = 1 };
    private UpdateEmployeePayHistoryRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
            updateModel = new UpdateEmployeePayHistoryRequest { Rate = Model.Rate, PayFrequency = Model.PayFrequency };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.EmployeePayHistories.AnyAsync(x => x.BusinessEntityId == createModel.BusinessEntityId && x.RateChangeDate == createModel.RateChangeDate))
                {
                    Snackbar.Add("Pay row for that employee + date already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.EmployeePayHistories.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.EmployeePayHistoryAuditLogs.Add(EmployeePayHistoryAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.EmployeePayHistories.FirstOrDefaultAsync(t => t.BusinessEntityId == Model!.BusinessEntityId && t.RateChangeDate == Model.RateChangeDate);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = EmployeePayHistoryAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.EmployeePayHistoryAuditLogs.Add(EmployeePayHistoryAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
