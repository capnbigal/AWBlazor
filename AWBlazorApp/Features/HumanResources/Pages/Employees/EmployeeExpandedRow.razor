@using AWBlazorApp.Features.HumanResources.Domain
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="my-2" />
}
else if (employee is null)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="my-2">Employee not found.</MudAlert>
}
else
{
    <div class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Employment</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Hired: <strong>@employee.HireDate.ToString("yyyy-MM-dd")</strong></MudText>
                    @{ var tenure = (DateTime.UtcNow - employee.HireDate).TotalDays / 365.25; }
                    <MudText Typo="Typo.body2">Tenure: <strong>@tenure.ToString("N1") years</strong></MudText>
                    <MudText Typo="Typo.body2">Status: <strong>@(employee.CurrentFlag ? "Active" : "Inactive")</strong></MudText>
                    <MudText Typo="Typo.body2">Type: <strong>@(employee.SalariedFlag ? "Salaried" : "Hourly")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Leave balances</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Vacation hours: <strong>@employee.VacationHours</strong></MudText>
                    <MudText Typo="Typo.body2">Sick leave hours: <strong>@employee.SickLeaveHours</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Current pay</MudText>
                @if (payHistory.Count > 0)
                {
                    var latest = payHistory[0];
                    <MudStack Spacing="1" Class="mt-1">
                        <MudText Typo="Typo.body2">Rate: <strong>@latest.Rate.ToString("C2")</strong></MudText>
                        <MudText Typo="Typo.body2">Frequency: <strong>@(latest.PayFrequency == 1 ? "Monthly" : "Biweekly")</strong></MudText>
                        <MudText Typo="Typo.body2">Since: <strong>@latest.RateChangeDate.ToString("yyyy-MM-dd")</strong></MudText>
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">No pay history.</MudText>
                }
            </MudItem>
        </MudGrid>

        @if (payHistory.Count > 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-1">Pay rate history</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead><tr><th>Effective date</th><th style="text-align:right">Rate</th><th>Frequency</th></tr></thead>
                <tbody>
                    @foreach (var p in payHistory)
                    {
                        <tr>
                            <td>@p.RateChangeDate.ToString("yyyy-MM-dd")</td>
                            <td style="text-align:right">@p.Rate.ToString("C2")</td>
                            <td>@(p.PayFrequency == 1 ? "Monthly" : "Biweekly")</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }

        @if (deptHistory.Count > 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-1">Department assignment history</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead><tr><th>Department</th><th>Start date</th><th>End date</th></tr></thead>
                <tbody>
                    @foreach (var d in deptHistory)
                    {
                        <tr>
                            <td>@d.DeptName</td>
                            <td>@d.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@(d.EndDate?.ToString("yyyy-MM-dd") ?? "Current")</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </div>
}

@code {
    [Parameter] public int EmployeeId { get; set; }

    private bool loading = true;
    private Employee? employee;
    private List<EmployeePayHistory> payHistory = [];
    private List<DeptHistoryRow> deptHistory = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        employee = await db.Employees.AsNoTracking().FirstOrDefaultAsync(e => e.Id == EmployeeId);

        payHistory = await db.EmployeePayHistories.AsNoTracking()
            .Where(p => p.BusinessEntityId == EmployeeId)
            .OrderByDescending(p => p.RateChangeDate)
            .ToListAsync();

        var departments = await db.Departments.AsNoTracking().ToDictionaryAsync(d => d.Id, d => d.Name);
        var rawDeptHistory = await db.EmployeeDepartmentHistories.AsNoTracking()
            .Where(d => d.BusinessEntityId == EmployeeId)
            .OrderByDescending(d => d.StartDate)
            .ToListAsync();

        deptHistory = rawDeptHistory.Select(d => new DeptHistoryRow
        {
            DeptName = departments.GetValueOrDefault(d.DepartmentId, $"Dept {d.DepartmentId}"),
            StartDate = d.StartDate,
            EndDate = d.EndDate,
        }).ToList();

        loading = false;
    }

    private sealed class DeptHistoryRow
    {
        public string DeptName { get; init; } = "";
        public DateTime StartDate { get; init; }
        public DateTime? EndDate { get; init; }
    }
}
