@page "/aw/employees"
@attribute [Authorize]
@using AWBlazorApp.Features.HumanResources.Domain
@using AWBlazorApp.Features.HumanResources.Models
@using AWBlazorApp.Features.HumanResources.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Employees</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Employees</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">HumanResources.Employee</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/employees/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New employee</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterJobTitle" Label="Job title contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterLoginId" Label="Login id contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="EmployeeDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <HierarchyColumn T="EmployeeDto" />
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.LoginID" Title="Login">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.LoginID)" Title="Login" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.JobTitle" Title="Job title">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.JobTitle)" Title="Job title" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.MaritalStatus" Title="MS">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.MaritalStatus)" Title="MS" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Gender" Title="G">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.Gender)" Title="G" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.HireDate" Title="Hired" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.HireDate)" Title="Hired" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CurrentFlag" Title="Current">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.CurrentFlag)" Title="Current" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
                <HeaderTemplate><GridColumnHeader TEntity="Employee" PropertyName="@nameof(EmployeeDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent>
            <EmployeeExpandedRow EmployeeId="@context.Item.Id" />
        </ChildRowContent>
        <PagerContent><MudDataGridPager T="EmployeeDto" /></PagerContent>
        <NoRecordsContent>
            <EmptyState />
        </NoRecordsContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<EmployeeDto> grid = null!;
    private bool _loading = true;
    private string? filterJobTitle;
    private string? filterLoginId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<EmployeeDto>> LoadServerDataAsync(GridState<EmployeeDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.Employees.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterJobTitle)) query = query.Where(x => x.JobTitle.Contains(filterJobTitle.Trim()));
            if (!string.IsNullOrWhiteSpace(filterLoginId)) query = query.Where(x => x.LoginID.Contains(filterLoginId.Trim()));
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(EmployeeDto.Id)            => sort.Descending ? query.OrderByDescending(x => x.Id)            : query.OrderBy(x => x.Id),
                nameof(EmployeeDto.LoginID)       => sort.Descending ? query.OrderByDescending(x => x.LoginID)       : query.OrderBy(x => x.LoginID),
                nameof(EmployeeDto.JobTitle)      => sort.Descending ? query.OrderByDescending(x => x.JobTitle)      : query.OrderBy(x => x.JobTitle),
                nameof(EmployeeDto.MaritalStatus) => sort.Descending ? query.OrderByDescending(x => x.MaritalStatus) : query.OrderBy(x => x.MaritalStatus),
                nameof(EmployeeDto.Gender)        => sort.Descending ? query.OrderByDescending(x => x.Gender)        : query.OrderBy(x => x.Gender),
                nameof(EmployeeDto.HireDate)      => sort.Descending ? query.OrderByDescending(x => x.HireDate)      : query.OrderBy(x => x.HireDate),
                nameof(EmployeeDto.CurrentFlag)   => sort.Descending ? query.OrderByDescending(x => x.CurrentFlag)   : query.OrderBy(x => x.CurrentFlag),
                nameof(EmployeeDto.ModifiedDate)  => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)  : query.OrderBy(x => x.ModifiedDate),
                _                                 => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<EmployeeDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<EmployeeDialog>("New employee", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Employee created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(EmployeeDto row)
    {
        var parameters = new DialogParameters<EmployeeDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<EmployeeDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Employee updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(EmployeeDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete employee?", $"Permanently delete employee #{row.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Employees.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Employee no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.EmployeeAuditLogs.Add(EmployeeAuditService.RecordDelete(entity, changedBy));
        db.Employees.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Employee deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(EmployeeDto row) => Navigation.NavigateTo($"aw/employees/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
