@page "/aw/person-phones/history"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.Domain
@using AWBlazorApp.Features.Person.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Person phone audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/person-phones"))" />
        <MudText Typo="Typo.h4">Person phone audit</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="BusinessEntityId" Label="Person id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="PhoneNumber" Label="Phone number" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="PhoneNumberTypeId" Label="Type id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="PersonPhoneAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="PersonPhoneAuditLog" PropertyName="@nameof(PersonPhoneAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Person">
                <HeaderTemplate><GridColumnHeader TEntity="PersonPhoneAuditLog" PropertyName="@nameof(PersonPhoneAuditLogDto.BusinessEntityId)" Title="Person" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PhoneNumberTypeId" Title="Type">
                <HeaderTemplate><GridColumnHeader TEntity="PersonPhoneAuditLog" PropertyName="@nameof(PersonPhoneAuditLogDto.PhoneNumberTypeId)" Title="Type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PhoneNumber" Title="Phone">
                <HeaderTemplate><GridColumnHeader TEntity="PersonPhoneAuditLog" PropertyName="@nameof(PersonPhoneAuditLogDto.PhoneNumber)" Title="Phone" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="PersonPhoneAuditLog" PropertyName="@nameof(PersonPhoneAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="PersonPhoneAuditLog" PropertyName="@nameof(PersonPhoneAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="PersonPhoneAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? BusinessEntityId { get; set; }
    [SupplyParameterFromQuery] public string? PhoneNumber { get; set; }
    [SupplyParameterFromQuery] public int? PhoneNumberTypeId { get; set; }

    private MudDataGrid<PersonPhoneAuditLogDto> grid = null!;
    private string? filterAction;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<PersonPhoneAuditLogDto>> LoadServerDataAsync(GridState<PersonPhoneAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.PersonPhoneAuditLogs.AsNoTracking();

        if (BusinessEntityId.HasValue) query = query.Where(a => a.BusinessEntityId == BusinessEntityId.Value);
        if (!string.IsNullOrWhiteSpace(PhoneNumber)) query = query.Where(a => a.PhoneNumber == PhoneNumber);
        if (PhoneNumberTypeId.HasValue) query = query.Where(a => a.PhoneNumberTypeId == PhoneNumberTypeId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(PersonPhoneAuditLogDto.ChangedDate) => sort.Descending ? query.OrderByDescending(a => a.ChangedDate) : query.OrderBy(a => a.ChangedDate),
            nameof(PersonPhoneAuditLogDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(a => a.BusinessEntityId) : query.OrderBy(a => a.BusinessEntityId),
            nameof(PersonPhoneAuditLogDto.PhoneNumberTypeId) => sort.Descending ? query.OrderByDescending(a => a.PhoneNumberTypeId) : query.OrderBy(a => a.PhoneNumberTypeId),
            nameof(PersonPhoneAuditLogDto.PhoneNumber) => sort.Descending ? query.OrderByDescending(a => a.PhoneNumber) : query.OrderBy(a => a.PhoneNumber),
            nameof(PersonPhoneAuditLogDto.ChangedBy) => sort.Descending ? query.OrderByDescending(a => a.ChangedBy) : query.OrderBy(a => a.ChangedBy),
            nameof(PersonPhoneAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _ => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<PersonPhoneAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
