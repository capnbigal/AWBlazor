@using AWBlazorApp.Features.Person.Domain
@using AWBlazorApp.Features.Person.Dtos
@using AWBlazorApp.Features.Person.Audit
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateEmailAddressRequest> CreateValidator
@inject MudFormValidator<UpdateEmailAddressRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create email" : $"Edit email ({Model!.BusinessEntityId}, {Model.EmailAddressId})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.BusinessEntityId" ValueChanged="@((int v) => createModel = createModel with { BusinessEntityId = v })" Label="Person" Required="true" SearchFunc="@(q => Lookup.SearchPersonsAsync(q))" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.EmailAddressValue" ValueChanged="@((string? v) => createModel = createModel with { EmailAddressValue = v })" Label="Email address" Variant="Variant.Outlined" Required="true" MaxLength="50" InputType="InputType.Email" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.EmailAddressValue" ValueChanged="@((string? v) => updateModel = updateModel with { EmailAddressValue = v })" Label="Email address" Variant="Variant.Outlined" MaxLength="50" InputType="InputType.Email" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public EmailAddressDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateEmailAddressRequest createModel = new();
    private UpdateEmailAddressRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateEmailAddressRequest { EmailAddressValue = Model.EmailAddressValue };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.EmailAddresses.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.EmailAddressAuditLogs.Add(EmailAddressAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.EmailAddresses.FirstOrDefaultAsync(t =>
                    t.BusinessEntityId == Model!.BusinessEntityId && t.EmailAddressId == Model.EmailAddressId);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = EmailAddressAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.EmailAddressAuditLogs.Add(EmailAddressAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
