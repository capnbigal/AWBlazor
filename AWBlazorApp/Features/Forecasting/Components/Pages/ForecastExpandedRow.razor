@using AWBlazorApp.Features.Forecasting.Domain
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (definition is not null)
{
    <MudStack Spacing="4" Class="pa-4">
        @* ── Summary grid ──────────────────────────────────────────────────── *@
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Configuration</MudText>
                <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                    <tbody>
                        <tr><td><strong>Data source</strong></td><td>@definition.DataSource</td></tr>
                        <tr><td><strong>Method</strong></td><td>@definition.Method</td></tr>
                        <tr><td><strong>Granularity</strong></td><td>@definition.Granularity</td></tr>
                        <tr><td><strong>Lookback</strong></td><td>@definition.LookbackMonths months</td></tr>
                        <tr><td><strong>Horizon</strong></td><td>@definition.HorizonPeriods periods</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Status</MudText>
                <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                    <tbody>
                        <tr><td><strong>Status</strong></td><td>@definition.Status</td></tr>
                        <tr><td><strong>Last computed</strong></td><td>@(definition.LastComputedDate?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td></tr>
                        <tr><td><strong>Total data points</strong></td><td>@dataPoints.Count</td></tr>
                        <tr><td><strong>Evaluated</strong></td><td>@evaluatedPoints.Count</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem xs="12" md="4">
                @if (evaluatedPoints.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Accuracy</MudText>
                    <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                        <tbody>
                            <tr><td><strong>Avg variance</strong></td><td>@($"{avgVariancePercent:N1}%")</td></tr>
                            <tr><td><strong>Best period</strong></td><td>@bestPeriod</td></tr>
                            <tr><td><strong>Worst period</strong></td><td>@worstPeriod</td></tr>
                        </tbody>
                    </MudSimpleTable>
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Accuracy</MudText>
                    <MudText Typo="Typo.body2">No evaluated data points yet.</MudText>
                }
            </MudItem>
        </MudGrid>

        @* ── Time series chart ─────────────────────────────────────────────── *@
        @if (chartLabels.Length > 0)
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Forecast vs. actuals</MudText>
                <MudChart T="double" ChartType="ChartType.Line"
                          ChartSeries="@chartSeries"
                          ChartLabels="@chartLabels"
                          ChartOptions="@AWBlazorApp.Shared.Theming.ChartPalettes.RotatedAxisLineOptions"
                          Width="100%" Height="320px" />
            </MudPaper>
        }

        @* ── Data points table ─────────────────────────────────────────────── *@
        @if (dataPoints.Count > 0)
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Data points</MudText>
                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Period</th>
                            <th style="text-align:right">Forecasted</th>
                            <th style="text-align:right">Actual</th>
                            <th style="text-align:right">Variance</th>
                            <th style="text-align:right">Variance %</th>
                            <th>Evaluated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dp in dataPoints)
                        {
                            <tr>
                                <td>@dp.PeriodDate.ToString("yyyy-MM")</td>
                                <td style="text-align:right">@dp.ForecastedValue.ToString("N2")</td>
                                <td style="text-align:right">
                                    @if (dp.ActualValue.HasValue)
                                    {
                                        @dp.ActualValue.Value.ToString("N2")
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Pending</MudText>
                                    }
                                </td>
                                <td style="text-align:right">
                                    @if (dp.Variance.HasValue)
                                    {
                                        <MudText Color="@VarianceColor(dp.VariancePercent)">@dp.Variance.Value.ToString("N2")</MudText>
                                    }
                                </td>
                                <td style="text-align:right">
                                    @if (dp.VariancePercent.HasValue)
                                    {
                                        <MudText Color="@VarianceColor(dp.VariancePercent)">@($"{dp.VariancePercent.Value:N1}%")</MudText>
                                    }
                                </td>
                                <td>@dp.EvaluatedDate?.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }
    </MudStack>
}

@code {
    [Parameter] public int ForecastId { get; set; }

    private bool loading = true;
    private ForecastDefinition? definition;
    private List<ForecastHistoricalSnapshot> snapshots = [];
    private List<ForecastDataPoint> dataPoints = [];
    private List<ForecastDataPoint> evaluatedPoints = [];

    // Accuracy stats
    private double avgVariancePercent;
    private string bestPeriod = "";
    private string worstPeriod = "";

    // Chart
    private string[] chartLabels = [];
    private List<ChartSeries<double>> chartSeries = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        definition = await db.ForecastDefinitions.AsNoTracking()
            .FirstOrDefaultAsync(f => f.Id == ForecastId);

        if (definition is null) { loading = false; return; }

        // Cap each load to MaxRowsPerView. For long-running forecasts with thousands of
        // historical points, eagerly loading everything blows up memory when many expand-rows
        // are open at once.
        const int MaxRowsPerView = 500;

        snapshots = await db.ForecastHistoricalSnapshots.AsNoTracking()
            .Where(s => s.ForecastDefinitionId == ForecastId)
            .OrderByDescending(s => s.PeriodDate)
            .Take(MaxRowsPerView)
            .OrderBy(s => s.PeriodDate)
            .ToListAsync();

        dataPoints = await db.ForecastDataPoints.AsNoTracking()
            .Where(dp => dp.ForecastDefinitionId == ForecastId)
            .OrderByDescending(dp => dp.PeriodDate)
            .Take(MaxRowsPerView)
            .OrderBy(dp => dp.PeriodDate)
            .ToListAsync();

        evaluatedPoints = dataPoints.Where(dp => dp.ActualValue.HasValue).ToList();

        // Accuracy stats
        if (evaluatedPoints.Count > 0)
        {
            avgVariancePercent = (double)evaluatedPoints.Average(dp => Math.Abs(dp.VariancePercent ?? 0));
            var best = evaluatedPoints.MinBy(dp => Math.Abs(dp.VariancePercent ?? decimal.MaxValue));
            var worst = evaluatedPoints.MaxBy(dp => Math.Abs(dp.VariancePercent ?? 0));
            bestPeriod = best is not null ? $"{best.PeriodDate:yyyy-MM} ({best.VariancePercent:N1}%)" : "";
            worstPeriod = worst is not null ? $"{worst.PeriodDate:yyyy-MM} ({worst.VariancePercent:N1}%)" : "";
        }

        // Build chart
        BuildChart();

        loading = false;
    }

    private void BuildChart()
    {
        var allDates = snapshots.Select(s => s.PeriodDate)
            .Union(dataPoints.Select(dp => dp.PeriodDate))
            .Distinct()
            .OrderBy(d => d)
            .ToList();

        if (allDates.Count == 0) return;

        chartLabels = allDates.Select(d => d.ToString("yyyy-MM")).ToArray();

        var snapshotLookup = snapshots.ToDictionary(s => s.PeriodDate, s => (double)s.Value);
        var forecastLookup = dataPoints.ToDictionary(dp => dp.PeriodDate, dp => (double)dp.ForecastedValue);
        var actualLookup = dataPoints.Where(dp => dp.ActualValue.HasValue)
            .ToDictionary(dp => dp.PeriodDate, dp => (double)dp.ActualValue!.Value);

        chartSeries =
        [
            new ChartSeries<double> { Name = "Historical", Data = allDates.Select(d => snapshotLookup.GetValueOrDefault(d, 0)).ToArray() },
            new ChartSeries<double> { Name = "Forecast",   Data = allDates.Select(d => forecastLookup.GetValueOrDefault(d, 0)).ToArray() },
            new ChartSeries<double> { Name = "Actual",     Data = allDates.Select(d => actualLookup.GetValueOrDefault(d, 0)).ToArray() },
        ];
    }

    private static Color VarianceColor(decimal? variancePercent)
    {
        if (!variancePercent.HasValue) return Color.Default;
        var abs = Math.Abs(variancePercent.Value);
        return abs <= 10 ? Color.Success : abs <= 25 ? Color.Warning : Color.Error;
    }
}
