@page "/admin/users"
@attribute [Authorize(Roles = AppRoles.Admin)]
@using AWBlazorApp.Shared.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Users</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Users</MudText>

    <MudDataGrid T="UserRow"
                 ServerData="LoadServerDataAsync"
                 @ref="grid"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 SortMode="SortMode.Single">
        <Columns>
            <PropertyColumn Property="x => x.UserName" Title="User name" />
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <PropertyColumn Property="x => x.DisplayName" Title="Display name" />
            <PropertyColumn Property="x => x.RolesText" Title="Roles" />
            <PropertyColumn Property="x => x.EmailConfirmed" Title="Confirmed" />
        </Columns>
        <PagerContent>
            <MudDataGridPager T="UserRow" />
        </PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    public sealed record UserRow(
        string Id,
        string? UserName,
        string? Email,
        string? DisplayName,
        bool EmailConfirmed,
        string RolesText);

    private MudDataGrid<UserRow> grid = null!;

    private async Task<GridData<UserRow>> LoadServerDataAsync(GridState<UserRow> state, CancellationToken ct)
    {
        var query = UserManager.Users.AsNoTracking();

        var sort = state.SortDefinitions.FirstOrDefault();
        var ordered = sort?.SortBy switch
        {
            nameof(UserRow.UserName)    => sort.Descending ? query.OrderByDescending(u => u.UserName)    : query.OrderBy(u => u.UserName),
            nameof(UserRow.Email)       => sort.Descending ? query.OrderByDescending(u => u.Email)       : query.OrderBy(u => u.Email),
            nameof(UserRow.DisplayName) => sort.Descending ? query.OrderByDescending(u => u.DisplayName) : query.OrderBy(u => u.DisplayName),
            _                           => query.OrderBy(u => u.UserName),
        };

        var total = await ordered.CountAsync(ct);
        var users = await ordered
            .Skip(state.Page * state.PageSize)
            .Take(state.PageSize)
            .ToListAsync(ct);

        // Batch-load all user→role mappings in a single query instead of one per user.
        // (UserManager.GetRolesAsync hits the DB per call — N+1 pattern at scale.)
        var userIds = users.Select(u => u.Id).ToList();
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var rolesByUser = await db.UserRoles
            .Where(ur => userIds.Contains(ur.UserId))
            .Join(db.Roles, ur => ur.RoleId, r => r.Id, (ur, r) => new { ur.UserId, RoleName = r.Name })
            .GroupBy(x => x.UserId)
            .ToDictionaryAsync(g => g.Key, g => g.Select(x => x.RoleName).ToList(), ct);

        var rows = users.Select(u => new UserRow(
            u.Id, u.UserName, u.Email, u.DisplayName, u.EmailConfirmed,
            rolesByUser.TryGetValue(u.Id, out var roles) ? string.Join(", ", roles) : ""
        )).ToList();

        return new GridData<UserRow> { Items = rows, TotalItems = total };
    }
}
