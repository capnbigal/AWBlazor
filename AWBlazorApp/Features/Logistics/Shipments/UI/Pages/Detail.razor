@page "/logistics/shipments/{Id:int}"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ILogisticsPostingService PostingService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Shipment @header?.ShipmentNumber</PageTitle>

@if (header is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("logistics/shipments"))" />
            <MudText Typo="Typo.h5">@header.ShipmentNumber</MudText>
            <MudChip T="string" Color="@StatusColor(header.Status)" Variant="Variant.Filled">@header.Status</MudChip>
            <MudSpacer />
            <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="@($"logistics/shipments/history?id={Id}")">History</MudButton>
            @if (header.Status is not (ShipmentStatus.Shipped or ShipmentStatus.Delivered or ShipmentStatus.Cancelled))
            {
                <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.LocalShipping" OnClick="PostAsync" Disabled="posting">@(posting ? "Shipping..." : "Ship (writes ledger)")</MudButton>
                </AuthorizeView>
            }
        </MudStack>

        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="6" md="3"><MudField Label="SO id" Variant="Variant.Text">@(header.SalesOrderId?.ToString() ?? "—")</MudField></MudItem>
                <MudItem xs="6" md="3"><MudField Label="Customer" Variant="Variant.Text">@(header.CustomerBusinessEntityId?.ToString() ?? "—")</MudField></MudItem>
                <MudItem xs="6" md="3"><MudField Label="From location" Variant="Variant.Text">@header.ShippedFromLocationId</MudField></MudItem>
                <MudItem xs="6" md="3"><MudField Label="Ship method" Variant="Variant.Text">@(header.ShipMethodId?.ToString() ?? "—")</MudField></MudItem>
                <MudItem xs="6" md="3"><MudField Label="Tracking" Variant="Variant.Text">@(header.TrackingNumber ?? "—")</MudField></MudItem>
                <MudItem xs="6" md="3"><MudField Label="Shipped at" Variant="Variant.Text">@(header.ShippedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</MudField></MudItem>
                <MudItem xs="6" md="3"><MudField Label="Delivered at" Variant="Variant.Text">@(header.DeliveredAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</MudField></MudItem>
                <MudItem xs="6" md="3"><MudField Label="Posted by" Variant="Variant.Text">@(header.PostedByUserId ?? "—")</MudField></MudItem>
                <MudItem xs="12"><MudField Label="Notes" Variant="Variant.Text">@(header.Notes ?? "—")</MudField></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-3" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Lines (@lines.Count)</MudText>
                <MudSpacer />
                @if (header.Status is not (ShipmentStatus.Shipped or ShipmentStatus.Delivered or ShipmentStatus.Cancelled))
                {
                    <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
                        <MudButton Color="Color.Primary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddLine">Add line</MudButton>
                    </AuthorizeView>
                }
            </MudStack>
            @if (lines.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="mt-2" Dense="true">No lines yet. Add at least one before shipping.</MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Class="mt-2">
                    <thead>
                        <tr><th>#</th><th>Item</th><th>SO line</th><th style="text-align:right">Qty</th><th>UoM</th><th>Lot</th><th>Serial</th><th>Tx id</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var line in lines)
                        {
                            <tr>
                                <td>@line.Id</td>
                                <td>@line.InventoryItemId</td>
                                <td>@(line.SalesOrderDetailId?.ToString() ?? "—")</td>
                                <td style="text-align:right">@line.Quantity.ToString("N4")</td>
                                <td>@line.UnitMeasureCode</td>
                                <td>@(line.LotId?.ToString() ?? "—")</td>
                                <td>@(line.SerialUnitId?.ToString() ?? "—")</td>
                                <td>@(line.PostedTransactionId?.ToString() ?? "—")</td>
                                <td>
                                    @if (header.Status is not (ShipmentStatus.Shipped or ShipmentStatus.Delivered))
                                    {
                                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteLineAsync(line.Id))" />
                                        </AuthorizeView>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    </MudStack>
}

<MudDialog @bind-Visible="lineDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New line</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newLine.InventoryItemId" Label="InventoryItemId" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newLine.SalesOrderDetailId" Label="SalesOrderDetailId (optional)" Variant="Variant.Outlined" />
            <MudNumericField T="decimal" @bind-Value="newLine.Quantity" Label="Quantity" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newLine.UnitMeasureCode" Label="UoM" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newLine.LotId" Label="LotId (optional)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newLine.SerialUnitId" Label="SerialUnitId (optional)" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => lineDialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddLineAsync" Disabled="addingLine">@(addingLine ? "Adding..." : "Add")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int Id { get; set; }
    private ShipmentDto? header;
    private List<ShipmentLineDto> lines = [];
    private bool posting;
    private bool lineDialogOpen, addingLine;
    private CreateShipmentLineRequest newLine = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Shipments.AsNoTracking().FirstOrDefaultAsync(x => x.Id == Id);
        header = entity?.ToDto();
        lines = await db.ShipmentLines.AsNoTracking().Where(l => l.ShipmentId == Id)
            .OrderBy(l => l.Id).Select(l => l.ToDto()).ToListAsync();
    }

    private async Task PostAsync()
    {
        posting = true;
        try
        {
            var by = await GetUserNameAsync();
            var result = await PostingService.PostShipmentAsync(Id, by, CancellationToken.None);
            Snackbar.Add($"Shipped: {result.LinesPosted} lines, {result.TransactionIds.Count} ledger rows.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Ship failed: {ex.Message}", Severity.Error); }
        finally { posting = false; }
    }

    private void OpenAddLine() { newLine = new CreateShipmentLineRequest { ShipmentId = Id, UnitMeasureCode = "EA", Quantity = 1 }; lineDialogOpen = true; }

    private async Task AddLineAsync()
    {
        addingLine = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            newLine.ShipmentId = Id;
            var entity = newLine.ToEntity();
            var by = await GetUserNameAsync();
            db.ShipmentLines.Add(entity);
            await db.SaveChangesAsync();
            db.ShipmentLineAuditLogs.Add(ShipmentLineAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            Snackbar.Add("Line added.", Severity.Success);
            lineDialogOpen = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Add line failed: {ex.Message}", Severity.Error); }
        finally { addingLine = false; }
    }

    private async Task DeleteLineAsync(int lineId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ShipmentLines.FirstOrDefaultAsync(x => x.Id == lineId);
        if (entity is null) return;
        var by = await GetUserNameAsync();
        db.ShipmentLines.Remove(entity);
        db.ShipmentLineAuditLogs.Add(ShipmentLineAuditService.RecordDelete(entity, by));
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private static Color StatusColor(ShipmentStatus s) => s switch
    {
        ShipmentStatus.Draft => Color.Default,
        ShipmentStatus.Picked => Color.Info,
        ShipmentStatus.Packed => Color.Info,
        ShipmentStatus.Shipped => Color.Success,
        ShipmentStatus.Delivered => Color.Success,
        ShipmentStatus.Cancelled => Color.Error,
        _ => Color.Default,
    };

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
