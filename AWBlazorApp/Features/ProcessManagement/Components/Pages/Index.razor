@page "/processes"
@attribute [Authorize]
@using AWBlazorApp.Features.ProcessManagement.Domain
@using AWBlazorApp.Shared.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Processes</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Processes</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">
            New process
        </MudButton>
    </MudStack>

    <MudDataGrid T="ProcessDto"
                 ServerData="LoadServerDataAsync"
                 @ref="grid"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 SortMode="SortMode.Single">
        <Columns>
            <HierarchyColumn T="ProcessDto" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.DepartmentId" Title="Department ID" />
            <TemplateColumn Title="Recurring" SortLabel="IsRecurring">
                <CellTemplate>
                    <MudChip T="string" Color="@(context.Item.IsRecurring ? Color.Success : Color.Default)" Size="Size.Small">
                        @(context.Item.IsRecurring ? "Yes" : "No")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.CronSchedule" Title="Cron schedule" />
            <TemplateColumn Title="Status" SortLabel="Status">
                <CellTemplate>
                    <MudChip T="string" Color="@StatusColor(context.Item.Status)" Size="Size.Small">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Next run" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
                <CellTemplate>
                    @(context.Item.NextRunDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="Trigger execution">
                            <MudIconButton Icon="@Icons.Material.Filled.RocketLaunch"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => TriggerAsync(context.Item))" />
                        </MudTooltip>
                        <MudTooltip Text="Timeline">
                            <MudIconButton Icon="@Icons.Material.Filled.Timeline"
                                           Size="Size.Small"
                                           Color="Color.Info"
                                           OnClick="@(() => Navigation.NavigateTo($"processes/{context.Item.Id}/timeline"))" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenEditAsync(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(context.Item))" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent>
            <ProcessExpandedRow ProcessId="@context.Item.Id" />
        </ChildRowContent>
        <PagerContent>
            <MudDataGridPager T="ProcessDto" />
        </PagerContent>
        <NoRecordsContent>
            <EmptyState />
        </NoRecordsContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<ProcessDto> grid = null!;

    private static Color StatusColor(ProcessStatus status) => status switch
    {
        ProcessStatus.Active   => Color.Success,
        ProcessStatus.Paused   => Color.Warning,
        ProcessStatus.Archived => Color.Default,
        _                      => Color.Default,
    };

    private async Task<GridData<ProcessDto>> LoadServerDataAsync(GridState<ProcessDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Processes.AsNoTracking().Where(p => p.DeletedDate == null);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProcessDto.Name)        => sort.Descending ? query.OrderByDescending(p => p.Name)        : query.OrderBy(p => p.Name),
            "Status"                        => sort.Descending ? query.OrderByDescending(p => p.Status)      : query.OrderBy(p => p.Status),
            "IsRecurring"                   => sort.Descending ? query.OrderByDescending(p => p.IsRecurring) : query.OrderBy(p => p.IsRecurring),
            nameof(ProcessDto.CreatedDate)  => sort.Descending ? query.OrderByDescending(p => p.CreatedDate) : query.OrderBy(p => p.CreatedDate),
            _                               => query.OrderByDescending(p => p.CreatedDate),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize)
            .Take(state.PageSize)
            .Select(p => p.ToDto())
            .ToListAsync(ct);

        return new GridData<ProcessDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProcessDialog>("Create process", new DialogOptions
        {
            MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true,
        });
        if ((await dialog.Result) is { Canceled: false })
        {
            Snackbar.Add("Process created.", Severity.Success);
            await grid.ReloadServerData();
        }
    }

    private async Task OpenEditAsync(ProcessDto item)
    {
        var parameters = new DialogParameters<ProcessDialog> { { x => x.Model, item } };
        var dialog = await DialogService.ShowAsync<ProcessDialog>("Edit process", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true,
        });
        if ((await dialog.Result) is { Canceled: false })
        {
            Snackbar.Add("Process updated.", Severity.Success);
            await grid.ReloadServerData();
        }
    }

    private async Task TriggerAsync(ProcessDto item)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var process = await db.Processes
                .Include(p => p.Steps)
                .FirstOrDefaultAsync(p => p.Id == item.Id && p.DeletedDate == null);

            if (process is null)
            {
                Snackbar.Add("Process no longer exists.", Severity.Warning);
                await grid.ReloadServerData();
                return;
            }

            var execution = new ProcessExecution
            {
                ProcessId = process.Id,
                ExecutionDate = DateTime.UtcNow,
                AssignedUserId = process.DefaultProcessorUserId,
                Status = ProcessExecutionStatus.Pending,
            };
            db.ProcessExecutions.Add(execution);

            foreach (var step in process.Steps.OrderBy(s => s.SequenceNumber))
            {
                db.ProcessStepExecutions.Add(new ProcessStepExecution
                {
                    ProcessExecution = execution,
                    ProcessStepId = step.Id,
                    Status = ProcessStepExecutionStatus.Pending,
                });
            }

            // If recurring, compute next run date
            if (process.IsRecurring && !string.IsNullOrWhiteSpace(process.CronSchedule))
            {
                var cron = Cronos.CronExpression.Parse(process.CronSchedule);
                process.NextRunDate = cron.GetNextOccurrence(DateTime.UtcNow);
            }

            await db.SaveChangesAsync();

            Snackbar.Add($"Execution triggered for '{item.Name}'.", Severity.Success);
            await grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Trigger failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteAsync(ProcessDto item)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Delete process?",
            $"Soft-delete process '{item.Name}'?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Processes.FirstOrDefaultAsync(p => p.Id == item.Id);
        if (entity is null)
        {
            Snackbar.Add("Process no longer exists.", Severity.Warning);
            await grid.ReloadServerData();
            return;
        }

        entity.DeletedDate = DateTime.UtcNow;
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Process deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }
}
