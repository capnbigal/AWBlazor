@page "/analytics/processes"
@attribute [Authorize]
@using AWBlazorApp.Features.ProcessManagement.Domain
@using AWBlazorApp.Shared.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AnalyticsCacheService Cache

<PageTitle>Process analytics</PageTitle>

<MudStack Spacing="4">
    <MudText Typo="Typo.h4">Process analytics</MudText>

    @if (loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">Loading process data...</MudText>
    }
    else
    {
        @* -- KPI row ---------------------------------------------------------- *@
        <MudGrid>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary"
                         Value="@data.ActiveProcesses.ToString("N0")" Label="Active processes" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Info"
                         Value="@data.ExecutionsThisMonth.ToString("N0")" Label="Executions this month" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
                         Value="@($"{data.OnTimeRate:N1}%")" Label="On-time completion" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <KpiCard Icon="@Icons.Material.Filled.Warning" Color="Color.Error"
                         Value="@data.OverdueCount.ToString("N0")" Label="Overdue" />
            </MudItem>
        </MudGrid>

        @* -- Execution volume by month ---------------------------------------- *@
        @* TimeSeriesChart carries its own empty-state fallback, so no outer guard. *@
        <TimeSeriesChart Title="Execution volume by month"
                         ChartType="ChartType.Bar"
                         Labels="@data.VolumeLabels"
                         Series="@data.VolumeSeries"
                         Periods="@(new[] { "6M", "12M", "All" })"
                         ShowGranularity="false"
                         XAxisCaption="month"
                         YAxisCaption="execution count" />

        @* -- Completion vs. overdue trend ------------------------------------- *@
        <TimeSeriesChart Title="Completed vs. overdue executions per month"
                         ChartType="ChartType.Line"
                         Labels="@data.OutcomeLabels"
                         Series="@data.OutcomeSeries"
                         Periods="@(new[] { "6M", "12M", "All" })"
                         ShowGranularity="false"
                         XAxisCaption="month"
                         YAxisCaption="execution count by outcome" />

        @* -- Top processes by execution count --------------------------------- *@
        @if (data.TopProcesses.Count > 0)
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Top processes by execution count</MudText>
                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Process</th>
                            <th style="text-align:right">Executions</th>
                            <th style="text-align:right">Completed</th>
                            <th style="text-align:right">Overdue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in data.TopProcesses)
                        {
                            <tr>
                                <td><strong>@row.Name</strong></td>
                                <td style="text-align:right">@row.Total</td>
                                <td style="text-align:right">@row.Completed</td>
                                <td style="text-align:right">@row.Overdue</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }

        @* -- Status distribution pie chart ------------------------------------ *@
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Execution status distribution</MudText>
            @if (data.StatusLabels.Length > 0)
            {
                <MudChart T="double" ChartType="ChartType.Pie"
                          InputData="@data.StatusData"
                          InputLabels="@data.StatusLabels"
                          ChartOptions="@AWBlazorApp.Shared.Theming.ChartPalettes.BlueOptions"
                          Width="320px" Height="320px" />
            }
            else
            {
                <EmptyChartState Icon="@Icons.Material.Outlined.PieChart"
                                 Message="No executions recorded yet."
                                 Height="320px" />
            }
        </MudPaper>
    }
</MudStack>

@code {
    private bool loading = true;
    private ProcessAnalyticsData data = new();

    protected override async Task OnInitializedAsync()
    {
        data = await Cache.GetOrCreateAsync(Cache.Key("processes-analytics", "all"), LoadDataAsync);
        loading = false;
    }

    private async Task<ProcessAnalyticsData> LoadDataAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var result = new ProcessAnalyticsData();

        var now = DateTime.UtcNow;
        var monthStart = new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc);

        // KPIs
        result.ActiveProcesses = await db.Processes.AsNoTracking()
            .CountAsync(p => p.Status == ProcessStatus.Active && p.DeletedDate == null);

        result.ExecutionsThisMonth = await db.ProcessExecutions.AsNoTracking()
            .CountAsync(e => e.ExecutionDate >= monthStart);

        var completedCount = await db.ProcessExecutions.AsNoTracking()
            .CountAsync(e => e.Status == ProcessExecutionStatus.Completed);
        var overdueCount = await db.ProcessExecutions.AsNoTracking()
            .CountAsync(e => e.Status == ProcessExecutionStatus.Overdue);

        result.OverdueCount = overdueCount;
        var totalResolved = completedCount + overdueCount;
        result.OnTimeRate = totalResolved > 0 ? (double)completedCount / totalResolved * 100 : 100;

        // Execution volume by month — single series, just a total count.
        var monthlyVolume = await db.ProcessExecutions.AsNoTracking()
            .GroupBy(e => new { e.ExecutionDate.Year, e.ExecutionDate.Month })
            .Select(g => new { g.Key.Year, g.Key.Month, Count = g.Count() })
            .OrderBy(g => g.Year).ThenBy(g => g.Month)
            .ToListAsync();

        if (monthlyVolume.Count > 0)
        {
            result.VolumeLabels = monthlyVolume.Select(g => $"{g.Year}-{g.Month:D2}").ToArray();
            result.VolumeSeries =
            [
                new ChartSeries<double> { Name = "Executions", Data = monthlyVolume.Select(g => (double)g.Count).ToArray() },
            ];
        }

        // Completion-vs-overdue trend — same monthly grouping, broken out by status so the
        // on-time-rate KPI at the top has a time-series view to accompany it.
        var monthlyOutcome = await db.ProcessExecutions.AsNoTracking()
            .GroupBy(e => new { e.ExecutionDate.Year, e.ExecutionDate.Month })
            .Select(g => new
            {
                g.Key.Year,
                g.Key.Month,
                Completed = g.Count(e => e.Status == ProcessExecutionStatus.Completed),
                Overdue = g.Count(e => e.Status == ProcessExecutionStatus.Overdue),
            })
            .OrderBy(g => g.Year).ThenBy(g => g.Month)
            .ToListAsync();

        if (monthlyOutcome.Count > 0)
        {
            result.OutcomeLabels = monthlyOutcome.Select(g => $"{g.Year}-{g.Month:D2}").ToArray();
            result.OutcomeSeries =
            [
                new ChartSeries<double> { Name = "Completed", Data = monthlyOutcome.Select(g => (double)g.Completed).ToArray() },
                new ChartSeries<double> { Name = "Overdue",   Data = monthlyOutcome.Select(g => (double)g.Overdue).ToArray() },
            ];
        }

        // Top processes
        result.TopProcesses = await db.ProcessExecutions.AsNoTracking()
            .Join(db.Processes.AsNoTracking().Where(p => p.DeletedDate == null),
                e => e.ProcessId, p => p.Id,
                (e, p) => new { p.Name, e.Status })
            .GroupBy(x => x.Name)
            .Select(g => new TopProcessRow
            {
                Name = g.Key,
                Total = g.Count(),
                Completed = g.Count(x => x.Status == ProcessExecutionStatus.Completed),
                Overdue = g.Count(x => x.Status == ProcessExecutionStatus.Overdue),
            })
            .OrderByDescending(x => x.Total)
            .Take(10)
            .ToListAsync();

        // Status distribution
        var statusCounts = await db.ProcessExecutions.AsNoTracking()
            .GroupBy(e => e.Status)
            .Select(g => new { Status = g.Key, Count = g.Count() })
            .OrderBy(g => g.Status)
            .ToListAsync();

        if (statusCounts.Count > 0)
        {
            result.StatusLabels = statusCounts.Select(s => s.Status.ToString()).ToArray();
            result.StatusData = statusCounts.Select(s => (double)s.Count).ToArray();
        }

        return result;
    }

    private sealed class ProcessAnalyticsData
    {
        public int ActiveProcesses { get; set; }
        public int ExecutionsThisMonth { get; set; }
        public double OnTimeRate { get; set; }
        public int OverdueCount { get; set; }
        public string[] VolumeLabels { get; set; } = [];
        public List<ChartSeries<double>> VolumeSeries { get; set; } = [];
        public string[] OutcomeLabels { get; set; } = [];
        public List<ChartSeries<double>> OutcomeSeries { get; set; } = [];
        public List<TopProcessRow> TopProcesses { get; set; } = [];
        public string[] StatusLabels { get; set; } = [];
        public double[] StatusData { get; set; } = [];
    }

    private sealed class TopProcessRow
    {
        public string Name { get; init; } = "";
        public int Total { get; init; }
        public int Completed { get; init; }
        public int Overdue { get; init; }
    }
}
