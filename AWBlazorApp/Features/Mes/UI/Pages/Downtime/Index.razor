@page "/mes/downtime"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Downtime</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Downtime events</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">mes.DowntimeEvent — feeds the Availability denominator in OEE rollups</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Rule" OnClick="@(() => Navigation.NavigateTo("mes/downtime/reasons"))">Manage reason codes</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Log downtime</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudCheckBox T="bool" @bind-Value="filterOpenOnly" Label="Open only (not yet closed)" />
            <MudNumericField T="int?" @bind-Value="filterStation" Label="Station" Variant="Variant.Outlined" Clearable="true" />
            <MudSelect T="int?" @bind-Value="filterReason" Label="Reason" Variant="Variant.Outlined" Clearable="true" Style="max-width: 250px">
                <MudSelectItem T="int?" Value="@null">(any)</MudSelectItem>
                @foreach (var r in reasons) { <MudSelectItem T="int?" Value="@r.Id">@r.Name</MudSelectItem> }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="DowntimeEventDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.StationId" Title="Station" />
            <PropertyColumn Property="x => x.ProductionRunId" Title="Run" />
            <TemplateColumn Title="Reason" Sortable="false"><CellTemplate>@ReasonName(context.Item.DowntimeReasonId)</CellTemplate></TemplateColumn>
            <PropertyColumn Property="x => x.StartAt" Title="Start" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.EndAt" Title="End" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Duration" Sortable="false">
                <CellTemplate>@Duration(context.Item)</CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Notes" Title="Notes" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    @if (context.Item.EndAt is null)
                    {
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Success" OnClick="@(() => CloseAsync(context.Item.Id))" />
                        </AuthorizeView>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="DowntimeEventDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Log downtime</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newEvent.StationId" Label="StationId" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="int" @bind-Value="newEvent.DowntimeReasonId" Label="Reason" Required="true" Variant="Variant.Outlined">
                @foreach (var r in reasons.Where(r => r.IsActive)) { <MudSelectItem T="int" Value="@r.Id">@($"{r.Code} — {r.Name}")</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="newEvent.ProductionRunId" Label="Run id (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newEvent.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Log event")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<DowntimeEventDto> grid = null!;
    private bool _loading = true;
    private bool filterOpenOnly;
    private int? filterStation, filterReason;
    private List<DowntimeReasonDto> reasons = [];

    private bool dialogOpen, saving;
    private CreateDowntimeEventRequest newEvent = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        reasons = await db.DowntimeReasons.AsNoTracking().OrderBy(r => r.Name).Select(r => r.ToDto()).ToListAsync();
    }

    private async Task<GridData<DowntimeEventDto>> LoadAsync(GridState<DowntimeEventDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.DowntimeEvents.AsNoTracking();
            if (filterOpenOnly) q = q.Where(x => x.EndAt == null);
            if (filterStation.HasValue) q = q.Where(x => x.StationId == filterStation.Value);
            if (filterReason.HasValue) q = q.Where(x => x.DowntimeReasonId == filterReason.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.StartAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<DowntimeEventDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newEvent = new CreateDowntimeEventRequest(); dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newEvent.ToEntity();
            db.DowntimeEvents.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add($"Downtime #{entity.Id} logged.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Log failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task CloseAsync(long id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.DowntimeEvents.FirstOrDefaultAsync(x => x.Id == id);
        if (entity is null || entity.EndAt is not null) return;
        entity.EndAt = DateTime.UtcNow;
        entity.ModifiedDate = DateTime.UtcNow;
        await db.SaveChangesAsync();
        Snackbar.Add("Closed.", Severity.Success);
        await grid.ReloadServerData();
    }

    private string ReasonName(int reasonId) => reasons.FirstOrDefault(r => r.Id == reasonId)?.Name ?? reasonId.ToString();

    private static string Duration(DowntimeEventDto d) =>
        d.EndAt is null
            ? "(ongoing)"
            : FormatSpan(d.EndAt.Value - d.StartAt);

    private static string FormatSpan(TimeSpan span) =>
        span.TotalHours >= 1 ? $"{span.TotalHours:N1}h" : $"{span.TotalMinutes:N0}m";
}
