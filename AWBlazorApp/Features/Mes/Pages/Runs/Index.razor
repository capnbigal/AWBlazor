@page "/mes/runs"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Production runs</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Production runs</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">mes.ProductionRun — Production and ad-hoc (Engineering, Replacement, Service) runs</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="mes/runs/history">All history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New run</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="ProductionRunStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="ProductionRunStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<ProductionRunStatus>()) { <MudSelectItem T="ProductionRunStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudSelect T="ProductionRunKind?" @bind-Value="filterKind" Label="Kind" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="ProductionRunKind?" Value="@null">(any)</MudSelectItem>
                @foreach (var k in Enum.GetValues<ProductionRunKind>()) { <MudSelectItem T="ProductionRunKind?" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterStation" Label="Station" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterWorkOrder" Label="WO id" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="ProductionRunDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.RunNumber" Title="Number" />
            <PropertyColumn Property="x => x.Kind" Title="Kind" />
            <PropertyColumn Property="x => x.Status" Title="Status" />
            <PropertyColumn Property="x => x.WorkOrderId" Title="WO" />
            <PropertyColumn Property="x => x.StationId" Title="Station" />
            <PropertyColumn Property="x => x.PlannedStartAt" Title="Planned" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.ActualStartAt" Title="Started" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.ActualEndAt" Title="Ended" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.QuantityPlanned" Title="Planned" Format="N2" />
            <PropertyColumn Property="x => x.QuantityProduced" Title="Produced" Format="N2" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"mes/runs/{context.Item.Id}"))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductionRunDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New production run</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudSelect T="ProductionRunKind" @bind-Value="newRun.Kind" Label="Kind" Variant="Variant.Outlined">
                @foreach (var k in Enum.GetValues<ProductionRunKind>()) { <MudSelectItem T="ProductionRunKind" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="newRun.WorkOrderId" Label="WorkOrderId" Variant="Variant.Outlined" HelperText="Required for Production; optional for other kinds" />
            <MudNumericField T="int?" @bind-Value="newRun.StationId" Label="StationId" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRun.AssetId" Label="AssetId (optional)" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="plannedStart" Label="Planned start" Variant="Variant.Outlined" />
            <MudNumericField T="decimal" @bind-Value="newRun.QuantityPlanned" Label="Quantity planned" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRun.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create draft")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<ProductionRunDto> grid = null!;
    private bool _loading = true;
    private ProductionRunStatus? filterStatus;
    private ProductionRunKind? filterKind;
    private int? filterStation, filterWorkOrder;

    private bool dialogOpen, saving;
    private CreateProductionRunRequest newRun = new();
    private DateTime? plannedStart;

    private async Task<GridData<ProductionRunDto>> LoadAsync(GridState<ProductionRunDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.ProductionRuns.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            if (filterKind.HasValue) q = q.Where(x => x.Kind == filterKind.Value);
            if (filterStation.HasValue) q = q.Where(x => x.StationId == filterStation.Value);
            if (filterWorkOrder.HasValue) q = q.Where(x => x.WorkOrderId == filterWorkOrder.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.PlannedStartAt ?? x.ModifiedDate).ThenByDescending(x => x.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ProductionRunDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRun = new CreateProductionRunRequest { Kind = ProductionRunKind.Production, QuantityPlanned = 1 }; plannedStart = DateTime.Today; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            newRun.PlannedStartAt = plannedStart;
            if (newRun.Kind == ProductionRunKind.Production && (newRun.WorkOrderId is null or 0))
            {
                Snackbar.Add("Production-kind runs require a WorkOrderId.", Severity.Error);
                return;
            }
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRun.ToEntity();
            var by = await GetUserNameAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            db.ProductionRuns.Add(entity);
            await db.SaveChangesAsync();
            db.ProductionRunAuditLogs.Add(ProductionRunAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.RunNumber}.", Severity.Success);
            dialogOpen = false;
            Navigation.NavigateTo($"mes/runs/{entity.Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
