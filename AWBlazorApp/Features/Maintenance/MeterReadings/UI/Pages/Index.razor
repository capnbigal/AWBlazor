@page "/maintenance/meter-readings"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Meter readings</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Meter readings</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">maint.MeterReading — runtime hours / cycles / kWh. Drives meter-based PM due checks.</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Record reading</MudButton>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterAsset" Label="Asset ID" Variant="Variant.Outlined" Clearable="true" />
            <MudSelect T="MeterKind?" @bind-Value="filterKind" Label="Kind" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="MeterKind?" Value="@null">(any)</MudSelectItem>
                @foreach (var k in Enum.GetValues<MeterKind>()) { <MudSelectItem T="MeterKind?" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="MeterReadingDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="#" />
            <PropertyColumn Property="x => x.AssetId" Title="Asset" />
            <PropertyColumn Property="x => x.Kind" Title="Kind" />
            <PropertyColumn Property="x => x.Value" Title="Value" Format="N2" />
            <PropertyColumn Property="x => x.RecordedAt" Title="Recorded" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.RecordedByUserId" Title="By" />
        </Columns>
        <PagerContent><MudDataGridPager T="MeterReadingDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Record meter reading</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newRow.AssetId" Label="Asset ID" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="MeterKind" @bind-Value="newRow.Kind" Label="Meter kind" Variant="Variant.Outlined">
                @foreach (var k in Enum.GetValues<MeterKind>()) { <MudSelectItem T="MeterKind" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="decimal" @bind-Value="newRow.Value" Label="Value" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Record")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<MeterReadingDto> grid = null!;
    private bool _loading = true;
    private int? filterAsset;
    private MeterKind? filterKind;

    private bool dialogOpen, saving;
    private CreateMeterReadingRequest newRow = new();

    private async Task<GridData<MeterReadingDto>> LoadAsync(GridState<MeterReadingDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.MeterReadings.AsNoTracking();
            if (filterAsset.HasValue) q = q.Where(x => x.AssetId == filterAsset.Value);
            if (filterKind.HasValue) q = q.Where(x => x.Kind == filterKind.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.RecordedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<MeterReadingDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateMeterReadingRequest { Kind = MeterKind.RuntimeHours }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var by = await GetUserNameAsync();
            var entity = newRow.ToEntity(by);
            db.MeterReadings.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add("Recorded.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Record failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
