@page "/maintenance/work-orders"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject AWBlazorApp.Features.Insights.Services.NotificationService NotificationService

<PageTitle>Maintenance work orders</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Work orders</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">maint.MaintenanceWorkOrder. Draft → Scheduled → InProgress → Completed.</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New WO</MudButton>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="WorkOrderStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="WorkOrderStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<WorkOrderStatus>()) { <MudSelectItem T="WorkOrderStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudSelect T="WorkOrderType?" @bind-Value="filterType" Label="Type" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="WorkOrderType?" Value="@null">(any)</MudSelectItem>
                @foreach (var t in Enum.GetValues<WorkOrderType>()) { <MudSelectItem T="WorkOrderType?" Value="@t">@t</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterAsset" Label="Asset ID" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="MaintenanceWorkOrderDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.WorkOrderNumber" Title="WO#" />
            <PropertyColumn Property="x => x.Title" Title="Title" />
            <PropertyColumn Property="x => x.AssetId" Title="Asset" />
            <PropertyColumn Property="x => x.Type" Title="Type" />
            <TemplateColumn Title="Priority" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@PriorityColor(context.Item.Priority)" Variant="Variant.Outlined">@context.Item.Priority</MudChip></CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)" Variant="Variant.Filled">@context.Item.Status</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ScheduledFor" Title="Scheduled" Format="yyyy-MM-dd" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate><MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"maintenance/work-orders/{context.Item.Id}"))" /></CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="MaintenanceWorkOrderDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New work order</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newWo.WorkOrderNumber" Label="WO number (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newWo.Title" Label="Title" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newWo.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
            <MudNumericField T="int" @bind-Value="newWo.AssetId" Label="Asset ID" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="WorkOrderType" @bind-Value="newWo.Type" Label="Type" Variant="Variant.Outlined">
                @foreach (var t in Enum.GetValues<WorkOrderType>()) { <MudSelectItem T="WorkOrderType" Value="@t">@t</MudSelectItem> }
            </MudSelect>
            <MudSelect T="WorkOrderPriority" @bind-Value="newWo.Priority" Label="Priority" Variant="Variant.Outlined">
                @foreach (var p in Enum.GetValues<WorkOrderPriority>()) { <MudSelectItem T="WorkOrderPriority" Value="@p">@p</MudSelectItem> }
            </MudSelect>
            <MudDatePicker @bind-Date="scheduledFor" Label="Scheduled for (optional)" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="newWo.AssignedBusinessEntityId" Label="Assignee (BusinessEntityId)" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [SupplyParameterFromQuery(Name = "status")] public string? StatusQuery { get; set; }

    private MudDataGrid<MaintenanceWorkOrderDto> grid = null!;
    private bool _loading = true;
    private WorkOrderStatus? filterStatus;
    private WorkOrderType? filterType;
    private int? filterAsset;
    // "Open" is a meta-status meaning any non-Completed and non-Cancelled WO. It comes from
    // the plant dashboard drill-through (?status=Open) — the dashboard tile counts "open WOs"
    // as that exact set, so we mirror it here.
    private bool filterOpenOnly;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(StatusQuery)) return;
        if (StatusQuery.Equals("Open", StringComparison.OrdinalIgnoreCase))
        {
            filterOpenOnly = true;
            filterStatus = null;
        }
        else if (Enum.TryParse<WorkOrderStatus>(StatusQuery, ignoreCase: true, out var s))
        {
            filterStatus = s;
        }
    }

    private bool dialogOpen, saving;
    private CreateMaintenanceWorkOrderRequest newWo = new();
    private DateTime? scheduledFor;

    private static Color StatusColor(WorkOrderStatus s) => s switch
    {
        WorkOrderStatus.Draft => Color.Default,
        WorkOrderStatus.Scheduled => Color.Info,
        WorkOrderStatus.InProgress => Color.Warning,
        WorkOrderStatus.OnHold => Color.Tertiary,
        WorkOrderStatus.Completed => Color.Success,
        WorkOrderStatus.Cancelled => Color.Dark,
        _ => Color.Default,
    };

    private static Color PriorityColor(WorkOrderPriority p) => p switch
    {
        WorkOrderPriority.Critical => Color.Error,
        WorkOrderPriority.High => Color.Warning,
        WorkOrderPriority.Medium => Color.Info,
        WorkOrderPriority.Low => Color.Default,
        _ => Color.Default,
    };

    private async Task<GridData<MaintenanceWorkOrderDto>> LoadAsync(GridState<MaintenanceWorkOrderDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.MaintenanceWorkOrders.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            else if (filterOpenOnly) q = q.Where(x => x.Status != WorkOrderStatus.Completed && x.Status != WorkOrderStatus.Cancelled);
            if (filterType.HasValue) q = q.Where(x => x.Type == filterType.Value);
            if (filterAsset.HasValue) q = q.Where(x => x.AssetId == filterAsset.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.RaisedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<MaintenanceWorkOrderDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newWo = new CreateMaintenanceWorkOrderRequest { Type = WorkOrderType.Corrective, Priority = WorkOrderPriority.Medium }; scheduledFor = null; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            newWo.ScheduledFor = scheduledFor;
            await using var db = await DbFactory.CreateDbContextAsync();
            var by = await GetUserNameAsync();
            var entity = newWo.ToEntity(by);
            await using var tx = await db.Database.BeginTransactionAsync();
            db.MaintenanceWorkOrders.Add(entity);
            await db.SaveChangesAsync();
            db.MaintenanceWorkOrderAuditLogs.Add(MaintenanceWorkOrderAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.WorkOrderNumber}.", Severity.Success);
            await NotificationService.NotifyDashboardChangedAsync("Maintenance");
            dialogOpen = false;
            Navigation.NavigateTo($"maintenance/work-orders/{entity.Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
