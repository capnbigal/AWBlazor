@using AWBlazorApp.Features.Inventory.Dtos
@page "/inventory/reports"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Inventory status reports</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Status reports</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Aging · slow movers · stockout risk — derived from inv.InventoryBalance + inv.InventoryTransaction</MudText>
    </MudStack>

    <MudTabs Elevation="1" Rounded="true" PanelClass="pa-3">
        <MudTabPanel Text="Aging">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Balances grouped by last-transaction age. Stale rows may indicate dead stock.</MudText>
            <MudSimpleTable Dense="true" Hover="true" Class="mt-2">
                <thead><tr><th>Age bucket</th><th>Rows</th><th>Total qty</th></tr></thead>
                <tbody>
                    @foreach (var a in agingRows)
                    {
                        <tr><td>@a.Bucket</td><td>@a.Rows</td><td>@a.Quantity.ToString("N4")</td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudTabPanel>
        <MudTabPanel Text="Slow movers">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Items with no transactions in the last 90 days. Non-zero balances only.</MudText>
            <MudSimpleTable Dense="true" Hover="true" Class="mt-2">
                <thead><tr><th>Item</th><th>Last tx</th><th>Qty on hand</th></tr></thead>
                <tbody>
                    @foreach (var s in slowMovers)
                    {
                        <tr><td>@s.InventoryItemId</td><td>@(s.LastTransactionAt?.ToString("yyyy-MM-dd") ?? "—")</td><td>@s.Quantity.ToString("N4")</td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudTabPanel>
        <MudTabPanel Text="Stockout risk">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Items with total available quantity at or below their ReorderPoint.</MudText>
            <MudSimpleTable Dense="true" Hover="true" Class="mt-2">
                <thead><tr><th>Item</th><th>Available</th><th>Reorder point</th><th>Reorder qty</th></tr></thead>
                <tbody>
                    @foreach (var r in stockouts)
                    {
                        <tr><td>@r.InventoryItemId</td><td>@r.Available.ToString("N4")</td><td>@r.ReorderPoint.ToString("N2")</td><td>@r.ReorderQty.ToString("N2")</td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    private record AgingBucket(string Bucket, int Rows, decimal Quantity);
    private record SlowMover(int InventoryItemId, DateTime? LastTransactionAt, decimal Quantity);
    private record StockoutRow(int InventoryItemId, decimal Available, decimal ReorderPoint, decimal ReorderQty);

    private List<AgingBucket> agingRows = [];
    private List<SlowMover> slowMovers = [];
    private List<StockoutRow> stockouts = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTime.UtcNow;
        var rows = await db.InventoryBalances.AsNoTracking().Where(x => x.Quantity != 0).ToListAsync();

        agingRows =
        [
            new("0-7 days",   rows.Count(r => Bucket(r.LastTransactionAt, now) <= 7),  rows.Where(r => Bucket(r.LastTransactionAt, now) <= 7).Sum(r => r.Quantity)),
            new("8-30 days",  rows.Count(r => Bucket(r.LastTransactionAt, now) is > 7 and <= 30),  rows.Where(r => Bucket(r.LastTransactionAt, now) is > 7 and <= 30).Sum(r => r.Quantity)),
            new("31-90 days", rows.Count(r => Bucket(r.LastTransactionAt, now) is > 30 and <= 90), rows.Where(r => Bucket(r.LastTransactionAt, now) is > 30 and <= 90).Sum(r => r.Quantity)),
            new(">90 days",   rows.Count(r => Bucket(r.LastTransactionAt, now) > 90),  rows.Where(r => Bucket(r.LastTransactionAt, now) > 90).Sum(r => r.Quantity)),
        ];

        slowMovers = rows
            .Where(r => Bucket(r.LastTransactionAt, now) > 90)
            .GroupBy(r => r.InventoryItemId)
            .Select(g => new SlowMover(g.Key, g.Max(r => r.LastTransactionAt), g.Sum(r => r.Quantity)))
            .OrderByDescending(x => x.Quantity)
            .Take(50)
            .ToList();

        var available = rows.Where(r => r.Status == BalanceStatus.Available)
            .GroupBy(r => r.InventoryItemId)
            .ToDictionary(g => g.Key, g => g.Sum(r => r.Quantity));
        var items = await db.InventoryItems.AsNoTracking()
            .Where(i => i.IsActive && i.ReorderPoint > 0).ToListAsync();
        stockouts = items
            .Where(i => available.TryGetValue(i.Id, out var qty) ? qty <= i.ReorderPoint : i.ReorderPoint > 0)
            .Select(i => new StockoutRow(i.Id, available.GetValueOrDefault(i.Id, 0m), i.ReorderPoint, i.ReorderQty))
            .OrderBy(x => x.Available)
            .Take(50)
            .ToList();
    }

    private static int Bucket(DateTime? last, DateTime now) => last is null ? int.MaxValue : (int)(now - last.Value).TotalDays;
}
