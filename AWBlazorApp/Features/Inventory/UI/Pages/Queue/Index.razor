@page "/inventory/queue"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService

<PageTitle>Inventory queue</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Transaction queue</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">inv.InventoryTransactionQueue — inbound transactions from AS2, imports, external API calls</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="TransactionQueueSource?" @bind-Value="filterSource" Label="Source" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="TransactionQueueSource?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<TransactionQueueSource>())
                {
                    <MudSelectItem T="TransactionQueueSource?" Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="QueueProcessStatus?" @bind-Value="filterProcess" Label="Process status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="QueueProcessStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<QueueProcessStatus>())
                {
                    <MudSelectItem T="QueueProcessStatus?" Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="InventoryQueueDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.Source" Title="Source" />
            <PropertyColumn Property="x => x.ParseStatus" Title="Parse" />
            <PropertyColumn Property="x => x.ProcessStatus" Title="Process" />
            <PropertyColumn Property="x => x.Attempts" Title="Attempts" />
            <PropertyColumn Property="x => x.ReceivedAt" Title="Received" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.ProcessedAt" Title="Processed" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.PostedTransactionId" Title="Tx id" />
            <PropertyColumn Property="x => x.LastError" Title="Error" />
            <TemplateColumn Title="" Sortable="false"><CellTemplate><MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ShowPayloadAsync(context.Item))" /></CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="InventoryQueueDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<InventoryQueueDto> grid = null!;
    private bool _loading = true;
    private TransactionQueueSource? filterSource;
    private QueueProcessStatus? filterProcess;

    private async Task<GridData<InventoryQueueDto>> LoadAsync(GridState<InventoryQueueDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.InventoryTransactionQueue.AsNoTracking();
            if (filterSource.HasValue) query = query.Where(x => x.Source == filterSource.Value);
            if (filterProcess.HasValue) query = query.Where(x => x.ProcessStatus == filterProcess.Value);
            var total = await query.CountAsync(ct);
            var rows = await query.OrderByDescending(x => x.ReceivedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<InventoryQueueDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task ShowPayloadAsync(InventoryQueueDto row)
    {
        await DialogService.ShowMessageBoxAsync($"Queue entry {row.Id}",
            (MarkupString)($"<pre style='white-space:pre-wrap;font-size:12px;'>{System.Net.WebUtility.HtmlEncode(row.RawPayload)}</pre>"),
            yesText: "Close");
    }
}
