@page "/enterprise/organizations"
@attribute [Authorize]
@using AWBlazorApp.Features.Enterprise.Domain
@using AWBlazorApp.Features.Enterprise.Dtos
@using AWBlazorApp.Features.Enterprise.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Organizations</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Organizations</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">org.Organization</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="enterprise/organizations/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New organization</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterCode" Label="Code contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="bool?" @bind-Value="filterIsActive" Label="Active" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="bool?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@true">Active</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@false">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="OrganizationDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <HierarchyColumn T="OrganizationDto" />
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="Organization" PropertyName="@nameof(OrganizationDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Code" Title="Code">
                <HeaderTemplate><GridColumnHeader TEntity="Organization" PropertyName="@nameof(OrganizationDto.Code)" Title="Code" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <HeaderTemplate><GridColumnHeader TEntity="Organization" PropertyName="@nameof(OrganizationDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Primary" Sortable="false">
                <CellTemplate>@(context.Item.IsPrimary ? "✓" : "")</CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ExternalRef" Title="External ref">
                <HeaderTemplate><GridColumnHeader TEntity="Organization" PropertyName="@nameof(OrganizationDto.ExternalRef)" Title="External ref" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Active" Sortable="false">
                <CellTemplate>@(context.Item.IsActive ? "✓" : "")</CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="Organization" PropertyName="@nameof(OrganizationDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent><OrganizationExpandedRow OrganizationId="@context.Item.Id" /></ChildRowContent>
        <PagerContent><MudDataGridPager T="OrganizationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<OrganizationDto> grid = null!;
    private bool _loading = true;
    private string? filterCode;
    private string? filterName;
    private bool? filterIsActive;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<OrganizationDto>> LoadServerDataAsync(GridState<OrganizationDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.Organizations.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterCode)) { var n = filterCode.Trim(); query = query.Where(x => x.Code.Contains(n)); }
            if (!string.IsNullOrWhiteSpace(filterName)) { var n = filterName.Trim(); query = query.Where(x => x.Name.Contains(n)); }
            if (filterIsActive.HasValue) query = query.Where(x => x.IsActive == filterIsActive.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(OrganizationDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
                nameof(OrganizationDto.Code)         => sort.Descending ? query.OrderByDescending(x => x.Code)         : query.OrderBy(x => x.Code),
                nameof(OrganizationDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
                nameof(OrganizationDto.ExternalRef)  => sort.Descending ? query.OrderByDescending(x => x.ExternalRef)  : query.OrderBy(x => x.ExternalRef),
                nameof(OrganizationDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _ => query.OrderBy(x => x.Code),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<OrganizationDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<OrganizationDialog>("New organization", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Organization created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(OrganizationDto row)
    {
        var parameters = new DialogParameters<OrganizationDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<OrganizationDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Organization updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(OrganizationDto row)
    {
        if (row.IsPrimary) { Snackbar.Add("Cannot delete the primary organization.", Severity.Warning); return; }
        var confirm = await DialogService.ShowMessageBoxAsync("Delete organization?", $"Permanently delete organization #{row.Id} \"{row.Name}\"?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Organizations.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Organization no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var by = await GetCurrentUserNameAsync();
        db.OrganizationAuditLogs.Add(OrganizationAuditService.RecordDelete(entity, by));
        db.Organizations.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Organization deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await grid.ReloadServerData();
    }

    private void OpenHistory(OrganizationDto row) => Navigation.NavigateTo($"enterprise/organizations/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
