@using AWBlazorApp.Features.Enterprise.Domain
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="my-2" />
}
else
{
    <div class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Children</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Child orgs: <strong>@childOrgs</strong></MudText>
                    <MudText Typo="Typo.body2">Org units: <strong>@orgUnitCount</strong></MudText>
                    <MudText Typo="Typo.body2">Cost centers: <strong>@costCenterCount</strong></MudText>
                    <MudText Typo="Typo.body2">Product lines: <strong>@productLineCount</strong></MudText>
                    <MudText Typo="Typo.body2">Assets: <strong>@assetCount</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Links</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudLink Href="@($"enterprise/org-units?organizationId={OrganizationId}")">View org units</MudLink>
                    <MudLink Href="@($"enterprise/cost-centers?organizationId={OrganizationId}")">View cost centers</MudLink>
                    <MudLink Href="@($"enterprise/product-lines?organizationId={OrganizationId}")">View product lines</MudLink>
                    <MudLink Href="@($"enterprise/assets?organizationId={OrganizationId}")">View assets</MudLink>
                    <MudLink Href="@($"enterprise/tree?orgId={OrganizationId}")">Open in tree</MudLink>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Metadata</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Primary? <strong>@(isPrimary ? "yes" : "no")</strong></MudText>
                    <MudText Typo="Typo.body2">External ref: <strong>@(externalRef ?? "—")</strong></MudText>
                </MudStack>
            </MudItem>
        </MudGrid>
    </div>
}

@code {
    [Parameter] public int OrganizationId { get; set; }

    private bool loading = true;
    private int childOrgs, orgUnitCount, costCenterCount, productLineCount, assetCount;
    private bool isPrimary;
    private string? externalRef;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var org = await db.Organizations.AsNoTracking().FirstOrDefaultAsync(o => o.Id == OrganizationId);
        if (org is not null) { isPrimary = org.IsPrimary; externalRef = org.ExternalRef; }
        childOrgs        = await db.Organizations.CountAsync(o => o.ParentOrganizationId == OrganizationId);
        orgUnitCount     = await db.OrgUnits.CountAsync(u => u.OrganizationId == OrganizationId);
        costCenterCount  = await db.CostCenters.CountAsync(c => c.OrganizationId == OrganizationId);
        productLineCount = await db.ProductLines.CountAsync(p => p.OrganizationId == OrganizationId);
        assetCount       = await db.Assets.CountAsync(a => a.OrganizationId == OrganizationId);
        loading = false;
    }
}
