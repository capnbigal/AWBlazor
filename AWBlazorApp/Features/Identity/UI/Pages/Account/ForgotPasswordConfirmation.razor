@page "/Account/ForgotPasswordConfirmation"

@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Reset link sent</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" GutterBottom="true">Check your email</MudText>
        <MudText>If an account exists for that address, a password reset link has been sent. Follow the
            link in the email to choose a new password.</MudText>
    </MudPaper>
</MudContainer>
