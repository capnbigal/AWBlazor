@using AWBlazorApp.Features.Purchasing.Domain
@using AWBlazorApp.Features.Purchasing.Dtos
@using AWBlazorApp.Features.Purchasing.Audit
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateProductVendorRequest> CreateValidator
@inject MudFormValidator<UpdateProductVendorRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create product vendor" : $"Edit ({Model!.ProductId}, {Model.BusinessEntityId})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@createModel.ProductId" ValueChanged="@((int v) => createModel = createModel with { ProductId = v })" Label="Product" SearchFunc="Lookup.SearchProductsAsync" Required="true" /></MudItem>
                    <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@createModel.BusinessEntityId" ValueChanged="@((int v) => createModel = createModel with { BusinessEntityId = v })" Label="Vendor" SearchFunc="Lookup.SearchVendorsAsync" Required="true" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int" Value="@createModel.AverageLeadTime" ValueChanged="@((int v) => createModel = createModel with { AverageLeadTime = v })" Label="Lead time (days)" Variant="Variant.Outlined" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal" Value="@createModel.StandardPrice" ValueChanged="@((decimal v) => createModel = createModel with { StandardPrice = v })" Label="Std price" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="4"><FkSelect TValue="string" Value="@(createModel.UnitMeasureCode ?? "")" ValueChanged="@((string v) => createModel = createModel with { UnitMeasureCode = string.IsNullOrEmpty(v) ? null : v })" Label="Unit of measure" Items="_unitMeasures" Required="true" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int" Value="@createModel.MinOrderQty" ValueChanged="@((int v) => createModel = createModel with { MinOrderQty = v })" Label="Min qty" Variant="Variant.Outlined" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int" Value="@createModel.MaxOrderQty" ValueChanged="@((int v) => createModel = createModel with { MaxOrderQty = v })" Label="Max qty" Variant="Variant.Outlined" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int?" Value="@createModel.OnOrderQty" ValueChanged="@((int? v) => createModel = createModel with { OnOrderQty = v })" Label="On order qty" Variant="Variant.Outlined" Clearable="true" Min="0" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4"><MudNumericField T="int?" Value="@updateModel.AverageLeadTime" ValueChanged="@((int? v) => updateModel = updateModel with { AverageLeadTime = v })" Label="Lead time (days)" Variant="Variant.Outlined" Clearable="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal?" Value="@updateModel.StandardPrice" ValueChanged="@((decimal? v) => updateModel = updateModel with { StandardPrice = v })" Label="Std price" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="4"><FkSelect TValue="string" Value="@(updateModel.UnitMeasureCode ?? "")" ValueChanged="@((string v) => updateModel = updateModel with { UnitMeasureCode = string.IsNullOrEmpty(v) ? null : v })" Label="Unit of measure" Items="_unitMeasures" Clearable="true" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int?" Value="@updateModel.MinOrderQty" ValueChanged="@((int? v) => updateModel = updateModel with { MinOrderQty = v })" Label="Min qty" Variant="Variant.Outlined" Clearable="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int?" Value="@updateModel.MaxOrderQty" ValueChanged="@((int? v) => updateModel = updateModel with { MaxOrderQty = v })" Label="Max qty" Variant="Variant.Outlined" Clearable="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int?" Value="@updateModel.OnOrderQty" ValueChanged="@((int? v) => updateModel = updateModel with { OnOrderQty = v })" Label="On order qty" Variant="Variant.Outlined" Clearable="true" Min="0" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ProductVendorDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateProductVendorRequest createModel = new() { AverageLeadTime = 1, MinOrderQty = 1, MaxOrderQty = 1 };
    private UpdateProductVendorRequest updateModel = new();
    private bool saving;
    private List<LookupItem<string>> _unitMeasures = [];

    protected override async Task OnInitializedAsync()
    {
        _unitMeasures = await Lookup.GetUnitMeasuresAsync();

        if (Model is not null)
            updateModel = new UpdateProductVendorRequest
            {
                AverageLeadTime = Model.AverageLeadTime,
                StandardPrice = Model.StandardPrice,
                LastReceiptCost = Model.LastReceiptCost,
                LastReceiptDate = Model.LastReceiptDate,
                MinOrderQty = Model.MinOrderQty,
                MaxOrderQty = Model.MaxOrderQty,
                OnOrderQty = Model.OnOrderQty,
                UnitMeasureCode = Model.UnitMeasureCode,
            };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.ProductVendors.AnyAsync(x => x.ProductId == createModel.ProductId && x.BusinessEntityId == createModel.BusinessEntityId))
                {
                    Snackbar.Add("Product vendor combination already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.ProductVendors.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.ProductVendorAuditLogs.Add(ProductVendorAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.ProductVendors.FirstOrDefaultAsync(t => t.ProductId == Model!.ProductId && t.BusinessEntityId == Model.BusinessEntityId);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = ProductVendorAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.ProductVendorAuditLogs.Add(ProductVendorAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
