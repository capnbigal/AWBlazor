@page "/aw/purchase-order-details/history"
@attribute [Authorize]
@using AWBlazorApp.Features.Purchasing.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>PO detail audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/purchase-order-details"))" />
        <MudText Typo="Typo.h4">PO detail audit</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="PurchaseOrderId" Label="PO id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="PurchaseOrderDetailId" Label="Detail id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="PurchaseOrderDetailAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetailAuditLog" PropertyName="@nameof(PurchaseOrderDetailAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PurchaseOrderId" Title="PO #">
                <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetailAuditLog" PropertyName="@nameof(PurchaseOrderDetailAuditLogDto.PurchaseOrderId)" Title="PO #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PurchaseOrderDetailId" Title="Line #">
                <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetailAuditLog" PropertyName="@nameof(PurchaseOrderDetailAuditLogDto.PurchaseOrderDetailId)" Title="Line #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetailAuditLog" PropertyName="@nameof(PurchaseOrderDetailAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.LineTotal" Title="Line total" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetailAuditLog" PropertyName="@nameof(PurchaseOrderDetailAuditLogDto.LineTotal)" Title="Line total" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetailAuditLog" PropertyName="@nameof(PurchaseOrderDetailAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="PurchaseOrderDetailAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? PurchaseOrderId { get; set; }
    [SupplyParameterFromQuery] public int? PurchaseOrderDetailId { get; set; }

    private MudDataGrid<PurchaseOrderDetailAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<PurchaseOrderDetailAuditLogDto>> LoadServerDataAsync(GridState<PurchaseOrderDetailAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.PurchaseOrderDetailAuditLogs.AsNoTracking();

        if (PurchaseOrderId.HasValue) query = query.Where(a => a.PurchaseOrderId == PurchaseOrderId.Value);
        if (PurchaseOrderDetailId.HasValue) query = query.Where(a => a.PurchaseOrderDetailId == PurchaseOrderDetailId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy)) query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(filterChangedBy.Trim()));
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(PurchaseOrderDetailAuditLogDto.ChangedDate)           => sort.Descending ? query.OrderByDescending(a => a.ChangedDate)           : query.OrderBy(a => a.ChangedDate),
            nameof(PurchaseOrderDetailAuditLogDto.PurchaseOrderId)       => sort.Descending ? query.OrderByDescending(a => a.PurchaseOrderId)       : query.OrderBy(a => a.PurchaseOrderId),
            nameof(PurchaseOrderDetailAuditLogDto.PurchaseOrderDetailId) => sort.Descending ? query.OrderByDescending(a => a.PurchaseOrderDetailId) : query.OrderBy(a => a.PurchaseOrderDetailId),
            nameof(PurchaseOrderDetailAuditLogDto.ChangedBy)             => sort.Descending ? query.OrderByDescending(a => a.ChangedBy)             : query.OrderBy(a => a.ChangedBy),
            nameof(PurchaseOrderDetailAuditLogDto.LineTotal)             => sort.Descending ? query.OrderByDescending(a => a.LineTotal)             : query.OrderBy(a => a.LineTotal),
            nameof(PurchaseOrderDetailAuditLogDto.ChangeSummary)         => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary)         : query.OrderBy(a => a.ChangeSummary),
            _                                                            => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<PurchaseOrderDetailAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
