@page "/aw/locations/history"
@page "/aw/locations/history/{SlotId:int}"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Dtos
@using AWBlazorApp.Features.Production.Cultures.Dtos
@using AWBlazorApp.Features.Production.Documents.Dtos
@using AWBlazorApp.Features.Production.Illustrations.Dtos
@using AWBlazorApp.Features.Production.Locations.Dtos
@using AWBlazorApp.Features.Production.ProductCategories.Dtos
@using AWBlazorApp.Features.Production.ProductCostHistories.Dtos
@using AWBlazorApp.Features.Production.ProductDescriptions.Dtos
@using AWBlazorApp.Features.Production.ProductDocuments.Dtos
@using AWBlazorApp.Features.Production.ProductInventories.Dtos
@using AWBlazorApp.Features.Production.ProductListPriceHistories.Dtos
@using AWBlazorApp.Features.Production.ProductModels.Dtos
@using AWBlazorApp.Features.Production.ProductModelIllustrations.Dtos
@using AWBlazorApp.Features.Production.ProductModelProductDescriptionCultures.Dtos
@using AWBlazorApp.Features.Production.ProductPhotos.Dtos
@using AWBlazorApp.Features.Production.ProductProductPhotos.Dtos
@using AWBlazorApp.Features.Production.ProductReviews.Dtos
@using AWBlazorApp.Features.Production.Products.Dtos
@using AWBlazorApp.Features.Production.ProductSubcategories.Dtos
@using AWBlazorApp.Features.Production.ScrapReasons.Dtos
@using AWBlazorApp.Features.Production.TransactionHistories.Dtos
@using AWBlazorApp.Features.Production.TransactionHistoryArchives.Dtos
@using AWBlazorApp.Features.Production.UnitMeasures.Dtos
@using AWBlazorApp.Features.Production.WorkOrders.Dtos
@using AWBlazorApp.Features.Production.WorkOrderRoutings.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Location history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/locations"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Location history" : $"History for location #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.List" Href="aw/locations/history">All history</MudButton>
        }
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">Every create, update, and delete of a <code>Production.Location</code> row is recorded here.</MudText>

    @if (SlotId is null)
    {
        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                        <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudNumericField T="int?" @bind-Value="filterRowId" Label="Location id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudDataGrid T="LocationAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="LocationAuditLog" PropertyName="@nameof(LocationAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.LocationId" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="LocationAuditLog" PropertyName="@nameof(LocationAuditLogDto.LocationId)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="LocationAuditLog" PropertyName="@nameof(LocationAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <HeaderTemplate><GridColumnHeader TEntity="LocationAuditLog" PropertyName="@nameof(LocationAuditLogDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CostRate" Title="Cost rate" Format="C">
                <HeaderTemplate><GridColumnHeader TEntity="LocationAuditLog" PropertyName="@nameof(LocationAuditLogDto.CostRate)" Title="Cost rate" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Availability" Title="Availability" Format="0.00">
                <HeaderTemplate><GridColumnHeader TEntity="LocationAuditLog" PropertyName="@nameof(LocationAuditLogDto.Availability)" Title="Availability" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="LocationAuditLog" PropertyName="@nameof(LocationAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="LocationAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }

    private MudDataGrid<LocationAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private int? filterRowId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<LocationAuditLogDto>> LoadServerDataAsync(GridState<LocationAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.LocationAuditLogs.AsNoTracking();

        var scopedId = SlotId ?? filterRowId;
        if (scopedId.HasValue)
        {
            var key = (short)scopedId.Value;
            query = query.Where(a => a.LocationId == key);
        }
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(LocationAuditLogDto.ChangedDate)   => sort.Descending ? query.OrderByDescending(a => a.ChangedDate)   : query.OrderBy(a => a.ChangedDate),
            nameof(LocationAuditLogDto.LocationId)    => sort.Descending ? query.OrderByDescending(a => a.LocationId)    : query.OrderBy(a => a.LocationId),
            nameof(LocationAuditLogDto.ChangedBy)     => sort.Descending ? query.OrderByDescending(a => a.ChangedBy)     : query.OrderBy(a => a.ChangedBy),
            nameof(LocationAuditLogDto.Name)          => sort.Descending ? query.OrderByDescending(a => a.Name)          : query.OrderBy(a => a.Name),
            nameof(LocationAuditLogDto.CostRate)      => sort.Descending ? query.OrderByDescending(a => a.CostRate)      : query.OrderBy(a => a.CostRate),
            nameof(LocationAuditLogDto.Availability)  => sort.Descending ? query.OrderByDescending(a => a.Availability)  : query.OrderBy(a => a.Availability),
            nameof(LocationAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _                                         => query.OrderByDescending(a => a.ChangedDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<LocationAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
