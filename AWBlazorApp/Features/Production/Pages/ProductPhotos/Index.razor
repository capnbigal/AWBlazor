@page "/aw/product-photos"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Domain
@using AWBlazorApp.Features.Production.Models
@using AWBlazorApp.Features.Production.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Product photos</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Product photos</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.ProductPhoto · image bytes not editable</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/product-photos/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New photo</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudDataGrid T="ProductPhotoDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.ThumbnailPhotoFileName" Title="Thumbnail file" />
            <PropertyColumn Property="x => x.HasThumbnail" Title="Has thumb?" />
            <PropertyColumn Property="x => x.LargePhotoFileName" Title="Large file" />
            <PropertyColumn Property="x => x.HasLargePhoto" Title="Has large?" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductPhotoDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<ProductPhotoDto> grid = null!;

    private async Task<GridData<ProductPhotoDto>> LoadServerDataAsync(GridState<ProductPhotoDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductPhotos.AsNoTracking();
        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductPhotoDto.Id) => sort.Descending ? query.OrderByDescending(x => x.Id) : query.OrderBy(x => x.Id),
            nameof(ProductPhotoDto.ThumbnailPhotoFileName) => sort.Descending ? query.OrderByDescending(x => x.ThumbnailPhotoFileName) : query.OrderBy(x => x.ThumbnailPhotoFileName),
            nameof(ProductPhotoDto.HasThumbnail) => sort.Descending ? query.OrderByDescending(x => x.ThumbNailPhoto != null && x.ThumbNailPhoto.Length > 0) : query.OrderBy(x => x.ThumbNailPhoto != null && x.ThumbNailPhoto.Length > 0),
            nameof(ProductPhotoDto.LargePhotoFileName) => sort.Descending ? query.OrderByDescending(x => x.LargePhotoFileName) : query.OrderBy(x => x.LargePhotoFileName),
            nameof(ProductPhotoDto.HasLargePhoto) => sort.Descending ? query.OrderByDescending(x => x.LargePhoto != null && x.LargePhoto.Length > 0) : query.OrderBy(x => x.LargePhoto != null && x.LargePhoto.Length > 0),
            nameof(ProductPhotoDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _ => query.OrderBy(x => x.Id),
        };

        // Don't pull image bytes back — project to DTO inside the SQL projection.
        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize)
            .Select(x => new ProductPhotoDto(
                x.Id, x.ThumbnailPhotoFileName, x.LargePhotoFileName,
                x.ThumbNailPhoto != null && x.ThumbNailPhoto.Length > 0,
                x.LargePhoto != null && x.LargePhoto.Length > 0,
                x.ModifiedDate))
            .ToListAsync(ct);
        return new GridData<ProductPhotoDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductPhotoDialog>("New product photo", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Photo created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(ProductPhotoDto row)
    {
        var parameters = new DialogParameters<ProductPhotoDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductPhotoDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Photo updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(ProductPhotoDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete photo?", $"Permanently delete photo #{row.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductPhotos.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Photo no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.ProductPhotoAuditLogs.Add(ProductPhotoAuditService.RecordDelete(entity, changedBy));
        db.ProductPhotos.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Photo deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(ProductPhotoDto row) => Navigation.NavigateTo($"aw/product-photos/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
