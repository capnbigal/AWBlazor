@using AWBlazorApp.Features.Production.Domain
@using AWBlazorApp.Features.Production.Models
@using AWBlazorApp.Features.Production.Audit
@using AWBlazorApp.Shared.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateProductReviewRequest> CreateValidator
@inject MudFormValidator<UpdateProductReviewRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create review" : $"Edit review #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.ProductId" ValueChanged="@((int v) => createModel = createModel with { ProductId = v })" Label="Product" SearchFunc="Lookup.SearchProductsAsync" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@createModel.ReviewDate" DateChanged="@((DateTime? v) => createModel = createModel with { ReviewDate = v ?? DateTime.UtcNow.Date })" Label="Review date" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.ReviewerName" ValueChanged="@((string? v) => createModel = createModel with { ReviewerName = v })" Label="Reviewer name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.EmailAddress" ValueChanged="@((string? v) => createModel = createModel with { EmailAddress = v })" Label="Email address" Variant="Variant.Outlined" Required="true" MaxLength="50" InputType="InputType.Email" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudNumericField T="int" Value="@createModel.Rating" ValueChanged="@((int v) => createModel = createModel with { Rating = v })" Label="Rating (1–5)" Variant="Variant.Outlined" Required="true" Min="1" Max="5" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.Comments" ValueChanged="@((string? v) => createModel = createModel with { Comments = v })" Label="Comments" Variant="Variant.Outlined" Lines="4" MaxLength="3850" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@(updateModel.ProductId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { ProductId = v == 0 ? null : v })" Label="Product" SearchFunc="Lookup.SearchProductsAsync" InitialDisplayText="@_editProductName" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@updateModel.ReviewDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { ReviewDate = v })" Label="Review date" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.ReviewerName" ValueChanged="@((string? v) => updateModel = updateModel with { ReviewerName = v })" Label="Reviewer name" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.EmailAddress" ValueChanged="@((string? v) => updateModel = updateModel with { EmailAddress = v })" Label="Email address" Variant="Variant.Outlined" MaxLength="50" InputType="InputType.Email" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudNumericField T="int?" Value="@updateModel.Rating" ValueChanged="@((int? v) => updateModel = updateModel with { Rating = v })" Label="Rating (1–5)" Variant="Variant.Outlined" Clearable="true" Min="1" Max="5" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.Comments" ValueChanged="@((string? v) => updateModel = updateModel with { Comments = v })" Label="Comments" Variant="Variant.Outlined" Lines="4" MaxLength="3850" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ProductReviewDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateProductReviewRequest createModel = new() { ReviewDate = DateTime.UtcNow.Date, Rating = 5 };
    private UpdateProductReviewRequest updateModel = new();
    private bool saving;
    private string? _editProductName;

    protected override async Task OnInitializedAsync()
    {
        if (Model is not null)
        {
            _editProductName = await Lookup.GetProductNameAsync(Model.ProductId);
            updateModel = new UpdateProductReviewRequest
            {
                ProductId = Model.ProductId,
                ReviewerName = Model.ReviewerName,
                ReviewDate = Model.ReviewDate,
                EmailAddress = Model.EmailAddress,
                Rating = Model.Rating,
                Comments = Model.Comments,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate required FK
                if (!await db.Products.AnyAsync(x => x.Id == createModel.ProductId))
                { Snackbar.Add($"Product #{createModel.ProductId} does not exist.", Severity.Error); return; }

                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.ProductReviews.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.ProductReviewAuditLogs.Add(ProductReviewAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.ProductReviews.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = ProductReviewAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FK on update
                if (updateModel.ProductId.HasValue && !await db.Products.AnyAsync(x => x.Id == updateModel.ProductId.Value))
                { Snackbar.Add($"Product #{updateModel.ProductId.Value} does not exist.", Severity.Error); return; }
                db.ProductReviewAuditLogs.Add(ProductReviewAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
