@page "/aw/unit-measures"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Domain
@using AWBlazorApp.Features.Production.Models
@using AWBlazorApp.Features.Production.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Units of measure</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Units of measure</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.UnitMeasure</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/unit-measures/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New unit of measure</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="UnitMeasureDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.UnitMeasureCode" Title="Code">
                <HeaderTemplate><GridColumnHeader TEntity="UnitMeasure" PropertyName="@nameof(UnitMeasureDto.UnitMeasureCode)" Title="Code" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <HeaderTemplate><GridColumnHeader TEntity="UnitMeasure" PropertyName="@nameof(UnitMeasureDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="UnitMeasure" PropertyName="@nameof(UnitMeasureDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History">
                            <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" />
                        </MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="UnitMeasureDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<UnitMeasureDto> grid = null!;
    private string? filterName;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<UnitMeasureDto>> LoadServerDataAsync(GridState<UnitMeasureDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.UnitMeasures.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var needle = filterName.Trim();
            query = query.Where(x => x.Name.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(UnitMeasureDto.UnitMeasureCode) => sort.Descending ? query.OrderByDescending(x => x.UnitMeasureCode) : query.OrderBy(x => x.UnitMeasureCode),
            nameof(UnitMeasureDto.Name)            => sort.Descending ? query.OrderByDescending(x => x.Name)            : query.OrderBy(x => x.Name),
            nameof(UnitMeasureDto.ModifiedDate)    => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)    : query.OrderBy(x => x.ModifiedDate),
            _                                      => query.OrderBy(x => x.UnitMeasureCode),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<UnitMeasureDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<UnitMeasureDialog>("New unit of measure", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Unit of measure created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(UnitMeasureDto row)
    {
        var parameters = new DialogParameters<UnitMeasureDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<UnitMeasureDialog>($"Edit {row.UnitMeasureCode}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Unit of measure updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(UnitMeasureDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete unit of measure?", $"Permanently delete {row.UnitMeasureCode} ({row.Name})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.UnitMeasures.FirstOrDefaultAsync(t => t.UnitMeasureCode == row.UnitMeasureCode);
        if (entity is null) { Snackbar.Add("Unit of measure no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.UnitMeasureAuditLogs.Add(UnitMeasureAuditService.RecordDelete(entity, changedBy));
        db.UnitMeasures.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Unit of measure deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(UnitMeasureDto row) => Navigation.NavigateTo($"aw/unit-measures/history/{row.UnitMeasureCode}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
