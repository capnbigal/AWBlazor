@page "/aw/product-list-price-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Domain
@using AWBlazorApp.Features.Production.Models
@using AWBlazorApp.Features.Production.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Product list-price history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Product list-price history</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.ProductListPriceHistory · composite PK (ProductID, StartDate)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/product-list-price-histories/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New price row</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => { filterProductId = v == 0 ? null : v; })" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="ProductListPriceHistoryDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ProductId" Title="Product id">
                <HeaderTemplate><GridColumnHeader TEntity="ProductListPriceHistory" PropertyName="@nameof(ProductListPriceHistoryDto.ProductId)" Title="Product id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="ProductListPriceHistory" PropertyName="@nameof(ProductListPriceHistoryDto.StartDate)" Title="Start" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.EndDate" Title="End" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="ProductListPriceHistory" PropertyName="@nameof(ProductListPriceHistoryDto.EndDate)" Title="End" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ListPrice" Title="List price" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="ProductListPriceHistory" PropertyName="@nameof(ProductListPriceHistoryDto.ListPrice)" Title="List price" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="ProductListPriceHistory" PropertyName="@nameof(ProductListPriceHistoryDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductListPriceHistoryDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<ProductListPriceHistoryDto> grid = null!;
    private bool _loading = true;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductListPriceHistoryDto>> LoadServerDataAsync(GridState<ProductListPriceHistoryDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.ProductListPriceHistories.AsNoTracking();
            if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);

            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(ProductListPriceHistoryDto.ProductId) => sort.Descending ? query.OrderByDescending(x => x.ProductId) : query.OrderBy(x => x.ProductId),
                nameof(ProductListPriceHistoryDto.StartDate) => sort.Descending ? query.OrderByDescending(x => x.StartDate) : query.OrderBy(x => x.StartDate),
                nameof(ProductListPriceHistoryDto.EndDate) => sort.Descending ? query.OrderByDescending(x => x.EndDate) : query.OrderBy(x => x.EndDate),
                nameof(ProductListPriceHistoryDto.ListPrice) => sort.Descending ? query.OrderByDescending(x => x.ListPrice) : query.OrderBy(x => x.ListPrice),
                nameof(ProductListPriceHistoryDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _ => query.OrderBy(x => x.ProductId).ThenByDescending(x => x.StartDate),
            };

            var rows = await query
                .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ProductListPriceHistoryDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductListPriceHistoryDialog>("New price row", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Price row created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(ProductListPriceHistoryDto row)
    {
        var parameters = new DialogParameters<ProductListPriceHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductListPriceHistoryDialog>($"Edit ({row.ProductId}, {row.StartDate:yyyy-MM-dd})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Price row updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(ProductListPriceHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete price row?", $"Permanently delete ({row.ProductId}, {row.StartDate:yyyy-MM-dd})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductListPriceHistories.FirstOrDefaultAsync(t =>
            t.ProductId == row.ProductId && t.StartDate == row.StartDate);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.ProductListPriceHistoryAuditLogs.Add(ProductListPriceHistoryAuditService.RecordDelete(entity, changedBy));
        db.ProductListPriceHistories.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Price row deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(ProductListPriceHistoryDto row)
        => Navigation.NavigateTo($"aw/product-list-price-histories/history?productId={row.ProductId}&startDate={row.StartDate:yyyy-MM-dd}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
