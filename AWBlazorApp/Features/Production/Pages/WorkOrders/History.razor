@page "/aw/work-orders/history"
@page "/aw/work-orders/history/{SlotId:int}"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Work order history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/work-orders"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Work order history" : $"History for work order #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.List" Href="aw/work-orders/history">All history</MudButton>
        }
    </MudStack>

    @if (SlotId is null)
    {
        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                        <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudNumericField T="int?" @bind-Value="filterRowId" Label="Work order id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudDataGrid T="WorkOrderAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="WorkOrderAuditLog" PropertyName="@nameof(WorkOrderAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.WorkOrderId" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="WorkOrderAuditLog" PropertyName="@nameof(WorkOrderAuditLogDto.WorkOrderId)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="WorkOrderAuditLog" PropertyName="@nameof(WorkOrderAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductId" Title="Product">
                <HeaderTemplate><GridColumnHeader TEntity="WorkOrderAuditLog" PropertyName="@nameof(WorkOrderAuditLogDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.OrderQty" Title="Order qty">
                <HeaderTemplate><GridColumnHeader TEntity="WorkOrderAuditLog" PropertyName="@nameof(WorkOrderAuditLogDto.OrderQty)" Title="Order qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ScrappedQty" Title="Scrapped">
                <HeaderTemplate><GridColumnHeader TEntity="WorkOrderAuditLog" PropertyName="@nameof(WorkOrderAuditLogDto.ScrappedQty)" Title="Scrapped" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="WorkOrderAuditLog" PropertyName="@nameof(WorkOrderAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="WorkOrderAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }

    private MudDataGrid<WorkOrderAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private int? filterRowId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<WorkOrderAuditLogDto>> LoadServerDataAsync(GridState<WorkOrderAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.WorkOrderAuditLogs.AsNoTracking();

        var scopedId = SlotId ?? filterRowId;
        if (scopedId.HasValue) query = query.Where(a => a.WorkOrderId == scopedId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(WorkOrderAuditLogDto.ChangedDate)   => sort.Descending ? query.OrderByDescending(a => a.ChangedDate)   : query.OrderBy(a => a.ChangedDate),
            nameof(WorkOrderAuditLogDto.WorkOrderId)   => sort.Descending ? query.OrderByDescending(a => a.WorkOrderId)   : query.OrderBy(a => a.WorkOrderId),
            nameof(WorkOrderAuditLogDto.ChangedBy)     => sort.Descending ? query.OrderByDescending(a => a.ChangedBy)     : query.OrderBy(a => a.ChangedBy),
            nameof(WorkOrderAuditLogDto.ProductId)     => sort.Descending ? query.OrderByDescending(a => a.ProductId)     : query.OrderBy(a => a.ProductId),
            nameof(WorkOrderAuditLogDto.OrderQty)      => sort.Descending ? query.OrderByDescending(a => a.OrderQty)      : query.OrderBy(a => a.OrderQty),
            nameof(WorkOrderAuditLogDto.ScrappedQty)   => sort.Descending ? query.OrderByDescending(a => a.ScrappedQty)   : query.OrderBy(a => a.ScrappedQty),
            nameof(WorkOrderAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _                                          => query.OrderByDescending(a => a.ChangedDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<WorkOrderAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
