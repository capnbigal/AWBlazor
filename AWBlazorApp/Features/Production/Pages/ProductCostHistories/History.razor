@page "/aw/product-cost-histories/history"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Product cost history audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-cost-histories"))" />
        <MudText Typo="Typo.h4">Product cost history audit</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="ProductId" Label="Product id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudDatePicker @bind-Date="StartDate" Label="Start date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="ProductCostHistoryAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25" FilterMode="DataGridFilterMode.ColumnFilterMenu">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <FilterTemplate><ColumnFilterButton TEntity="ProductCostHistoryAuditLog" PropertyName="@nameof(ProductCostHistoryAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductId" Title="Product">
                <FilterTemplate><ColumnFilterButton TEntity="ProductCostHistoryAuditLog" PropertyName="@nameof(ProductCostHistoryAuditLogDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.StartDate" Title="Start date" Format="yyyy-MM-dd">
                <FilterTemplate><ColumnFilterButton TEntity="ProductCostHistoryAuditLog" PropertyName="@nameof(ProductCostHistoryAuditLogDto.StartDate)" Title="Start date" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <FilterTemplate><ColumnFilterButton TEntity="ProductCostHistoryAuditLog" PropertyName="@nameof(ProductCostHistoryAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.StandardCost" Title="Cost" Format="C2">
                <FilterTemplate><ColumnFilterButton TEntity="ProductCostHistoryAuditLog" PropertyName="@nameof(ProductCostHistoryAuditLogDto.StandardCost)" Title="Cost" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <FilterTemplate><ColumnFilterButton TEntity="ProductCostHistoryAuditLog" PropertyName="@nameof(ProductCostHistoryAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></FilterTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductCostHistoryAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? ProductId { get; set; }
    [SupplyParameterFromQuery] public DateTime? StartDate { get; set; }

    private MudDataGrid<ProductCostHistoryAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductCostHistoryAuditLogDto>> LoadServerDataAsync(GridState<ProductCostHistoryAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductCostHistoryAuditLogs.AsNoTracking();

        if (ProductId.HasValue) query = query.Where(a => a.ProductId == ProductId.Value);
        if (StartDate.HasValue)
        {
            var key = StartDate.Value;
            query = query.Where(a => a.StartDate == key);
        }
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductCostHistoryAuditLogDto.ChangedDate) => sort.Descending ? query.OrderByDescending(a => a.ChangedDate) : query.OrderBy(a => a.ChangedDate),
            nameof(ProductCostHistoryAuditLogDto.ProductId) => sort.Descending ? query.OrderByDescending(a => a.ProductId) : query.OrderBy(a => a.ProductId),
            nameof(ProductCostHistoryAuditLogDto.StartDate) => sort.Descending ? query.OrderByDescending(a => a.StartDate) : query.OrderBy(a => a.StartDate),
            nameof(ProductCostHistoryAuditLogDto.ChangedBy) => sort.Descending ? query.OrderByDescending(a => a.ChangedBy) : query.OrderBy(a => a.ChangedBy),
            nameof(ProductCostHistoryAuditLogDto.StandardCost) => sort.Descending ? query.OrderByDescending(a => a.StandardCost) : query.OrderBy(a => a.StandardCost),
            nameof(ProductCostHistoryAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _ => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<ProductCostHistoryAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
