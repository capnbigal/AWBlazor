@page "/aw/product-subcategories/history"
@page "/aw/product-subcategories/history/{SlotId:int}"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Subcategory history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-subcategories"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Product subcategory history" : $"History for subcategory #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.List" Href="aw/product-subcategories/history">All history</MudButton>
        }
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">Every create, update, and delete of a <code>Production.ProductSubcategory</code> row is recorded here.</MudText>

    @if (SlotId is null)
    {
        <MudPaper Class="pa-3" Elevation="1">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                        <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudNumericField T="int?" @bind-Value="filterRowId" Label="Subcategory id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudDataGrid T="ProductSubcategoryAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="ProductSubcategoryAuditLog" PropertyName="@nameof(ProductSubcategoryAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductSubcategoryId" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="ProductSubcategoryAuditLog" PropertyName="@nameof(ProductSubcategoryAuditLogDto.ProductSubcategoryId)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="ProductSubcategoryAuditLog" PropertyName="@nameof(ProductSubcategoryAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductCategoryId" Title="Cat id">
                <HeaderTemplate><GridColumnHeader TEntity="ProductSubcategoryAuditLog" PropertyName="@nameof(ProductSubcategoryAuditLogDto.ProductCategoryId)" Title="Cat id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <HeaderTemplate><GridColumnHeader TEntity="ProductSubcategoryAuditLog" PropertyName="@nameof(ProductSubcategoryAuditLogDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="ProductSubcategoryAuditLog" PropertyName="@nameof(ProductSubcategoryAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductSubcategoryAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }

    private MudDataGrid<ProductSubcategoryAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private int? filterRowId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductSubcategoryAuditLogDto>> LoadServerDataAsync(GridState<ProductSubcategoryAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductSubcategoryAuditLogs.AsNoTracking();

        var scopedId = SlotId ?? filterRowId;
        if (scopedId.HasValue) query = query.Where(a => a.ProductSubcategoryId == scopedId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductSubcategoryAuditLogDto.ChangedDate)          => sort.Descending ? query.OrderByDescending(a => a.ChangedDate)          : query.OrderBy(a => a.ChangedDate),
            nameof(ProductSubcategoryAuditLogDto.ProductSubcategoryId) => sort.Descending ? query.OrderByDescending(a => a.ProductSubcategoryId) : query.OrderBy(a => a.ProductSubcategoryId),
            nameof(ProductSubcategoryAuditLogDto.ProductCategoryId)    => sort.Descending ? query.OrderByDescending(a => a.ProductCategoryId)    : query.OrderBy(a => a.ProductCategoryId),
            nameof(ProductSubcategoryAuditLogDto.ChangedBy)            => sort.Descending ? query.OrderByDescending(a => a.ChangedBy)            : query.OrderBy(a => a.ChangedBy),
            nameof(ProductSubcategoryAuditLogDto.Name)                 => sort.Descending ? query.OrderByDescending(a => a.Name)                 : query.OrderBy(a => a.Name),
            nameof(ProductSubcategoryAuditLogDto.ChangeSummary)        => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary)        : query.OrderBy(a => a.ChangeSummary),
            _                                                          => query.OrderByDescending(a => a.ChangedDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<ProductSubcategoryAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
