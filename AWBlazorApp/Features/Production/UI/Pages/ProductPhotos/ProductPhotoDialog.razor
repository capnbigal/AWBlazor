@using AWBlazorApp.Features.Production.Domain
@using AWBlazorApp.Features.Production.Dtos
@using AWBlazorApp.Features.Production.Audit
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateProductPhotoRequest> CreateValidator
@inject MudFormValidator<UpdateProductPhotoRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create photo" : $"Edit photo #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.ThumbnailPhotoFileName" ValueChanged="@((string? v) => createModel = createModel with { ThumbnailPhotoFileName = v })" Label="Thumbnail file name" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.LargePhotoFileName" ValueChanged="@((string? v) => createModel = createModel with { LargePhotoFileName = v })" Label="Large photo file name" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Image binary upload is not supported through this UI — only the filename metadata is editable.</MudText>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.ThumbnailPhotoFileName" ValueChanged="@((string? v) => updateModel = updateModel with { ThumbnailPhotoFileName = v })" Label="Thumbnail file name" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.LargePhotoFileName" ValueChanged="@((string? v) => updateModel = updateModel with { LargePhotoFileName = v })" Label="Large photo file name" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ProductPhotoDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateProductPhotoRequest createModel = new();
    private UpdateProductPhotoRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateProductPhotoRequest
            {
                ThumbnailPhotoFileName = Model.ThumbnailPhotoFileName,
                LargePhotoFileName = Model.LargePhotoFileName,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.ProductPhotos.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.ProductPhotoAuditLogs.Add(ProductPhotoAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.ProductPhotos.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = ProductPhotoAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.ProductPhotoAuditLogs.Add(ProductPhotoAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
