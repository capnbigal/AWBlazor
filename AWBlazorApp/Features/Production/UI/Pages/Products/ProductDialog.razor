@using AWBlazorApp.Features.Production.Domain
@using AWBlazorApp.Features.Production.Dtos
@using AWBlazorApp.Features.Production.Audit
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateProductRequest> CreateValidator
@inject MudFormValidator<UpdateProductRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create product" : $"Edit product #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.ProductNumber" ValueChanged="@((string? v) => createModel = createModel with { ProductNumber = v })" Label="Product number" Variant="Variant.Outlined" Required="true" MaxLength="25" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch T="bool" Value="@createModel.MakeFlag" ValueChanged="@((bool v) => createModel = createModel with { MakeFlag = v })" Label="Make in-house" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch T="bool" Value="@createModel.FinishedGoodsFlag" ValueChanged="@((bool v) => createModel = createModel with { FinishedGoodsFlag = v })" Label="Finished goods" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="short" Value="@createModel.SafetyStockLevel" ValueChanged="@((short v) => createModel = createModel with { SafetyStockLevel = v })" Label="Safety stock" Variant="Variant.Outlined" Required="true" Min="1" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="short" Value="@createModel.ReorderPoint" ValueChanged="@((short v) => createModel = createModel with { ReorderPoint = v })" Label="Reorder point" Variant="Variant.Outlined" Required="true" Min="1" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="decimal" Value="@createModel.StandardCost" ValueChanged="@((decimal v) => createModel = createModel with { StandardCost = v })" Label="Standard cost" Variant="Variant.Outlined" Required="true" Min="0" Step="0.01M" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="decimal" Value="@createModel.ListPrice" ValueChanged="@((decimal v) => createModel = createModel with { ListPrice = v })" Label="List price" Variant="Variant.Outlined" Required="true" Min="0" Step="0.01M" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@createModel.Color" ValueChanged="@((string? v) => createModel = createModel with { Color = v })" Label="Color" Variant="Variant.Outlined" MaxLength="15" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@createModel.Size" ValueChanged="@((string? v) => createModel = createModel with { Size = v })" Label="Size" Variant="Variant.Outlined" MaxLength="5" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="string" Value="@(createModel.SizeUnitMeasureCode ?? "")" ValueChanged="@((string v) => createModel = createModel with { SizeUnitMeasureCode = string.IsNullOrEmpty(v) ? null : v })" Label="Size unit" Items="_unitMeasures" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="decimal?" Value="@createModel.Weight" ValueChanged="@((decimal? v) => createModel = createModel with { Weight = v })" Label="Weight" Variant="Variant.Outlined" Clearable="true" Step="0.01M" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="string" Value="@(createModel.WeightUnitMeasureCode ?? "")" ValueChanged="@((string v) => createModel = createModel with { WeightUnitMeasureCode = string.IsNullOrEmpty(v) ? null : v })" Label="Weight unit" Items="_unitMeasures" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="int" Value="@createModel.DaysToManufacture" ValueChanged="@((int v) => createModel = createModel with { DaysToManufacture = v })" Label="Days to mfr" Variant="Variant.Outlined" Min="0" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="string?" Value="@createModel.ProductLine" ValueChanged="@((string? v) => createModel = createModel with { ProductLine = v })" Label="Product line" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var opt in ProductConstants.ProductLines)
                            {
                                <MudSelectItem T="string?" Value="@opt.Code">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="string?" Value="@createModel.Class" ValueChanged="@((string? v) => createModel = createModel with { Class = v })" Label="Class" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var opt in ProductConstants.Classes)
                            {
                                <MudSelectItem T="string?" Value="@opt.Code">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="string?" Value="@createModel.Style" ValueChanged="@((string? v) => createModel = createModel with { Style = v })" Label="Style" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var opt in ProductConstants.Styles)
                            {
                                <MudSelectItem T="string?" Value="@opt.Code">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="int" Value="@(createModel.ProductSubcategoryId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { ProductSubcategoryId = v == 0 ? null : v })" Label="Subcategory" Items="_subcategories" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="int" Value="@(createModel.ProductModelId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { ProductModelId = v == 0 ? null : v })" Label="Product model" Items="_models" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.SellStartDate" DateChanged="@((DateTime? v) => createModel = createModel with { SellStartDate = v ?? DateTime.UtcNow.Date })" Label="Sell start" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.SellEndDate" DateChanged="@((DateTime? v) => createModel = createModel with { SellEndDate = v })" Label="Sell end" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.DiscontinuedDate" DateChanged="@((DateTime? v) => createModel = createModel with { DiscontinuedDate = v })" Label="Discontinued" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.ProductNumber" ValueChanged="@((string? v) => updateModel = updateModel with { ProductNumber = v })" Label="Product number" Variant="Variant.Outlined" MaxLength="25" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch T="bool" Value="@(updateModel.MakeFlag ?? false)" ValueChanged="@((bool v) => updateModel = updateModel with { MakeFlag = v })" Label="Make in-house" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch T="bool" Value="@(updateModel.FinishedGoodsFlag ?? false)" ValueChanged="@((bool v) => updateModel = updateModel with { FinishedGoodsFlag = v })" Label="Finished goods" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="short?" Value="@updateModel.SafetyStockLevel" ValueChanged="@((short? v) => updateModel = updateModel with { SafetyStockLevel = v })" Label="Safety stock" Variant="Variant.Outlined" Clearable="true" Min="1" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="short?" Value="@updateModel.ReorderPoint" ValueChanged="@((short? v) => updateModel = updateModel with { ReorderPoint = v })" Label="Reorder point" Variant="Variant.Outlined" Clearable="true" Min="1" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="decimal?" Value="@updateModel.StandardCost" ValueChanged="@((decimal? v) => updateModel = updateModel with { StandardCost = v })" Label="Standard cost" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="decimal?" Value="@updateModel.ListPrice" ValueChanged="@((decimal? v) => updateModel = updateModel with { ListPrice = v })" Label="List price" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@updateModel.Color" ValueChanged="@((string? v) => updateModel = updateModel with { Color = v })" Label="Color" Variant="Variant.Outlined" MaxLength="15" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@updateModel.Size" ValueChanged="@((string? v) => updateModel = updateModel with { Size = v })" Label="Size" Variant="Variant.Outlined" MaxLength="5" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="string" Value="@(updateModel.SizeUnitMeasureCode ?? "")" ValueChanged="@((string v) => updateModel = updateModel with { SizeUnitMeasureCode = string.IsNullOrEmpty(v) ? null : v })" Label="Size unit" Items="_unitMeasures" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="decimal?" Value="@updateModel.Weight" ValueChanged="@((decimal? v) => updateModel = updateModel with { Weight = v })" Label="Weight" Variant="Variant.Outlined" Clearable="true" Step="0.01M" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="string" Value="@(updateModel.WeightUnitMeasureCode ?? "")" ValueChanged="@((string v) => updateModel = updateModel with { WeightUnitMeasureCode = string.IsNullOrEmpty(v) ? null : v })" Label="Weight unit" Items="_unitMeasures" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="string?" Value="@updateModel.ProductLine" ValueChanged="@((string? v) => updateModel = updateModel with { ProductLine = v })" Label="Product line" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var opt in ProductConstants.ProductLines)
                            {
                                <MudSelectItem T="string?" Value="@opt.Code">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="string?" Value="@updateModel.Class" ValueChanged="@((string? v) => updateModel = updateModel with { Class = v })" Label="Class" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var opt in ProductConstants.Classes)
                            {
                                <MudSelectItem T="string?" Value="@opt.Code">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="string?" Value="@updateModel.Style" ValueChanged="@((string? v) => updateModel = updateModel with { Style = v })" Label="Style" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var opt in ProductConstants.Styles)
                            {
                                <MudSelectItem T="string?" Value="@opt.Code">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="int" Value="@(updateModel.ProductSubcategoryId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { ProductSubcategoryId = v == 0 ? null : v })" Label="Subcategory" Items="_subcategories" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <FkSelect TValue="int" Value="@(updateModel.ProductModelId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { ProductModelId = v == 0 ? null : v })" Label="Product model" Items="_models" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.SellStartDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { SellStartDate = v })" Label="Sell start" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.SellEndDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { SellEndDate = v })" Label="Sell end" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.DiscontinuedDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { DiscontinuedDate = v })" Label="Discontinued" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ProductDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateProductRequest createModel = new() { SellStartDate = DateTime.UtcNow.Date, SafetyStockLevel = 1, ReorderPoint = 1 };
    private UpdateProductRequest updateModel = new();
    private bool saving;
    private List<LookupItem<int>> _subcategories = [];
    private List<LookupItem<int>> _models = [];
    private List<LookupItem<string>> _unitMeasures = [];

    protected override async Task OnInitializedAsync()
    {
        _subcategories = await Lookup.GetProductSubcategoriesAsync();
        _models = await Lookup.GetProductModelsAsync();
        _unitMeasures = await Lookup.GetUnitMeasuresAsync();

        if (Model is not null)
        {
            updateModel = new UpdateProductRequest
            {
                Name = Model.Name,
                ProductNumber = Model.ProductNumber,
                MakeFlag = Model.MakeFlag,
                FinishedGoodsFlag = Model.FinishedGoodsFlag,
                Color = Model.Color,
                SafetyStockLevel = Model.SafetyStockLevel,
                ReorderPoint = Model.ReorderPoint,
                StandardCost = Model.StandardCost,
                ListPrice = Model.ListPrice,
                Size = Model.Size,
                SizeUnitMeasureCode = Model.SizeUnitMeasureCode,
                WeightUnitMeasureCode = Model.WeightUnitMeasureCode,
                Weight = Model.Weight,
                DaysToManufacture = Model.DaysToManufacture,
                ProductLine = Model.ProductLine,
                Class = Model.Class,
                Style = Model.Style,
                ProductSubcategoryId = Model.ProductSubcategoryId,
                ProductModelId = Model.ProductModelId,
                SellStartDate = Model.SellStartDate,
                SellEndDate = Model.SellEndDate,
                DiscontinuedDate = Model.DiscontinuedDate,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate optional FKs
                if (createModel.ProductSubcategoryId.HasValue && !await db.ProductSubcategories.AnyAsync(x => x.Id == createModel.ProductSubcategoryId.Value))
                { Snackbar.Add($"Product subcategory #{createModel.ProductSubcategoryId.Value} does not exist.", Severity.Error); return; }
                if (createModel.ProductModelId.HasValue && !await db.ProductModels.AnyAsync(x => x.Id == createModel.ProductModelId.Value))
                { Snackbar.Add($"Product model #{createModel.ProductModelId.Value} does not exist.", Severity.Error); return; }

                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.Products.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.ProductAuditLogs.Add(ProductAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Products.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = ProductAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FKs on update
                if (updateModel.ProductSubcategoryId.HasValue && !await db.ProductSubcategories.AnyAsync(x => x.Id == updateModel.ProductSubcategoryId.Value))
                { Snackbar.Add($"Product subcategory #{updateModel.ProductSubcategoryId.Value} does not exist.", Severity.Error); return; }
                if (updateModel.ProductModelId.HasValue && !await db.ProductModels.AnyAsync(x => x.Id == updateModel.ProductModelId.Value))
                { Snackbar.Add($"Product model #{updateModel.ProductModelId.Value} does not exist.", Severity.Error); return; }
                db.ProductAuditLogs.Add(ProductAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
