@page "/engineering"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Engineering</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Engineering</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Routings, BOMs, ECOs, drawings, deviations — ECO approval auto-activates new revisions</MudText>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.ChangeCircle" Color="Color.Warning" Value="@ecosUnderReview.ToString("N0")" Label="ECOs under review" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Value="@activeBoms.ToString("N0")" Label="Active BOMs" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" Value="@activeRoutings.ToString("N0")" Label="Active routings" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.RuleFolder" Color="Color.Error" Value="@pendingDeviations.ToString("N0")" Label="Pending deviations" /></MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        @foreach (var card in Cards)
        {
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@card.Icon" Color="Color.Primary" Size="Size.Large" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6">@card.Title</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@card.Subtitle</MudText>
                        </MudStack>
                        <MudSpacer />
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.List" Href="@card.Href">Open</MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudStack>

@code {
    private int ecosUnderReview, activeBoms, activeRoutings, pendingDeviations;

    private record NavCard(string Title, string Subtitle, string Href, string Icon);

    private static readonly NavCard[] Cards =
    [
        new("Change orders", "Draft → UnderReview → Approved/Rejected. Approval auto-activates affected BOM/Routing revisions.", "engineering/ecos", Icons.Material.Filled.ChangeCircle),
        new("Routings", "Ordered sequence of stations per product — template used by MES runs.", "engineering/routings", Icons.Material.Filled.Timeline),
        new("Bills of materials", "Engineering BOM with revision control — independent of AW's finance BOM.", "engineering/boms", Icons.Material.Filled.AccountTree),
        new("Documents", "Drawings, specs, CAD models, procedures — URL refs to external storage.", "engineering/documents", Icons.Material.Filled.Description),
        new("Deviations", "Time- and quantity-bounded spec exceptions — temporary, not permanent changes.", "engineering/deviations", Icons.Material.Filled.RuleFolder),
    ];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        ecosUnderReview = await db.EngineeringChangeOrders.CountAsync(e => e.Status == EcoStatus.UnderReview);
        activeBoms = await db.BomHeaders.CountAsync(b => b.IsActive);
        activeRoutings = await db.ManufacturingRoutings.CountAsync(r => r.IsActive);
        pendingDeviations = await db.DeviationRequests.CountAsync(d => d.Status == DeviationStatus.Pending);
    }
}
