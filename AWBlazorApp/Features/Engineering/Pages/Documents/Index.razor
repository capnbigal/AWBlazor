@page "/engineering/documents"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Engineering documents</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Engineering documents</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">eng.EngineeringDocument — drawings, specifications, CAD models, procedures (URL refs)</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New document</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="EngineeringDocumentKind?" @bind-Value="filterKind" Label="Kind" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="EngineeringDocumentKind?" Value="@null">(any)</MudSelectItem>
                @foreach (var k in Enum.GetValues<EngineeringDocumentKind>()) { <MudSelectItem T="EngineeringDocumentKind?" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterProduct" Label="Product" Variant="Variant.Outlined" Clearable="true" />
            <MudCheckBox T="bool" @bind-Value="activeOnly" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="EngineeringDocumentDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Title" Title="Title" />
            <PropertyColumn Property="x => x.Kind" Title="Kind" />
            <PropertyColumn Property="x => x.ProductId" Title="Product" />
            <PropertyColumn Property="x => x.RevisionNumber" Title="Rev" />
            <TemplateColumn Title="URL" Sortable="false">
                <CellTemplate>
                    @if (!string.IsNullOrWhiteSpace(context.Item.Url))
                    { <MudLink Href="@context.Item.Url" Target="_blank">open</MudLink> }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate>@(context.Item.IsActive ? "✓" : "")</CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="EngineeringDocumentDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New document</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newRow.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Title" Label="Title" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="EngineeringDocumentKind" @bind-Value="newRow.Kind" Label="Kind" Variant="Variant.Outlined">
                @foreach (var k in Enum.GetValues<EngineeringDocumentKind>()) { <MudSelectItem T="EngineeringDocumentKind" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="newRow.ProductId" Label="Product ID (optional)" Variant="Variant.Outlined" />
            <MudNumericField T="int" @bind-Value="newRow.RevisionNumber" Label="Revision" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Url" Label="URL" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
            <MudCheckBox T="bool" @bind-Value="newRow.IsActive" Label="Active" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<EngineeringDocumentDto> grid = null!;
    private bool _loading = true;
    private EngineeringDocumentKind? filterKind;
    private int? filterProduct;
    private bool activeOnly = true;

    private bool dialogOpen, saving;
    private CreateEngineeringDocumentRequest newRow = new();

    private async Task<GridData<EngineeringDocumentDto>> LoadAsync(GridState<EngineeringDocumentDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.EngineeringDocuments.AsNoTracking();
            if (filterKind.HasValue) q = q.Where(x => x.Kind == filterKind.Value);
            if (filterProduct.HasValue) q = q.Where(x => x.ProductId == filterProduct.Value);
            if (activeOnly) q = q.Where(x => x.IsActive);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.Code)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<EngineeringDocumentDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateEngineeringDocumentRequest { Kind = EngineeringDocumentKind.Drawing, RevisionNumber = 1, IsActive = true }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRow.ToEntity();
            var by = await GetUserNameAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            db.EngineeringDocuments.Add(entity);
            await db.SaveChangesAsync();
            db.EngineeringDocumentAuditLogs.Add(EngineeringDocumentAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.Code}.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
