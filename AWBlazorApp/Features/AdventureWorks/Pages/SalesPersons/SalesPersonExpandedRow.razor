@using AWBlazorApp.Features.AdventureWorks.Domain
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="my-2" />
}
else
{
    <div class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Territory & compensation</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Territory: @if (territoryName is not null) { <MudLink Href="aw/sales-territories" Color="Color.Primary">@territoryName</MudLink> } else { <strong>Unassigned</strong> }</MudText>
                    <MudText Typo="Typo.body2">Quota: <strong>@(sp?.SalesQuota?.ToString("C0") ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Bonus: <strong>@(sp?.Bonus.ToString("C0") ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Commission: <strong>@(sp?.CommissionPct.ToString("P2") ?? "—")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Order summary</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Total orders: <strong>@orderCount.ToString("N0")</strong></MudText>
                    <MudText Typo="Typo.body2">Total revenue: <strong>@totalRevenue.ToString("C0")</strong></MudText>
                    <MudText Typo="Typo.body2">YTD: <strong>@(sp?.SalesYtd.ToString("C0") ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Last year: <strong>@(sp?.SalesLastYear.ToString("C0") ?? "—")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Performance</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    @if (sp?.SalesQuota is > 0)
                    {
                        var attainment = sp.SalesYtd / sp.SalesQuota.Value * 100;
                        <MudText Typo="Typo.body2">Quota attainment: <strong>@attainment.ToString("N1")%</strong></MudText>
                    }
                    <MudText Typo="Typo.body2">Avg order: <strong>@(orderCount > 0 ? (totalRevenue / orderCount).ToString("C0") : "—")</strong></MudText>
                </MudStack>
            </MudItem>
        </MudGrid>

        @if (quotaHistory.Count > 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-1">Quota history</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead><tr><th>Effective date</th><th style="text-align:right">Quota</th></tr></thead>
                <tbody>
                    @foreach (var q in quotaHistory)
                    {
                        <tr><td>@q.QuotaDate.ToString("yyyy-MM-dd")</td><td style="text-align:right">@q.SalesQuota.ToString("C0")</td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        }

        @if (recentOrders.Count > 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-1">Recent orders (last 10)</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead><tr><th>Order #</th><th>Date</th><th style="text-align:right">Total due</th><th>Customer</th></tr></thead>
                <tbody>
                    @foreach (var o in recentOrders)
                    {
                        <tr><td><MudLink Href="aw/sales-order-headers" Color="Color.Primary">@o.OrderNumber</MudLink></td><td>@o.OrderDate.ToString("yyyy-MM-dd")</td><td style="text-align:right">@o.TotalDue.ToString("C2")</td><td><MudLink Href="aw/customers" Color="Color.Primary">@o.CustomerId</MudLink></td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </div>
}

@code {
    [Parameter] public int SalesPersonId { get; set; }

    private bool loading = true;
    private SalesPerson? sp;
    private string? territoryName;
    private int orderCount;
    private decimal totalRevenue;
    private List<SalesPersonQuotaHistory> quotaHistory = [];
    private List<OrderRow> recentOrders = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        sp = await db.SalesPersons.AsNoTracking().FirstOrDefaultAsync(s => s.Id == SalesPersonId);

        if (sp?.TerritoryId.HasValue == true)
        {
            var t = await db.SalesTerritories.AsNoTracking().FirstOrDefaultAsync(t => t.Id == sp.TerritoryId.Value);
            territoryName = t?.Name;
        }

        var orders = await db.SalesOrderHeaders.AsNoTracking()
            .Where(o => o.SalesPersonId == SalesPersonId)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
        orderCount = orders.Count;
        totalRevenue = orders.Sum(o => o.TotalDue);

        quotaHistory = await db.SalesPersonQuotaHistories.AsNoTracking()
            .Where(q => q.BusinessEntityId == SalesPersonId)
            .OrderByDescending(q => q.QuotaDate)
            .ToListAsync();

        recentOrders = orders.Take(10).Select(o => new OrderRow
        {
            OrderNumber = o.SalesOrderNumber,
            OrderDate = o.OrderDate,
            TotalDue = o.TotalDue,
            CustomerId = o.CustomerId,
        }).ToList();

        loading = false;
    }

    private sealed class OrderRow
    {
        public string OrderNumber { get; init; } = "";
        public DateTime OrderDate { get; init; }
        public decimal TotalDue { get; init; }
        public int CustomerId { get; init; }
    }
}
