@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@using AWBlazorApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateDocumentRequest> CreateValidator
@inject MudFormValidator<UpdateDocumentRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create document" : $"Edit document {Model!.DocumentNode}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.DocumentNode" ValueChanged="@((string? v) => createModel = createModel with { DocumentNode = v })" Label="Document node (hierarchyid path, e.g. /1/ or /1/2/)" Variant="Variant.Outlined" Required="true" HelperText="Must be a valid hierarchyid path like /, /1/, /1/2/, etc." />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.Title" ValueChanged="@((string? v) => createModel = createModel with { Title = v })" Label="Title" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.Owner" ValueChanged="@((int v) => createModel = createModel with { Owner = v })" Label="Owner (employee)" Required="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.FileName" ValueChanged="@((string? v) => createModel = createModel with { FileName = v })" Label="File name" Variant="Variant.Outlined" Required="true" MaxLength="400" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField Value="@createModel.FileExtension" ValueChanged="@((string? v) => createModel = createModel with { FileExtension = v })" Label="Extension" Variant="Variant.Outlined" Required="true" MaxLength="8" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField Value="@createModel.Revision" ValueChanged="@((string? v) => createModel = createModel with { Revision = v })" Label="Revision" Variant="Variant.Outlined" Required="true" MaxLength="5" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="int" Value="@createModel.ChangeNumber" ValueChanged="@((int v) => createModel = createModel with { ChangeNumber = v })" Label="Change #" Variant="Variant.Outlined" Min="0" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="byte" Value="@createModel.Status" ValueChanged="@((byte v) => createModel = createModel with { Status = v })" Label="Status (1-3)" Variant="Variant.Outlined" Min="1" Max="3" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch T="bool" Value="@createModel.FolderFlag" ValueChanged="@((bool v) => createModel = createModel with { FolderFlag = v })" Label="Folder?" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.DocumentSummary" ValueChanged="@((string? v) => createModel = createModel with { DocumentSummary = v })" Label="Summary" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.Title" ValueChanged="@((string? v) => updateModel = updateModel with { Title = v })" Label="Title" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@(updateModel.Owner ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { Owner = v == 0 ? null : v })" Label="Owner (employee)" Clearable="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" InitialDisplayText="@_editOwnerDisplay" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.FileName" ValueChanged="@((string? v) => updateModel = updateModel with { FileName = v })" Label="File name" Variant="Variant.Outlined" MaxLength="400" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField Value="@updateModel.FileExtension" ValueChanged="@((string? v) => updateModel = updateModel with { FileExtension = v })" Label="Extension" Variant="Variant.Outlined" MaxLength="8" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudTextField Value="@updateModel.Revision" ValueChanged="@((string? v) => updateModel = updateModel with { Revision = v })" Label="Revision" Variant="Variant.Outlined" MaxLength="5" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="int?" Value="@updateModel.ChangeNumber" ValueChanged="@((int? v) => updateModel = updateModel with { ChangeNumber = v })" Label="Change #" Variant="Variant.Outlined" Clearable="true" Min="0" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField T="byte?" Value="@updateModel.Status" ValueChanged="@((byte? v) => updateModel = updateModel with { Status = v })" Label="Status (1-3)" Variant="Variant.Outlined" Clearable="true" Min="1" Max="3" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch T="bool" Value="@(updateModel.FolderFlag ?? false)" ValueChanged="@((bool v) => updateModel = updateModel with { FolderFlag = v })" Label="Folder?" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.DocumentSummary" ValueChanged="@((string? v) => updateModel = updateModel with { DocumentSummary = v })" Label="Summary" Variant="Variant.Outlined" Lines="3" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DocumentDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateDocumentRequest createModel = new() { Status = 1 };
    private UpdateDocumentRequest updateModel = new();
    private bool saving;
    private string? _editOwnerDisplay;

    protected override async Task OnInitializedAsync()
    {
        if (Model is not null)
        {
            updateModel = new UpdateDocumentRequest
            {
                Title = Model.Title,
                Owner = Model.Owner,
                FolderFlag = Model.FolderFlag,
                FileName = Model.FileName,
                FileExtension = Model.FileExtension,
                Revision = Model.Revision,
                ChangeNumber = Model.ChangeNumber,
                Status = Model.Status,
                DocumentSummary = Model.DocumentSummary,
            };
            if (Model.Owner != 0)
                _editOwnerDisplay = await Lookup.GetEmployeeDisplayAsync(Model.Owner);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var node = HierarchyId.Parse(createModel.DocumentNode!);
                if (await db.Documents.AnyAsync(x => x.DocumentNode == node))
                {
                    Snackbar.Add($"Document with node '{createModel.DocumentNode}' already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.Documents.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                var reloaded = await db.Documents.AsNoTracking().FirstAsync(x => x.DocumentNode == entity.DocumentNode);
                db.DocumentAuditLogs.Add(DocumentAuditService.RecordCreate(reloaded, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var node = HierarchyId.Parse(Model!.DocumentNode);
                var entity = await db.Documents.FirstOrDefaultAsync(t => t.DocumentNode == node);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = DocumentAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.DocumentAuditLogs.Add(DocumentAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
