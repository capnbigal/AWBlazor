@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@using AWBlazorApp.Shared.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateWorkOrderRoutingRequest> CreateValidator
@inject MudFormValidator<UpdateWorkOrderRoutingRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create routing" : "Edit routing")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <FkAutocomplete TValue="int" Value="@createModel.WorkOrderId" ValueChanged="@((int v) => createModel = createModel with { WorkOrderId = v })" SearchFunc="@(q => Lookup.SearchWorkOrdersAsync(q))" Label="Work order" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FkAutocomplete TValue="int" Value="@createModel.ProductId" ValueChanged="@((int v) => createModel = createModel with { ProductId = v })" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Label="Product" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="short" Value="@createModel.OperationSequence" ValueChanged="@((short v) => createModel = createModel with { OperationSequence = v })" Label="Op sequence" Variant="Variant.Outlined" Required="true" Min="1" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FkSelect TValue="short" Value="@createModel.LocationId" ValueChanged="@((short v) => createModel = createModel with { LocationId = v })" Label="Location" Required="true" Items="_locations" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.ScheduledStartDate" DateChanged="@((DateTime? v) => createModel = createModel with { ScheduledStartDate = v ?? DateTime.UtcNow.Date })" Label="Sched start" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.ScheduledEndDate" DateChanged="@((DateTime? v) => createModel = createModel with { ScheduledEndDate = v ?? DateTime.UtcNow.Date })" Label="Sched end" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.ActualStartDate" DateChanged="@((DateTime? v) => createModel = createModel with { ActualStartDate = v })" Label="Actual start" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@createModel.ActualEndDate" DateChanged="@((DateTime? v) => createModel = createModel with { ActualEndDate = v })" Label="Actual end" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal?" Value="@createModel.ActualResourceHrs" ValueChanged="@((decimal? v) => createModel = createModel with { ActualResourceHrs = v })" Label="Actual hrs" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal" Value="@createModel.PlannedCost" ValueChanged="@((decimal v) => createModel = createModel with { PlannedCost = v })" Label="Planned cost" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@createModel.ActualCost" ValueChanged="@((decimal? v) => createModel = createModel with { ActualCost = v })" Label="Actual cost" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <FkSelect TValue="short?" Value="@updateModel.LocationId" ValueChanged="@((short? v) => updateModel = updateModel with { LocationId = v })" Label="Location" Clearable="true" Items="_locationsNullable" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.ScheduledStartDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { ScheduledStartDate = v })" Label="Sched start" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.ScheduledEndDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { ScheduledEndDate = v })" Label="Sched end" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.ActualStartDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { ActualStartDate = v })" Label="Actual start" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Date="@updateModel.ActualEndDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { ActualEndDate = v })" Label="Actual end" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal?" Value="@updateModel.ActualResourceHrs" ValueChanged="@((decimal? v) => updateModel = updateModel with { ActualResourceHrs = v })" Label="Actual hrs" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.PlannedCost" ValueChanged="@((decimal? v) => updateModel = updateModel with { PlannedCost = v })" Label="Planned cost" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.ActualCost" ValueChanged="@((decimal? v) => updateModel = updateModel with { ActualCost = v })" Label="Actual cost" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public WorkOrderRoutingDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateWorkOrderRoutingRequest createModel = new() { ScheduledStartDate = DateTime.UtcNow.Date, ScheduledEndDate = DateTime.UtcNow.Date };
    private UpdateWorkOrderRoutingRequest updateModel = new();
    private bool saving;
    private List<LookupItem<short>> _locations = [];
    private List<LookupItem<short?>> _locationsNullable = [];

    protected override async Task OnInitializedAsync()
    {
        _locations = await Lookup.GetLocationsAsync();
        _locationsNullable = _locations.Select(x => new LookupItem<short?>(x.Id, x.DisplayText)).ToList();

        if (Model is not null)
        {
            updateModel = new UpdateWorkOrderRoutingRequest
            {
                LocationId = Model.LocationId,
                ScheduledStartDate = Model.ScheduledStartDate,
                ScheduledEndDate = Model.ScheduledEndDate,
                ActualStartDate = Model.ActualStartDate,
                ActualEndDate = Model.ActualEndDate,
                ActualResourceHrs = Model.ActualResourceHrs,
                PlannedCost = Model.PlannedCost,
                ActualCost = Model.ActualCost,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate required FKs
                if (!await db.WorkOrders.AnyAsync(x => x.Id == createModel.WorkOrderId))
                { Snackbar.Add($"Work order #{createModel.WorkOrderId} does not exist.", Severity.Error); return; }
                if (!await db.Products.AnyAsync(x => x.Id == createModel.ProductId))
                { Snackbar.Add($"Product #{createModel.ProductId} does not exist.", Severity.Error); return; }
                if (!await db.Locations.AnyAsync(x => x.Id == createModel.LocationId))
                { Snackbar.Add($"Location #{createModel.LocationId} does not exist.", Severity.Error); return; }

                if (await db.WorkOrderRoutings.AnyAsync(x =>
                        x.WorkOrderId == createModel.WorkOrderId
                        && x.ProductId == createModel.ProductId
                        && x.OperationSequence == createModel.OperationSequence))
                {
                    Snackbar.Add("Row already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.WorkOrderRoutings.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.WorkOrderRoutingAuditLogs.Add(WorkOrderRoutingAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.WorkOrderRoutings.FirstOrDefaultAsync(t =>
                    t.WorkOrderId == Model!.WorkOrderId && t.ProductId == Model.ProductId && t.OperationSequence == Model.OperationSequence);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = WorkOrderRoutingAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FK on update
                if (updateModel.LocationId.HasValue && !await db.Locations.AnyAsync(x => x.Id == updateModel.LocationId.Value))
                { Snackbar.Add($"Location #{updateModel.LocationId.Value} does not exist.", Severity.Error); return; }
                db.WorkOrderRoutingAuditLogs.Add(WorkOrderRoutingAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
