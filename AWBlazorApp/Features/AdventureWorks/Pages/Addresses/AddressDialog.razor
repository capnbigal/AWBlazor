@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@using AWBlazorApp.Shared.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateAddressRequest> CreateValidator
@inject MudFormValidator<UpdateAddressRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create address" : $"Edit address #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.AddressLine1" ValueChanged="@((string? v) => createModel = createModel with { AddressLine1 = v })" Label="Address line 1" Variant="Variant.Outlined" Required="true" MaxLength="60" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.AddressLine2" ValueChanged="@((string? v) => createModel = createModel with { AddressLine2 = v })" Label="Address line 2" Variant="Variant.Outlined" MaxLength="60" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.City" ValueChanged="@((string? v) => createModel = createModel with { City = v })" Label="City" Variant="Variant.Outlined" Required="true" MaxLength="30" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="int" Value="@createModel.StateProvinceId" ValueChanged="@((int v) => createModel = createModel with { StateProvinceId = v })" Label="State / province" Required="true" Items="stateProvinceItems" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.PostalCode" ValueChanged="@((string? v) => createModel = createModel with { PostalCode = v })" Label="Postal code" Variant="Variant.Outlined" Required="true" MaxLength="15" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.AddressLine1" ValueChanged="@((string? v) => updateModel = updateModel with { AddressLine1 = v })" Label="Address line 1" Variant="Variant.Outlined" MaxLength="60" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.AddressLine2" ValueChanged="@((string? v) => updateModel = updateModel with { AddressLine2 = v })" Label="Address line 2" Variant="Variant.Outlined" MaxLength="60" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.City" ValueChanged="@((string? v) => updateModel = updateModel with { City = v })" Label="City" Variant="Variant.Outlined" MaxLength="30" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="int" Value="@(updateModel.StateProvinceId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { StateProvinceId = v == 0 ? null : v })" Label="State / province" Clearable="true" Items="stateProvinceItems" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.PostalCode" ValueChanged="@((string? v) => updateModel = updateModel with { PostalCode = v })" Label="Postal code" Variant="Variant.Outlined" MaxLength="15" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public AddressDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateAddressRequest createModel = new();
    private UpdateAddressRequest updateModel = new();
    private bool saving;
    private List<LookupItem<int>> stateProvinceItems = [];

    protected override async Task OnInitializedAsync()
    {
        stateProvinceItems = await Lookup.GetStateProvincesAsync();

        if (Model is not null)
        {
            updateModel = new UpdateAddressRequest
            {
                AddressLine1 = Model.AddressLine1,
                AddressLine2 = Model.AddressLine2,
                City = Model.City,
                StateProvinceId = Model.StateProvinceId,
                PostalCode = Model.PostalCode,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate required FK
                if (!await db.StateProvinces.AnyAsync(x => x.Id == createModel.StateProvinceId))
                { Snackbar.Add($"State/province #{createModel.StateProvinceId} does not exist.", Severity.Error); return; }

                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.Addresses.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.AddressAuditLogs.Add(AddressAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Addresses.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = AddressAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FK on update
                if (updateModel.StateProvinceId.HasValue && !await db.StateProvinces.AnyAsync(x => x.Id == updateModel.StateProvinceId.Value))
                { Snackbar.Add($"State/province #{updateModel.StateProvinceId.Value} does not exist.", Severity.Error); return; }
                db.AddressAuditLogs.Add(AddressAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
