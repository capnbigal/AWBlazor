@page "/analytics/geo"
@attribute [Authorize]
@using AWBlazorApp.Shared.Endpoints
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject ILogger<GeoAnalytics> Logger

<PageTitle>Geographic analytics</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
        <div>
            <MudText Typo="Typo.h4">Geographic customer map</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Person.Address.SpatialLocation plotted on Leaflet + OpenStreetMap. Colored by sales territory.
            </MudText>
        </div>
        <MudSpacer />
        <MudSelect T="int" Label="Territory" @bind-Value="territoryFilter" @bind-Value:after="ReloadAsync"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 240px;">
            <MudSelectItem T="int" Value="0">All territories</MudSelectItem>
            @foreach (var t in territories)
            {
                <MudSelectItem T="int" Value="@t.Id">@t.Name (@t.CountryRegionCode)</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="int" Label="Max markers" @bind-Value="maxMarkers" @bind-Value:after="ReloadAsync"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 160px;">
            <MudSelectItem T="int" Value="500">500</MudSelectItem>
            <MudSelectItem T="int" Value="1000">1,000</MudSelectItem>
            <MudSelectItem T="int" Value="2000">2,000</MudSelectItem>
            <MudSelectItem T="int" Value="5000">5,000</MudSelectItem>
        </MudSelect>
    </MudStack>

    @if (loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-n2">
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@markerCount markers</MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@uniqueTerritories territories</MudChip>
            <MudSpacer />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Click markers for city / territory details.</MudText>
        </MudStack>
    }

    <MudPaper Elevation="2" Style="overflow: hidden; border-radius: 8px;">
        <div id="geo-map" style="height: 560px; width: 100%;"></div>
    </MudPaper>
</MudStack>

@code {
    private const string MapElementId = "geo-map";

    private int territoryFilter;
    private int maxMarkers = 1000;
    private bool loading = true;
    private int markerCount;
    private int uniqueTerritories;
    private List<GeoEndpoints.TerritoryOption> territories = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        territories = await db.SalesTerritories.AsNoTracking()
            .OrderBy(t => t.Name)
            .Select(t => new GeoEndpoints.TerritoryOption(t.Id, t.Name, t.CountryRegionCode))
            .ToListAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // First render is where the map div exists in the DOM.
        if (firstRender) await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        loading = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var take = Math.Clamp(maxMarkers, 1, 10_000);
            var sql = $@"
                SELECT TOP ({take})
                    a.AddressID            AS Id,
                    a.City                 AS City,
                    sp.Name                AS StateProvince,
                    st.TerritoryID         AS TerritoryId,
                    st.Name                AS TerritoryName,
                    a.SpatialLocation.Lat  AS Latitude,
                    a.SpatialLocation.Long AS Longitude
                FROM Person.Address a
                INNER JOIN Person.StateProvince sp ON sp.StateProvinceID = a.StateProvinceID
                INNER JOIN Sales.SalesTerritory  st ON st.TerritoryID     = sp.TerritoryID
                WHERE a.SpatialLocation IS NOT NULL
                {(territoryFilter > 0 ? "AND st.TerritoryID = {0}" : "")}
                ORDER BY a.AddressID";

            var markers = territoryFilter > 0
                ? await db.Database.SqlQueryRaw<GeoEndpoints.AddressMarker>(sql, territoryFilter).ToListAsync()
                : await db.Database.SqlQueryRaw<GeoEndpoints.AddressMarker>(sql).ToListAsync();

            markerCount = markers.Count;
            uniqueTerritories = markers.Select(m => m.TerritoryId).Distinct().Count();

            if (markerCount == 0)
            {
                Snackbar.Add("No geo-tagged addresses found for the current filter.", Severity.Info);
            }

            try
            {
                await JS.InvokeVoidAsync("awLeafletMap.render", MapElementId, markers);
            }
            catch (JSException jsEx)
            {
                Logger.LogWarning(jsEx, "Leaflet render failed");
                Snackbar.Add("Map failed to render: " + jsEx.Message, Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Geo map query failed");
            Snackbar.Add("Map data query failed: " + ex.Message, Severity.Error);
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }
}
