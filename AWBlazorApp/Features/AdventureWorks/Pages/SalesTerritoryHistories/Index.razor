@page "/aw/sales-territory-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Sales territory history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Sales territory history</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.SalesTerritoryHistory · composite PK (BusinessEntityID, StartDate, TerritoryID)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/sales-territory-histories/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New assignment</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => { filterBusinessEntityId = v == 0 ? null : v; })" Label="Sales person" Clearable="true" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" OnSelectionChanged="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><MudNumericField T="int?" @bind-Value="filterTerritoryId" Label="Territory id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="SalesTerritoryHistoryDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Business entity" />
            <PropertyColumn Property="x => x.TerritoryId" Title="Territory" />
            <PropertyColumn Property="x => x.StartDate" Title="Start date" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.EndDate" Title="End date" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SalesTerritoryHistoryDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<SalesTerritoryHistoryDto> grid = null!;
    private int? filterBusinessEntityId;
    private int? filterTerritoryId;

    private async Task<GridData<SalesTerritoryHistoryDto>> LoadServerDataAsync(GridState<SalesTerritoryHistoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesTerritoryHistories.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        if (filterTerritoryId.HasValue) query = query.Where(x => x.TerritoryId == filterTerritoryId.Value);

        var total = await query.CountAsync(ct);
        var rows = await query.OrderBy(x => x.BusinessEntityId).ThenByDescending(x => x.StartDate)
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SalesTerritoryHistoryDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesTerritoryHistoryDialog>("New assignment", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Assignment created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(SalesTerritoryHistoryDto row)
    {
        var parameters = new DialogParameters<SalesTerritoryHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesTerritoryHistoryDialog>($"Edit assignment", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Assignment updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(SalesTerritoryHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete assignment?", $"Permanently delete assignment ({row.BusinessEntityId}, {row.StartDate:d}, {row.TerritoryId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesTerritoryHistories.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.StartDate == row.StartDate && t.TerritoryId == row.TerritoryId);
        if (entity is null) { Snackbar.Add("Assignment no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.SalesTerritoryHistoryAuditLogs.Add(SalesTerritoryHistoryAuditService.RecordDelete(entity, changedBy));
        db.SalesTerritoryHistories.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Assignment deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(SalesTerritoryHistoryDto row) => Navigation.NavigateTo($"aw/sales-territory-histories/history?businessEntityId={row.BusinessEntityId}&startDate={row.StartDate:O}&territoryId={row.TerritoryId}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
