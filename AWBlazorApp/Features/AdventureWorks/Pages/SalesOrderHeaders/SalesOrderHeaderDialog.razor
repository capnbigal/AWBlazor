@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@using AWBlazorApp.Shared.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateSalesOrderHeaderRequest> CreateValidator
@inject MudFormValidator<UpdateSalesOrderHeaderRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create sales order" : $"Edit order #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@createModel.OrderDate" DateChanged="@((DateTime? v) => createModel = createModel with { OrderDate = v ?? DateTime.UtcNow.Date })" Label="Order date" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@createModel.DueDate" DateChanged="@((DateTime? v) => createModel = createModel with { DueDate = v ?? DateTime.UtcNow.Date })" Label="Due date" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@createModel.ShipDate" DateChanged="@((DateTime? v) => createModel = createModel with { ShipDate = v })" Label="Ship date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="byte" Value="@createModel.Status" ValueChanged="@((byte v) => createModel = createModel with { Status = v })" Label="Status" Variant="Variant.Outlined">
                            <MudSelectItem T="byte" Value="1">1 — In process</MudSelectItem>
                            <MudSelectItem T="byte" Value="2">2 — Approved</MudSelectItem>
                            <MudSelectItem T="byte" Value="3">3 — Backordered</MudSelectItem>
                            <MudSelectItem T="byte" Value="4">4 — Rejected</MudSelectItem>
                            <MudSelectItem T="byte" Value="5">5 — Shipped</MudSelectItem>
                            <MudSelectItem T="byte" Value="6">6 — Cancelled</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3"><MudSwitch T="bool" Value="@createModel.OnlineOrderFlag" ValueChanged="@((bool v) => createModel = createModel with { OnlineOrderFlag = v })" Label="Online order" Color="Color.Primary" /></MudItem>
                    <MudItem xs="6" sm="3"><FkAutocomplete TValue="int" Value="@createModel.CustomerId" ValueChanged="@((int v) => createModel = createModel with { CustomerId = v })" Label="Customer" SearchFunc="@(q => Lookup.SearchCustomersAsync(q))" Required="true" /></MudItem>
                    <MudItem xs="6" sm="3"><FkAutocomplete TValue="int" Value="@(createModel.SalesPersonId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { SalesPersonId = v == 0 ? null : v })" Label="Sales person" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" Clearable="true" /></MudItem>
                    <MudItem xs="6" sm="3"><FkSelect TValue="int" Value="@(createModel.TerritoryId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { TerritoryId = v == 0 ? null : v })" Label="Territory" Items="_territories" Clearable="true" /></MudItem>
                    <MudItem xs="6" sm="3"><FkAutocomplete TValue="int" Value="@createModel.BillToAddressId" ValueChanged="@((int v) => createModel = createModel with { BillToAddressId = v })" Label="Bill-to address" SearchFunc="@(q => Lookup.SearchAddressesAsync(q))" Required="true" /></MudItem>
                    <MudItem xs="6" sm="3"><FkAutocomplete TValue="int" Value="@createModel.ShipToAddressId" ValueChanged="@((int v) => createModel = createModel with { ShipToAddressId = v })" Label="Ship-to address" SearchFunc="@(q => Lookup.SearchAddressesAsync(q))" Required="true" /></MudItem>
                    <MudItem xs="6" sm="3"><FkSelect TValue="int" Value="@createModel.ShipMethodId" ValueChanged="@((int v) => createModel = createModel with { ShipMethodId = v })" Label="Ship method" Items="_shipMethods" Required="true" /></MudItem>
                    <MudItem xs="6" sm="3"><FkAutocomplete TValue="int" Value="@(createModel.CreditCardId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { CreditCardId = v == 0 ? null : v })" Label="Credit card" SearchFunc="@(q => Lookup.SearchCreditCardsAsync(q))" Clearable="true" /></MudItem>
                    <MudItem xs="6" sm="3"><FkAutocomplete TValue="int" Value="@(createModel.CurrencyRateId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { CurrencyRateId = v == 0 ? null : v })" Label="Currency rate" SearchFunc="@(q => Lookup.SearchCurrencyRatesAsync(q))" Clearable="true" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal" Value="@createModel.SubTotal" ValueChanged="@((decimal v) => createModel = createModel with { SubTotal = v })" Label="Subtotal" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal" Value="@createModel.TaxAmt" ValueChanged="@((decimal v) => createModel = createModel with { TaxAmt = v })" Label="Tax" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal" Value="@createModel.Freight" ValueChanged="@((decimal v) => createModel = createModel with { Freight = v })" Label="Freight" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12"><MudTextField Value="@createModel.Comment" ValueChanged="@((string? v) => createModel = createModel with { Comment = v })" Label="Comment" Variant="Variant.Outlined" MaxLength="128" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@updateModel.DueDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { DueDate = v })" Label="Due date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@updateModel.ShipDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { ShipDate = v })" Label="Ship date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect T="byte?" Value="@updateModel.Status" ValueChanged="@((byte? v) => updateModel = updateModel with { Status = v })" Label="Status" Variant="Variant.Outlined" Clearable="true">
                            <MudSelectItem T="byte?" Value="@((byte)1)">1 — In process</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@((byte)2)">2 — Approved</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@((byte)3)">3 — Backordered</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@((byte)4)">4 — Rejected</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@((byte)5)">5 — Shipped</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@((byte)6)">6 — Cancelled</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3"><FkAutocomplete TValue="int" Value="@(updateModel.SalesPersonId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { SalesPersonId = v == 0 ? null : v })" Label="Sales person" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" Clearable="true" InitialDisplayText="@_editSalesPersonDisplay" /></MudItem>
                    <MudItem xs="6" sm="3"><FkSelect TValue="int" Value="@(updateModel.ShipMethodId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { ShipMethodId = v == 0 ? null : v })" Label="Ship method" Items="_shipMethods" Clearable="true" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal?" Value="@updateModel.SubTotal" ValueChanged="@((decimal? v) => updateModel = updateModel with { SubTotal = v })" Label="Subtotal" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal?" Value="@updateModel.TaxAmt" ValueChanged="@((decimal? v) => updateModel = updateModel with { TaxAmt = v })" Label="Tax" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal?" Value="@updateModel.Freight" ValueChanged="@((decimal? v) => updateModel = updateModel with { Freight = v })" Label="Freight" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12"><MudTextField Value="@updateModel.Comment" ValueChanged="@((string? v) => updateModel = updateModel with { Comment = v })" Label="Comment" Variant="Variant.Outlined" MaxLength="128" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SalesOrderHeaderDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateSalesOrderHeaderRequest createModel = new() { OrderDate = DateTime.UtcNow.Date, DueDate = DateTime.UtcNow.Date.AddDays(14), Status = 1 };
    private UpdateSalesOrderHeaderRequest updateModel = new();
    private bool saving;

    private List<LookupItem<int>> _territories = [];
    private List<LookupItem<int>> _shipMethods = [];

    // Edit-mode initial display text for autocomplete fields
    private string? _editSalesPersonDisplay;

    protected override async Task OnInitializedAsync()
    {
        _territories = await Lookup.GetSalesTerritoriesAsync();
        _shipMethods = await Lookup.GetShipMethodsAsync();

        if (Model is not null)
        {
            updateModel = new UpdateSalesOrderHeaderRequest
            {
                DueDate = Model.DueDate,
                ShipDate = Model.ShipDate,
                Status = Model.Status,
                SalesPersonId = Model.SalesPersonId,
                ShipMethodId = Model.ShipMethodId,
                SubTotal = Model.SubTotal,
                TaxAmt = Model.TaxAmt,
                Freight = Model.Freight,
                Comment = Model.Comment,
            };

            // Resolve display text for autocomplete fields in edit mode
            if (Model.SalesPersonId.HasValue)
                _editSalesPersonDisplay = await Lookup.GetSalesPersonDisplayAsync(Model.SalesPersonId.Value);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate required FKs
                if (!await db.Customers.AnyAsync(x => x.Id == createModel.CustomerId))
                { Snackbar.Add($"Customer #{createModel.CustomerId} does not exist.", Severity.Error); return; }
                if (!await db.Addresses.AnyAsync(x => x.Id == createModel.BillToAddressId))
                { Snackbar.Add($"Address #{createModel.BillToAddressId} does not exist.", Severity.Error); return; }
                if (!await db.Addresses.AnyAsync(x => x.Id == createModel.ShipToAddressId))
                { Snackbar.Add($"Address #{createModel.ShipToAddressId} does not exist.", Severity.Error); return; }
                if (!await db.ShipMethods.AnyAsync(x => x.Id == createModel.ShipMethodId))
                { Snackbar.Add($"Ship method #{createModel.ShipMethodId} does not exist.", Severity.Error); return; }
                // Validate optional FKs
                if (createModel.SalesPersonId.HasValue && !await db.SalesPersons.AnyAsync(x => x.Id == createModel.SalesPersonId.Value))
                { Snackbar.Add($"Sales person #{createModel.SalesPersonId.Value} does not exist.", Severity.Error); return; }
                if (createModel.TerritoryId.HasValue && !await db.SalesTerritories.AnyAsync(x => x.Id == createModel.TerritoryId.Value))
                { Snackbar.Add($"Territory #{createModel.TerritoryId.Value} does not exist.", Severity.Error); return; }
                if (createModel.CreditCardId.HasValue && !await db.CreditCards.AnyAsync(x => x.Id == createModel.CreditCardId.Value))
                { Snackbar.Add($"Credit card #{createModel.CreditCardId.Value} does not exist.", Severity.Error); return; }
                if (createModel.CurrencyRateId.HasValue && !await db.CurrencyRates.AnyAsync(x => x.Id == createModel.CurrencyRateId.Value))
                { Snackbar.Add($"Currency rate #{createModel.CurrencyRateId.Value} does not exist.", Severity.Error); return; }

                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.SalesOrderHeaders.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                var reloaded = await db.SalesOrderHeaders.AsNoTracking().FirstAsync(x => x.Id == entity.Id);
                db.SalesOrderHeaderAuditLogs.Add(SalesOrderHeaderAuditService.RecordCreate(reloaded, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.SalesOrderHeaders.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = SalesOrderHeaderAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FKs on update
                if (updateModel.SalesPersonId.HasValue && !await db.SalesPersons.AnyAsync(x => x.Id == updateModel.SalesPersonId.Value))
                { Snackbar.Add($"Sales person #{updateModel.SalesPersonId.Value} does not exist.", Severity.Error); return; }
                if (updateModel.ShipMethodId.HasValue && !await db.ShipMethods.AnyAsync(x => x.Id == updateModel.ShipMethodId.Value))
                { Snackbar.Add($"Ship method #{updateModel.ShipMethodId.Value} does not exist.", Severity.Error); return; }
                db.SalesOrderHeaderAuditLogs.Add(SalesOrderHeaderAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
