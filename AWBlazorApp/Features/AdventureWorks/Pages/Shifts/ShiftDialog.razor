@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@using AWBlazorApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateShiftRequest> CreateValidator
@inject MudFormValidator<UpdateShiftRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create shift" : $"Edit shift #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@startText" ValueChanged="@((string? v) => OnStartChanged(v))" Label="Start (hh:mm, 24-hour)" Variant="Variant.Outlined" Required="true" Placeholder="07:00" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@endText" ValueChanged="@((string? v) => OnEndChanged(v))" Label="End (hh:mm, 24-hour)" Variant="Variant.Outlined" Required="true" Placeholder="15:00" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@startText" ValueChanged="@((string? v) => OnStartChanged(v))" Label="Start (hh:mm, 24-hour)" Variant="Variant.Outlined" Required="true" Placeholder="07:00" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@endText" ValueChanged="@((string? v) => OnEndChanged(v))" Label="End (hh:mm, 24-hour)" Variant="Variant.Outlined" Required="true" Placeholder="15:00" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ShiftDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateShiftRequest createModel = new();
    private UpdateShiftRequest updateModel = new();
    private string? startText;
    private string? endText;
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateShiftRequest
            {
                Name = Model.Name,
                StartTime = Model.StartTime,
                EndTime = Model.EndTime,
            };
            startText = Model.StartTime.ToString(@"hh\:mm");
            endText   = Model.EndTime.ToString(@"hh\:mm");
        }
    }

    private void OnStartChanged(string? v)
    {
        startText = v;
        if (TimeSpan.TryParse(v, out var parsed))
        {
            if (IsNew) createModel = createModel with { StartTime = parsed };
            else       updateModel = updateModel with { StartTime = parsed };
        }
    }

    private void OnEndChanged(string? v)
    {
        endText = v;
        if (TimeSpan.TryParse(v, out var parsed))
        {
            if (IsNew) createModel = createModel with { EndTime = parsed };
            else       updateModel = updateModel with { EndTime = parsed };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            if (!TimeSpan.TryParse(startText, out _) || !TimeSpan.TryParse(endText, out _))
            {
                Snackbar.Add("Start and End must be valid hh:mm times.", Severity.Error);
                return;
            }

            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.Shifts.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.ShiftAuditLogs.Add(ShiftAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Shifts.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = ShiftAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.ShiftAuditLogs.Add(ShiftAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
