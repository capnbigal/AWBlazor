@page "/aw/product-model-illustrations"
@attribute [Authorize]
@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Model ↔ illustration</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Model ↔ illustration</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.ProductModelIllustration · composite PK (ProductModelID, IllustrationID)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/product-model-illustrations/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New link</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudNumericField T="int?" @bind-Value="filterProductModelId" Label="Product model id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="ProductModelIllustrationDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ProductModelId" Title="Product model id" />
            <PropertyColumn Property="x => x.IllustrationId" Title="Illustration id" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductModelIllustrationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<ProductModelIllustrationDto> grid = null!;
    private int? filterProductModelId;

    private async Task<GridData<ProductModelIllustrationDto>> LoadServerDataAsync(GridState<ProductModelIllustrationDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductModelIllustrations.AsNoTracking();
        if (filterProductModelId.HasValue) query = query.Where(x => x.ProductModelId == filterProductModelId.Value);

        var total = await query.CountAsync(ct);
        var rows = await query.OrderBy(x => x.ProductModelId).ThenBy(x => x.IllustrationId)
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductModelIllustrationDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductModelIllustrationDialog>("Link a model to an illustration", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Link created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(ProductModelIllustrationDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.ProductModelId}, {row.IllustrationId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductModelIllustrations
            .FirstOrDefaultAsync(t => t.ProductModelId == row.ProductModelId && t.IllustrationId == row.IllustrationId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.ProductModelIllustrationAuditLogs.Add(ProductModelIllustrationAuditService.RecordDelete(entity, changedBy));
        db.ProductModelIllustrations.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Link deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(ProductModelIllustrationDto row)
        => Navigation.NavigateTo($"aw/product-model-illustrations/history?productModelId={row.ProductModelId}&illustrationId={row.IllustrationId}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
