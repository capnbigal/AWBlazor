@page "/aw/business-entities"
@attribute [Authorize]
@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Business entities</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Business entities</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Person.BusinessEntity · root identifier shared by Person, Store, Vendor</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/business-entities/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New business entity</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">
        BusinessEntity is just an integer surrogate key. Creating one allocates the next id;
        it has no editable data of its own. Persons, Stores, and Vendors all share this ID.
    </MudText>

    <MudDataGrid T="BusinessEntityDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" Virtualize="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.RowGuid" Title="Row GUID" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="BusinessEntityDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<BusinessEntityDto> grid = null!;

    private async Task<GridData<BusinessEntityDto>> LoadServerDataAsync(GridState<BusinessEntityDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.BusinessEntities.AsNoTracking();
        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(BusinessEntityDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(BusinessEntityDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                      => query.OrderBy(x => x.Id),
        };
        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<BusinessEntityDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Create business entity?",
            "This allocates a new BusinessEntity row with a fresh id and row GUID. The row has no other editable data.",
            yesText: "Create", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = new CreateBusinessEntityRequest().ToEntity();
        db.BusinessEntities.Add(entity);
        await db.SaveChangesAsync();

        var changedBy = await GetCurrentUserNameAsync();
        db.BusinessEntityAuditLogs.Add(BusinessEntityAuditService.RecordCreate(entity, changedBy));
        await db.SaveChangesAsync();

        Snackbar.Add($"Business entity #{entity.Id} created.", Severity.Success);
        await grid.ReloadServerData();
    }

    private async Task DeleteAsync(BusinessEntityDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete business entity?",
            $"Permanently delete business entity #{row.Id}? This will fail if any Person, Store, or Vendor references it.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BusinessEntities.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Business entity no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.BusinessEntityAuditLogs.Add(BusinessEntityAuditService.RecordDelete(entity, changedBy));
        db.BusinessEntities.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Business entity deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(BusinessEntityDto row) => Navigation.NavigateTo($"aw/business-entities/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
