@page "/aw/currency-rates"
@attribute [Authorize]
@using AWBlazorApp.Features.AdventureWorks.Domain
@using AWBlazorApp.Features.AdventureWorks.Models
@using AWBlazorApp.Features.AdventureWorks.Audit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Currency rates</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Currency rates</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.CurrencyRate</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/currency-rates/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New rate</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterFrom" Label="From currency" Variant="Variant.Outlined" MaxLength="3" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterTo" Label="To currency" Variant="Variant.Outlined" MaxLength="3" OnBlur="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="CurrencyRateDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.CurrencyRateDate" Title="Date" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.FromCurrencyCode" Title="From" />
            <PropertyColumn Property="x => x.ToCurrencyCode" Title="To" />
            <PropertyColumn Property="x => x.AverageRate" Title="Average" Format="N4" />
            <PropertyColumn Property="x => x.EndOfDayRate" Title="End-of-day" Format="N4" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="CurrencyRateDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<CurrencyRateDto> grid = null!;
    private string? filterFrom;
    private string? filterTo;

    private async Task<GridData<CurrencyRateDto>> LoadServerDataAsync(GridState<CurrencyRateDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CurrencyRates.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterFrom))
        {
            var f = filterFrom.Trim();
            query = query.Where(x => x.FromCurrencyCode == f);
        }
        if (!string.IsNullOrWhiteSpace(filterTo))
        {
            var t = filterTo.Trim();
            query = query.Where(x => x.ToCurrencyCode == t);
        }

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CurrencyRateDto.Id)               => sort.Descending ? query.OrderByDescending(x => x.Id)               : query.OrderBy(x => x.Id),
            nameof(CurrencyRateDto.CurrencyRateDate) => sort.Descending ? query.OrderByDescending(x => x.CurrencyRateDate) : query.OrderBy(x => x.CurrencyRateDate),
            _                                        => query.OrderByDescending(x => x.CurrencyRateDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CurrencyRateDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CurrencyRateDialog>("New currency rate", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Currency rate created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(CurrencyRateDto row)
    {
        var parameters = new DialogParameters<CurrencyRateDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CurrencyRateDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Currency rate updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(CurrencyRateDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete currency rate?", $"Permanently delete rate #{row.Id} ({row.FromCurrencyCode}/{row.ToCurrencyCode} on {row.CurrencyRateDate:yyyy-MM-dd})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CurrencyRates.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Rate no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.CurrencyRateAuditLogs.Add(CurrencyRateAuditService.RecordDelete(entity, changedBy));
        db.CurrencyRates.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Currency rate deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(CurrencyRateDto row) => Navigation.NavigateTo($"aw/currency-rates/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
