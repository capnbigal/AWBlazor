@page "/Account/InvalidPasswordReset"

@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Invalid password reset</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" Color="Color.Error" GutterBottom="true">Invalid password reset link</MudText>
        <MudText>This password reset link is missing required parameters. Request a new one from the
            <MudLink Href="Account/ForgotPassword">forgot password</MudLink> page.</MudText>
    </MudPaper>
</MudContainer>
