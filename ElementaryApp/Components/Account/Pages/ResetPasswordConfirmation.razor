@page "/Account/ResetPasswordConfirmation"

@attribute [ExcludeFromInteractiveRouting]

<PageTitle>Password reset</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" GutterBottom="true">Password reset</MudText>
        <MudText>Your password has been reset.
            <MudLink Href="Account/Login">Click here to log in.</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>
