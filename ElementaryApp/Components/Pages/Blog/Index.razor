@page "/blog"
@page "/blog/tag/{tag}"
@using ElementaryApp.Services
@inject MarkdownBlogService Blog

<PageTitle>Blog</PageTitle>

<MudStack Spacing="4">
    <MudText Typo="Typo.h3">Blog</MudText>

    @if (!string.IsNullOrEmpty(Tag))
    {
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled">
            tag: @Tag
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Href="blog" />
        </MudChip>
    }

    @if (posts.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No posts yet.</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var post in posts)
            {
                <MudItem xs="12" md="6">
                    <MudCard>
                        @if (!string.IsNullOrEmpty(post.Image))
                        {
                            <MudCardMedia Image="@post.Image" Height="200" />
                        }
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                @post.Date.ToString("yyyy-MM-dd")
                                @if (!string.IsNullOrEmpty(post.Author)) { <text> &middot; @post.Author</text> }
                            </MudText>
                            <MudText Typo="Typo.h5" GutterBottom="true">
                                <MudLink Href="@($"blog/{post.Slug}")">@post.Title</MudLink>
                            </MudText>
                            @if (!string.IsNullOrEmpty(post.Summary))
                            {
                                <MudText>@post.Summary</MudText>
                            }
                            @if (post.Tags.Count > 0)
                            {
                                <MudStack Row="true" Spacing="1" Class="mt-2">
                                    @foreach (var t in post.Tags)
                                    {
                                        <MudChip T="string" Size="Size.Small" Href="@($"blog/tag/{t}")">@t</MudChip>
                                    }
                                </MudStack>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>

@code {
    [Parameter] public string? Tag { get; set; }

    private IReadOnlyList<BlogPost> posts = [];

    protected override void OnParametersSet()
    {
        posts = string.IsNullOrEmpty(Tag) ? Blog.All : Blog.ByTag(Tag);
    }
}
