@using ElementaryApp.Data.Entities
@using ElementaryApp.Models
@using ElementaryApp.Validators
@using FluentValidation
@inject IDialogService DialogService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateBookingRequest> CreateValidator
@inject MudFormValidator<UpdateBookingRequest> UpdateValidator

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsNew ? "Create booking" : $"Edit booking #{Booking?.Id}")</MudText>
    </TitleContent>
    <DialogContent>
        @if (loadingCoupons)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="createModel.Name"
                                  For="@(() => createModel.Name)"
                                  Label="Name" Variant="Variant.Outlined" Required="true" />

                    <MudSelect T="RoomType" @bind-Value="createModel.RoomType"
                               Label="Room type" Variant="Variant.Outlined">
                        @foreach (var room in Enum.GetValues<RoomType>())
                        {
                            <MudSelectItem Value="@room">@room</MudSelectItem>
                        }
                    </MudSelect>

                    <MudNumericField @bind-Value="createModel.RoomNumber"
                                     For="@(() => createModel.RoomNumber)"
                                     Label="Room number" Variant="Variant.Outlined" Min="1" />

                    <MudNumericField @bind-Value="createModel.Cost"
                                     For="@(() => createModel.Cost)"
                                     Label="Cost (USD)" Variant="Variant.Outlined" Min="0.01m" Format="N2" />

                    <MudDatePicker @bind-Date="createStartDate"
                                   Label="Booking start" Variant="Variant.Outlined" />

                    <MudDatePicker @bind-Date="createEndDate"
                                   Label="Booking end (optional)" Variant="Variant.Outlined" />

                    <MudSelect T="string?" @bind-Value="createModel.CouponId"
                               Label="Coupon (optional)" Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="string?" Value="@((string?)null)">— None —</MudSelectItem>
                        @foreach (var c in coupons)
                        {
                            <MudSelectItem T="string?" Value="@c.Id">@c.Id — @c.Description</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField @bind-Value="createModel.Notes" Label="Notes" Variant="Variant.Outlined" Lines="3" />
                </MudStack>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="updateModel.Name"
                                  Label="Name" Variant="Variant.Outlined" />

                    <MudSelect T="RoomType?" @bind-Value="updateModel.RoomType"
                               Label="Room type" Variant="Variant.Outlined">
                        @foreach (var room in Enum.GetValues<RoomType>())
                        {
                            <MudSelectItem T="RoomType?" Value="@((RoomType?)room)">@room</MudSelectItem>
                        }
                    </MudSelect>

                    <MudNumericField @bind-Value="updateModel.RoomNumber"
                                     Label="Room number" Variant="Variant.Outlined" Min="1" />

                    <MudNumericField @bind-Value="updateModel.Cost"
                                     Label="Cost (USD)" Variant="Variant.Outlined" Min="0.01m" Format="N2" />

                    <MudDatePicker @bind-Date="updateStartDate"
                                   Label="Booking start" Variant="Variant.Outlined" />

                    <MudDatePicker @bind-Date="updateEndDate"
                                   Label="Booking end" Variant="Variant.Outlined" />

                    <MudSelect T="string?" @bind-Value="updateModel.CouponId"
                               Label="Coupon" Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="string?" Value="@((string?)null)">— None —</MudSelectItem>
                        @foreach (var c in coupons)
                        {
                            <MudSelectItem T="string?" Value="@c.Id">@c.Id — @c.Description</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField @bind-Value="updateModel.Notes" Label="Notes" Variant="Variant.Outlined" Lines="3" />

                    <MudSwitch T="bool" Value="@(updateModel.Cancelled ?? false)"
                               ValueChanged="@((bool v) => updateModel = updateModel with { Cancelled = v })"
                               Label="Cancelled" Color="Color.Warning" />
                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">
            @(saving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public BookingDto? Booking { get; set; }

    private bool IsNew => Booking is null;

    private MudForm form = null!;
    private CreateBookingRequest createModel = new();
    private UpdateBookingRequest updateModel = new();
    private DateTime? createStartDate = DateTime.Today;
    private DateTime? createEndDate;
    private DateTime? updateStartDate;
    private DateTime? updateEndDate;

    private List<CouponDto> coupons = [];
    private bool loadingCoupons = true;
    private bool saving;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        coupons = await db.Coupons
            .OrderBy(c => c.Id)
            .Select(c => new CouponDto(c.Id, c.Description, c.Discount, c.ExpiryDate))
            .ToListAsync();
        loadingCoupons = false;

        if (Booking is not null)
        {
            updateModel = new UpdateBookingRequest
            {
                Name = Booking.Name,
                RoomType = Booking.RoomType,
                RoomNumber = Booking.RoomNumber,
                Cost = Booking.Cost,
                BookingStartDate = Booking.BookingStartDate,
                BookingEndDate = Booking.BookingEndDate,
                Notes = Booking.Notes,
                CouponId = Booking.CouponId,
                Cancelled = Booking.Cancelled,
            };
            updateStartDate = Booking.BookingStartDate;
            updateEndDate = Booking.BookingEndDate;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            if (IsNew)
            {
                createModel = createModel with
                {
                    BookingStartDate = createStartDate ?? DateTime.UtcNow,
                    BookingEndDate = createEndDate,
                };

                if (!await CreateValidator.ValidateAllAsync(createModel))
                {
                    await form.ValidateAsync();
                    return;
                }

                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                db.Bookings.Add(entity);
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                updateModel = updateModel with
                {
                    BookingStartDate = updateStartDate,
                    BookingEndDate = updateEndDate,
                };

                if (!await UpdateValidator.ValidateAllAsync(updateModel))
                {
                    await form.ValidateAsync();
                    return;
                }

                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Bookings.FirstOrDefaultAsync(b => b.Id == Booking!.Id);
                if (entity is null)
                {
                    MudDialog.Close(DialogResult.Cancel());
                    return;
                }
                updateModel.ApplyTo(entity);
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally
        {
            saving = false;
        }
    }
}
