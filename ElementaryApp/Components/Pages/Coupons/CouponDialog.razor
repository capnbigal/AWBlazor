@using ElementaryApp.Models
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateCouponRequest> CreateValidator
@inject MudFormValidator<UpdateCouponRequest> UpdateValidator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsNew ? "Create coupon" : $"Edit coupon {Coupon?.Id}")</MudText>
    </TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="createModel.Id"
                                  For="@(() => createModel.Id)"
                                  Label="Id (e.g. BOOK10)" Variant="Variant.Outlined" Required="true" />

                    <MudTextField @bind-Value="createModel.Description"
                                  For="@(() => createModel.Description)"
                                  Label="Description" Variant="Variant.Outlined" Required="true" />

                    <MudNumericField @bind-Value="createModel.Discount"
                                     For="@(() => createModel.Discount)"
                                     Label="Discount %" Variant="Variant.Outlined" Min="1" Max="100" />

                    <MudDatePicker @bind-Date="createExpiry"
                                   Label="Expires" Variant="Variant.Outlined" />
                </MudStack>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudStack Spacing="3">
                    <MudTextField Value="@Coupon!.Id" Label="Id" Variant="Variant.Outlined" Disabled="true" />

                    <MudTextField @bind-Value="updateModel.Description"
                                  Label="Description" Variant="Variant.Outlined" />

                    <MudNumericField @bind-Value="updateModel.Discount"
                                     Label="Discount %" Variant="Variant.Outlined" Min="1" Max="100" />

                    <MudDatePicker @bind-Date="updateExpiry"
                                   Label="Expires" Variant="Variant.Outlined" />
                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">
            @(saving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public CouponDto? Coupon { get; set; }

    private bool IsNew => Coupon is null;

    private MudForm form = null!;
    private CreateCouponRequest createModel = new() { ExpiryDate = DateTime.UtcNow.AddDays(30) };
    private UpdateCouponRequest updateModel = new();
    private DateTime? createExpiry = DateTime.UtcNow.AddDays(30);
    private DateTime? updateExpiry;
    private bool saving;

    protected override void OnInitialized()
    {
        if (Coupon is not null)
        {
            updateModel = new UpdateCouponRequest
            {
                Description = Coupon.Description,
                Discount = Coupon.Discount,
                ExpiryDate = Coupon.ExpiryDate,
            };
            updateExpiry = Coupon.ExpiryDate;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            if (IsNew)
            {
                createModel = createModel with { ExpiryDate = createExpiry ?? DateTime.UtcNow.AddDays(30) };

                if (!await CreateValidator.ValidateAllAsync(createModel))
                {
                    await form.ValidateAsync();
                    return;
                }

                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.Coupons.AnyAsync(c => c.Id == createModel.Id))
                {
                    Snackbar.Add($"Coupon {createModel.Id} already exists.", Severity.Error);
                    return;
                }

                db.Coupons.Add(createModel.ToEntity());
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(createModel.Id));
            }
            else
            {
                updateModel = updateModel with { ExpiryDate = updateExpiry };

                if (!await UpdateValidator.ValidateAllAsync(updateModel))
                {
                    await form.ValidateAsync();
                    return;
                }

                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Coupons.FirstOrDefaultAsync(c => c.Id == Coupon!.Id);
                if (entity is null)
                {
                    MudDialog.Close(DialogResult.Cancel());
                    return;
                }
                updateModel.ApplyTo(entity);
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally
        {
            saving = false;
        }
    }
}
