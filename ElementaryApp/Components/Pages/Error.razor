@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h4" Color="Color.Error" GutterBottom="true">An error occurred</MudText>
        <MudText Typo="Typo.body1">An error occurred while processing your request.</MudText>

        @if (ShowRequestId)
        {
            <MudText Class="mt-3"><strong>Request ID:</strong> <code>@RequestId</code></MudText>
        }

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6">Development mode</MudText>
        <MudText Typo="Typo.body2">
            Switching to the Development environment will display more detailed information about the error.
            Do not enable Development on deployed applications &mdash; it can leak sensitive information.
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter] public HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
