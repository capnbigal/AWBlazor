@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateSalesPersonQuotaHistoryRequest> CreateValidator
@inject MudFormValidator<UpdateSalesPersonQuotaHistoryRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create quota row" : $"Edit quota ({Model!.BusinessEntityId}, {Model.QuotaDate:yyyy-MM-dd})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" Value="@createModel.BusinessEntityId" ValueChanged="@((int v) => createModel = createModel with { BusinessEntityId = v })" Label="Sales person id" Variant="Variant.Outlined" Required="true" Min="1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@createModel.QuotaDate" DateChanged="@((DateTime? v) => createModel = createModel with { QuotaDate = v ?? DateTime.UtcNow.Date })" Label="Quota date" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudNumericField T="decimal" Value="@createModel.SalesQuota" ValueChanged="@((decimal v) => createModel = createModel with { SalesQuota = v })" Label="Sales quota" Variant="Variant.Outlined" Required="true" Min="0" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudNumericField T="decimal?" Value="@updateModel.SalesQuota" ValueChanged="@((decimal? v) => updateModel = updateModel with { SalesQuota = v })" Label="Sales quota" Variant="Variant.Outlined" Clearable="true" Min="0" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SalesPersonQuotaHistoryDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateSalesPersonQuotaHistoryRequest createModel = new() { QuotaDate = DateTime.UtcNow.Date };
    private UpdateSalesPersonQuotaHistoryRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateSalesPersonQuotaHistoryRequest { SalesQuota = Model.SalesQuota };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.SalesPersonQuotaHistories.AnyAsync(x =>
                        x.BusinessEntityId == createModel.BusinessEntityId && x.QuotaDate == createModel.QuotaDate))
                {
                    Snackbar.Add("Quota row for that sales person + date already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                db.SalesPersonQuotaHistories.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.SalesPersonQuotaHistoryAuditLogs.Add(SalesPersonQuotaHistoryAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.SalesPersonQuotaHistories
                    .FirstOrDefaultAsync(t => t.BusinessEntityId == Model!.BusinessEntityId && t.QuotaDate == Model.QuotaDate);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = SalesPersonQuotaHistoryAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.SalesPersonQuotaHistoryAuditLogs.Add(SalesPersonQuotaHistoryAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
