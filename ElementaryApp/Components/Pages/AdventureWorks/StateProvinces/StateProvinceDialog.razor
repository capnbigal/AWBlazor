@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateStateProvinceRequest> CreateValidator
@inject MudFormValidator<UpdateStateProvinceRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create state / province" : $"Edit #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@createModel.StateProvinceCode" ValueChanged="@((string? v) => createModel = createModel with { StateProvinceCode = v })" Label="State/prov code" Variant="Variant.Outlined" Required="true" MaxLength="3" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FkSelect TValue="string" Value="@createModel.CountryRegionCode" ValueChanged="@((string v) => createModel = createModel with { CountryRegionCode = v })" Label="Country / region" Required="true" Items="_countryRegions" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FkSelect TValue="int" Value="@createModel.TerritoryId" ValueChanged="@((int v) => createModel = createModel with { TerritoryId = v })" Label="Territory" Required="true" Items="_territories" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch T="bool" Value="@createModel.IsOnlyStateProvinceFlag" ValueChanged="@((bool v) => createModel = createModel with { IsOnlyStateProvinceFlag = v })" Label="Only state/province for the country" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@updateModel.StateProvinceCode" ValueChanged="@((string? v) => updateModel = updateModel with { StateProvinceCode = v })" Label="State/prov code" Variant="Variant.Outlined" Required="true" MaxLength="3" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FkSelect TValue="string?" Value="@updateModel.CountryRegionCode" ValueChanged="@((string? v) => updateModel = updateModel with { CountryRegionCode = v })" Label="Country / region" Clearable="true" Items="_countryRegionsNullable" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FkSelect TValue="int?" Value="@updateModel.TerritoryId" ValueChanged="@((int? v) => updateModel = updateModel with { TerritoryId = v })" Label="Territory" Clearable="true" Items="_territoriesNullable" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch T="bool" Value="@(updateModel.IsOnlyStateProvinceFlag ?? false)" ValueChanged="@((bool v) => updateModel = updateModel with { IsOnlyStateProvinceFlag = v })" Label="Only state/province for the country" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public StateProvinceDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateStateProvinceRequest createModel = new();
    private UpdateStateProvinceRequest updateModel = new();
    private bool saving;
    private List<LookupItem<int>> _territories = [];
    private List<LookupItem<int?>> _territoriesNullable = [];
    private List<LookupItem<string>> _countryRegions = [];
    private List<LookupItem<string?>> _countryRegionsNullable = [];

    protected override async Task OnInitializedAsync()
    {
        _territories = await Lookup.GetSalesTerritoriesAsync();
        _territoriesNullable = _territories.Select(x => new LookupItem<int?>(x.Id, x.DisplayText)).ToList();
        _countryRegions = await Lookup.GetCountryRegionsAsync();
        _countryRegionsNullable = _countryRegions.Select(x => new LookupItem<string?>(x.Id, x.DisplayText)).ToList();
    }

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateStateProvinceRequest
            {
                StateProvinceCode = Model.StateProvinceCode,
                CountryRegionCode = Model.CountryRegionCode,
                IsOnlyStateProvinceFlag = Model.IsOnlyStateProvinceFlag,
                Name = Model.Name,
                TerritoryId = Model.TerritoryId,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                db.StateProvinces.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.StateProvinceAuditLogs.Add(StateProvinceAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.StateProvinces.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = StateProvinceAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.StateProvinceAuditLogs.Add(StateProvinceAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
