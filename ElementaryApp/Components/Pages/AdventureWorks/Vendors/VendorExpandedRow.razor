@using ElementaryApp.Data.Entities.AdventureWorks
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="my-2" />
}
else
{
    <div class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Vendor info</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Credit rating: <strong>@(vendor?.CreditRating ?? 0) / 5</strong></MudText>
                    <MudText Typo="Typo.body2">Preferred: <strong>@(vendor?.PreferredVendorStatus == true ? "Yes" : "No")</strong></MudText>
                    <MudText Typo="Typo.body2">Active: <strong>@(vendor?.ActiveFlag == true ? "Yes" : "No")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Purchase order summary</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Total POs: <strong>@poCount.ToString("N0")</strong></MudText>
                    <MudText Typo="Typo.body2">Total spend: <strong>@totalSpend.ToString("C2")</strong></MudText>
                    <MudText Typo="Typo.body2">Avg PO value: <strong>@(poCount > 0 ? (totalSpend / poCount).ToString("C2") : "—")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Products supplied</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Distinct products: <strong>@productCount.ToString("N0")</strong></MudText>
                </MudStack>
            </MudItem>
        </MudGrid>

        @if (recentPos.Count > 0)
        {
            <MudText Typo="Typo.subtitle1" Class="mt-3 mb-1">Recent purchase orders (last 10)</MudText>
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead><tr><th>PO #</th><th>Date</th><th>Status</th><th style="text-align:right">Subtotal</th><th style="text-align:right">Total due</th></tr></thead>
                <tbody>
                    @foreach (var po in recentPos)
                    {
                        <tr><td><MudLink Href="aw/purchase-order-headers" Color="Color.Primary">@po.Id</MudLink></td><td>@po.OrderDate.ToString("yyyy-MM-dd")</td><td>@po.Status</td><td style="text-align:right">@po.SubTotal.ToString("C2")</td><td style="text-align:right">@po.TotalDue.ToString("C2")</td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </div>
}

@code {
    [Parameter] public int VendorId { get; set; }

    private bool loading = true;
    private Vendor? vendor;
    private int poCount;
    private decimal totalSpend;
    private int productCount;
    private List<PoRow> recentPos = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        vendor = await db.Vendors.AsNoTracking().FirstOrDefaultAsync(v => v.Id == VendorId);

        var pos = await db.PurchaseOrderHeaders.AsNoTracking()
            .Where(p => p.VendorId == VendorId)
            .OrderByDescending(p => p.OrderDate)
            .ToListAsync();
        poCount = pos.Count;
        totalSpend = pos.Sum(p => p.TotalDue);

        productCount = await db.ProductVendors.AsNoTracking()
            .Where(pv => pv.BusinessEntityId == VendorId)
            .Select(pv => pv.ProductId)
            .Distinct()
            .CountAsync();

        recentPos = pos.Take(10).Select(p => new PoRow { Id = p.Id, OrderDate = p.OrderDate, Status = p.Status, SubTotal = p.SubTotal, TotalDue = p.TotalDue }).ToList();
        loading = false;
    }

    private sealed class PoRow
    {
        public int Id { get; init; }
        public DateTime OrderDate { get; init; }
        public byte Status { get; init; }
        public decimal SubTotal { get; init; }
        public decimal TotalDue { get; init; }
    }
}
