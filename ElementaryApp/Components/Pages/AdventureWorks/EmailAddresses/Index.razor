@page "/aw/email-addresses"
@attribute [Authorize]
@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Email addresses</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Email addresses</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Person.EmailAddress · composite PK (BusinessEntityID, EmailAddressID)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/email-addresses/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New email</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><MudNumericField T="int?" @bind-Value="filterBusinessEntityId" Label="Person id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterEmail" Label="Email contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="EmailAddressDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single">
        <Columns>
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Person id" />
            <PropertyColumn Property="x => x.EmailAddressId" Title="Email id" />
            <PropertyColumn Property="x => x.EmailAddressValue" Title="Email" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="EmailAddressDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<EmailAddressDto> grid = null!;
    private int? filterBusinessEntityId;
    private string? filterEmail;

    private async Task<GridData<EmailAddressDto>> LoadServerDataAsync(GridState<EmailAddressDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.EmailAddresses.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        if (!string.IsNullOrWhiteSpace(filterEmail))
        {
            var n = filterEmail.Trim();
            query = query.Where(x => x.EmailAddressValue != null && x.EmailAddressValue.Contains(n));
        }

        var total = await query.CountAsync(ct);
        var rows = await query.OrderBy(x => x.BusinessEntityId).ThenBy(x => x.EmailAddressId)
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<EmailAddressDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<EmailAddressDialog>("New email", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Email created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(EmailAddressDto row)
    {
        var parameters = new DialogParameters<EmailAddressDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<EmailAddressDialog>($"Edit ({row.BusinessEntityId}, {row.EmailAddressId})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Email updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(EmailAddressDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete email?", $"Permanently delete email ({row.BusinessEntityId}, {row.EmailAddressId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.EmailAddresses.FirstOrDefaultAsync(t =>
            t.BusinessEntityId == row.BusinessEntityId && t.EmailAddressId == row.EmailAddressId);
        if (entity is null) { Snackbar.Add("Email no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.EmailAddressAuditLogs.Add(EmailAddressAuditService.RecordDelete(entity, changedBy));
        db.EmailAddresses.Remove(entity);
        await db.SaveChangesAsync();
        Snackbar.Add("Email deleted.", Severity.Success);
        await grid.ReloadServerData();
    }

    private void OpenHistory(EmailAddressDto row)
        => Navigation.NavigateTo($"aw/email-addresses/history?businessEntityId={row.BusinessEntityId}&emailAddressId={row.EmailAddressId}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
