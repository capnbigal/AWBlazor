@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateSalesOrderHeaderSalesReasonRequest> CreateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">Link a sales reason to an order</MudText></TitleContent>
    <DialogContent>
        <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int" Value="@createModel.SalesOrderId" ValueChanged="@((int v) => createModel = createModel with { SalesOrderId = v })" Label="Sales order id" Variant="Variant.Outlined" Required="true" Min="1" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int" Value="@createModel.SalesReasonId" ValueChanged="@((int v) => createModel = createModel with { SalesReasonId = v })" Label="Sales reason id" Variant="Variant.Outlined" Required="true" Min="1" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm form = null!;
    private CreateSalesOrderHeaderSalesReasonRequest createModel = new();
    private bool saving;

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }

            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.SalesOrderHeaderSalesReasons.AnyAsync(x =>
                    x.SalesOrderId == createModel.SalesOrderId && x.SalesReasonId == createModel.SalesReasonId))
            {
                Snackbar.Add("Link already exists.", Severity.Error);
                return;
            }

            var changedBy = await GetCurrentUserNameAsync();
            var entity = createModel.ToEntity();
            db.SalesOrderHeaderSalesReasons.Add(entity);
            try
            {
                await db.SaveChangesAsync();
            }
            catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
            {
                Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                return;
            }
            db.SalesOrderHeaderSalesReasonAuditLogs.Add(SalesOrderHeaderSalesReasonAuditService.RecordCreate(entity, changedBy));
            await db.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
