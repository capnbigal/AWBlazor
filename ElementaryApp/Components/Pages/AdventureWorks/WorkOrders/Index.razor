@page "/aw/work-orders"
@attribute [Authorize]
@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Work orders</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Work orders</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.WorkOrder</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/work-orders/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New work order</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudNumericField T="int?" @bind-Value="filterProductId" Label="Product id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="WorkOrderDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" Virtualize="true" SortMode="SortMode.Single">
        <Columns>
            <HierarchyColumn T="WorkOrderDto" />
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.ProductId" Title="Product id" />
            <PropertyColumn Property="x => x.OrderQty" Title="Order qty" />
            <PropertyColumn Property="x => x.ScrappedQty" Title="Scrapped" />
            <PropertyColumn Property="x => x.StockedQty" Title="Stocked" />
            <PropertyColumn Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.DueDate" Title="Due" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.EndDate" Title="End" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.ScrapReasonId" Title="Scrap reason" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent>
            <WorkOrderExpandedRow WorkOrderId="@context.Item.Id" />
        </ChildRowContent>
        <PagerContent><MudDataGridPager T="WorkOrderDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<WorkOrderDto> grid = null!;
    private int? filterProductId;

    private async Task<GridData<WorkOrderDto>> LoadServerDataAsync(GridState<WorkOrderDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.WorkOrders.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(WorkOrderDto.Id)        => sort.Descending ? query.OrderByDescending(x => x.Id)        : query.OrderBy(x => x.Id),
            nameof(WorkOrderDto.ProductId) => sort.Descending ? query.OrderByDescending(x => x.ProductId) : query.OrderBy(x => x.ProductId),
            nameof(WorkOrderDto.StartDate) => sort.Descending ? query.OrderByDescending(x => x.StartDate) : query.OrderBy(x => x.StartDate),
            nameof(WorkOrderDto.DueDate)   => sort.Descending ? query.OrderByDescending(x => x.DueDate)   : query.OrderBy(x => x.DueDate),
            _                              => query.OrderByDescending(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<WorkOrderDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<WorkOrderDialog>("New work order", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Work order created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(WorkOrderDto row)
    {
        var parameters = new DialogParameters<WorkOrderDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<WorkOrderDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Work order updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(WorkOrderDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete work order?", $"Permanently delete work order #{row.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.WorkOrders.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Work order no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.WorkOrderAuditLogs.Add(WorkOrderAuditService.RecordDelete(entity, changedBy));
        db.WorkOrders.Remove(entity);
        await db.SaveChangesAsync();
        Snackbar.Add("Work order deleted.", Severity.Success);
        await grid.ReloadServerData();
    }

    private void OpenHistory(WorkOrderDto row) => Navigation.NavigateTo($"aw/work-orders/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
