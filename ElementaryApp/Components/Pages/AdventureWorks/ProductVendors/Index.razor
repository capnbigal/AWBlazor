@page "/aw/product-vendors"
@attribute [Authorize]
@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Product vendors</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Product vendors</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Purchasing.ProductVendor · composite PK (ProductID, BusinessEntityID)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/product-vendors/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New product vendor</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => { filterProductId = v == 0 ? null : v; })" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => { filterBusinessEntityId = v == 0 ? null : v; })" Label="Vendor" SearchFunc="@(q => Lookup.SearchVendorsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="ProductVendorDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single">
        <Columns>
            <PropertyColumn Property="x => x.ProductId" Title="Product" />
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Vendor" />
            <PropertyColumn Property="x => x.AverageLeadTime" Title="Lead time" />
            <PropertyColumn Property="x => x.StandardPrice" Title="Std price" Format="C2" />
            <PropertyColumn Property="x => x.MinOrderQty" Title="Min qty" />
            <PropertyColumn Property="x => x.MaxOrderQty" Title="Max qty" />
            <PropertyColumn Property="x => x.UnitMeasureCode" Title="UoM" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductVendorDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<ProductVendorDto> grid = null!;
    private int? filterProductId;
    private int? filterBusinessEntityId;

    private async Task<GridData<ProductVendorDto>> LoadServerDataAsync(GridState<ProductVendorDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductVendors.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);

        var total = await query.CountAsync(ct);
        var rows = await query.OrderBy(x => x.ProductId).ThenBy(x => x.BusinessEntityId)
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductVendorDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductVendorDialog>("New product vendor", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Product vendor created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(ProductVendorDto row)
    {
        var parameters = new DialogParameters<ProductVendorDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductVendorDialog>($"Edit ({row.ProductId}, {row.BusinessEntityId})", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Product vendor updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(ProductVendorDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete product vendor?", $"Permanently delete product vendor ({row.ProductId}, {row.BusinessEntityId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductVendors.FirstOrDefaultAsync(t => t.ProductId == row.ProductId && t.BusinessEntityId == row.BusinessEntityId);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.ProductVendorAuditLogs.Add(ProductVendorAuditService.RecordDelete(entity, changedBy));
        db.ProductVendors.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Product vendor deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(ProductVendorDto row)
        => Navigation.NavigateTo($"aw/product-vendors/history?productId={row.ProductId}&businessEntityId={row.BusinessEntityId}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
