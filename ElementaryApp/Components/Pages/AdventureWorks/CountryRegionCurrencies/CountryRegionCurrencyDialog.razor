@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateCountryRegionCurrencyRequest> CreateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">Link a currency to a country</MudText></TitleContent>
    <DialogContent>
        <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@createModel.CountryRegionCode" ValueChanged="@((string? v) => createModel = createModel with { CountryRegionCode = v })" Label="Country code" Variant="Variant.Outlined" Required="true" MaxLength="3" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@createModel.CurrencyCode" ValueChanged="@((string? v) => createModel = createModel with { CurrencyCode = v })" Label="Currency code" Variant="Variant.Outlined" Required="true" MaxLength="3" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm form = null!;
    private CreateCountryRegionCurrencyRequest createModel = new();
    private bool saving;

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }

            var crc = (createModel.CountryRegionCode ?? string.Empty).Trim();
            var cur = (createModel.CurrencyCode ?? string.Empty).Trim();

            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.CountryRegionCurrencies.AnyAsync(x => x.CountryRegionCode == crc && x.CurrencyCode == cur))
            {
                Snackbar.Add("Link already exists.", Severity.Error);
                return;
            }

            var changedBy = await GetCurrentUserNameAsync();
            var entity = createModel.ToEntity();
            db.CountryRegionCurrencies.Add(entity);
            try
            {
                await db.SaveChangesAsync();
            }
            catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
            {
                Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                return;
            }
            db.CountryRegionCurrencyAuditLogs.Add(CountryRegionCurrencyAuditService.RecordCreate(entity, changedBy));
            await db.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
