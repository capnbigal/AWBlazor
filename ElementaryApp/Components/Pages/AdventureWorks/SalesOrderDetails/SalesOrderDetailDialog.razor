@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateSalesOrderDetailRequest> CreateValidator
@inject MudFormValidator<UpdateSalesOrderDetailRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create order detail" : $"Edit detail ({Model!.SalesOrderId}, {Model.SalesOrderDetailId})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@createModel.SalesOrderId" ValueChanged="@((int v) => createModel = createModel with { SalesOrderId = v })" Label="Sales order" SearchFunc="Lookup.SearchSalesOrdersAsync" Required="true" /></MudItem>
                    <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@createModel.ProductId" ValueChanged="@((int v) => createModel = createModel with { ProductId = v })" Label="Product" SearchFunc="Lookup.SearchProductsAsync" Required="true" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="short" Value="@createModel.OrderQty" ValueChanged="@((short v) => createModel = createModel with { OrderQty = v })" Label="Order qty" Variant="Variant.Outlined" Required="true" Min="1" /></MudItem>
                    <MudItem xs="6" sm="3"><FkSelect TValue="int" Value="@createModel.SpecialOfferId" ValueChanged="@((int v) => createModel = createModel with { SpecialOfferId = v })" Label="Special offer" Items="_specialOffers" Required="true" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal" Value="@createModel.UnitPrice" ValueChanged="@((decimal v) => createModel = createModel with { UnitPrice = v })" Label="Unit price" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="decimal" Value="@createModel.UnitPriceDiscount" ValueChanged="@((decimal v) => createModel = createModel with { UnitPriceDiscount = v })" Label="Discount" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12"><MudTextField Value="@createModel.CarrierTrackingNumber" ValueChanged="@((string? v) => createModel = createModel with { CarrierTrackingNumber = v })" Label="Carrier tracking #" Variant="Variant.Outlined" MaxLength="25" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="6"><MudNumericField T="short?" Value="@updateModel.OrderQty" ValueChanged="@((short? v) => updateModel = updateModel with { OrderQty = v })" Label="Order qty" Variant="Variant.Outlined" Clearable="true" Min="1" /></MudItem>
                    <MudItem xs="6"><MudNumericField T="decimal?" Value="@updateModel.UnitPrice" ValueChanged="@((decimal? v) => updateModel = updateModel with { UnitPrice = v })" Label="Unit price" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="6"><MudNumericField T="decimal?" Value="@updateModel.UnitPriceDiscount" ValueChanged="@((decimal? v) => updateModel = updateModel with { UnitPriceDiscount = v })" Label="Discount" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12"><MudTextField Value="@updateModel.CarrierTrackingNumber" ValueChanged="@((string? v) => updateModel = updateModel with { CarrierTrackingNumber = v })" Label="Carrier tracking #" Variant="Variant.Outlined" MaxLength="25" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SalesOrderDetailDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateSalesOrderDetailRequest createModel = new() { OrderQty = 1, SpecialOfferId = 1 };
    private UpdateSalesOrderDetailRequest updateModel = new();
    private bool saving;
    private List<LookupItem<int>> _specialOffers = [];

    protected override async Task OnInitializedAsync()
    {
        _specialOffers = await Lookup.GetSpecialOffersAsync();

        if (Model is not null)
        {
            updateModel = new UpdateSalesOrderDetailRequest
            {
                CarrierTrackingNumber = Model.CarrierTrackingNumber,
                OrderQty = Model.OrderQty,
                UnitPrice = Model.UnitPrice,
                UnitPriceDiscount = Model.UnitPriceDiscount,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate required FKs
                if (!await db.SalesOrderHeaders.AnyAsync(x => x.Id == createModel.SalesOrderId))
                { Snackbar.Add($"Sales order #{createModel.SalesOrderId} does not exist.", Severity.Error); return; }
                if (!await db.Products.AnyAsync(x => x.Id == createModel.ProductId))
                { Snackbar.Add($"Product #{createModel.ProductId} does not exist.", Severity.Error); return; }
                if (!await db.SpecialOffers.AnyAsync(x => x.Id == createModel.SpecialOfferId))
                { Snackbar.Add($"Special offer #{createModel.SpecialOfferId} does not exist.", Severity.Error); return; }

                var entity = createModel.ToEntity();
                db.SalesOrderDetails.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                var reloaded = await db.SalesOrderDetails.AsNoTracking().FirstAsync(x => x.SalesOrderId == entity.SalesOrderId && x.SalesOrderDetailId == entity.SalesOrderDetailId);
                db.SalesOrderDetailAuditLogs.Add(SalesOrderDetailAuditService.RecordCreate(reloaded, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.SalesOrderDetails.FirstOrDefaultAsync(t => t.SalesOrderId == Model!.SalesOrderId && t.SalesOrderDetailId == Model.SalesOrderDetailId);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = SalesOrderDetailAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.SalesOrderDetailAuditLogs.Add(SalesOrderDetailAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
