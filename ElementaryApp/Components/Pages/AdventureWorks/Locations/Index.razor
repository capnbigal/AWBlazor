@page "/aw/locations"
@attribute [Authorize]
@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Locations</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Locations</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.Location</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/locations/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New location</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="LocationDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.CostRate" Title="Cost rate" Format="C" />
            <PropertyColumn Property="x => x.Availability" Title="Availability" Format="0.00" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History">
                            <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" />
                        </MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="LocationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<LocationDto> grid = null!;
    private string? filterName;

    private async Task<GridData<LocationDto>> LoadServerDataAsync(GridState<LocationDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Locations.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var needle = filterName.Trim();
            query = query.Where(x => x.Name.Contains(needle));
        }

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(LocationDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(LocationDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
            nameof(LocationDto.CostRate)     => sort.Descending ? query.OrderByDescending(x => x.CostRate)     : query.OrderBy(x => x.CostRate),
            nameof(LocationDto.Availability) => sort.Descending ? query.OrderByDescending(x => x.Availability) : query.OrderBy(x => x.Availability),
            nameof(LocationDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<LocationDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<LocationDialog>("New location", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Location created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(LocationDto row)
    {
        var parameters = new DialogParameters<LocationDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<LocationDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Location updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(LocationDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete location?", $"Permanently delete location #{row.Id} \"{row.Name}\"?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Locations.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Location no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.LocationAuditLogs.Add(LocationAuditService.RecordDelete(entity, changedBy));
        db.Locations.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Location deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(LocationDto row) => Navigation.NavigateTo($"aw/locations/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
