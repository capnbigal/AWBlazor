@page "/aw/country-regions"
@attribute [Authorize]
@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Country / region codes</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Country / region codes</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Person.CountryRegion</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/country-regions/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New country / region</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterCode" Label="Code" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="CountryRegionDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single">
        <Columns>
            <PropertyColumn Property="x => x.CountryRegionCode" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History">
                            <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" />
                        </MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="CountryRegionDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<CountryRegionDto> grid = null!;
    private string? filterCode;
    private string? filterName;

    private async Task<GridData<CountryRegionDto>> LoadServerDataAsync(GridState<CountryRegionDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CountryRegions.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCode))
        {
            var needle = filterCode.Trim();
            query = query.Where(x => x.CountryRegionCode == needle);
        }
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var needle = filterName.Trim();
            query = query.Where(x => x.Name.Contains(needle));
        }

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CountryRegionDto.CountryRegionCode) => sort.Descending ? query.OrderByDescending(x => x.CountryRegionCode) : query.OrderBy(x => x.CountryRegionCode),
            nameof(CountryRegionDto.Name)              => sort.Descending ? query.OrderByDescending(x => x.Name)              : query.OrderBy(x => x.Name),
            nameof(CountryRegionDto.ModifiedDate)      => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)      : query.OrderBy(x => x.ModifiedDate),
            _                                          => query.OrderBy(x => x.CountryRegionCode),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CountryRegionDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CountryRegionDialog>("New country / region", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Country / region created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(CountryRegionDto row)
    {
        var parameters = new DialogParameters<CountryRegionDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CountryRegionDialog>($"Edit {row.CountryRegionCode}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Country / region updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(CountryRegionDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete country / region?", $"Permanently delete {row.CountryRegionCode} ({row.Name})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CountryRegions.FirstOrDefaultAsync(t => t.CountryRegionCode == row.CountryRegionCode);
        if (entity is null) { Snackbar.Add("Country / region no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.CountryRegionAuditLogs.Add(CountryRegionAuditService.RecordDelete(entity, changedBy));
        db.CountryRegions.Remove(entity);
        await db.SaveChangesAsync();
        Snackbar.Add("Country / region deleted.", Severity.Success);
        await grid.ReloadServerData();
    }

    private void OpenHistory(CountryRegionDto row) => Navigation.NavigateTo($"aw/country-regions/history/{row.CountryRegionCode}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
