@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreatePurchaseOrderHeaderRequest> CreateValidator
@inject MudFormValidator<UpdatePurchaseOrderHeaderRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create PO" : $"Edit PO #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4"><MudNumericField T="int" Value="@createModel.EmployeeId" ValueChanged="@((int v) => createModel = createModel with { EmployeeId = v })" Label="Employee id" Variant="Variant.Outlined" Required="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int" Value="@createModel.VendorId" ValueChanged="@((int v) => createModel = createModel with { VendorId = v })" Label="Vendor id" Variant="Variant.Outlined" Required="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int" Value="@createModel.ShipMethodId" ValueChanged="@((int v) => createModel = createModel with { ShipMethodId = v })" Label="Ship method id" Variant="Variant.Outlined" Required="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="byte" Value="@createModel.Status" ValueChanged="@((byte v) => createModel = createModel with { Status = v })" Label="Status (1-4)" Variant="Variant.Outlined" Min="1" Max="4" /></MudItem>
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@createModel.OrderDate" DateChanged="@((DateTime? v) => createModel = createModel with { OrderDate = v ?? DateTime.UtcNow.Date })" Label="Order date" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="12" sm="4"><MudDatePicker Date="@createModel.ShipDate" DateChanged="@((DateTime? v) => createModel = createModel with { ShipDate = v })" Label="Ship date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal" Value="@createModel.SubTotal" ValueChanged="@((decimal v) => createModel = createModel with { SubTotal = v })" Label="Subtotal" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal" Value="@createModel.TaxAmt" ValueChanged="@((decimal v) => createModel = createModel with { TaxAmt = v })" Label="Tax" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal" Value="@createModel.Freight" ValueChanged="@((decimal v) => createModel = createModel with { Freight = v })" Label="Freight" Variant="Variant.Outlined" Min="0" Step="0.01M" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4"><MudNumericField T="byte?" Value="@updateModel.Status" ValueChanged="@((byte? v) => updateModel = updateModel with { Status = v })" Label="Status (1-4)" Variant="Variant.Outlined" Clearable="true" Min="1" Max="4" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int?" Value="@updateModel.VendorId" ValueChanged="@((int? v) => updateModel = updateModel with { VendorId = v })" Label="Vendor id" Variant="Variant.Outlined" Clearable="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="int?" Value="@updateModel.ShipMethodId" ValueChanged="@((int? v) => updateModel = updateModel with { ShipMethodId = v })" Label="Ship method id" Variant="Variant.Outlined" Clearable="true" Min="1" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal?" Value="@updateModel.SubTotal" ValueChanged="@((decimal? v) => updateModel = updateModel with { SubTotal = v })" Label="Subtotal" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal?" Value="@updateModel.TaxAmt" ValueChanged="@((decimal? v) => updateModel = updateModel with { TaxAmt = v })" Label="Tax" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="4"><MudNumericField T="decimal?" Value="@updateModel.Freight" ValueChanged="@((decimal? v) => updateModel = updateModel with { Freight = v })" Label="Freight" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" /></MudItem>
                    <MudItem xs="12" sm="6"><MudDatePicker Date="@updateModel.ShipDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { ShipDate = v })" Label="Ship date" Variant="Variant.Outlined" Clearable="true" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public PurchaseOrderHeaderDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreatePurchaseOrderHeaderRequest createModel = new() { Status = 1, OrderDate = DateTime.UtcNow.Date };
    private UpdatePurchaseOrderHeaderRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
            updateModel = new UpdatePurchaseOrderHeaderRequest
            {
                Status = Model.Status,
                EmployeeId = Model.EmployeeId,
                VendorId = Model.VendorId,
                ShipMethodId = Model.ShipMethodId,
                SubTotal = Model.SubTotal,
                TaxAmt = Model.TaxAmt,
                Freight = Model.Freight,
                ShipDate = Model.ShipDate,
            };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();

                // Validate required FKs
                if (!await db.Employees.AnyAsync(x => x.Id == createModel.EmployeeId))
                { Snackbar.Add($"Employee #{createModel.EmployeeId} does not exist.", Severity.Error); return; }
                if (!await db.Vendors.AnyAsync(x => x.Id == createModel.VendorId))
                { Snackbar.Add($"Vendor #{createModel.VendorId} does not exist.", Severity.Error); return; }
                if (!await db.ShipMethods.AnyAsync(x => x.Id == createModel.ShipMethodId))
                { Snackbar.Add($"Ship method #{createModel.ShipMethodId} does not exist.", Severity.Error); return; }

                var entity = createModel.ToEntity();
                db.PurchaseOrderHeaders.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.PurchaseOrderHeaderAuditLogs.Add(PurchaseOrderHeaderAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.PurchaseOrderHeaders.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = PurchaseOrderHeaderAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                // Validate optional FKs on update
                if (updateModel.VendorId.HasValue && !await db.Vendors.AnyAsync(x => x.Id == updateModel.VendorId.Value))
                { Snackbar.Add($"Vendor #{updateModel.VendorId.Value} does not exist.", Severity.Error); return; }
                if (updateModel.ShipMethodId.HasValue && !await db.ShipMethods.AnyAsync(x => x.Id == updateModel.ShipMethodId.Value))
                { Snackbar.Add($"Ship method #{updateModel.ShipMethodId.Value} does not exist.", Severity.Error); return; }
                db.PurchaseOrderHeaderAuditLogs.Add(PurchaseOrderHeaderAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
