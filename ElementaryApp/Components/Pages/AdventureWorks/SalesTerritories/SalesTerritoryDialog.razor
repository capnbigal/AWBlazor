@using ElementaryApp.Data.Entities.AdventureWorks
@using ElementaryApp.Models.AdventureWorks
@using ElementaryApp.Services.AdventureWorksAudit
@using ElementaryApp.Validators
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateSalesTerritoryRequest> CreateValidator
@inject MudFormValidator<UpdateSalesTerritoryRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create territory" : $"Edit territory #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="string" Value="@createModel.CountryRegionCode" ValueChanged="@((string v) => createModel = createModel with { CountryRegionCode = v })" Label="Country / region" Required="true" Items="_countryRegions" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.GroupName" ValueChanged="@((string? v) => createModel = createModel with { GroupName = v })" Label="Group" Variant="Variant.Outlined" Required="true" MaxLength="50" HelperText="e.g. North America, Europe, Pacific" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="string?" Value="@updateModel.CountryRegionCode" ValueChanged="@((string? v) => updateModel = updateModel with { CountryRegionCode = v })" Label="Country / region" Clearable="true" Items="_countryRegionsNullable" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.GroupName" ValueChanged="@((string? v) => updateModel = updateModel with { GroupName = v })" Label="Group" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.SalesYtd" ValueChanged="@((decimal? v) => updateModel = updateModel with { SalesYtd = v })" Label="Sales YTD" Variant="Variant.Outlined" Format="F4" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.SalesLastYear" ValueChanged="@((decimal? v) => updateModel = updateModel with { SalesLastYear = v })" Label="Sales last year" Variant="Variant.Outlined" Format="F4" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.CostYtd" ValueChanged="@((decimal? v) => updateModel = updateModel with { CostYtd = v })" Label="Cost YTD" Variant="Variant.Outlined" Format="F4" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.CostLastYear" ValueChanged="@((decimal? v) => updateModel = updateModel with { CostLastYear = v })" Label="Cost last year" Variant="Variant.Outlined" Format="F4" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SalesTerritoryDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateSalesTerritoryRequest createModel = new();
    private UpdateSalesTerritoryRequest updateModel = new();
    private bool saving;
    private List<LookupItem<string>> _countryRegions = [];
    private List<LookupItem<string?>> _countryRegionsNullable = [];

    protected override async Task OnInitializedAsync()
    {
        _countryRegions = await Lookup.GetCountryRegionsAsync();
        _countryRegionsNullable = _countryRegions.Select(x => new LookupItem<string?>(x.Id, x.DisplayText)).ToList();
    }

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateSalesTerritoryRequest
            {
                Name = Model.Name,
                CountryRegionCode = Model.CountryRegionCode,
                GroupName = Model.GroupName,
                SalesYtd = Model.SalesYtd,
                SalesLastYear = Model.SalesLastYear,
                CostYtd = Model.CostYtd,
                CostLastYear = Model.CostLastYear,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                db.SalesTerritories.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.SalesTerritoryAuditLogs.Add(SalesTerritoryAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.SalesTerritories.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = SalesTerritoryAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.SalesTerritoryAuditLogs.Add(SalesTerritoryAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
