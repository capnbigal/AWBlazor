@page "/admin/request-log"
@attribute [Authorize(Roles = AppRoles.Admin)]
@using Microsoft.Data.SqlClient
@using static ElementaryApp.Components.Pages.Admin.RequestLogDetailDialog
@inject IConfiguration Configuration
@inject IDialogService DialogService

<PageTitle>Request log</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Request log</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Persisted by Serilog's MSSqlServer sink to the <code>dbo.RequestLogs</code> table.
        Newest entries first. Click a row to view full details.
    </MudText>

    @* ── Filter panel ─────────────────────────────────────────────────── *@
    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="string" Label="Level" @bind-Value="filterLevel" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("")">(any)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Information")">Information</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Warning")">Warning</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Error")">Error</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Fatal")">Fatal</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Label="From" @bind-Date="filterFrom" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudDatePicker Label="To" @bind-Date="filterTo" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudTextField T="string" Label="Path contains" @bind-Value="filterPath" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudTextField T="string" Label="User contains" @bind-Value="filterUser" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="1">
                <MudSelect T="string" Label="Method" @bind-Value="filterMethod" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("")">(any)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("GET")">GET</MudSelectItem>
                    <MudSelectItem T="string" Value="@("POST")">POST</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PATCH")">PATCH</MudSelectItem>
                    <MudSelectItem T="string" Value="@("DELETE")">DELETE</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PUT")">PUT</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="1" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters" Size="Size.Small">
                    Apply
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ── Error alert ──────────────────────────────────────────────────── *@
    @if (loadError is not null)
    {
        <MudAlert Severity="Severity.Warning">
            @loadError
        </MudAlert>
    }
    else
    {
        @* ── Data grid ────────────────────────────────────────────────── *@
        <MudDataGrid T="RequestLogRow"
                     ServerData="LoadServerDataAsync"
                     @ref="grid"
                     Dense="true"
                     Hover="true"
                     Striped="true"
                     RowClick="OnRowClick"
                     RowStyle="cursor:pointer;">
            <Columns>
                <PropertyColumn Property="x => x.TimeStamp" Title="Time" Format="yyyy-MM-dd HH:mm:ss" />
                <TemplateColumn Title="Level">
                    <CellTemplate>
                        <MudChip T="string" Color="@GetLevelColor(context.Item.Level)" Size="Size.Small">
                            @(context.Item.Level ?? "—")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.RequestMethod" Title="Method" />
                <PropertyColumn Property="x => x.RequestPath" Title="Path" />
                <PropertyColumn Property="x => x.UserName" Title="User" />
                <PropertyColumn Property="x => x.RemoteIp" Title="IP" />
                <TemplateColumn Title="Message">
                    <CellTemplate>
                        @(Truncate(context.Item.Message, 100))
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Exc">
                    <CellTemplate>
                        @if (!string.IsNullOrWhiteSpace(context.Item.Exception))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                        }
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="RequestLogRow" />
            </PagerContent>
        </MudDataGrid>
    }
</MudStack>

@code {
    private MudDataGrid<RequestLogRow> grid = null!;
    private string? loadError;

    // Filter state
    private string filterLevel = "";
    private DateTime? filterFrom;
    private DateTime? filterTo;
    private string? filterPath;
    private string? filterUser;
    private string filterMethod = "";

    // Track which enriched columns actually exist in the table so we gracefully degrade
    // if the table was created before enrichment was added.
    private HashSet<string>? availableColumns;

    private async Task ApplyFilters()
    {
        if (grid is not null)
            await grid.ReloadServerData();
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<RequestLogRow> args)
    {
        var parameters = new DialogParameters<RequestLogDetailDialog>
        {
            { x => x.Row, args.Item }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        await DialogService.ShowAsync<RequestLogDetailDialog>("Request Log Detail", parameters, options);
    }

    /// <summary>
    /// Discovers which columns exist in dbo.RequestLogs so we can SELECT only those that are
    /// present. This handles the case where the table was created before enrichment columns were added.
    /// </summary>
    private async Task<HashSet<string>> GetAvailableColumnsAsync(SqlConnection conn, CancellationToken ct)
    {
        if (availableColumns is not null)
            return availableColumns;

        var cols = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        await using var cmd = new SqlCommand(
            "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = 'dbo' AND TABLE_NAME = 'RequestLogs'",
            conn);
        await using var reader = await cmd.ExecuteReaderAsync(ct);
        while (await reader.ReadAsync(ct))
            cols.Add(reader.GetString(0));

        availableColumns = cols;
        return cols;
    }

    private async Task<GridData<RequestLogRow>> LoadServerDataAsync(GridState<RequestLogRow> state, CancellationToken ct)
    {
        var connStr = Configuration.GetConnectionString("DefaultConnection");
        if (string.IsNullOrWhiteSpace(connStr))
        {
            loadError = "No DefaultConnection connection string configured.";
            return new GridData<RequestLogRow> { Items = [], TotalItems = 0 };
        }

        try
        {
            await using var conn = new SqlConnection(connStr);
            await conn.OpenAsync(ct);

            // Check if table exists at all
            await using (var existsCmd = new SqlCommand(
                "SELECT OBJECT_ID('dbo.RequestLogs','U')", conn))
            {
                var result = await existsCmd.ExecuteScalarAsync(ct);
                if (result is null || result == DBNull.Value)
                {
                    loadError = "No request log entries yet (table will be created on first request after a Serilog Information+ event).";
                    return new GridData<RequestLogRow> { Items = [], TotalItems = 0 };
                }
            }

            var cols = await GetAvailableColumnsAsync(conn, ct);

            // Build WHERE clauses with parameterized values
            var whereClauses = new List<string>();
            var parameters = new List<SqlParameter>();

            if (!string.IsNullOrWhiteSpace(filterLevel))
            {
                whereClauses.Add("[Level] = @Level");
                parameters.Add(new SqlParameter("@Level", filterLevel));
            }
            if (filterFrom.HasValue)
            {
                whereClauses.Add("[TimeStamp] >= @FromDate");
                parameters.Add(new SqlParameter("@FromDate", filterFrom.Value.Date));
            }
            if (filterTo.HasValue)
            {
                whereClauses.Add("[TimeStamp] < @ToDate");
                // Add one day so "To" is inclusive of the whole day
                parameters.Add(new SqlParameter("@ToDate", filterTo.Value.Date.AddDays(1)));
            }
            if (!string.IsNullOrWhiteSpace(filterPath) && cols.Contains("RequestPath"))
            {
                whereClauses.Add("[RequestPath] LIKE @PathFilter");
                parameters.Add(new SqlParameter("@PathFilter", $"%{filterPath}%"));
            }
            if (!string.IsNullOrWhiteSpace(filterUser) && cols.Contains("UserName"))
            {
                whereClauses.Add("[UserName] LIKE @UserFilter");
                parameters.Add(new SqlParameter("@UserFilter", $"%{filterUser}%"));
            }
            if (!string.IsNullOrWhiteSpace(filterMethod) && cols.Contains("RequestMethod"))
            {
                whereClauses.Add("[RequestMethod] = @Method");
                parameters.Add(new SqlParameter("@Method", filterMethod));
            }

            var whereClause = whereClauses.Count > 0
                ? "WHERE " + string.Join(" AND ", whereClauses)
                : "";

            // Count query
            int total;
            await using (var countCmd = new SqlCommand($"SELECT COUNT(*) FROM dbo.RequestLogs {whereClause}", conn))
            {
                countCmd.Parameters.AddRange(parameters.Select(p => CloneParameter(p)).ToArray());
                total = Convert.ToInt32(await countCmd.ExecuteScalarAsync(ct) ?? 0);
            }

            if (total == 0)
            {
                loadError = whereClauses.Count > 0 ? null : "No request log entries yet.";
                return new GridData<RequestLogRow> { Items = [], TotalItems = 0 };
            }

            // Build SELECT columns dynamically based on what exists in the table
            var selectCols = new List<string> { "[TimeStamp]", "[Level]", "[Message]", "[Exception]" };
            if (cols.Contains("RequestMethod")) selectCols.Add("[RequestMethod]");
            if (cols.Contains("RequestPath")) selectCols.Add("[RequestPath]");
            if (cols.Contains("UserName")) selectCols.Add("[UserName]");
            if (cols.Contains("RemoteIp")) selectCols.Add("[RemoteIp]");
            if (cols.Contains("MachineName")) selectCols.Add("[MachineName]");
            if (cols.Contains("LogEvent")) selectCols.Add("[LogEvent]");

            var skip = state.Page * state.PageSize;
            var sql = $@"SELECT {string.Join(", ", selectCols)}
                         FROM dbo.RequestLogs
                         {whereClause}
                         ORDER BY [Id] DESC
                         OFFSET @Skip ROWS FETCH NEXT @Take ROWS ONLY";

            var rows = new List<RequestLogRow>();
            await using var dataCmd = new SqlCommand(sql, conn);
            dataCmd.Parameters.AddRange(parameters.Select(p => CloneParameter(p)).ToArray());
            dataCmd.Parameters.Add(new SqlParameter("@Skip", skip));
            dataCmd.Parameters.Add(new SqlParameter("@Take", state.PageSize));

            await using var reader = await dataCmd.ExecuteReaderAsync(ct);
            while (await reader.ReadAsync(ct))
            {
                rows.Add(new RequestLogRow(
                    TimeStamp: reader.GetDateTime(reader.GetOrdinal("TimeStamp")),
                    Level: GetNullableString(reader, "Level"),
                    Message: GetNullableString(reader, "Message"),
                    Exception: GetNullableString(reader, "Exception"),
                    RequestMethod: TryGetNullableString(reader, "RequestMethod"),
                    RequestPath: TryGetNullableString(reader, "RequestPath"),
                    UserName: TryGetNullableString(reader, "UserName"),
                    RemoteIp: TryGetNullableString(reader, "RemoteIp"),
                    MachineName: TryGetNullableString(reader, "MachineName"),
                    LogEvent: TryGetNullableString(reader, "LogEvent")));
            }

            loadError = null;
            return new GridData<RequestLogRow> { Items = rows, TotalItems = total };
        }
        catch (Exception ex)
        {
            loadError = $"Failed to read request log: {ex.Message}";
            return new GridData<RequestLogRow> { Items = [], TotalItems = 0 };
        }
    }

    private static string? GetNullableString(SqlDataReader reader, string column)
    {
        var ordinal = reader.GetOrdinal(column);
        return reader.IsDBNull(ordinal) ? null : reader.GetString(ordinal);
    }

    /// <summary>
    /// Reads a column if it exists in the result set; returns null if the column is not present.
    /// </summary>
    private static string? TryGetNullableString(SqlDataReader reader, string column)
    {
        try
        {
            var ordinal = reader.GetOrdinal(column);
            return reader.IsDBNull(ordinal) ? null : reader.GetString(ordinal);
        }
        catch (IndexOutOfRangeException)
        {
            return null;
        }
    }

    /// <summary>
    /// SqlParameter can't be reused across commands, so clone it for the count query vs. data query.
    /// </summary>
    private static SqlParameter CloneParameter(SqlParameter source) =>
        new(source.ParameterName, source.SqlDbType) { Value = source.Value };

    private static string Truncate(string? text, int maxLength) =>
        string.IsNullOrEmpty(text)
            ? "—"
            : text.Length <= maxLength ? text : text[..maxLength] + "...";

    private static Color GetLevelColor(string? level) => level switch
    {
        "Fatal" => Color.Dark,
        "Error" => Color.Error,
        "Warning" => Color.Warning,
        "Information" => Color.Info,
        "Debug" => Color.Default,
        "Verbose" => Color.Default,
        _ => Color.Default,
    };
}
