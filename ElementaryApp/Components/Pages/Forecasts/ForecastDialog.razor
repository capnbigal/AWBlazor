@using ElementaryApp.Data.Entities.Forecasting
@using ElementaryApp.Models
@using ElementaryApp.Validators
@using System.Text.Json
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateForecastRequest> Validator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsNew ? "Create forecast" : $"Edit forecast: {Model?.Name}")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" Model="@formModel" Validation="@Validator.ValidateField" ValidationDelay="0">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField @bind-Value="formModel.Name" Label="Name" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="formModel.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="ForecastDataSource" @bind-Value="selectedDataSource" Label="Data source" Variant="Variant.Outlined" Disabled="@(!IsNew)">
                        @foreach (var ds in Enum.GetValues<ForecastDataSource>())
                        {
                            <MudSelectItem T="ForecastDataSource" Value="@ds">@ds</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="ForecastMethod" @bind-Value="selectedMethod" Label="Method" Variant="Variant.Outlined">
                        @foreach (var m in Enum.GetValues<ForecastMethod>())
                        {
                            <MudSelectItem T="ForecastMethod" Value="@m">@m</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="ForecastGranularity" @bind-Value="selectedGranularity" Label="Granularity" Variant="Variant.Outlined" Disabled="@(!IsNew)">
                        @foreach (var g in Enum.GetValues<ForecastGranularity>())
                        {
                            <MudSelectItem T="ForecastGranularity" Value="@g">@g</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int" @bind-Value="formModel.LookbackMonths" Label="Lookback months" Variant="Variant.Outlined" Min="3" Max="60" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int" @bind-Value="formModel.HorizonPeriods" Label="Horizon periods" Variant="Variant.Outlined" Min="1" Max="24" />
                </MudItem>

                @* ── Method-specific parameters ──────────────────────────────── *@
                @if (selectedMethod is ForecastMethod.SimpleMovingAverage or ForecastMethod.WeightedMovingAverage)
                {
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int" @bind-Value="windowSize" Label="Window size" Variant="Variant.Outlined" Min="2" Max="24" />
                    </MudItem>
                }
                else if (selectedMethod == ForecastMethod.ExponentialSmoothing)
                {
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="double" @bind-Value="alpha" Label="Alpha (smoothing factor)" Variant="Variant.Outlined" Min="0.01" Max="0.99" Step="0.01" />
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">
            @(saving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ForecastDefinitionDto? Model { get; set; }

    private bool IsNew => Model is null;

    private MudForm form = null!;
    private FormModel formModel = new();
    private ForecastDataSource selectedDataSource;
    private ForecastMethod selectedMethod;
    private ForecastGranularity selectedGranularity;
    private int windowSize = 3;
    private double alpha = 0.3;
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            formModel = new FormModel
            {
                Name = Model.Name,
                Description = Model.Description,
                LookbackMonths = Model.LookbackMonths,
                HorizonPeriods = Model.HorizonPeriods,
            };
            selectedDataSource = Model.DataSource;
            selectedMethod = Model.Method;
            selectedGranularity = Model.Granularity;

            // Parse method parameters
            if (!string.IsNullOrEmpty(Model.MethodParametersJson))
            {
                try
                {
                    using var doc = JsonDocument.Parse(Model.MethodParametersJson);
                    if (doc.RootElement.TryGetProperty("windowSize", out var ws))
                        windowSize = ws.GetInt32();
                    if (doc.RootElement.TryGetProperty("alpha", out var a))
                        alpha = a.GetDouble();
                }
                catch { /* ignore parse errors */ }
            }
        }
    }

    private string? BuildMethodParametersJson()
    {
        return selectedMethod switch
        {
            ForecastMethod.SimpleMovingAverage or ForecastMethod.WeightedMovingAverage
                => JsonSerializer.Serialize(new { windowSize }),
            ForecastMethod.ExponentialSmoothing
                => JsonSerializer.Serialize(new { alpha }),
            _ => null,
        };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var request = new CreateForecastRequest
            {
                Name = formModel.Name,
                Description = formModel.Description,
                DataSource = selectedDataSource,
                Method = selectedMethod,
                Granularity = selectedGranularity,
                LookbackMonths = formModel.LookbackMonths,
                HorizonPeriods = formModel.HorizonPeriods,
                MethodParametersJson = BuildMethodParametersJson(),
            };

            if (!await Validator.ValidateAllAsync(request))
            {
                Snackbar.Add("Please fix validation errors.", Severity.Error);
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();

            if (IsNew)
            {
                var entity = request.ToEntity();
                db.ForecastDefinitions.Add(entity);
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                var entity = await db.ForecastDefinitions.FirstOrDefaultAsync(f => f.Id == Model!.Id);
                if (entity is null)
                {
                    MudDialog.Close(DialogResult.Cancel());
                    return;
                }

                var update = new UpdateForecastRequest
                {
                    Name = request.Name,
                    Description = request.Description,
                    Method = request.Method,
                    LookbackMonths = request.LookbackMonths,
                    HorizonPeriods = request.HorizonPeriods,
                    MethodParametersJson = request.MethodParametersJson,
                };
                update.ApplyTo(entity);
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally
        {
            saving = false;
        }
    }

    private sealed class FormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int LookbackMonths { get; set; } = 12;
        public int HorizonPeriods { get; set; } = 6;
    }
}
