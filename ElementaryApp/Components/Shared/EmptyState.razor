@* Friendly empty-state display for grids with no records. *@

<div class="d-flex flex-column align-center justify-center pa-8" style="min-height: 200px;">
    <MudIcon Icon="@Icon" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
    <MudText Typo="Typo.h6" Color="Color.Secondary">@Title</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">@Message</MudText>
</div>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.SearchOff;
    [Parameter] public string Title { get; set; } = "No records found";
    [Parameter] public string Message { get; set; } = "Try adjusting your filters or create a new record.";
}
