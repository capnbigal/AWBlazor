@implements IDisposable
@inject NavigationManager Nav

<MudNavMenu>
    @* ─── Overview ──────────────────────────────────────────────────────────── *@
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
    <MudNavLink Href="dashboard/plant" Icon="@Icons.Material.Filled.Factory">Plant dashboard</MudNavLink>
    <MudNavLink Href="guide" Icon="@Icons.Material.Filled.MenuBook">User guide</MudNavLink>

    <AuthorizeView>
        <Authorized>
            @* ─── Operations ───────────────────────────────────────────────────
               Each domain module is a single top-level link landing on its dashboard
               at /<module>. The dashboard hosts KPIs + a Modules grid with one card
               per sub-page + a "Reference data" card linking to /<module>/reference
               (where the legacy aw/* CRUD pages live). *@
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4">Operations</MudText>
            <MudNavLink Href="enterprise"   Icon="@Icons.Material.Filled.Domain">Enterprise</MudNavLink>
            <MudNavLink Href="engineering"  Icon="@Icons.Material.Filled.Architecture">Engineering</MudNavLink>
            <MudNavLink Href="mes"          Icon="@Icons.Material.Filled.Engineering">Production</MudNavLink>
            <MudNavLink Href="quality"      Icon="@Icons.Material.Filled.Verified">Quality</MudNavLink>
            <MudNavLink Href="maintenance"  Icon="@Icons.Material.Filled.Build">Maintenance</MudNavLink>
            <MudNavLink Href="workforce"    Icon="@Icons.Material.Filled.Groups">Workforce</MudNavLink>
            <MudNavLink Href="inventory"    Icon="@Icons.Material.Filled.Inventory2">Inventory</MudNavLink>
            <MudNavLink Href="logistics"    Icon="@Icons.Material.Filled.LocalShipping">Logistics</MudNavLink>
            <MudNavLink Href="purchasing"   Icon="@Icons.Material.Filled.ShoppingBag">Purchasing</MudNavLink>
            <MudNavLink Href="sales"        Icon="@Icons.Material.Filled.AttachMoney">Sales</MudNavLink>

            @* ─── Insights ───────────────────────────────────────────────────── *@
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4">Insights</MudText>
            <MudNavLink Href="forecasts" Icon="@Icons.Material.Filled.TrendingUp">Forecasts</MudNavLink>
            <MudNavLink Href="analytics/forecasts" Icon="@Icons.Material.Filled.Analytics">Forecast analytics</MudNavLink>
            <MudNavLink Href="processes" Icon="@Icons.Material.Filled.AccountTree">Processes</MudNavLink>
            <MudNavLink Href="analytics/processes" Icon="@Icons.Material.Filled.Assessment">Process analytics</MudNavLink>
            <MudNavLink Href="analytics/geo" Icon="@Icons.Material.Filled.Map">Geographic map</MudNavLink>
            <MudNavGroup Title="Performance" Icon="@Icons.Material.Filled.Insights" Expanded="@IsActive("performance")">
                <MudNavLink Href="performance" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Performance summary</MudNavLink>
                <MudNavLink Href="performance/oee" Icon="@Icons.Material.Filled.Speed">OEE snapshots</MudNavLink>
                <MudNavLink Href="performance/production-metrics" Icon="@Icons.Material.Filled.Factory">Production metrics</MudNavLink>
                <MudNavLink Href="performance/maintenance-metrics" Icon="@Icons.Material.Filled.Handyman">Maintenance metrics</MudNavLink>
                <MudNavLink Href="performance/kpis" Icon="@Icons.Material.Filled.ShowChart">KPIs</MudNavLink>
                <MudNavLink Href="performance/scorecards" Icon="@Icons.Material.Filled.Dashboard">Scorecards</MudNavLink>
                <MudNavLink Href="performance/reports" Icon="@Icons.Material.Filled.Description">Reports</MudNavLink>
            </MudNavGroup>

            @* ─── My workspace ──────────────────────────────────────────────── *@
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4">My workspace</MudText>
            <MudNavLink Href="my-activity" Icon="@Icons.Material.Filled.Timeline">My activity</MudNavLink>
            <MudNavLink Href="notifications" Icon="@Icons.Material.Filled.NotificationsActive">Notification rules</MudNavLink>
            <MudNavLink Href="reports" Icon="@Icons.Material.Filled.Assessment">Database explorer</MudNavLink>
            <MudNavLink Href="documents/tree" Icon="@Icons.Material.Filled.AccountTree">Document tree</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@AppRoles.Admin">
        <Authorized>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="px-4 mt-2">— Admin tools —</MudText>
            <MudNavLink Href="queries" Icon="@Icons.Material.Filled.QueryStats">Saved queries</MudNavLink>
            <MudNavLink Href="kpis" Icon="@Icons.Material.Filled.EditNote">KPI editor</MudNavLink>
            <MudNavLink Href="dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Insights dashboard</MudNavLink>
            <MudNavLink Href="reports/schedule" Icon="@Icons.Material.Filled.Schedule">Scheduled reports</MudNavLink>

            @* ─── Admin ─────────────────────────────────────────────────────── *@
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4">Admin</MudText>
            <MudNavLink Href="admin" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Admin dashboard</MudNavLink>
            <MudNavLink Href="admin/users" Icon="@Icons.Material.Filled.People">Users</MudNavLink>
            <MudNavLink Href="admin/permissions" Icon="@Icons.Material.Filled.Security">Permissions</MudNavLink>
            <MudNavLink Href="admin/request-log" Icon="@Icons.Material.Filled.Receipt">Request log</MudNavLink>
            <MudNavLink Href="admin/activity" Icon="@Icons.Material.Filled.Timeline">User activity</MudNavLink>
            <MudNavLink Href="admin/guide-stats" Icon="@Icons.Material.Filled.MenuBook">Guide stats</MudNavLink>
            <MudNavLink Href="admin/rollup" Icon="@Icons.Material.Filled.Update">Performance rollup</MudNavLink>

            @* ─── Developer ─────────────────────────────────────────────────── *@
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4">Developer</MudText>
            <MudNavLink Href="api-explorer" Icon="@Icons.Material.Filled.Api">API explorer</MudNavLink>
            <MudNavLink Href="swagger" Icon="@Icons.Material.Filled.MenuBook">API docs</MudNavLink>
            <MudNavLink Href="import" Icon="@Icons.Material.Filled.UploadFile">CSV import</MudNavLink>
            <MudNavLink Href="hangfire" Icon="@Icons.Material.Filled.Schedule">Hangfire</MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* ─── Account ──────────────────────────────────────────────────────────── *@
    <AuthorizeView>
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4">Account</MudText>
            <MudNavLink Href="Account/Manage" Icon="@Icons.Material.Filled.AccountCircle">My account</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => InvokeAsync(StateHasChanged);

    // Matches the current route's relative path against a prefix so the current
    // domain group auto-expands on navigation.
    private bool IsActive(string prefix)
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/');
        return relative.Equals(prefix, StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith(prefix + "/", StringComparison.OrdinalIgnoreCase);
    }
}
