<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="icon" href="/img/logo.svg" type="image/svg+xml" />

    <script>
      window.getDarkModeCookie = function() {
        var m = document.cookie.match(/(?:^|;\s*)darkMode=([^;]*)/);
        return m !== null && m[1] === 'true';
      };
      if (window.getDarkModeCookie()) document.documentElement.setAttribute('data-mud-theme', 'dark');
    </script>
    <style>
      /* FOUC preload: paint the dark surface before MudBlazor CSS loads. Values mirror
         AppTheme.cs PaletteDark (Background = #0B1220, TextPrimary = #F1F5F9). */
      html[data-mud-theme="dark"] { background-color: #0B1220; }
      html[data-mud-theme="dark"] body { background-color: #0B1220; color: #F1F5F9; }
    </style>

    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="css/account-forms.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="AWBlazorApp.styles.css" />

    <!-- Leaflet + MarkerCluster (used only by /analytics/geo). BSD-2-Clause / MIT.
         Integrity hashes omitted intentionally — unpkg serves content through a CDN that
         occasionally varies the exact byte sequence (different gzip encodings), which with
         a pinned SRI hash causes the browser to silently block the script and the map to
         never initialize. If this ever needs SRI, switch to a self-hosted copy in wwwroot. -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

    <HeadOutlet @rendermode="@PageRenderMode" />
</head>
<body>
    <Routes @rendermode="@PageRenderMode" />

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss" aria-label="Dismiss" role="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </span>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="js/app.js"></script>
    <script src="js/api-explorer.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    <script src="js/leaflet-map.js"></script>
</body>
</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // Per the .NET 8/9/10 Blazor Web App pattern: render every page with InteractiveServer EXCEPT
    // pages that opt out via [ExcludeFromInteractiveRouting]. Identity scaffold pages need to be
    // static SSR so they have access to HttpContext (for SignInManager / cookie writes / form
    // POSTs). Without this, those pages enter an infinite redirect loop because:
    //   1. Page renders statically with HttpContext available.
    //   2. Blazor immediately upgrades to interactive via SignalR.
    //   3. In the interactive render, HttpContext is null.
    //   4. AccountLayout sees null HttpContext and calls NavigationManager.Refresh().
    //   5. Goto 1 — infinite loop.
    // See: https://learn.microsoft.com/aspnet/core/blazor/security/server/
    private IComponentRenderMode? PageRenderMode
        => HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;
}
