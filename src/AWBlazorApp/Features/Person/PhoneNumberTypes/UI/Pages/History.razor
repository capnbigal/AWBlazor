@page "/aw/phone-number-types/history"
@page "/aw/phone-number-types/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Phone number type history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/phone-number-types"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Phone number type history" : $"History for PhoneNumberType #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="PhoneNumberType" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
