@page "/aw/state-provinces"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.Addresses.Domain
@using AWBlazorApp.Features.Person.AddressTypes.Domain
@using AWBlazorApp.Features.Person.BusinessEntities.Domain
@using AWBlazorApp.Features.Person.BusinessEntityAddresses.Domain
@using AWBlazorApp.Features.Person.BusinessEntityContacts.Domain
@using AWBlazorApp.Features.Person.ContactTypes.Domain
@using AWBlazorApp.Features.Person.CountryRegions.Domain
@using AWBlazorApp.Features.Person.EmailAddresses.Domain
@using AWBlazorApp.Features.Person.Persons.Domain
@using AWBlazorApp.Features.Person.PersonPhones.Domain
@using AWBlazorApp.Features.Person.PhoneNumberTypes.Domain
@using AWBlazorApp.Features.Person.StateProvinces.Domain
@using AWBlazorApp.Features.Person.Addresses.Dtos
@using AWBlazorApp.Features.Person.AddressTypes.Dtos
@using AWBlazorApp.Features.Person.BusinessEntities.Dtos
@using AWBlazorApp.Features.Person.BusinessEntityAddresses.Dtos
@using AWBlazorApp.Features.Person.BusinessEntityContacts.Dtos
@using AWBlazorApp.Features.Person.ContactTypes.Dtos
@using AWBlazorApp.Features.Person.CountryRegions.Dtos
@using AWBlazorApp.Features.Person.EmailAddresses.Dtos
@using AWBlazorApp.Features.Person.Persons.Dtos
@using AWBlazorApp.Features.Person.PersonPhones.Dtos
@using AWBlazorApp.Features.Person.PhoneNumberTypes.Dtos
@using AWBlazorApp.Features.Person.StateProvinces.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="StateProvinceDto"
          Title="State / provinces"
          Caption="Person.StateProvince"
          NewButtonLabel="New state / province"
          HistoryRoute="aw/state-provinces/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="state / province">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterCountryRegionCode" Label="Country / region" Variant="Variant.Outlined" /></MudItem>
    </Filters>
    <Columns>

            <PropertyColumn T="StateProvinceDto" TProperty="int" Property="x => x.Id" Title="Id" />
            <PropertyColumn T="StateProvinceDto" TProperty="string" Property="x => x.StateProvinceCode" Title="Code" />
            <PropertyColumn T="StateProvinceDto" TProperty="string" Property="x => x.CountryRegionCode" Title="Country" />
            <PropertyColumn T="StateProvinceDto" TProperty="string" Property="x => x.Name" Title="Name" />
            <PropertyColumn T="StateProvinceDto" TProperty="int" Property="x => x.TerritoryId" Title="Territory" />
            <PropertyColumn T="StateProvinceDto" TProperty="bool" Property="x => x.IsOnlyStateProvinceFlag" Title="Only" />
            <PropertyColumn T="StateProvinceDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            
    </Columns>
</CrudPage>

@code {
    private string? filterName;
    private string? filterCountryRegionCode;

    private async Task<GridData<StateProvinceDto>> LoadServerDataAsync(GridState<StateProvinceDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.StateProvinces.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName))
            {
                var needle = filterName.Trim();
                query = query.Where(x => x.Name.Contains(needle));
            }
            if (!string.IsNullOrWhiteSpace(filterCountryRegionCode))
            {
                var needle = filterCountryRegionCode.Trim();
                query = query.Where(x => x.CountryRegionCode == needle);
            }var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(StateProvinceDto.Id)                        => sort.Descending ? query.OrderByDescending(x => x.Id)                        : query.OrderBy(x => x.Id),
                nameof(StateProvinceDto.StateProvinceCode)         => sort.Descending ? query.OrderByDescending(x => x.StateProvinceCode)         : query.OrderBy(x => x.StateProvinceCode),
                nameof(StateProvinceDto.CountryRegionCode)         => sort.Descending ? query.OrderByDescending(x => x.CountryRegionCode)         : query.OrderBy(x => x.CountryRegionCode),
                nameof(StateProvinceDto.IsOnlyStateProvinceFlag)   => sort.Descending ? query.OrderByDescending(x => x.IsOnlyStateProvinceFlag)   : query.OrderBy(x => x.IsOnlyStateProvinceFlag),
                nameof(StateProvinceDto.Name)                      => sort.Descending ? query.OrderByDescending(x => x.Name)                      : query.OrderBy(x => x.Name),
                nameof(StateProvinceDto.TerritoryId)               => sort.Descending ? query.OrderByDescending(x => x.TerritoryId)               : query.OrderBy(x => x.TerritoryId),
                nameof(StateProvinceDto.ModifiedDate)              => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)              : query.OrderBy(x => x.ModifiedDate),
                _                                                  => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<StateProvinceDto> { Items = rows, TotalItems = total };
        }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<StateProvinceDialog>("New state / province", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("State / province created.", Severity.Success);
    }

    private async Task OpenEditAsync(StateProvinceDto row)
    {
        var parameters = new DialogParameters<StateProvinceDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<StateProvinceDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("State / province updated.", Severity.Success);
    }

    private async Task DeleteAsync(StateProvinceDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.StateProvinces.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.StateProvinces.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("State / province deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
