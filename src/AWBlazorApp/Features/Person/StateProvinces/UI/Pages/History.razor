@page "/aw/state-provinces/history"
@page "/aw/state-provinces/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>State / province history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/state-provinces"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "State / province history" : $"History for StateProvince #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="StateProvince" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
