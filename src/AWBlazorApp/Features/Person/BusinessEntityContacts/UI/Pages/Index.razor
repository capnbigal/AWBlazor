@page "/aw/business-entity-contacts"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.BusinessEntityContacts.Domain
@using AWBlazorApp.Features.Person.BusinessEntityContacts.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="BusinessEntityContactDto"
          @ref="page"
          Title="Business entity ↔ contact"
          Caption="Person.BusinessEntityContact · 3-column composite PK"
          NewButtonLabel="New link"
          HistoryRoute="aw/business-entity-contacts/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Business entity" Clearable="true" SearchFunc="@(q => Lookup.SearchPersonsAsync(q))" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="BusinessEntityContactDto" TProperty="int" Property="x => x.BusinessEntityId" Title="Business entity id">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityContact" PropertyName="@nameof(BusinessEntityContactDto.BusinessEntityId)" Title="Business entity id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="BusinessEntityContactDto" TProperty="int" Property="x => x.PersonId" Title="Person id">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityContact" PropertyName="@nameof(BusinessEntityContactDto.PersonId)" Title="Person id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="BusinessEntityContactDto" TProperty="int" Property="x => x.ContactTypeId" Title="Contact type id">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityContact" PropertyName="@nameof(BusinessEntityContactDto.ContactTypeId)" Title="Contact type id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="BusinessEntityContactDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityContact" PropertyName="@nameof(BusinessEntityContactDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/business-entity-contacts/history?businessEntityId={row.BusinessEntityId}&personId={row.PersonId}&contactTypeId={row.ContactTypeId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<BusinessEntityContactDto> page = null!;
    private int? filterBusinessEntityId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<BusinessEntityContactDto>> LoadServerDataAsync(GridState<BusinessEntityContactDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.BusinessEntityContacts.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(BusinessEntityContactDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(BusinessEntityContactDto.PersonId)         => sort.Descending ? query.OrderByDescending(x => x.PersonId)         : query.OrderBy(x => x.PersonId),
            nameof(BusinessEntityContactDto.ContactTypeId)    => sort.Descending ? query.OrderByDescending(x => x.ContactTypeId)    : query.OrderBy(x => x.ContactTypeId),
            nameof(BusinessEntityContactDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _                                                 => query.OrderBy(x => x.BusinessEntityId).ThenBy(x => x.ContactTypeId).ThenBy(x => x.PersonId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<BusinessEntityContactDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<BusinessEntityContactDialog>("Link a business entity to a contact", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(BusinessEntityContactDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.BusinessEntityId}, {row.PersonId}, {row.ContactTypeId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BusinessEntityContacts.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.PersonId == row.PersonId && t.ContactTypeId == row.ContactTypeId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.BusinessEntityContacts.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
