@page "/aw/country-regions"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.CountryRegions.Domain
@using AWBlazorApp.Features.Person.CountryRegions.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="CountryRegionDto"
          @ref="page"
          Title="Country / region codes"
          Caption="Person.CountryRegion"
          NewButtonLabel="New country / region"
          HistoryRoute="aw/country-regions/history"
          IdOf="row => row.CountryRegionCode"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="country / region"
          DeleteConfirmMessage="@(row => $"Permanently delete {row.CountryRegionCode} ({row.Name})?")">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterCode" Label="Code" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="CountryRegionDto" TProperty="string" Property="x => x.CountryRegionCode" Title="Code">
            <HeaderTemplate><GridColumnHeader TEntity="CountryRegion" PropertyName="@nameof(CountryRegionDto.CountryRegionCode)" Title="Code" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CountryRegionDto" TProperty="string" Property="x => x.Name" Title="Name">
            <HeaderTemplate><GridColumnHeader TEntity="CountryRegion" PropertyName="@nameof(CountryRegionDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CountryRegionDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="CountryRegion" PropertyName="@nameof(CountryRegionDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<CountryRegionDto> page = null!;
    private string? filterCode;
    private string? filterName;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<CountryRegionDto>> LoadServerDataAsync(GridState<CountryRegionDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CountryRegions.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCode))
        {
            var needle = filterCode.Trim();
            query = query.Where(x => x.CountryRegionCode == needle);
        }
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var needle = filterName.Trim();
            query = query.Where(x => x.Name.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CountryRegionDto.CountryRegionCode) => sort.Descending ? query.OrderByDescending(x => x.CountryRegionCode) : query.OrderBy(x => x.CountryRegionCode),
            nameof(CountryRegionDto.Name)              => sort.Descending ? query.OrderByDescending(x => x.Name)              : query.OrderBy(x => x.Name),
            nameof(CountryRegionDto.ModifiedDate)      => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)      : query.OrderBy(x => x.ModifiedDate),
            _                                          => query.OrderBy(x => x.CountryRegionCode),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CountryRegionDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CountryRegionDialog>("New country / region", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Country / region created.", Severity.Success);
    }

    private async Task OpenEditAsync(CountryRegionDto row)
    {
        var parameters = new DialogParameters<CountryRegionDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CountryRegionDialog>($"Edit {row.CountryRegionCode}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Country / region updated.", Severity.Success);
    }

    private async Task DeleteAsync(CountryRegionDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CountryRegions.FirstOrDefaultAsync(t => t.CountryRegionCode == row.CountryRegionCode);
        if (entity is null) { Snackbar.Add("Country / region no longer exists.", Severity.Warning); return; }
        db.CountryRegions.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Country / region deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
