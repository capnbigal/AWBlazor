@page "/aw/country-regions/history"
@page "/aw/country-regions/history/{Code}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Country / region history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/country-regions"))" />

        <MudText Typo="Typo.h4">"Country / region history"</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="CountryRegion"  />
</MudStack>

