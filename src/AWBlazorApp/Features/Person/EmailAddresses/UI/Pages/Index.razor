@page "/aw/email-addresses"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.EmailAddresses.Domain
@using AWBlazorApp.Features.Person.EmailAddresses.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="EmailAddressDto"
          @ref="page"
          Title="Email addresses"
          Caption="Person.EmailAddress · composite PK (BusinessEntityID, EmailAddressID)"
          NewButtonLabel="New email"
          HistoryRoute="aw/email-addresses/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="email">
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Person" Clearable="true" SearchFunc="@(q => Lookup.SearchPersonsAsync(q))" OnSelectionChanged="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterEmail" Label="Email contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="EmailAddressDto" TProperty="int" Property="x => x.BusinessEntityId" Title="Person id">
            <HeaderTemplate><GridColumnHeader TEntity="EmailAddress" PropertyName="@nameof(EmailAddressDto.BusinessEntityId)" Title="Person id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmailAddressDto" TProperty="int" Property="x => x.EmailAddressId" Title="Email id">
            <HeaderTemplate><GridColumnHeader TEntity="EmailAddress" PropertyName="@nameof(EmailAddressDto.EmailAddressId)" Title="Email id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmailAddressDto" TProperty="string" Property="x => x.EmailAddressValue" Title="Email">
            <HeaderTemplate><GridColumnHeader TEntity="EmailAddress" PropertyName="@nameof(EmailAddressDto.EmailAddressValue)" Title="Email" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmailAddressDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="EmailAddress" PropertyName="@nameof(EmailAddressDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/email-addresses/history?businessEntityId={row.BusinessEntityId}&emailAddressId={row.EmailAddressId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<EmailAddressDto> page = null!;
    private int? filterBusinessEntityId;
    private string? filterEmail;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<EmailAddressDto>> LoadServerDataAsync(GridState<EmailAddressDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.EmailAddresses.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        if (!string.IsNullOrWhiteSpace(filterEmail))
        {
            var n = filterEmail.Trim();
            query = query.Where(x => x.EmailAddressValue != null && x.EmailAddressValue.Contains(n));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(EmailAddressDto.BusinessEntityId)  => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId)  : query.OrderBy(x => x.BusinessEntityId),
            nameof(EmailAddressDto.EmailAddressId)    => sort.Descending ? query.OrderByDescending(x => x.EmailAddressId)    : query.OrderBy(x => x.EmailAddressId),
            nameof(EmailAddressDto.EmailAddressValue) => sort.Descending ? query.OrderByDescending(x => x.EmailAddressValue) : query.OrderBy(x => x.EmailAddressValue),
            nameof(EmailAddressDto.ModifiedDate)      => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)      : query.OrderBy(x => x.ModifiedDate),
            _                                         => query.OrderBy(x => x.BusinessEntityId).ThenBy(x => x.EmailAddressId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<EmailAddressDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<EmailAddressDialog>("New email", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Email created.", Severity.Success);
    }

    private async Task OpenEditAsync(EmailAddressDto row)
    {
        var parameters = new DialogParameters<EmailAddressDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<EmailAddressDialog>($"Edit ({row.BusinessEntityId}, {row.EmailAddressId})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Email updated.", Severity.Success); await page.ReloadAsync(); }
    }

    private async Task DeleteAsync(EmailAddressDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete email?", $"Permanently delete email ({row.BusinessEntityId}, {row.EmailAddressId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.EmailAddresses.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.EmailAddressId == row.EmailAddressId);
        if (entity is null) { Snackbar.Add("Email no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.EmailAddresses.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Email deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
