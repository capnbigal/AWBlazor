@page "/aw/business-entities/history"
@page "/aw/business-entities/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Business entity history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/business-entities"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Business entity history" : $"History for BusinessEntity #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="BusinessEntity" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
