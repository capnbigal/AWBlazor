@page "/aw/business-entities"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.Addresses.Domain
@using AWBlazorApp.Features.Person.AddressTypes.Domain
@using AWBlazorApp.Features.Person.BusinessEntities.Domain
@using AWBlazorApp.Features.Person.BusinessEntityAddresses.Domain
@using AWBlazorApp.Features.Person.BusinessEntityContacts.Domain
@using AWBlazorApp.Features.Person.ContactTypes.Domain
@using AWBlazorApp.Features.Person.CountryRegions.Domain
@using AWBlazorApp.Features.Person.EmailAddresses.Domain
@using AWBlazorApp.Features.Person.Persons.Domain
@using AWBlazorApp.Features.Person.PersonPhones.Domain
@using AWBlazorApp.Features.Person.PhoneNumberTypes.Domain
@using AWBlazorApp.Features.Person.StateProvinces.Domain
@using AWBlazorApp.Features.Person.Addresses.Dtos
@using AWBlazorApp.Features.Person.AddressTypes.Dtos
@using AWBlazorApp.Features.Person.BusinessEntities.Dtos
@using AWBlazorApp.Features.Person.BusinessEntityAddresses.Dtos
@using AWBlazorApp.Features.Person.BusinessEntityContacts.Dtos
@using AWBlazorApp.Features.Person.ContactTypes.Dtos
@using AWBlazorApp.Features.Person.CountryRegions.Dtos
@using AWBlazorApp.Features.Person.EmailAddresses.Dtos
@using AWBlazorApp.Features.Person.Persons.Dtos
@using AWBlazorApp.Features.Person.PersonPhones.Dtos
@using AWBlazorApp.Features.Person.PhoneNumberTypes.Dtos
@using AWBlazorApp.Features.Person.StateProvinces.Dtos
@using AWBlazorApp.Features.Person.Addresses.Application.Services
@using AWBlazorApp.Features.Person.AddressTypes.Application.Services
@using AWBlazorApp.Features.Person.BusinessEntities.Application.Services
@using AWBlazorApp.Features.Person.BusinessEntityAddresses.Application.Services
@using AWBlazorApp.Features.Person.BusinessEntityContacts.Application.Services
@using AWBlazorApp.Features.Person.ContactTypes.Application.Services
@using AWBlazorApp.Features.Person.CountryRegions.Application.Services
@using AWBlazorApp.Features.Person.EmailAddresses.Application.Services
@using AWBlazorApp.Features.Person.Persons.Application.Services
@using AWBlazorApp.Features.Person.PersonPhones.Application.Services
@using AWBlazorApp.Features.Person.PhoneNumberTypes.Application.Services
@using AWBlazorApp.Features.Person.StateProvinces.Application.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Business entities</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Business entities</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Person.BusinessEntity · root identifier shared by Person, Store, Vendor</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/business-entities/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New business entity</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">
        BusinessEntity is just an integer surrogate key. Creating one allocates the next id;
        it has no editable data of its own. Persons, Stores, and Vendors all share this ID.
    </MudText>

    <MudDataGrid T="BusinessEntityDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" Virtualize="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="BusinessEntity" PropertyName="@nameof(BusinessEntityDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.RowGuid" Title="Row GUID">
                <HeaderTemplate><GridColumnHeader TEntity="BusinessEntity" PropertyName="@nameof(BusinessEntityDto.RowGuid)" Title="Row GUID" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="BusinessEntity" PropertyName="@nameof(BusinessEntityDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="BusinessEntityDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<BusinessEntityDto> grid = null!;
    private bool _loading = true;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<BusinessEntityDto>> LoadServerDataAsync(GridState<BusinessEntityDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.BusinessEntities.AsNoTracking();
            query = query.ApplyColumnFilters(columnFilters);
            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(BusinessEntityDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
                nameof(BusinessEntityDto.RowGuid)      => sort.Descending ? query.OrderByDescending(x => x.RowGuid)      : query.OrderBy(x => x.RowGuid),
                nameof(BusinessEntityDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _                                      => query.OrderBy(x => x.Id),
            };
            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<BusinessEntityDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Create business entity?",
            "This allocates a new BusinessEntity row with a fresh id and row GUID. The row has no other editable data.",
            yesText: "Create", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = new CreateBusinessEntityRequest().ToEntity();
        db.BusinessEntities.Add(entity);
        await db.SaveChangesAsync();

        var changedBy = await GetCurrentUserNameAsync();
        db.BusinessEntityAuditLogs.Add(BusinessEntityAuditService.RecordCreate(entity, changedBy));
        await db.SaveChangesAsync();

        Snackbar.Add($"Business entity #{entity.Id} created.", Severity.Success);
        await grid.ReloadServerData();
    }

    private async Task DeleteAsync(BusinessEntityDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete business entity?",
            $"Permanently delete business entity #{row.Id}? This will fail if any Person, Store, or Vendor references it.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BusinessEntities.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Business entity no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.BusinessEntityAuditLogs.Add(BusinessEntityAuditService.RecordDelete(entity, changedBy));
        db.BusinessEntities.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Business entity deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(BusinessEntityDto row) => Navigation.NavigateTo($"aw/business-entities/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
