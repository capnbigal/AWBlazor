@page "/aw/persons/history"
@page "/aw/persons/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Person history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/persons"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Person history" : $"History for Person #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Person" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
