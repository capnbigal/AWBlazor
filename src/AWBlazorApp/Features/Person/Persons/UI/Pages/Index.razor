@page "/aw/persons"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.Persons.Dtos
@using PersonEntity = AWBlazorApp.Features.Person.Persons.Domain.Person
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="PersonDto"
          @ref="page"
          Title="Persons"
          Caption="Person.Person"
          NewButtonLabel="New person"
          HistoryRoute="aw/persons/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="person"
          DeleteConfirmMessage="@(row => $"Permanently delete person #{row.Id} ({row.FirstName} {row.LastName})?")">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterLastName" Label="Last name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect T="string?" @bind-Value="filterPersonType" Label="Person type" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                <MudSelectItem T="string?" Value="@("SC")">SC — Store contact</MudSelectItem>
                <MudSelectItem T="string?" Value="@("IN")">IN — Individual</MudSelectItem>
                <MudSelectItem T="string?" Value="@("SP")">SP — Sales person</MudSelectItem>
                <MudSelectItem T="string?" Value="@("EM")">EM — Employee</MudSelectItem>
                <MudSelectItem T="string?" Value="@("VC")">VC — Vendor contact</MudSelectItem>
                <MudSelectItem T="string?" Value="@("GC")">GC — General contact</MudSelectItem>
            </MudSelect>
        </MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="PersonDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PersonDto" TProperty="string" Property="x => x.PersonType" Title="Type">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.PersonType)" Title="Type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PersonDto" TProperty="string" Property="x => x.Title" Title="Title">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.Title)" Title="Title" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PersonDto" TProperty="string" Property="x => x.FirstName" Title="First name">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.FirstName)" Title="First name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PersonDto" TProperty="string" Property="x => x.MiddleName" Title="Middle">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.MiddleName)" Title="Middle" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PersonDto" TProperty="string" Property="x => x.LastName" Title="Last name">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.LastName)" Title="Last name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PersonDto" TProperty="string" Property="x => x.Suffix" Title="Suffix">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.Suffix)" Title="Suffix" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PersonDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="PersonEntity" PropertyName="@nameof(PersonDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<PersonDto> page = null!;
    private string? filterLastName;
    private string? filterPersonType;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<PersonDto>> LoadServerDataAsync(GridState<PersonDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Persons.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterLastName))
        {
            var n = filterLastName.Trim();
            query = query.Where(x => x.LastName.Contains(n));
        }
        if (!string.IsNullOrWhiteSpace(filterPersonType)) query = query.Where(x => x.PersonType == filterPersonType);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(PersonDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(PersonDto.LastName)     => sort.Descending ? query.OrderByDescending(x => x.LastName)     : query.OrderBy(x => x.LastName),
            nameof(PersonDto.FirstName)    => sort.Descending ? query.OrderByDescending(x => x.FirstName)    : query.OrderBy(x => x.FirstName),
            nameof(PersonDto.MiddleName)   => sort.Descending ? query.OrderByDescending(x => x.MiddleName)   : query.OrderBy(x => x.MiddleName),
            nameof(PersonDto.Title)        => sort.Descending ? query.OrderByDescending(x => x.Title)        : query.OrderBy(x => x.Title),
            nameof(PersonDto.Suffix)       => sort.Descending ? query.OrderByDescending(x => x.Suffix)       : query.OrderBy(x => x.Suffix),
            nameof(PersonDto.PersonType)   => sort.Descending ? query.OrderByDescending(x => x.PersonType)   : query.OrderBy(x => x.PersonType),
            nameof(PersonDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                              => query.OrderBy(x => x.LastName).ThenBy(x => x.FirstName),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<PersonDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<PersonDialog>("New person", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Person created.", Severity.Success);
    }

    private async Task OpenEditAsync(PersonDto row)
    {
        var parameters = new DialogParameters<PersonDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<PersonDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Person updated.", Severity.Success);
    }

    private async Task DeleteAsync(PersonDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Persons.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Person no longer exists.", Severity.Warning); return; }
        db.Persons.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Person deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
