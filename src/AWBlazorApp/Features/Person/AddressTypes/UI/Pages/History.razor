@page "/aw/address-types/history"
@page "/aw/address-types/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Address type history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/address-types"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Address type history" : $"History for AddressType #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="AddressType" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
