@page "/aw/contact-types/history"
@page "/aw/contact-types/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Contact type history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/contact-types"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Contact type history" : $"History for ContactType #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ContactType" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
