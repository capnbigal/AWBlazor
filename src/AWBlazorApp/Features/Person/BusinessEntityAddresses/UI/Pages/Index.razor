@page "/aw/business-entity-addresses"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.BusinessEntityAddresses.Domain
@using AWBlazorApp.Features.Person.BusinessEntityAddresses.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="BusinessEntityAddressDto"
          @ref="page"
          Title="Business entity ↔ address"
          Caption="Person.BusinessEntityAddress · 3-column composite PK"
          NewButtonLabel="New link"
          HistoryRoute="aw/business-entity-addresses/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Business entity" Clearable="true" SearchFunc="@(q => Lookup.SearchPersonsAsync(q))" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="BusinessEntityAddressDto" TProperty="int" Property="x => x.BusinessEntityId" Title="Business entity id">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityAddress" PropertyName="@nameof(BusinessEntityAddressDto.BusinessEntityId)" Title="Business entity id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="BusinessEntityAddressDto" TProperty="int" Property="x => x.AddressId" Title="Address id">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityAddress" PropertyName="@nameof(BusinessEntityAddressDto.AddressId)" Title="Address id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="BusinessEntityAddressDto" TProperty="int" Property="x => x.AddressTypeId" Title="Address type id">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityAddress" PropertyName="@nameof(BusinessEntityAddressDto.AddressTypeId)" Title="Address type id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="BusinessEntityAddressDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="BusinessEntityAddress" PropertyName="@nameof(BusinessEntityAddressDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/business-entity-addresses/history?businessEntityId={row.BusinessEntityId}&addressId={row.AddressId}&addressTypeId={row.AddressTypeId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<BusinessEntityAddressDto> page = null!;
    private int? filterBusinessEntityId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<BusinessEntityAddressDto>> LoadServerDataAsync(GridState<BusinessEntityAddressDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.BusinessEntityAddresses.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(BusinessEntityAddressDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(BusinessEntityAddressDto.AddressId)        => sort.Descending ? query.OrderByDescending(x => x.AddressId)        : query.OrderBy(x => x.AddressId),
            nameof(BusinessEntityAddressDto.AddressTypeId)    => sort.Descending ? query.OrderByDescending(x => x.AddressTypeId)    : query.OrderBy(x => x.AddressTypeId),
            nameof(BusinessEntityAddressDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _                                                 => query.OrderBy(x => x.BusinessEntityId).ThenBy(x => x.AddressTypeId).ThenBy(x => x.AddressId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<BusinessEntityAddressDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<BusinessEntityAddressDialog>("Link a business entity to an address", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(BusinessEntityAddressDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.BusinessEntityId}, {row.AddressId}, {row.AddressTypeId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BusinessEntityAddresses.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.AddressId == row.AddressId && t.AddressTypeId == row.AddressTypeId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.BusinessEntityAddresses.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
