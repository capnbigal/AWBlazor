@page "/aw/addresses/history"
@page "/aw/addresses/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Address history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/addresses"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Address history" : $"History for Address #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Address" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
