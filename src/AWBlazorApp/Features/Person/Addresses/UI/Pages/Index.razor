@page "/aw/addresses"
@attribute [Authorize]
@using AWBlazorApp.Features.Person.Addresses.Domain
@using AWBlazorApp.Features.Person.Addresses.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="AddressDto"
          @ref="page"
          Title="Addresses"
          Caption="Person.Address"
          NewButtonLabel="New address"
          HistoryRoute="aw/addresses/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="address"
          DeleteConfirmMessage="@(row => $"Permanently delete address #{row.Id}?")">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterCity" Label="City contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterPostalCode" Label="Postal code starts with" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="AddressDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="Address" PropertyName="@nameof(AddressDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="AddressDto" TProperty="string" Property="x => x.AddressLine1" Title="Line 1">
            <HeaderTemplate><GridColumnHeader TEntity="Address" PropertyName="@nameof(AddressDto.AddressLine1)" Title="Line 1" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="AddressDto" TProperty="string" Property="x => x.AddressLine2" Title="Line 2">
            <HeaderTemplate><GridColumnHeader TEntity="Address" PropertyName="@nameof(AddressDto.AddressLine2)" Title="Line 2" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="AddressDto" TProperty="string" Property="x => x.City" Title="City">
            <HeaderTemplate><GridColumnHeader TEntity="Address" PropertyName="@nameof(AddressDto.City)" Title="City" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="AddressDto" TProperty="int" Property="x => x.StateProvinceId" Title="State id">
            <HeaderTemplate><GridColumnHeader TEntity="Address" PropertyName="@nameof(AddressDto.StateProvinceId)" Title="State id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="AddressDto" TProperty="string" Property="x => x.PostalCode" Title="Postal">
            <HeaderTemplate><GridColumnHeader TEntity="Address" PropertyName="@nameof(AddressDto.PostalCode)" Title="Postal" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="AddressDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="Address" PropertyName="@nameof(AddressDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<AddressDto> page = null!;
    private string? filterCity;
    private string? filterPostalCode;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<AddressDto>> LoadServerDataAsync(GridState<AddressDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Addresses.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCity))
        {
            var c = filterCity.Trim();
            query = query.Where(x => x.City.Contains(c));
        }
        if (!string.IsNullOrWhiteSpace(filterPostalCode))
        {
            var p = filterPostalCode.Trim();
            query = query.Where(x => x.PostalCode.StartsWith(p));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(AddressDto.Id)              => sort.Descending ? query.OrderByDescending(x => x.Id)              : query.OrderBy(x => x.Id),
            nameof(AddressDto.AddressLine1)    => sort.Descending ? query.OrderByDescending(x => x.AddressLine1)    : query.OrderBy(x => x.AddressLine1),
            nameof(AddressDto.AddressLine2)    => sort.Descending ? query.OrderByDescending(x => x.AddressLine2)    : query.OrderBy(x => x.AddressLine2),
            nameof(AddressDto.City)            => sort.Descending ? query.OrderByDescending(x => x.City)            : query.OrderBy(x => x.City),
            nameof(AddressDto.StateProvinceId) => sort.Descending ? query.OrderByDescending(x => x.StateProvinceId) : query.OrderBy(x => x.StateProvinceId),
            nameof(AddressDto.PostalCode)      => sort.Descending ? query.OrderByDescending(x => x.PostalCode)      : query.OrderBy(x => x.PostalCode),
            nameof(AddressDto.ModifiedDate)    => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)    : query.OrderBy(x => x.ModifiedDate),
            _                                  => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<AddressDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<AddressDialog>("New address", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Address created.", Severity.Success);
    }

    private async Task OpenEditAsync(AddressDto row)
    {
        var parameters = new DialogParameters<AddressDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<AddressDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Address updated.", Severity.Success);
    }

    private async Task DeleteAsync(AddressDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Addresses.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Address no longer exists.", Severity.Warning); return; }
        db.Addresses.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Address deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
