@page "/enterprise/product-lines"
@attribute [Authorize]
@using AWBlazorApp.Features.Enterprise.Assets.Domain
@using AWBlazorApp.Features.Enterprise.CostCenters.Domain
@using AWBlazorApp.Features.Enterprise.OrgUnits.Domain
@using AWBlazorApp.Features.Enterprise.Organizations.Domain
@using AWBlazorApp.Features.Enterprise.ProductLines.Domain
@using AWBlazorApp.Features.Enterprise.Stations.Domain
@using AWBlazorApp.Features.Enterprise.Assets.Dtos
@using AWBlazorApp.Features.Enterprise.CostCenters.Dtos
@using AWBlazorApp.Features.Enterprise.OrgUnits.Dtos
@using AWBlazorApp.Features.Enterprise.Organizations.Dtos
@using AWBlazorApp.Features.Enterprise.ProductLines.Dtos
@using AWBlazorApp.Features.Enterprise.Stations.Dtos
@using AWBlazorApp.Features.Enterprise.Assets.Application.Services
@using AWBlazorApp.Features.Enterprise.CostCenters.Application.Services
@using AWBlazorApp.Features.Enterprise.OrgUnits.Application.Services
@using AWBlazorApp.Features.Enterprise.Organizations.Application.Services
@using AWBlazorApp.Features.Enterprise.ProductLines.Application.Services
@using AWBlazorApp.Features.Enterprise.Stations.Application.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Product lines</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Product lines</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">org.ProductLine — management-level grouping above product categories</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="enterprise/product-lines/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New product line</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterCode" Label="Code contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="bool?" @bind-Value="filterIsActive" Label="Active" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="bool?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@true">Active</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@false">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="ProductLineDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <HierarchyColumn T="ProductLineDto" />
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Description" Title="Description" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate></TemplateColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent><ProductLineExpandedRow ProductLineId="@context.Item.Id" /></ChildRowContent>
        <PagerContent><MudDataGridPager T="ProductLineDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<ProductLineDto> grid = null!;
    private bool _loading = true;
    private string? filterCode;
    private string? filterName;
    private bool? filterIsActive;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductLineDto>> LoadServerDataAsync(GridState<ProductLineDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.ProductLines.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterCode)) { var n = filterCode.Trim(); query = query.Where(x => x.Code.Contains(n)); }
            if (!string.IsNullOrWhiteSpace(filterName)) { var n = filterName.Trim(); query = query.Where(x => x.Name.Contains(n)); }
            if (filterIsActive.HasValue) query = query.Where(x => x.IsActive == filterIsActive.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(ProductLineDto.Id)   => sort.Descending ? query.OrderByDescending(x => x.Id)   : query.OrderBy(x => x.Id),
                nameof(ProductLineDto.Code) => sort.Descending ? query.OrderByDescending(x => x.Code) : query.OrderBy(x => x.Code),
                nameof(ProductLineDto.Name) => sort.Descending ? query.OrderByDescending(x => x.Name) : query.OrderBy(x => x.Name),
                _ => query.OrderBy(x => x.Code),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ProductLineDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductLineDialog>("New product line", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Product line created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(ProductLineDto row)
    {
        var parameters = new DialogParameters<ProductLineDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductLineDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Product line updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(ProductLineDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete product line?", $"Delete \"{row.Name}\"?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductLines.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); await grid.ReloadServerData(); return; }
        var by = await GetCurrentUserNameAsync();
        db.ProductLineAuditLogs.Add(ProductLineAuditService.RecordDelete(entity, by));
        db.ProductLines.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Product line deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await grid.ReloadServerData();
    }

    private void OpenHistory(ProductLineDto row) => Navigation.NavigateTo($"enterprise/product-lines/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
