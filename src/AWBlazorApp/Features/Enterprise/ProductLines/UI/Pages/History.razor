@page "/enterprise/product-lines/history"
@page "/enterprise/product-lines/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Product line history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium"
                       OnClick="@(() => Navigation.NavigateTo("enterprise/product-lines"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Product line history" : $"History for product line #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="enterprise/product-lines/history">All history</MudButton>
        }
    </MudStack>

    <AuditHistoryGrid EntityType="ProductLine" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
