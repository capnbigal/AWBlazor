@page "/enterprise/organizations/history"
@page "/enterprise/organizations/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Organization history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium"
                       OnClick="@(() => Navigation.NavigateTo("enterprise/organizations"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Organization history" : $"History for organization #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="enterprise/organizations/history">All history</MudButton>
        }
    </MudStack>

    <AuditHistoryGrid EntityType="Organization" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
