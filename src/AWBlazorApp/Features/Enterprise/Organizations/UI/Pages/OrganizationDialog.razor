@using AWBlazorApp.Features.Enterprise.Assets.Domain
@using AWBlazorApp.Features.Enterprise.CostCenters.Domain
@using AWBlazorApp.Features.Enterprise.OrgUnits.Domain
@using AWBlazorApp.Features.Enterprise.Organizations.Domain
@using AWBlazorApp.Features.Enterprise.ProductLines.Domain
@using AWBlazorApp.Features.Enterprise.Stations.Domain
@using AWBlazorApp.Features.Enterprise.Assets.Dtos
@using AWBlazorApp.Features.Enterprise.CostCenters.Dtos
@using AWBlazorApp.Features.Enterprise.OrgUnits.Dtos
@using AWBlazorApp.Features.Enterprise.Organizations.Dtos
@using AWBlazorApp.Features.Enterprise.ProductLines.Dtos
@using AWBlazorApp.Features.Enterprise.Stations.Dtos
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateOrganizationRequest> CreateValidator
@inject MudFormValidator<UpdateOrganizationRequest> UpdateValidator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create organization" : $"Edit organization #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><MudTextField Value="@createModel.Code" ValueChanged="@((string? v) => createModel = createModel with { Code = v })" Label="Code" HelperText="Uppercase letters/digits/_ / -" Variant="Variant.Outlined" Required="true" MaxLength="32" /></MudItem>
                    <MudItem xs="12" sm="6"><MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="200" /></MudItem>
                    <MudItem xs="12" sm="6"><MudSwitch T="bool" Value="@createModel.IsPrimary" ValueChanged="@((bool v) => createModel = createModel with { IsPrimary = v })" Label="Primary organization" Color="Color.Primary" /></MudItem>
                    <MudItem xs="12" sm="6"><MudSwitch T="bool" Value="@createModel.IsActive" ValueChanged="@((bool v) => createModel = createModel with { IsActive = v })" Label="Active" Color="Color.Primary" /></MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Value="@createModel.ParentOrganizationId" ValueChanged="@((int? v) => createModel = createModel with { ParentOrganizationId = v })" Label="Parent organization" Variant="Variant.Outlined" Clearable="true">
                            <MudSelectItem T="int?" Value="@null">(none — this is a root)</MudSelectItem>
                            @foreach (var o in siblings) { <MudSelectItem T="int?" Value="@o.Id">@o.Code — @o.Name</MudSelectItem> }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6"><MudTextField Value="@createModel.ExternalRef" ValueChanged="@((string? v) => createModel = createModel with { ExternalRef = v })" Label="External ref (AS2 / D-U-N-S / etc)" Variant="Variant.Outlined" MaxLength="128" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><MudTextField Value="@updateModel.Code" ValueChanged="@((string? v) => updateModel = updateModel with { Code = v })" Label="Code" Variant="Variant.Outlined" Required="true" MaxLength="32" /></MudItem>
                    <MudItem xs="12" sm="6"><MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="200" /></MudItem>
                    <MudItem xs="12" sm="6"><MudSwitch T="bool" Value="@(updateModel.IsPrimary ?? false)" ValueChanged="@((bool v) => updateModel = updateModel with { IsPrimary = v })" Label="Primary organization" Color="Color.Primary" /></MudItem>
                    <MudItem xs="12" sm="6"><MudSwitch T="bool" Value="@(updateModel.IsActive ?? true)" ValueChanged="@((bool v) => updateModel = updateModel with { IsActive = v })" Label="Active" Color="Color.Primary" /></MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" Value="@updateModel.ParentOrganizationId" ValueChanged="@((int? v) => updateModel = updateModel with { ParentOrganizationId = v })" Label="Parent organization" Variant="Variant.Outlined" Clearable="true">
                            <MudSelectItem T="int?" Value="@null">(none — this is a root)</MudSelectItem>
                            @foreach (var o in siblings.Where(o => o.Id != Model!.Id)) { <MudSelectItem T="int?" Value="@o.Id">@o.Code — @o.Name</MudSelectItem> }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6"><MudTextField Value="@updateModel.ExternalRef" ValueChanged="@((string? v) => updateModel = updateModel with { ExternalRef = v })" Label="External ref" Variant="Variant.Outlined" MaxLength="128" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public OrganizationDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateOrganizationRequest createModel = new();
    private UpdateOrganizationRequest updateModel = new();
    private bool saving;
    private List<OrganizationDto> siblings = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        siblings = await db.Organizations.AsNoTracking().OrderBy(o => o.Code).Select(o => o.ToDto()).ToListAsync();

        if (Model is not null)
        {
            updateModel = new UpdateOrganizationRequest
            {
                Code = Model.Code, Name = Model.Name, IsPrimary = Model.IsPrimary,
                ParentOrganizationId = Model.ParentOrganizationId, ExternalRef = Model.ExternalRef,
                IsActive = Model.IsActive,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                db.Organizations.Add(entity);
                // AuditLogInterceptor writes the audit row inside this SaveChangesAsync.
                try { await db.SaveChangesAsync(); }
                catch (DbUpdateException ex) { Snackbar.Add($"Save failed: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); return; }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Organizations.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                updateModel.ApplyTo(entity);
                try { await db.SaveChangesAsync(); }
                catch (DbUpdateException ex) { Snackbar.Add($"Save failed: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); return; }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

}
