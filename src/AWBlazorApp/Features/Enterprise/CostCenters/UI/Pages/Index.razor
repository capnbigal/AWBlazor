@page "/enterprise/cost-centers"
@attribute [Authorize]
@using AWBlazorApp.Features.Enterprise.CostCenters.Domain
@using AWBlazorApp.Features.Enterprise.CostCenters.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="CostCenterDto"
          Title="Cost centers"
          Caption="org.CostCenter"
          NewButtonLabel="New cost center"
          HistoryRoute="enterprise/cost-centers/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="cost center"
          DeleteConfirmMessage="@(row => $"Delete \"{row.Name}\"?")">
    <Filters>
        <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterCode" Label="Code contains" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" sm="4"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" sm="4">
            <MudSelect T="bool?" @bind-Value="filterIsActive" Label="Active" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem T="bool?" Value="@null">(any)</MudSelectItem>
                <MudSelectItem T="bool?" Value="@true">Active</MudSelectItem>
                <MudSelectItem T="bool?" Value="@false">Inactive</MudSelectItem>
            </MudSelect>
        </MudItem>
    </Filters>
    <Columns>
        <HierarchyColumn T="CostCenterDto" />
        <PropertyColumn T="CostCenterDto" TProperty="int" Property="x => x.Id" Title="Id" />
        <PropertyColumn T="CostCenterDto" TProperty="string" Property="x => x.Code" Title="Code" />
        <PropertyColumn T="CostCenterDto" TProperty="string" Property="x => x.Name" Title="Name" />
        <PropertyColumn T="CostCenterDto" TProperty="int?" Property="x => x.OwnerBusinessEntityId" Title="Owner BE#" />
        <TemplateColumn T="CostCenterDto" Title="Active" Sortable="false"><CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate></TemplateColumn>
        <PropertyColumn T="CostCenterDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
    </Columns>
    <ExpandedContent Context="item">
        <CostCenterExpandedRow CostCenterId="@item.Id" />
    </ExpandedContent>
</CrudPage>

@code {
    private string? filterCode;
    private string? filterName;
    private bool? filterIsActive;

    private async Task<GridData<CostCenterDto>> LoadServerDataAsync(GridState<CostCenterDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CostCenters.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCode)) { var n = filterCode.Trim(); query = query.Where(x => x.Code.Contains(n)); }
        if (!string.IsNullOrWhiteSpace(filterName)) { var n = filterName.Trim(); query = query.Where(x => x.Name.Contains(n)); }
        if (filterIsActive.HasValue) query = query.Where(x => x.IsActive == filterIsActive.Value);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CostCenterDto.Id)   => sort.Descending ? query.OrderByDescending(x => x.Id)   : query.OrderBy(x => x.Id),
            nameof(CostCenterDto.Code) => sort.Descending ? query.OrderByDescending(x => x.Code) : query.OrderBy(x => x.Code),
            nameof(CostCenterDto.Name) => sort.Descending ? query.OrderByDescending(x => x.Name) : query.OrderBy(x => x.Name),
            _ => query.OrderBy(x => x.Code),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CostCenterDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CostCenterDialog>("New cost center", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Cost center created.", Severity.Success);
    }

    private async Task OpenEditAsync(CostCenterDto row)
    {
        var parameters = new DialogParameters<CostCenterDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CostCenterDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Cost center updated.", Severity.Success);
    }

    private async Task DeleteAsync(CostCenterDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CostCenters.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.CostCenters.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Cost center deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
