@using AWBlazorApp.Features.Enterprise.Assets.Domain
@using AWBlazorApp.Features.Enterprise.CostCenters.Domain
@using AWBlazorApp.Features.Enterprise.OrgUnits.Domain
@using AWBlazorApp.Features.Enterprise.Organizations.Domain
@using AWBlazorApp.Features.Enterprise.ProductLines.Domain
@using AWBlazorApp.Features.Enterprise.Stations.Domain
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="my-2" />
}
else
{
    <div class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Scope</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudText Typo="Typo.body2">Organization: <strong>@(orgCode ?? "—")</strong></MudText>
                    <MudText Typo="Typo.body2">Org units rolling up: <strong>@orgUnitCount</strong></MudText>
                    <MudText Typo="Typo.body2">Owner Business Entity #: <strong>@(ownerBeId?.ToString() ?? "—")</strong></MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Links</MudText>
                <MudStack Spacing="1" Class="mt-1">
                    <MudLink Href="@($"enterprise/org-units?costCenterId={CostCenterId}")">Org units in this cost center</MudLink>
                </MudStack>
            </MudItem>
        </MudGrid>
    </div>
}

@code {
    [Parameter] public int CostCenterId { get; set; }

    private bool loading = true;
    private string? orgCode;
    private int orgUnitCount;
    private int? ownerBeId;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var cc = await db.CostCenters.AsNoTracking().FirstOrDefaultAsync(c => c.Id == CostCenterId);
        if (cc is not null)
        {
            ownerBeId = cc.OwnerBusinessEntityId;
            orgCode = await db.Organizations.AsNoTracking().Where(o => o.Id == cc.OrganizationId).Select(o => o.Code).FirstOrDefaultAsync();
        }
        orgUnitCount = await db.OrgUnits.CountAsync(u => u.CostCenterId == CostCenterId);
        loading = false;
    }
}
