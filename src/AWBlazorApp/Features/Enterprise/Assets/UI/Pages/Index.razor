@page "/enterprise/assets"
@attribute [Authorize]
@using AWBlazorApp.Features.Enterprise.Assets.Domain
@using AWBlazorApp.Features.Enterprise.CostCenters.Domain
@using AWBlazorApp.Features.Enterprise.OrgUnits.Domain
@using AWBlazorApp.Features.Enterprise.Organizations.Domain
@using AWBlazorApp.Features.Enterprise.ProductLines.Domain
@using AWBlazorApp.Features.Enterprise.Stations.Domain
@using AWBlazorApp.Features.Enterprise.Assets.Dtos
@using AWBlazorApp.Features.Enterprise.CostCenters.Dtos
@using AWBlazorApp.Features.Enterprise.OrgUnits.Dtos
@using AWBlazorApp.Features.Enterprise.Organizations.Dtos
@using AWBlazorApp.Features.Enterprise.ProductLines.Dtos
@using AWBlazorApp.Features.Enterprise.Stations.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Assets</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Assets / machines</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">org.Asset — physical equipment register</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="enterprise/assets/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New asset</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterAssetTag" Label="Tag contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="AssetType?" @bind-Value="filterAssetType" Label="Type" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="AssetType?" Value="@null">(any)</MudSelectItem>
                    @foreach (var k in Enum.GetValues<AssetType>())
                    { <MudSelectItem T="AssetType?" Value="@k">@k</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="AssetStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="AssetStatus?" Value="@null">(any)</MudSelectItem>
                    @foreach (var k in Enum.GetValues<AssetStatus>())
                    { <MudSelectItem T="AssetStatus?" Value="@k">@k</MudSelectItem> }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="AssetDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <HierarchyColumn T="AssetDto" />
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.AssetTag" Title="Tag" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.AssetType" Title="Type" />
            <PropertyColumn Property="x => x.Manufacturer" Title="Manufacturer" />
            <PropertyColumn Property="x => x.Model" Title="Model" />
            <PropertyColumn Property="x => x.SerialNumber" Title="Serial" />
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)" Variant="Variant.Filled">@context.Item.Status</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.CommissionedAt" Title="Commissioned" Format="yyyy-MM-dd" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent><AssetExpandedRow AssetId="@context.Item.Id" /></ChildRowContent>
        <PagerContent><MudDataGridPager T="AssetDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<AssetDto> grid = null!;
    private bool _loading = true;
    private string? filterAssetTag;
    private string? filterName;
    private AssetType? filterAssetType;
    private AssetStatus? filterStatus;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<AssetDto>> LoadServerDataAsync(GridState<AssetDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.Assets.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterAssetTag)) { var n = filterAssetTag.Trim(); query = query.Where(x => x.AssetTag.Contains(n)); }
            if (!string.IsNullOrWhiteSpace(filterName)) { var n = filterName.Trim(); query = query.Where(x => x.Name.Contains(n)); }
            if (filterAssetType.HasValue) query = query.Where(x => x.AssetType == filterAssetType.Value);
            if (filterStatus.HasValue) query = query.Where(x => x.Status == filterStatus.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(AssetDto.Id)             => sort.Descending ? query.OrderByDescending(x => x.Id)             : query.OrderBy(x => x.Id),
                nameof(AssetDto.AssetTag)       => sort.Descending ? query.OrderByDescending(x => x.AssetTag)       : query.OrderBy(x => x.AssetTag),
                nameof(AssetDto.Name)           => sort.Descending ? query.OrderByDescending(x => x.Name)           : query.OrderBy(x => x.Name),
                nameof(AssetDto.AssetType)      => sort.Descending ? query.OrderByDescending(x => x.AssetType)      : query.OrderBy(x => x.AssetType),
                nameof(AssetDto.CommissionedAt) => sort.Descending ? query.OrderByDescending(x => x.CommissionedAt) : query.OrderBy(x => x.CommissionedAt),
                _ => query.OrderBy(x => x.AssetTag),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<AssetDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<AssetDialog>("New asset", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Asset created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(AssetDto row)
    {
        var parameters = new DialogParameters<AssetDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<AssetDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Asset updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(AssetDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete asset?", $"Delete \"{row.Name}\" (tag {row.AssetTag})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Assets.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); await grid.ReloadServerData(); return; }
        db.Assets.Remove(entity);
        // AuditLogInterceptor writes the Deleted audit row inside this SaveChangesAsync.
        try { await db.SaveChangesAsync(); Snackbar.Add("Asset deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await grid.ReloadServerData();
    }

    private void OpenHistory(AssetDto row) => Navigation.NavigateTo($"enterprise/assets/history/{row.Id}");

    private static Color StatusColor(AssetStatus s) => s switch
    {
        AssetStatus.Active      => Color.Success,
        AssetStatus.Standby     => Color.Info,
        AssetStatus.Maintenance => Color.Warning,
        AssetStatus.Retired     => Color.Dark,
        _ => Color.Default,
    };
}
