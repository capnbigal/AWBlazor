@page "/enterprise/stations"
@attribute [Authorize]
@using AWBlazorApp.Features.Enterprise.Assets.Domain
@using AWBlazorApp.Features.Enterprise.CostCenters.Domain
@using AWBlazorApp.Features.Enterprise.OrgUnits.Domain
@using AWBlazorApp.Features.Enterprise.Organizations.Domain
@using AWBlazorApp.Features.Enterprise.ProductLines.Domain
@using AWBlazorApp.Features.Enterprise.Stations.Domain
@using AWBlazorApp.Features.Enterprise.Assets.Dtos
@using AWBlazorApp.Features.Enterprise.CostCenters.Dtos
@using AWBlazorApp.Features.Enterprise.OrgUnits.Dtos
@using AWBlazorApp.Features.Enterprise.Organizations.Dtos
@using AWBlazorApp.Features.Enterprise.ProductLines.Dtos
@using AWBlazorApp.Features.Enterprise.Stations.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Stations</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Stations</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">org.Station — leaf of the hierarchy, where people (and sometimes machines) work</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="enterprise/stations/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New station</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3">
                <MudSelect T="StationKind?" @bind-Value="filterKind" Label="Kind" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="StationKind?" Value="@null">(any)</MudSelectItem>
                    @foreach (var k in Enum.GetValues<StationKind>())
                    { <MudSelectItem T="StationKind?" Value="@k">@k</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterCode" Label="Code contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="bool?" @bind-Value="filterIsActive" Label="Active" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="bool?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@true">Active</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@false">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="StationDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <HierarchyColumn T="StationDto" />
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.StationKind" Title="Kind" />
            <PropertyColumn Property="x => x.OrgUnitId" Title="Org unit #" />
            <PropertyColumn Property="x => x.OperatorBusinessEntityId" Title="Operator BE#" />
            <PropertyColumn Property="x => x.AssetId" Title="Asset #" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate></TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent><StationExpandedRow StationId="@context.Item.Id" /></ChildRowContent>
        <PagerContent><MudDataGridPager T="StationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<StationDto> grid = null!;
    private bool _loading = true;
    private StationKind? filterKind;
    private string? filterCode;
    private string? filterName;
    private bool? filterIsActive;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<StationDto>> LoadServerDataAsync(GridState<StationDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.Stations.AsNoTracking();
            if (filterKind.HasValue) query = query.Where(x => x.StationKind == filterKind.Value);
            if (!string.IsNullOrWhiteSpace(filterCode)) { var n = filterCode.Trim(); query = query.Where(x => x.Code.Contains(n)); }
            if (!string.IsNullOrWhiteSpace(filterName)) { var n = filterName.Trim(); query = query.Where(x => x.Name.Contains(n)); }
            if (filterIsActive.HasValue) query = query.Where(x => x.IsActive == filterIsActive.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(StationDto.Id)          => sort.Descending ? query.OrderByDescending(x => x.Id)          : query.OrderBy(x => x.Id),
                nameof(StationDto.Code)        => sort.Descending ? query.OrderByDescending(x => x.Code)        : query.OrderBy(x => x.Code),
                nameof(StationDto.Name)        => sort.Descending ? query.OrderByDescending(x => x.Name)        : query.OrderBy(x => x.Name),
                nameof(StationDto.StationKind) => sort.Descending ? query.OrderByDescending(x => x.StationKind) : query.OrderBy(x => x.StationKind),
                _ => query.OrderBy(x => x.OrgUnitId).ThenBy(x => x.Code),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<StationDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<StationDialog>("New station", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Station created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(StationDto row)
    {
        var parameters = new DialogParameters<StationDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<StationDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Station updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(StationDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete station?", $"Delete station #{row.Id} \"{row.Name}\"?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Stations.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); await grid.ReloadServerData(); return; }
        db.Stations.Remove(entity);
        // AuditLogInterceptor writes the Deleted audit row inside this SaveChangesAsync.
        try { await db.SaveChangesAsync(); Snackbar.Add("Station deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await grid.ReloadServerData();
    }

    private void OpenHistory(StationDto row) => Navigation.NavigateTo($"enterprise/stations/history/{row.Id}");
}
