@page "/enterprise/org-units/history"
@page "/enterprise/org-units/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Org unit history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium"
                       OnClick="@(() => Navigation.NavigateTo("enterprise/org-units"))" />
        <MudText Typo="Typo.h4">@(SlotId is null ? "Org unit history" : $"History for org unit #{SlotId}")</MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="enterprise/org-units/history">All history</MudButton>
        }
    </MudStack>

    <AuditHistoryGrid EntityType="OrgUnit" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
