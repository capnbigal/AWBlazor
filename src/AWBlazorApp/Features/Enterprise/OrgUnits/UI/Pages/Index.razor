@page "/enterprise/org-units"
@attribute [Authorize]
@using AWBlazorApp.Features.Enterprise.Assets.Domain
@using AWBlazorApp.Features.Enterprise.CostCenters.Domain
@using AWBlazorApp.Features.Enterprise.OrgUnits.Domain
@using AWBlazorApp.Features.Enterprise.Organizations.Domain
@using AWBlazorApp.Features.Enterprise.ProductLines.Domain
@using AWBlazorApp.Features.Enterprise.Stations.Domain
@using AWBlazorApp.Features.Enterprise.Assets.Dtos
@using AWBlazorApp.Features.Enterprise.CostCenters.Dtos
@using AWBlazorApp.Features.Enterprise.OrgUnits.Dtos
@using AWBlazorApp.Features.Enterprise.Organizations.Dtos
@using AWBlazorApp.Features.Enterprise.ProductLines.Dtos
@using AWBlazorApp.Features.Enterprise.Stations.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Org units</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Org units</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">org.OrgUnit — Plant → Division → Department → Subdepartment → Team → Area</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AccountTree" Href="enterprise/tree">Tree view</MudButton>
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="enterprise/org-units/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New org unit</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3">
                <MudSelect T="OrgUnitKind?" @bind-Value="filterKind" Label="Kind" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="OrgUnitKind?" Value="@null">(any)</MudSelectItem>
                    @foreach (var k in Enum.GetValues<OrgUnitKind>())
                    { <MudSelectItem T="OrgUnitKind?" Value="@k">@k</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterCode" Label="Code contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="bool?" @bind-Value="filterIsActive" Label="Active" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="bool?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@true">Active</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@false">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="OrgUnitDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="50">
        <Columns>
            <HierarchyColumn T="OrgUnitDto" />
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.Kind" Title="Kind" />
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Path" Title="Path" />
            <PropertyColumn Property="x => x.Depth" Title="Depth" />
            <TemplateColumn Title="Active" Sortable="false">
                <CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent><OrgUnitExpandedRow OrgUnitId="@context.Item.Id" /></ChildRowContent>
        <PagerContent><MudDataGridPager T="OrgUnitDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<OrgUnitDto> grid = null!;
    private bool _loading = true;
    private OrgUnitKind? filterKind;
    private string? filterCode;
    private string? filterName;
    private bool? filterIsActive;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<OrgUnitDto>> LoadServerDataAsync(GridState<OrgUnitDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.OrgUnits.AsNoTracking();
            if (filterKind.HasValue) query = query.Where(x => x.Kind == filterKind.Value);
            if (!string.IsNullOrWhiteSpace(filterCode)) { var n = filterCode.Trim(); query = query.Where(x => x.Code.Contains(n)); }
            if (!string.IsNullOrWhiteSpace(filterName)) { var n = filterName.Trim(); query = query.Where(x => x.Name.Contains(n)); }
            if (filterIsActive.HasValue) query = query.Where(x => x.IsActive == filterIsActive.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(OrgUnitDto.Id)    => sort.Descending ? query.OrderByDescending(x => x.Id)    : query.OrderBy(x => x.Id),
                nameof(OrgUnitDto.Kind)  => sort.Descending ? query.OrderByDescending(x => x.Kind)  : query.OrderBy(x => x.Kind),
                nameof(OrgUnitDto.Code)  => sort.Descending ? query.OrderByDescending(x => x.Code)  : query.OrderBy(x => x.Code),
                nameof(OrgUnitDto.Name)  => sort.Descending ? query.OrderByDescending(x => x.Name)  : query.OrderBy(x => x.Name),
                nameof(OrgUnitDto.Depth) => sort.Descending ? query.OrderByDescending(x => x.Depth) : query.OrderBy(x => x.Depth),
                _ => query.OrderBy(x => x.Path).ThenBy(x => x.Code),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<OrgUnitDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<OrgUnitDialog>("New org unit", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Org unit created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(OrgUnitDto row)
    {
        var parameters = new DialogParameters<OrgUnitDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<OrgUnitDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Org unit updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(OrgUnitDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete org unit?", $"Delete \"{row.Name}\"? Cannot delete if it has children.", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        if (await db.OrgUnits.AnyAsync(x => x.ParentOrgUnitId == row.Id))
        {
            Snackbar.Add("Cannot delete — this org unit has children.", Severity.Warning);
            return;
        }
        var entity = await db.OrgUnits.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); await grid.ReloadServerData(); return; }

        db.OrgUnits.Remove(entity);
        // AuditLogInterceptor writes the Deleted audit row inside this SaveChangesAsync.
        try { await db.SaveChangesAsync(); Snackbar.Add("Org unit deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await grid.ReloadServerData();
    }

    private void OpenHistory(OrgUnitDto row) => Navigation.NavigateTo($"enterprise/org-units/history/{row.Id}");
}
