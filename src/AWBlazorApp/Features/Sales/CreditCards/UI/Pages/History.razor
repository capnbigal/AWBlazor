@page "/aw/credit-cards/history"
@page "/aw/credit-cards/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Credit card history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/credit-cards"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Credit card history" : $"History for CreditCard #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="CreditCard" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
