@page "/aw/credit-cards"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CreditCards.Domain
@using AWBlazorApp.Features.Sales.CreditCards.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="CreditCardDto"
          @ref="page"
          Title="Credit cards"
          Caption="Sales.CreditCard"
          NewButtonLabel="New credit card"
          HistoryRoute="aw/credit-cards/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="credit card"
          DeleteConfirmMessage="@(row => $"Permanently delete credit card #{row.Id}?")">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterCardType" Label="Card type" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="CreditCardDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CreditCardDto" TProperty="string" Property="x => x.CardType" Title="Card type">
            <HeaderTemplate><GridColumnHeader TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.CardType)" Title="Card type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CreditCardDto" TProperty="string" Property="x => x.CardNumber" Title="Card number">
            <HeaderTemplate><GridColumnHeader TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.CardNumber)" Title="Card number" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CreditCardDto" TProperty="byte" Property="x => x.ExpMonth" Title="Exp month">
            <HeaderTemplate><GridColumnHeader TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.ExpMonth)" Title="Exp month" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CreditCardDto" TProperty="short" Property="x => x.ExpYear" Title="Exp year">
            <HeaderTemplate><GridColumnHeader TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.ExpYear)" Title="Exp year" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CreditCardDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="CreditCard" PropertyName="@nameof(CreditCardDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<CreditCardDto> page = null!;
    private string? filterCardType;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<CreditCardDto>> LoadServerDataAsync(GridState<CreditCardDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CreditCards.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCardType)) query = query.Where(x => x.CardType == filterCardType.Trim());
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CreditCardDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(CreditCardDto.CardType)     => sort.Descending ? query.OrderByDescending(x => x.CardType)     : query.OrderBy(x => x.CardType),
            nameof(CreditCardDto.CardNumber)   => sort.Descending ? query.OrderByDescending(x => x.CardNumber)   : query.OrderBy(x => x.CardNumber),
            nameof(CreditCardDto.ExpMonth)     => sort.Descending ? query.OrderByDescending(x => x.ExpMonth)     : query.OrderBy(x => x.ExpMonth),
            nameof(CreditCardDto.ExpYear)      => sort.Descending ? query.OrderByDescending(x => x.ExpYear)      : query.OrderBy(x => x.ExpYear),
            nameof(CreditCardDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                  => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CreditCardDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CreditCardDialog>("New credit card", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Credit card created.", Severity.Success);
    }

    private async Task OpenEditAsync(CreditCardDto row)
    {
        var parameters = new DialogParameters<CreditCardDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CreditCardDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Credit card updated.", Severity.Success);
    }

    private async Task DeleteAsync(CreditCardDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CreditCards.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Credit card no longer exists.", Severity.Warning); return; }
        db.CreditCards.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Credit card deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
