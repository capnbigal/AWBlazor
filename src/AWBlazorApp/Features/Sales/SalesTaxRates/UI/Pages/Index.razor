@page "/aw/sales-tax-rates"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.SalesTaxRates.Domain
@using AWBlazorApp.Features.Sales.SalesTaxRates.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="SalesTaxRateDto"
          Title="Sales tax rates"
          Caption="Sales.SalesTaxRate"
          NewButtonLabel="New tax rate"
          HistoryRoute="aw/sales-tax-rates/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="tax rate"
          DeleteConfirmMessage="@(row => $"Permanently delete tax rate #{row.Id} \"{row.Name}\"?")">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" sm="6"><MudNumericField T="int?" @bind-Value="filterStateProvinceId" Label="State/prov id" Variant="Variant.Outlined" Clearable="true" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="SalesTaxRateDto" TProperty="int" Property="x => x.Id" Title="Id" />
        <PropertyColumn T="SalesTaxRateDto" TProperty="int" Property="x => x.StateProvinceId" Title="State/prov" />
        <PropertyColumn T="SalesTaxRateDto" TProperty="byte" Property="x => x.TaxType" Title="Type" />
        <PropertyColumn T="SalesTaxRateDto" TProperty="decimal" Property="x => x.TaxRate" Title="Rate" Format="F4" />
        <PropertyColumn T="SalesTaxRateDto" TProperty="string" Property="x => x.Name" Title="Name" />
        <PropertyColumn T="SalesTaxRateDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
    </Columns>
</CrudPage>

@code {
    private string? filterName;
    private int? filterStateProvinceId;

    private async Task<GridData<SalesTaxRateDto>> LoadServerDataAsync(GridState<SalesTaxRateDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesTaxRates.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var needle = filterName.Trim();
            query = query.Where(x => x.Name.Contains(needle));
        }
        if (filterStateProvinceId.HasValue) query = query.Where(x => x.StateProvinceId == filterStateProvinceId.Value);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SalesTaxRateDto.Id)              => sort.Descending ? query.OrderByDescending(x => x.Id)              : query.OrderBy(x => x.Id),
            nameof(SalesTaxRateDto.StateProvinceId) => sort.Descending ? query.OrderByDescending(x => x.StateProvinceId) : query.OrderBy(x => x.StateProvinceId),
            nameof(SalesTaxRateDto.TaxType)         => sort.Descending ? query.OrderByDescending(x => x.TaxType)         : query.OrderBy(x => x.TaxType),
            nameof(SalesTaxRateDto.TaxRate)         => sort.Descending ? query.OrderByDescending(x => x.TaxRate)         : query.OrderBy(x => x.TaxRate),
            nameof(SalesTaxRateDto.Name)            => sort.Descending ? query.OrderByDescending(x => x.Name)            : query.OrderBy(x => x.Name),
            nameof(SalesTaxRateDto.ModifiedDate)    => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)    : query.OrderBy(x => x.ModifiedDate),
            _                                       => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SalesTaxRateDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesTaxRateDialog>("New tax rate", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Tax rate created.", Severity.Success);
    }

    private async Task OpenEditAsync(SalesTaxRateDto row)
    {
        var parameters = new DialogParameters<SalesTaxRateDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesTaxRateDialog>($"Edit tax rate #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Tax rate updated.", Severity.Success);
    }

    private async Task DeleteAsync(SalesTaxRateDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesTaxRates.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Tax rate no longer exists.", Severity.Warning); return; }
        db.SalesTaxRates.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Tax rate deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
