@page "/aw/country-region-currencies"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Domain
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<CrudPage TDto="CountryRegionCurrencyDto"
          Title="Country ↔ currency"
          Caption="Sales.CountryRegionCurrency · composite PK (CountryRegionCode, CurrencyCode)"
          NewButtonLabel="New link"
          HistoryRoute="aw/country-region-currencies/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterCountry" Label="Country code" Variant="Variant.Outlined" MaxLength="3" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="CountryRegionCurrencyDto" TProperty="string" Property="x => x.CountryRegionCode" Title="Country code" />
        <PropertyColumn T="CountryRegionCurrencyDto" TProperty="string" Property="x => x.CurrencyCode" Title="Currency code" />
        <PropertyColumn T="CountryRegionCurrencyDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/country-region-currencies/history?countryRegionCode={row.CountryRegionCode}&currencyCode={row.CurrencyCode}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private string? filterCountry;

    private async Task<GridData<CountryRegionCurrencyDto>> LoadServerDataAsync(GridState<CountryRegionCurrencyDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CountryRegionCurrencies.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCountry))
        {
            var c = filterCountry.Trim();
            query = query.Where(x => x.CountryRegionCode == c);
        }

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CountryRegionCurrencyDto.CountryRegionCode) => sort.Descending ? query.OrderByDescending(x => x.CountryRegionCode) : query.OrderBy(x => x.CountryRegionCode),
            nameof(CountryRegionCurrencyDto.CurrencyCode)      => sort.Descending ? query.OrderByDescending(x => x.CurrencyCode)      : query.OrderBy(x => x.CurrencyCode),
            nameof(CountryRegionCurrencyDto.ModifiedDate)      => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)      : query.OrderBy(x => x.ModifiedDate),
            _ => query.OrderBy(x => x.CountryRegionCode).ThenBy(x => x.CurrencyCode),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CountryRegionCurrencyDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CountryRegionCurrencyDialog>("Link a currency to a country", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(CountryRegionCurrencyDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.CountryRegionCode}, {row.CurrencyCode})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CountryRegionCurrencies.FirstOrDefaultAsync(t => t.CountryRegionCode == row.CountryRegionCode && t.CurrencyCode == row.CurrencyCode);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); return; }
        db.CountryRegionCurrencies.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
