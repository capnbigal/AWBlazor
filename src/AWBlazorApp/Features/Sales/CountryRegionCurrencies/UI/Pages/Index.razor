@page "/aw/country-region-currencies"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Domain
@using AWBlazorApp.Features.Sales.CreditCards.Domain
@using AWBlazorApp.Features.Sales.Currencies.Domain
@using AWBlazorApp.Features.Sales.CurrencyRates.Domain
@using AWBlazorApp.Features.Sales.Customers.Domain
@using AWBlazorApp.Features.Sales.PersonCreditCards.Domain
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesPeople.Domain
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Domain
@using AWBlazorApp.Features.Sales.SalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesTaxRates.Domain
@using AWBlazorApp.Features.Sales.SalesTerritories.Domain
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Domain
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Domain
@using AWBlazorApp.Features.Sales.SpecialOffers.Domain
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Domain
@using AWBlazorApp.Features.Sales.Stores.Domain
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Dtos
@using AWBlazorApp.Features.Sales.CreditCards.Dtos
@using AWBlazorApp.Features.Sales.Currencies.Dtos
@using AWBlazorApp.Features.Sales.CurrencyRates.Dtos
@using AWBlazorApp.Features.Sales.Customers.Dtos
@using AWBlazorApp.Features.Sales.PersonCreditCards.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesPeople.Dtos
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Dtos
@using AWBlazorApp.Features.Sales.SalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesTaxRates.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritories.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Dtos
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Dtos
@using AWBlazorApp.Features.Sales.SpecialOffers.Dtos
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Dtos
@using AWBlazorApp.Features.Sales.Stores.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Country ↔ currency</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Country ↔ currency</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.CountryRegionCurrency · composite PK (CountryRegionCode, CurrencyCode)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/country-region-currencies/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New link</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudTextField @bind-Value="filterCountry" Label="Country code" Variant="Variant.Outlined" MaxLength="3" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="CountryRegionCurrencyDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.CountryRegionCode" Title="Country code">
                <HeaderTemplate><GridColumnHeader TEntity="CountryRegionCurrency" PropertyName="@nameof(CountryRegionCurrencyDto.CountryRegionCode)" Title="Country code" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CurrencyCode" Title="Currency code">
                <HeaderTemplate><GridColumnHeader TEntity="CountryRegionCurrency" PropertyName="@nameof(CountryRegionCurrencyDto.CurrencyCode)" Title="Currency code" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="CountryRegionCurrency" PropertyName="@nameof(CountryRegionCurrencyDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="CountryRegionCurrencyDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<CountryRegionCurrencyDto> grid = null!;
    private bool _loading = true;
    private string? filterCountry;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<CountryRegionCurrencyDto>> LoadServerDataAsync(GridState<CountryRegionCurrencyDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.CountryRegionCurrencies.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterCountry))
            {
                var c = filterCountry.Trim();
                query = query.Where(x => x.CountryRegionCode == c);
            }
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);

            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(CountryRegionCurrencyDto.CountryRegionCode) => sort.Descending ? query.OrderByDescending(x => x.CountryRegionCode) : query.OrderBy(x => x.CountryRegionCode),
                nameof(CountryRegionCurrencyDto.CurrencyCode) => sort.Descending ? query.OrderByDescending(x => x.CurrencyCode) : query.OrderBy(x => x.CurrencyCode),
                nameof(CountryRegionCurrencyDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _ => query.OrderBy(x => x.CountryRegionCode).ThenBy(x => x.CurrencyCode),
            };

            var rows = await query
                .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<CountryRegionCurrencyDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CountryRegionCurrencyDialog>("Link a currency to a country", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Link created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(CountryRegionCurrencyDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.CountryRegionCode}, {row.CurrencyCode})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CountryRegionCurrencies
            .FirstOrDefaultAsync(t => t.CountryRegionCode == row.CountryRegionCode && t.CurrencyCode == row.CurrencyCode);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.CountryRegionCurrencies.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Link deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(CountryRegionCurrencyDto row)
        => Navigation.NavigateTo($"aw/country-region-currencies/history?countryRegionCode={row.CountryRegionCode}&currencyCode={row.CurrencyCode}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
