@page "/aw/sales-order-header-sales-reasons"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<CrudPage TDto="SalesOrderHeaderSalesReasonDto"
          Title="Sales order ↔ reason"
          Caption="Sales.SalesOrderHeaderSalesReason · composite PK (SalesOrderID, SalesReasonID)"
          NewButtonLabel="New link"
          HistoryRoute="aw/sales-order-header-sales-reasons/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12">
            <MudNumericField T="int?" @bind-Value="filterSalesOrderId" Label="Sales order id" Variant="Variant.Outlined" Clearable="true" />
        </MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="SalesOrderHeaderSalesReasonDto" TProperty="int" Property="x => x.SalesOrderId" Title="Sales order id" />
        <PropertyColumn T="SalesOrderHeaderSalesReasonDto" TProperty="int" Property="x => x.SalesReasonId" Title="Sales reason id" />
        <PropertyColumn T="SalesOrderHeaderSalesReasonDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/sales-order-header-sales-reasons/history?salesOrderId={row.SalesOrderId}&salesReasonId={row.SalesReasonId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private int? filterSalesOrderId;

    private async Task<GridData<SalesOrderHeaderSalesReasonDto>> LoadServerDataAsync(GridState<SalesOrderHeaderSalesReasonDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesOrderHeaderSalesReasons.AsNoTracking();
        if (filterSalesOrderId.HasValue) query = query.Where(x => x.SalesOrderId == filterSalesOrderId.Value);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SalesOrderHeaderSalesReasonDto.SalesOrderId) => sort.Descending ? query.OrderByDescending(x => x.SalesOrderId) : query.OrderBy(x => x.SalesOrderId),
            nameof(SalesOrderHeaderSalesReasonDto.SalesReasonId) => sort.Descending ? query.OrderByDescending(x => x.SalesReasonId) : query.OrderBy(x => x.SalesReasonId),
            nameof(SalesOrderHeaderSalesReasonDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _ => query.OrderBy(x => x.SalesOrderId).ThenBy(x => x.SalesReasonId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SalesOrderHeaderSalesReasonDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesOrderHeaderSalesReasonDialog>("Link a sales reason", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(SalesOrderHeaderSalesReasonDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.SalesOrderId}, {row.SalesReasonId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesOrderHeaderSalesReasons.FirstOrDefaultAsync(t => t.SalesOrderId == row.SalesOrderId && t.SalesReasonId == row.SalesReasonId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); return; }
        db.SalesOrderHeaderSalesReasons.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
