@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Sales order ↔ reason</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Sales order ↔ reason</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Sales.SalesOrderHeaderSalesReason · composite PK (SalesOrderID, SalesReasonID)</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/sales-order-header-sales-reasons/history">View audit history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New link</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudNumericField T="int?" @bind-Value="filterSalesOrderId" Label="Sales order id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="SalesOrderHeaderSalesReasonDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.SalesOrderId" Title="Sales order id">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeaderSalesReason" PropertyName="@nameof(SalesOrderHeaderSalesReasonDto.SalesOrderId)" Title="Sales order id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SalesReasonId" Title="Sales reason id">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeaderSalesReason" PropertyName="@nameof(SalesOrderHeaderSalesReasonDto.SalesReasonId)" Title="Sales reason id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeaderSalesReason" PropertyName="@nameof(SalesOrderHeaderSalesReasonDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SalesOrderHeaderSalesReasonDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<SalesOrderHeaderSalesReasonDto> grid = null!;
    private bool _loading = true;
    private int? filterSalesOrderId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SalesOrderHeaderSalesReasonDto>> LoadServerDataAsync(GridState<SalesOrderHeaderSalesReasonDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.SalesOrderHeaderSalesReasons.AsNoTracking();
            if (filterSalesOrderId.HasValue) query = query.Where(x => x.SalesOrderId == filterSalesOrderId.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);

            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(SalesOrderHeaderSalesReasonDto.SalesOrderId) => sort.Descending ? query.OrderByDescending(x => x.SalesOrderId) : query.OrderBy(x => x.SalesOrderId),
                nameof(SalesOrderHeaderSalesReasonDto.SalesReasonId) => sort.Descending ? query.OrderByDescending(x => x.SalesReasonId) : query.OrderBy(x => x.SalesReasonId),
                nameof(SalesOrderHeaderSalesReasonDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _ => query.OrderBy(x => x.SalesOrderId).ThenBy(x => x.SalesReasonId),
            };

            var rows = await query
                .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<SalesOrderHeaderSalesReasonDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesOrderHeaderSalesReasonDialog>("Link a sales reason", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Link created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(SalesOrderHeaderSalesReasonDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.SalesOrderId}, {row.SalesReasonId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesOrderHeaderSalesReasons
            .FirstOrDefaultAsync(t => t.SalesOrderId == row.SalesOrderId && t.SalesReasonId == row.SalesReasonId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.SalesOrderHeaderSalesReasonAuditLogs.Add(SalesOrderHeaderSalesReasonAuditService.RecordDelete(entity, changedBy));
        db.SalesOrderHeaderSalesReasons.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Link deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(SalesOrderHeaderSalesReasonDto row)
        => Navigation.NavigateTo($"aw/sales-order-header-sales-reasons/history?salesOrderId={row.SalesOrderId}&salesReasonId={row.SalesReasonId}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
