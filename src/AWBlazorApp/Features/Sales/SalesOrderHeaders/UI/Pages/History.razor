@page "/aw/sales-order-headers/history"
@page "/aw/sales-order-headers/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Sales order history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/sales-order-headers"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Sales order history" : $"History for SalesOrderHeader #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="SalesOrderHeader" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
