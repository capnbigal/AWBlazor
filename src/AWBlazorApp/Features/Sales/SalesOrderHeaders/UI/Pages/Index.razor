@page "/aw/sales-order-headers"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="SalesOrderHeaderDto"
          @ref="page"
          Title="Sales order headers"
          Caption="Sales.SalesOrderHeader"
          NewButtonLabel="New order"
          HistoryRoute="aw/sales-order-headers/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="sales order"
          DeleteConfirmMessage="@(row => $"Permanently delete order #{row.Id} ({row.SalesOrderNumber})?")">
    <ExpandedContent Context="row">
        <SalesOrderHeaderExpandedRow OrderId="@row.Id" />
    </ExpandedContent>
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterCustomerId ?? 0)" ValueChanged="@(v => filterCustomerId = v == 0 ? null : v)" Label="Customer" SearchFunc="@(q => Lookup.SearchCustomersAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect T="byte?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                <MudSelectItem T="byte?" Value="@((byte?)null)">(any)</MudSelectItem>
                <MudSelectItem T="byte?" Value="@((byte)1)">1 — In process</MudSelectItem>
                <MudSelectItem T="byte?" Value="@((byte)2)">2 — Approved</MudSelectItem>
                <MudSelectItem T="byte?" Value="@((byte)3)">3 — Backordered</MudSelectItem>
                <MudSelectItem T="byte?" Value="@((byte)4)">4 — Rejected</MudSelectItem>
                <MudSelectItem T="byte?" Value="@((byte)5)">5 — Shipped</MudSelectItem>
                <MudSelectItem T="byte?" Value="@((byte)6)">6 — Cancelled</MudSelectItem>
            </MudSelect>
        </MudItem>
    </Filters>
    <Columns>
        <HierarchyColumn T="SalesOrderHeaderDto" />
        <PropertyColumn T="SalesOrderHeaderDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesOrderHeaderDto" TProperty="string" Property="x => x.SalesOrderNumber" Title="Order #">
            <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.SalesOrderNumber)" Title="Order #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesOrderHeaderDto" TProperty="DateTime" Property="x => x.OrderDate" Title="Order date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.OrderDate)" Title="Order date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <TemplateColumn T="SalesOrderHeaderDto" Title="Status" Sortable="false">
            <CellTemplate>
                @{ var (label, color) = StatusHelper.SalesOrderStatus(context.Item.Status); }
                <MudChip T="string" Size="Size.Small" Color="@color" Variant="Variant.Filled">@label</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn T="SalesOrderHeaderDto" TProperty="int" Property="x => x.CustomerId" Title="Customer">
            <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.CustomerId)" Title="Customer" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesOrderHeaderDto" TProperty="decimal" Property="x => x.SubTotal" Title="Subtotal" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.SubTotal)" Title="Subtotal" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesOrderHeaderDto" TProperty="decimal" Property="x => x.TotalDue" Title="Total due" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.TotalDue)" Title="Total due" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesOrderHeaderDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
            <HeaderTemplate><GridColumnHeader TEntity="SalesOrderHeader" PropertyName="@nameof(SalesOrderHeaderDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<SalesOrderHeaderDto> page = null!;
    private int? filterCustomerId;
    private byte? filterStatus;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<SalesOrderHeaderDto>> LoadServerDataAsync(GridState<SalesOrderHeaderDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesOrderHeaders.AsNoTracking();
        if (filterCustomerId.HasValue) query = query.Where(x => x.CustomerId == filterCustomerId.Value);
        if (filterStatus.HasValue) query = query.Where(x => x.Status == filterStatus.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SalesOrderHeaderDto.Id)               => sort.Descending ? query.OrderByDescending(x => x.Id)               : query.OrderBy(x => x.Id),
            nameof(SalesOrderHeaderDto.SalesOrderNumber) => sort.Descending ? query.OrderByDescending(x => x.SalesOrderNumber) : query.OrderBy(x => x.SalesOrderNumber),
            nameof(SalesOrderHeaderDto.OrderDate)        => sort.Descending ? query.OrderByDescending(x => x.OrderDate)        : query.OrderBy(x => x.OrderDate),
            nameof(SalesOrderHeaderDto.SubTotal)         => sort.Descending ? query.OrderByDescending(x => x.SubTotal)         : query.OrderBy(x => x.SubTotal),
            nameof(SalesOrderHeaderDto.TotalDue)         => sort.Descending ? query.OrderByDescending(x => x.TotalDue)         : query.OrderBy(x => x.TotalDue),
            nameof(SalesOrderHeaderDto.CustomerId)       => sort.Descending ? query.OrderByDescending(x => x.CustomerId)       : query.OrderBy(x => x.CustomerId),
            nameof(SalesOrderHeaderDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _                                            => query.OrderByDescending(x => x.OrderDate).ThenBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SalesOrderHeaderDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesOrderHeaderDialog>("New sales order", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Sales order created.", Severity.Success);
    }

    private async Task OpenEditAsync(SalesOrderHeaderDto row)
    {
        var parameters = new DialogParameters<SalesOrderHeaderDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesOrderHeaderDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Sales order updated.", Severity.Success);
    }

    private async Task DeleteAsync(SalesOrderHeaderDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesOrderHeaders.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Order no longer exists.", Severity.Warning); return; }
        db.SalesOrderHeaders.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Sales order deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
