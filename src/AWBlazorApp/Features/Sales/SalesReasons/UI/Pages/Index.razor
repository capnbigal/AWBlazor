@page "/aw/sales-reasons"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Domain
@using AWBlazorApp.Features.Sales.CreditCards.Domain
@using AWBlazorApp.Features.Sales.Currencies.Domain
@using AWBlazorApp.Features.Sales.CurrencyRates.Domain
@using AWBlazorApp.Features.Sales.Customers.Domain
@using AWBlazorApp.Features.Sales.PersonCreditCards.Domain
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesPeople.Domain
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Domain
@using AWBlazorApp.Features.Sales.SalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesTaxRates.Domain
@using AWBlazorApp.Features.Sales.SalesTerritories.Domain
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Domain
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Domain
@using AWBlazorApp.Features.Sales.SpecialOffers.Domain
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Domain
@using AWBlazorApp.Features.Sales.Stores.Domain
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Dtos
@using AWBlazorApp.Features.Sales.CreditCards.Dtos
@using AWBlazorApp.Features.Sales.Currencies.Dtos
@using AWBlazorApp.Features.Sales.CurrencyRates.Dtos
@using AWBlazorApp.Features.Sales.Customers.Dtos
@using AWBlazorApp.Features.Sales.PersonCreditCards.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesPeople.Dtos
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Dtos
@using AWBlazorApp.Features.Sales.SalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesTaxRates.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritories.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Dtos
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Dtos
@using AWBlazorApp.Features.Sales.SpecialOffers.Dtos
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Dtos
@using AWBlazorApp.Features.Sales.Stores.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="SalesReasonDto"
          Title="Sales reasons"
          Caption="Sales.SalesReason"
          NewButtonLabel="New sales reason"
          HistoryRoute="aw/sales-reasons/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="sales reason">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterReasonType" Label="Reason type" Variant="Variant.Outlined" /></MudItem>
    </Filters>
    <Columns>

            <PropertyColumn T="SalesReasonDto" TProperty="int" Property="x => x.Id" Title="Id" />
            <PropertyColumn T="SalesReasonDto" TProperty="string" Property="x => x.Name" Title="Name" />
            <PropertyColumn T="SalesReasonDto" TProperty="string" Property="x => x.ReasonType" Title="Reason type" />
            <PropertyColumn T="SalesReasonDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            
    </Columns>
</CrudPage>

@code {
    private string? filterName;
    private string? filterReasonType;

    private async Task<GridData<SalesReasonDto>> LoadServerDataAsync(GridState<SalesReasonDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.SalesReasons.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName))
            {
                var needle = filterName.Trim();
                query = query.Where(x => x.Name.Contains(needle));
            }
            if (!string.IsNullOrWhiteSpace(filterReasonType))
            {
                var needle = filterReasonType.Trim();
                query = query.Where(x => x.ReasonType == needle);
            }var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(SalesReasonDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
                nameof(SalesReasonDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
                nameof(SalesReasonDto.ReasonType)   => sort.Descending ? query.OrderByDescending(x => x.ReasonType)   : query.OrderBy(x => x.ReasonType),
                nameof(SalesReasonDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _                                   => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<SalesReasonDto> { Items = rows, TotalItems = total };
        }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesReasonDialog>("New sales reason", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Sales reason created.", Severity.Success);
    }

    private async Task OpenEditAsync(SalesReasonDto row)
    {
        var parameters = new DialogParameters<SalesReasonDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesReasonDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Sales reason updated.", Severity.Success);
    }

    private async Task DeleteAsync(SalesReasonDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesReasons.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.SalesReasons.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Sales reason deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
