@page "/aw/sales-reasons/history"
@page "/aw/sales-reasons/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Sales reason history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/sales-reasons"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Sales reason history" : $"History for SalesReason #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="SalesReason" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
