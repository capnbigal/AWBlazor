@page "/aw/shopping-cart-items"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Domain
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="ShoppingCartItemDto"
          @ref="page"
          Title="Shopping cart items"
          Caption="Sales.ShoppingCartItem"
          NewButtonLabel="New cart item"
          HistoryRoute="aw/shopping-cart-items/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="cart item"
          DeleteConfirmMessage="@(row => $"Permanently delete cart item #{row.Id}?")">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterCartId" Label="Shopping cart id" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ShoppingCartItemDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ShoppingCartItemDto" TProperty="string" Property="x => x.ShoppingCartId" Title="Cart id">
            <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.ShoppingCartId)" Title="Cart id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ShoppingCartItemDto" TProperty="int" Property="x => x.ProductId" Title="Product">
            <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ShoppingCartItemDto" TProperty="int" Property="x => x.Quantity" Title="Qty">
            <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.Quantity)" Title="Qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ShoppingCartItemDto" TProperty="DateTime" Property="x => x.DateCreated" Title="Created" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.DateCreated)" Title="Created" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ShoppingCartItemDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ShoppingCartItem" PropertyName="@nameof(ShoppingCartItemDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<ShoppingCartItemDto> page = null!;
    private string? filterCartId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ShoppingCartItemDto>> LoadServerDataAsync(GridState<ShoppingCartItemDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ShoppingCartItems.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterCartId))
        {
            var needle = filterCartId.Trim();
            query = query.Where(x => x.ShoppingCartId == needle);
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ShoppingCartItemDto.Id)             => sort.Descending ? query.OrderByDescending(x => x.Id)             : query.OrderBy(x => x.Id),
            nameof(ShoppingCartItemDto.ShoppingCartId) => sort.Descending ? query.OrderByDescending(x => x.ShoppingCartId) : query.OrderBy(x => x.ShoppingCartId),
            nameof(ShoppingCartItemDto.ProductId)      => sort.Descending ? query.OrderByDescending(x => x.ProductId)      : query.OrderBy(x => x.ProductId),
            nameof(ShoppingCartItemDto.Quantity)       => sort.Descending ? query.OrderByDescending(x => x.Quantity)       : query.OrderBy(x => x.Quantity),
            nameof(ShoppingCartItemDto.DateCreated)    => sort.Descending ? query.OrderByDescending(x => x.DateCreated)    : query.OrderBy(x => x.DateCreated),
            nameof(ShoppingCartItemDto.ModifiedDate)   => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)   : query.OrderBy(x => x.ModifiedDate),
            _                                          => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ShoppingCartItemDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ShoppingCartItemDialog>("New cart item", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Cart item created.", Severity.Success);
    }

    private async Task OpenEditAsync(ShoppingCartItemDto row)
    {
        var parameters = new DialogParameters<ShoppingCartItemDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ShoppingCartItemDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Cart item updated.", Severity.Success);
    }

    private async Task DeleteAsync(ShoppingCartItemDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ShoppingCartItems.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Cart item no longer exists.", Severity.Warning); return; }
        db.ShoppingCartItems.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Cart item deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
