@page "/aw/shopping-cart-items/history"
@page "/aw/shopping-cart-items/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Cart item history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/shopping-cart-items"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Cart item history" : $"History for ShoppingCartItem #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ShoppingCartItem" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
