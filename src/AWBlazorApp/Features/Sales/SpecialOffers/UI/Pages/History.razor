@page "/aw/special-offers/history"
@page "/aw/special-offers/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Special offer history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/special-offers"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Special offer history" : $"History for SpecialOffer #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="SpecialOffer" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
