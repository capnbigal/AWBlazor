@page "/aw/person-credit-cards"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.PersonCreditCards.Domain
@using AWBlazorApp.Features.Sales.PersonCreditCards.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="PersonCreditCardDto"
          Title="Person ↔ credit card"
          Caption="Sales.PersonCreditCard · composite PK (BusinessEntityID, CreditCardID)"
          NewButtonLabel="New link"
          HistoryRoute="aw/person-credit-cards/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Business entity" Clearable="true" SearchFunc="@(q => Lookup.SearchPersonsAsync(q))" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="PersonCreditCardDto" TProperty="int" Property="x => x.BusinessEntityId" Title="Business entity id" />
        <PropertyColumn T="PersonCreditCardDto" TProperty="int" Property="x => x.CreditCardId" Title="Credit card id" />
        <PropertyColumn T="PersonCreditCardDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/person-credit-cards/history?businessEntityId={row.BusinessEntityId}&creditCardId={row.CreditCardId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private int? filterBusinessEntityId;

    private async Task<GridData<PersonCreditCardDto>> LoadServerDataAsync(GridState<PersonCreditCardDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.PersonCreditCards.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(PersonCreditCardDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(PersonCreditCardDto.CreditCardId)     => sort.Descending ? query.OrderByDescending(x => x.CreditCardId)     : query.OrderBy(x => x.CreditCardId),
            nameof(PersonCreditCardDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _ => query.OrderBy(x => x.BusinessEntityId).ThenBy(x => x.CreditCardId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<PersonCreditCardDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<PersonCreditCardDialog>("Link a person to a credit card", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(PersonCreditCardDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.BusinessEntityId}, {row.CreditCardId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.PersonCreditCards.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.CreditCardId == row.CreditCardId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); return; }
        db.PersonCreditCards.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
