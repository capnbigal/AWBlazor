@page "/aw/currency-rates/history"
@page "/aw/currency-rates/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Currency rate history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/currency-rates"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Currency rate history" : $"History for CurrencyRate #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="CurrencyRate" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
