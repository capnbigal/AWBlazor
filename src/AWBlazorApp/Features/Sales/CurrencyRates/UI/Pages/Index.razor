@page "/aw/currency-rates"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CurrencyRates.Domain
@using AWBlazorApp.Features.Sales.CurrencyRates.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="CurrencyRateDto"
          @ref="page"
          Title="Currency rates"
          Caption="Sales.CurrencyRate"
          NewButtonLabel="New rate"
          HistoryRoute="aw/currency-rates/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="currency rate"
          DeleteConfirmMessage="@(row => $"Permanently delete rate #{row.Id} ({row.FromCurrencyCode}/{row.ToCurrencyCode} on {row.CurrencyRateDate:yyyy-MM-dd})?")">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterFrom" Label="From currency" Variant="Variant.Outlined" MaxLength="3" OnBlur="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterTo" Label="To currency" Variant="Variant.Outlined" MaxLength="3" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="CurrencyRateDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="CurrencyRate" PropertyName="@nameof(CurrencyRateDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CurrencyRateDto" TProperty="DateTime" Property="x => x.CurrencyRateDate" Title="Date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="CurrencyRate" PropertyName="@nameof(CurrencyRateDto.CurrencyRateDate)" Title="Date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CurrencyRateDto" TProperty="string" Property="x => x.FromCurrencyCode" Title="From">
            <HeaderTemplate><GridColumnHeader TEntity="CurrencyRate" PropertyName="@nameof(CurrencyRateDto.FromCurrencyCode)" Title="From" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CurrencyRateDto" TProperty="string" Property="x => x.ToCurrencyCode" Title="To">
            <HeaderTemplate><GridColumnHeader TEntity="CurrencyRate" PropertyName="@nameof(CurrencyRateDto.ToCurrencyCode)" Title="To" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CurrencyRateDto" TProperty="decimal" Property="x => x.AverageRate" Title="Average" Format="N4">
            <HeaderTemplate><GridColumnHeader TEntity="CurrencyRate" PropertyName="@nameof(CurrencyRateDto.AverageRate)" Title="Average" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CurrencyRateDto" TProperty="decimal" Property="x => x.EndOfDayRate" Title="End-of-day" Format="N4">
            <HeaderTemplate><GridColumnHeader TEntity="CurrencyRate" PropertyName="@nameof(CurrencyRateDto.EndOfDayRate)" Title="End-of-day" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<CurrencyRateDto> page = null!;
    private string? filterFrom;
    private string? filterTo;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<CurrencyRateDto>> LoadServerDataAsync(GridState<CurrencyRateDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.CurrencyRates.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterFrom))
        {
            var f = filterFrom.Trim();
            query = query.Where(x => x.FromCurrencyCode == f);
        }
        if (!string.IsNullOrWhiteSpace(filterTo))
        {
            var t = filterTo.Trim();
            query = query.Where(x => x.ToCurrencyCode == t);
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CurrencyRateDto.Id)               => sort.Descending ? query.OrderByDescending(x => x.Id)               : query.OrderBy(x => x.Id),
            nameof(CurrencyRateDto.CurrencyRateDate) => sort.Descending ? query.OrderByDescending(x => x.CurrencyRateDate) : query.OrderBy(x => x.CurrencyRateDate),
            nameof(CurrencyRateDto.FromCurrencyCode) => sort.Descending ? query.OrderByDescending(x => x.FromCurrencyCode) : query.OrderBy(x => x.FromCurrencyCode),
            nameof(CurrencyRateDto.ToCurrencyCode)   => sort.Descending ? query.OrderByDescending(x => x.ToCurrencyCode)   : query.OrderBy(x => x.ToCurrencyCode),
            nameof(CurrencyRateDto.AverageRate)      => sort.Descending ? query.OrderByDescending(x => x.AverageRate)      : query.OrderBy(x => x.AverageRate),
            nameof(CurrencyRateDto.EndOfDayRate)     => sort.Descending ? query.OrderByDescending(x => x.EndOfDayRate)     : query.OrderBy(x => x.EndOfDayRate),
            _                                        => query.OrderByDescending(x => x.CurrencyRateDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CurrencyRateDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CurrencyRateDialog>("New currency rate", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Currency rate created.", Severity.Success);
    }

    private async Task OpenEditAsync(CurrencyRateDto row)
    {
        var parameters = new DialogParameters<CurrencyRateDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CurrencyRateDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Currency rate updated.", Severity.Success);
    }

    private async Task DeleteAsync(CurrencyRateDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.CurrencyRates.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Rate no longer exists.", Severity.Warning); return; }
        db.CurrencyRates.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Currency rate deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
