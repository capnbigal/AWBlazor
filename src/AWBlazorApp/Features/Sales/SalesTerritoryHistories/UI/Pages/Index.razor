@page "/aw/sales-territory-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Domain
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="SalesTerritoryHistoryDto"
          Title="Sales territory history"
          Caption="Sales.SalesTerritoryHistory · composite PK (BusinessEntityID, StartDate, TerritoryID)"
          NewButtonLabel="New assignment"
          HistoryRoute="aw/sales-territory-histories/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="assignment">
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Sales person" Clearable="true" SearchFunc="@(q => Lookup.SearchSalesPersonsAsync(q))" /></MudItem>
        <MudItem xs="12" sm="6"><MudNumericField T="int?" @bind-Value="filterTerritoryId" Label="Territory id" Variant="Variant.Outlined" Clearable="true" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="SalesTerritoryHistoryDto" TProperty="int" Property="x => x.BusinessEntityId" Title="Business entity" />
        <PropertyColumn T="SalesTerritoryHistoryDto" TProperty="int" Property="x => x.TerritoryId" Title="Territory" />
        <PropertyColumn T="SalesTerritoryHistoryDto" TProperty="DateTime" Property="x => x.StartDate" Title="Start date" Format="yyyy-MM-dd" />
        <PropertyColumn T="SalesTerritoryHistoryDto" TProperty="DateTime?" Property="x => x.EndDate" Title="End date" Format="yyyy-MM-dd" />
        <PropertyColumn T="SalesTerritoryHistoryDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/sales-territory-histories/history?businessEntityId={row.BusinessEntityId}&territoryId={row.TerritoryId}&startDate={row.StartDate:yyyy-MM-dd}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private int? filterBusinessEntityId;
    private int? filterTerritoryId;

    private async Task<GridData<SalesTerritoryHistoryDto>> LoadServerDataAsync(GridState<SalesTerritoryHistoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesTerritoryHistories.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        if (filterTerritoryId.HasValue) query = query.Where(x => x.TerritoryId == filterTerritoryId.Value);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SalesTerritoryHistoryDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(SalesTerritoryHistoryDto.TerritoryId)      => sort.Descending ? query.OrderByDescending(x => x.TerritoryId)      : query.OrderBy(x => x.TerritoryId),
            nameof(SalesTerritoryHistoryDto.StartDate)        => sort.Descending ? query.OrderByDescending(x => x.StartDate)        : query.OrderBy(x => x.StartDate),
            nameof(SalesTerritoryHistoryDto.EndDate)          => sort.Descending ? query.OrderByDescending(x => x.EndDate)          : query.OrderBy(x => x.EndDate),
            nameof(SalesTerritoryHistoryDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _ => query.OrderBy(x => x.BusinessEntityId).ThenByDescending(x => x.StartDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SalesTerritoryHistoryDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesTerritoryHistoryDialog>("New assignment", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Assignment created.", Severity.Success);
    }

    private async Task OpenEditAsync(SalesTerritoryHistoryDto row)
    {
        var parameters = new DialogParameters<SalesTerritoryHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesTerritoryHistoryDialog>("Edit assignment", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Assignment updated.", Severity.Success);
    }

    private async Task DeleteAsync(SalesTerritoryHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete assignment?", $"Permanently delete assignment ({row.BusinessEntityId}, {row.StartDate:d}, {row.TerritoryId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesTerritoryHistories.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.StartDate == row.StartDate && t.TerritoryId == row.TerritoryId);
        if (entity is null) { Snackbar.Add("Assignment no longer exists.", Severity.Warning); return; }
        db.SalesTerritoryHistories.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Assignment deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
