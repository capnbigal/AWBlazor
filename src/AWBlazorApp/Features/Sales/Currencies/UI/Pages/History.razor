@page "/aw/currencies/history"
@page "/aw/currencies/history/{Code}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Currency history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/currencies"))" />

        <MudText Typo="Typo.h4">"Currency history"</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Currency"  />
</MudStack>

