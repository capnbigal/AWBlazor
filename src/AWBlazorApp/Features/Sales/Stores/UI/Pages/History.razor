@page "/aw/stores/history"
@page "/aw/stores/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Store history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/stores"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Store history" : $"History for Store #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Store" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
