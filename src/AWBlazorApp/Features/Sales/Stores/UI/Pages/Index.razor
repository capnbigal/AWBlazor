@page "/aw/stores"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Stores.Domain
@using AWBlazorApp.Features.Sales.Stores.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="StoreDto"
          @ref="page"
          Title="Stores"
          Caption="Sales.Store"
          NewButtonLabel="New store"
          HistoryRoute="aw/stores/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="store"
          DeleteConfirmMessage="@(row => $"Permanently delete store #{row.Id} ({row.Name})?")">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="StoreDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="Store" PropertyName="@nameof(StoreDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="StoreDto" TProperty="string" Property="x => x.Name" Title="Name">
            <HeaderTemplate><GridColumnHeader TEntity="Store" PropertyName="@nameof(StoreDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="StoreDto" TProperty="int?" Property="x => x.SalesPersonId" Title="Sales person id">
            <HeaderTemplate><GridColumnHeader TEntity="Store" PropertyName="@nameof(StoreDto.SalesPersonId)" Title="Sales person id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="StoreDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="Store" PropertyName="@nameof(StoreDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<StoreDto> page = null!;
    private string? filterName;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<StoreDto>> LoadServerDataAsync(GridState<StoreDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Stores.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName)) { var n = filterName.Trim(); query = query.Where(x => x.Name.Contains(n)); }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(StoreDto.Id)            => sort.Descending ? query.OrderByDescending(x => x.Id)            : query.OrderBy(x => x.Id),
            nameof(StoreDto.Name)          => sort.Descending ? query.OrderByDescending(x => x.Name)          : query.OrderBy(x => x.Name),
            nameof(StoreDto.SalesPersonId) => sort.Descending ? query.OrderByDescending(x => x.SalesPersonId) : query.OrderBy(x => x.SalesPersonId),
            nameof(StoreDto.ModifiedDate)  => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)  : query.OrderBy(x => x.ModifiedDate),
            _                              => query.OrderBy(x => x.Name),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<StoreDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<StoreDialog>("New store", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Store created.", Severity.Success);
    }

    private async Task OpenEditAsync(StoreDto row)
    {
        var parameters = new DialogParameters<StoreDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<StoreDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Store updated.", Severity.Success);
    }

    private async Task DeleteAsync(StoreDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Stores.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Store no longer exists.", Severity.Warning); return; }
        db.Stores.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Store deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
