@page "/aw/special-offer-products"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Domain
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="SpecialOfferProductDto"
          Title="Special offer ↔ product"
          Caption="Sales.SpecialOfferProduct · composite PK (SpecialOfferID, ProductID)"
          NewButtonLabel="New link"
          HistoryRoute="aw/special-offer-products/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12" sm="6"><FkSelect TValue="int" Value="@(filterSpecialOfferId ?? 0)" ValueChanged="@(v => filterSpecialOfferId = v == 0 ? null : v)" Label="Special offer" Items="_specialOffers" Clearable="true" /></MudItem>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="SpecialOfferProductDto" TProperty="int" Property="x => x.SpecialOfferId" Title="Special offer id" />
        <PropertyColumn T="SpecialOfferProductDto" TProperty="int" Property="x => x.ProductId" Title="Product id" />
        <PropertyColumn T="SpecialOfferProductDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/special-offer-products/history?specialOfferId={row.SpecialOfferId}&productId={row.ProductId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private int? filterSpecialOfferId;
    private int? filterProductId;
    private List<LookupItem<int>> _specialOffers = [];

    protected override async Task OnInitializedAsync()
    {
        _specialOffers = await Lookup.GetSpecialOffersAsync();
    }

    private async Task<GridData<SpecialOfferProductDto>> LoadServerDataAsync(GridState<SpecialOfferProductDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SpecialOfferProducts.AsNoTracking();
        if (filterSpecialOfferId.HasValue) query = query.Where(x => x.SpecialOfferId == filterSpecialOfferId.Value);
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SpecialOfferProductDto.SpecialOfferId) => sort.Descending ? query.OrderByDescending(x => x.SpecialOfferId) : query.OrderBy(x => x.SpecialOfferId),
            nameof(SpecialOfferProductDto.ProductId)      => sort.Descending ? query.OrderByDescending(x => x.ProductId)      : query.OrderBy(x => x.ProductId),
            nameof(SpecialOfferProductDto.ModifiedDate)   => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)   : query.OrderBy(x => x.ModifiedDate),
            _ => query.OrderBy(x => x.SpecialOfferId).ThenBy(x => x.ProductId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SpecialOfferProductDto> { Items = rows, TotalItems = total };
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SpecialOfferProductDialog>("Link a special offer to a product", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(SpecialOfferProductDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.SpecialOfferId}, {row.ProductId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SpecialOfferProducts.FirstOrDefaultAsync(t => t.SpecialOfferId == row.SpecialOfferId && t.ProductId == row.ProductId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); return; }
        db.SpecialOfferProducts.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
