@page "/aw/sales-territories/history"
@page "/aw/sales-territories/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Territory history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/sales-territories"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Territory history" : $"History for SalesTerritory #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="SalesTerritory" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
