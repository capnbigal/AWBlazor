@page "/aw/sales-territories"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Domain
@using AWBlazorApp.Features.Sales.CreditCards.Domain
@using AWBlazorApp.Features.Sales.Currencies.Domain
@using AWBlazorApp.Features.Sales.CurrencyRates.Domain
@using AWBlazorApp.Features.Sales.Customers.Domain
@using AWBlazorApp.Features.Sales.PersonCreditCards.Domain
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesPeople.Domain
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Domain
@using AWBlazorApp.Features.Sales.SalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesTaxRates.Domain
@using AWBlazorApp.Features.Sales.SalesTerritories.Domain
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Domain
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Domain
@using AWBlazorApp.Features.Sales.SpecialOffers.Domain
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Domain
@using AWBlazorApp.Features.Sales.Stores.Domain
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Dtos
@using AWBlazorApp.Features.Sales.CreditCards.Dtos
@using AWBlazorApp.Features.Sales.Currencies.Dtos
@using AWBlazorApp.Features.Sales.CurrencyRates.Dtos
@using AWBlazorApp.Features.Sales.Customers.Dtos
@using AWBlazorApp.Features.Sales.PersonCreditCards.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesPeople.Dtos
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Dtos
@using AWBlazorApp.Features.Sales.SalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesTaxRates.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritories.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Dtos
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Dtos
@using AWBlazorApp.Features.Sales.SpecialOffers.Dtos
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Dtos
@using AWBlazorApp.Features.Sales.Stores.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="SalesTerritoryDto"
          Title="Sales territories"
          Caption="Sales.SalesTerritory"
          NewButtonLabel="New territory"
          HistoryRoute="aw/sales-territories/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="territory">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterGroupName" Label="Group" Variant="Variant.Outlined" /></MudItem>
    </Filters>
    <Columns>

            <HierarchyColumn T="SalesTerritoryDto" />
            <PropertyColumn T="SalesTerritoryDto" TProperty="int" Property="x => x.Id" Title="Id" />
            <PropertyColumn T="SalesTerritoryDto" TProperty="string" Property="x => x.Name" Title="Name" />
            <PropertyColumn T="SalesTerritoryDto" TProperty="string" Property="x => x.CountryRegionCode" Title="Country" />
            <PropertyColumn T="SalesTerritoryDto" TProperty="string" Property="x => x.GroupName" Title="Group" />
            <PropertyColumn T="SalesTerritoryDto" TProperty="decimal" Property="x => x.SalesYtd" Title="Sales YTD" Format="C" />
            <PropertyColumn T="SalesTerritoryDto" TProperty="decimal" Property="x => x.SalesLastYear" Title="Sales last yr" Format="C" />
            <PropertyColumn T="SalesTerritoryDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            
    </Columns>
</CrudPage>

@code {
    private string? filterName;
    private string? filterGroupName;

    private async Task<GridData<SalesTerritoryDto>> LoadServerDataAsync(GridState<SalesTerritoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.SalesTerritories.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName))
            {
                var needle = filterName.Trim();
                query = query.Where(x => x.Name.Contains(needle));
            }
            if (!string.IsNullOrWhiteSpace(filterGroupName))
            {
                var needle = filterGroupName.Trim();
                query = query.Where(x => x.GroupName == needle);
            }var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(SalesTerritoryDto.Id)                => sort.Descending ? query.OrderByDescending(x => x.Id)                : query.OrderBy(x => x.Id),
                nameof(SalesTerritoryDto.Name)              => sort.Descending ? query.OrderByDescending(x => x.Name)              : query.OrderBy(x => x.Name),
                nameof(SalesTerritoryDto.CountryRegionCode) => sort.Descending ? query.OrderByDescending(x => x.CountryRegionCode) : query.OrderBy(x => x.CountryRegionCode),
                nameof(SalesTerritoryDto.GroupName)         => sort.Descending ? query.OrderByDescending(x => x.GroupName)         : query.OrderBy(x => x.GroupName),
                nameof(SalesTerritoryDto.SalesYtd)          => sort.Descending ? query.OrderByDescending(x => x.SalesYtd)          : query.OrderBy(x => x.SalesYtd),
                nameof(SalesTerritoryDto.SalesLastYear)     => sort.Descending ? query.OrderByDescending(x => x.SalesLastYear)     : query.OrderBy(x => x.SalesLastYear),
                nameof(SalesTerritoryDto.ModifiedDate)      => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)      : query.OrderBy(x => x.ModifiedDate),
                _                                           => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<SalesTerritoryDto> { Items = rows, TotalItems = total };
        }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesTerritoryDialog>("New territory", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Territory created.", Severity.Success);
    }

    private async Task OpenEditAsync(SalesTerritoryDto row)
    {
        var parameters = new DialogParameters<SalesTerritoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesTerritoryDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Territory updated.", Severity.Success);
    }

    private async Task DeleteAsync(SalesTerritoryDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesTerritories.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.SalesTerritories.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Territory deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
