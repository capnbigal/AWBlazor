@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Domain
@using AWBlazorApp.Features.Sales.CreditCards.Domain
@using AWBlazorApp.Features.Sales.Currencies.Domain
@using AWBlazorApp.Features.Sales.CurrencyRates.Domain
@using AWBlazorApp.Features.Sales.Customers.Domain
@using AWBlazorApp.Features.Sales.PersonCreditCards.Domain
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Domain
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesPeople.Domain
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Domain
@using AWBlazorApp.Features.Sales.SalesReasons.Domain
@using AWBlazorApp.Features.Sales.SalesTaxRates.Domain
@using AWBlazorApp.Features.Sales.SalesTerritories.Domain
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Domain
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Domain
@using AWBlazorApp.Features.Sales.SpecialOffers.Domain
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Domain
@using AWBlazorApp.Features.Sales.Stores.Domain
@using AWBlazorApp.Features.Sales.CountryRegionCurrencies.Dtos
@using AWBlazorApp.Features.Sales.CreditCards.Dtos
@using AWBlazorApp.Features.Sales.Currencies.Dtos
@using AWBlazorApp.Features.Sales.CurrencyRates.Dtos
@using AWBlazorApp.Features.Sales.Customers.Dtos
@using AWBlazorApp.Features.Sales.PersonCreditCards.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderDetails.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaders.Dtos
@using AWBlazorApp.Features.Sales.SalesOrderHeaderSalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesPeople.Dtos
@using AWBlazorApp.Features.Sales.SalesPersonQuotaHistories.Dtos
@using AWBlazorApp.Features.Sales.SalesReasons.Dtos
@using AWBlazorApp.Features.Sales.SalesTaxRates.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritories.Dtos
@using AWBlazorApp.Features.Sales.SalesTerritoryHistories.Dtos
@using AWBlazorApp.Features.Sales.ShoppingCartItems.Dtos
@using AWBlazorApp.Features.Sales.SpecialOffers.Dtos
@using AWBlazorApp.Features.Sales.SpecialOfferProducts.Dtos
@using AWBlazorApp.Features.Sales.Stores.Dtos
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateSalesPersonRequest> CreateValidator
@inject MudFormValidator<UpdateSalesPersonRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create sales person" : $"Edit sales person #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.Id" ValueChanged="@((int v) => createModel = createModel with { Id = v })" Label="Employee" Required="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="int" Value="@(createModel.TerritoryId ?? 0)" ValueChanged="@((int v) => createModel = createModel with { TerritoryId = v == 0 ? null : v })" Label="Territory" Clearable="true" Items="_territories" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@createModel.SalesQuota" ValueChanged="@((decimal? v) => createModel = createModel with { SalesQuota = v })" Label="Sales quota" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal" Value="@createModel.Bonus" ValueChanged="@((decimal v) => createModel = createModel with { Bonus = v })" Label="Bonus" Variant="Variant.Outlined" Min="0" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudNumericField T="decimal" Value="@createModel.CommissionPct" ValueChanged="@((decimal v) => createModel = createModel with { CommissionPct = v })" Label="Commission %" Variant="Variant.Outlined" HelperText="0 to 1" Min="0" Max="1" Step="0.01M" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkSelect TValue="int" Value="@(updateModel.TerritoryId ?? 0)" ValueChanged="@((int v) => updateModel = updateModel with { TerritoryId = v == 0 ? null : v })" Label="Territory" Clearable="true" Items="_territories" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.SalesQuota" ValueChanged="@((decimal? v) => updateModel = updateModel with { SalesQuota = v })" Label="Sales quota" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.Bonus" ValueChanged="@((decimal? v) => updateModel = updateModel with { Bonus = v })" Label="Bonus" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.CommissionPct" ValueChanged="@((decimal? v) => updateModel = updateModel with { CommissionPct = v })" Label="Commission %" Variant="Variant.Outlined" Clearable="true" Step="0.01M" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.SalesYtd" ValueChanged="@((decimal? v) => updateModel = updateModel with { SalesYtd = v })" Label="Sales YTD" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.SalesLastYear" ValueChanged="@((decimal? v) => updateModel = updateModel with { SalesLastYear = v })" Label="Sales last year" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SalesPersonDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateSalesPersonRequest createModel = new();
    private UpdateSalesPersonRequest updateModel = new();
    private bool saving;
    private List<LookupItem<int>> _territories = [];

    protected override async Task OnInitializedAsync()
    {
        _territories = await Lookup.GetSalesTerritoriesAsync();

        if (Model is not null)
        {
            updateModel = new UpdateSalesPersonRequest
            {
                TerritoryId = Model.TerritoryId,
                SalesQuota = Model.SalesQuota,
                Bonus = Model.Bonus,
                CommissionPct = Model.CommissionPct,
                SalesYtd = Model.SalesYtd,
                SalesLastYear = Model.SalesLastYear,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.SalesPersons.AnyAsync(x => x.Id == createModel.Id))
                {
                    Snackbar.Add($"Sales person #{createModel.Id} already exists.", Severity.Error);
                    return;
                }
                // Validate optional FK
                if (createModel.TerritoryId.HasValue && !await db.SalesTerritories.AnyAsync(x => x.Id == createModel.TerritoryId.Value))
                { Snackbar.Add($"Territory #{createModel.TerritoryId.Value} does not exist.", Severity.Error); return; }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.SalesPersons.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.SalesPersons.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                updateModel.ApplyTo(entity);
                // Validate optional FK on update
                if (updateModel.TerritoryId.HasValue && !await db.SalesTerritories.AnyAsync(x => x.Id == updateModel.TerritoryId.Value))
                { Snackbar.Add($"Territory #{updateModel.TerritoryId.Value} does not exist.", Severity.Error); return; }
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
