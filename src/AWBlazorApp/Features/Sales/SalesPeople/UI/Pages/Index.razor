@page "/aw/sales-persons"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.SalesPeople.Domain
@using AWBlazorApp.Features.Sales.SalesPeople.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="SalesPersonDto"
          @ref="page"
          Title="Sales persons"
          Caption="Sales.SalesPerson"
          NewButtonLabel="New sales person"
          HistoryRoute="aw/sales-persons/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="sales person"
          DeleteConfirmMessage="@(row => $"Permanently delete sales person #{row.Id}?")">
    <ExpandedContent Context="row">
        <SalesPersonExpandedRow SalesPersonId="@row.Id" />
    </ExpandedContent>
    <Filters>
        <MudItem xs="12"><FkSelect TValue="int" Value="@(filterTerritoryId ?? 0)" ValueChanged="@(v => filterTerritoryId = v == 0 ? null : v)" Label="Territory" Items="_territories" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <HierarchyColumn T="SalesPersonDto" />
        <PropertyColumn T="SalesPersonDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesPersonDto" TProperty="int?" Property="x => x.TerritoryId" Title="Territory id">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.TerritoryId)" Title="Territory id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesPersonDto" TProperty="decimal?" Property="x => x.SalesQuota" Title="Quota" Format="C0">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.SalesQuota)" Title="Quota" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesPersonDto" TProperty="decimal" Property="x => x.Bonus" Title="Bonus" Format="C0">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.Bonus)" Title="Bonus" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesPersonDto" TProperty="decimal" Property="x => x.CommissionPct" Title="Commission %" Format="P2">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.CommissionPct)" Title="Commission %" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesPersonDto" TProperty="decimal" Property="x => x.SalesYtd" Title="YTD" Format="C0">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.SalesYtd)" Title="YTD" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesPersonDto" TProperty="decimal" Property="x => x.SalesLastYear" Title="Last year" Format="C0">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.SalesLastYear)" Title="Last year" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="SalesPersonDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="SalesPerson" PropertyName="@nameof(SalesPersonDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<SalesPersonDto> page = null!;
    private int? filterTerritoryId;
    private List<LookupItem<int>> _territories = [];
    private readonly ColumnFilterState columnFilters = new();

    protected override async Task OnInitializedAsync()
    {
        _territories = await Lookup.GetSalesTerritoriesAsync();
    }

    private async Task<GridData<SalesPersonDto>> LoadServerDataAsync(GridState<SalesPersonDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.SalesPersons.AsNoTracking();
        if (filterTerritoryId.HasValue) query = query.Where(x => x.TerritoryId == filterTerritoryId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(SalesPersonDto.Id)            => sort.Descending ? query.OrderByDescending(x => x.Id)            : query.OrderBy(x => x.Id),
            nameof(SalesPersonDto.TerritoryId)   => sort.Descending ? query.OrderByDescending(x => x.TerritoryId)   : query.OrderBy(x => x.TerritoryId),
            nameof(SalesPersonDto.SalesQuota)    => sort.Descending ? query.OrderByDescending(x => x.SalesQuota)    : query.OrderBy(x => x.SalesQuota),
            nameof(SalesPersonDto.Bonus)         => sort.Descending ? query.OrderByDescending(x => x.Bonus)         : query.OrderBy(x => x.Bonus),
            nameof(SalesPersonDto.CommissionPct) => sort.Descending ? query.OrderByDescending(x => x.CommissionPct) : query.OrderBy(x => x.CommissionPct),
            nameof(SalesPersonDto.SalesYtd)      => sort.Descending ? query.OrderByDescending(x => x.SalesYtd)      : query.OrderBy(x => x.SalesYtd),
            nameof(SalesPersonDto.SalesLastYear) => sort.Descending ? query.OrderByDescending(x => x.SalesLastYear) : query.OrderBy(x => x.SalesLastYear),
            nameof(SalesPersonDto.ModifiedDate)  => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)  : query.OrderBy(x => x.ModifiedDate),
            _                                    => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<SalesPersonDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<SalesPersonDialog>("New sales person", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Sales person created.", Severity.Success);
    }

    private async Task OpenEditAsync(SalesPersonDto row)
    {
        var parameters = new DialogParameters<SalesPersonDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<SalesPersonDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Sales person updated.", Severity.Success);
    }

    private async Task DeleteAsync(SalesPersonDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.SalesPersons.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Sales person no longer exists.", Severity.Warning); return; }
        db.SalesPersons.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Sales person deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
