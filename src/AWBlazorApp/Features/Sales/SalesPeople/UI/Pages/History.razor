@page "/aw/sales-persons/history"
@page "/aw/sales-persons/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Sales person history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/sales-persons"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Sales person history" : $"History for SalesPerson #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="SalesPerson" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
