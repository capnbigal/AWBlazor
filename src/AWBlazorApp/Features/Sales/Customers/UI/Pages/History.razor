@page "/aw/customers/history"
@page "/aw/customers/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Customer history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/customers"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Customer history" : $"History for Customer #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Customer" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
