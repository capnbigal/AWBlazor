@page "/aw/customers"
@attribute [Authorize]
@using AWBlazorApp.Features.Sales.Customers.Domain
@using AWBlazorApp.Features.Sales.Customers.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="CustomerDto"
          @ref="page"
          Title="Customers"
          Caption="Sales.Customer"
          NewButtonLabel="New customer"
          HistoryRoute="aw/customers/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="customer"
          DeleteConfirmMessage="@(row => $"Permanently delete customer #{row.Id} ({row.AccountNumber})?")">
    <ExpandedContent Context="row">
        <CustomerExpandedRow CustomerId="@row.Id" />
    </ExpandedContent>
    <Filters>
        <MudItem xs="12" sm="6"><FkSelect TValue="int" Value="@(filterTerritoryId ?? 0)" ValueChanged="@(v => filterTerritoryId = v == 0 ? null : v)" Label="Territory" Items="_territories" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <HierarchyColumn T="CustomerDto" />
        <PropertyColumn T="CustomerDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="Customer" PropertyName="@nameof(CustomerDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CustomerDto" TProperty="string" Property="x => x.AccountNumber" Title="Account #">
            <HeaderTemplate><GridColumnHeader TEntity="Customer" PropertyName="@nameof(CustomerDto.AccountNumber)" Title="Account #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CustomerDto" TProperty="int?" Property="x => x.PersonId" Title="Person id">
            <HeaderTemplate><GridColumnHeader TEntity="Customer" PropertyName="@nameof(CustomerDto.PersonId)" Title="Person id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CustomerDto" TProperty="int?" Property="x => x.StoreId" Title="Store id">
            <HeaderTemplate><GridColumnHeader TEntity="Customer" PropertyName="@nameof(CustomerDto.StoreId)" Title="Store id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CustomerDto" TProperty="int?" Property="x => x.TerritoryId" Title="Territory id">
            <HeaderTemplate><GridColumnHeader TEntity="Customer" PropertyName="@nameof(CustomerDto.TerritoryId)" Title="Territory id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CustomerDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
            <HeaderTemplate><GridColumnHeader TEntity="Customer" PropertyName="@nameof(CustomerDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<CustomerDto> page = null!;
    private int? filterTerritoryId;
    private List<LookupItem<int>> _territories = [];
    private readonly ColumnFilterState columnFilters = new();

    protected override async Task OnInitializedAsync()
    {
        _territories = await Lookup.GetSalesTerritoriesAsync();
    }

    private async Task<GridData<CustomerDto>> LoadServerDataAsync(GridState<CustomerDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Customers.AsNoTracking();
        if (filterTerritoryId.HasValue) query = query.Where(x => x.TerritoryId == filterTerritoryId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CustomerDto.Id)            => sort.Descending ? query.OrderByDescending(x => x.Id)            : query.OrderBy(x => x.Id),
            nameof(CustomerDto.PersonId)      => sort.Descending ? query.OrderByDescending(x => x.PersonId)      : query.OrderBy(x => x.PersonId),
            nameof(CustomerDto.StoreId)       => sort.Descending ? query.OrderByDescending(x => x.StoreId)       : query.OrderBy(x => x.StoreId),
            nameof(CustomerDto.AccountNumber) => sort.Descending ? query.OrderByDescending(x => x.AccountNumber) : query.OrderBy(x => x.AccountNumber),
            nameof(CustomerDto.TerritoryId)   => sort.Descending ? query.OrderByDescending(x => x.TerritoryId)   : query.OrderBy(x => x.TerritoryId),
            nameof(CustomerDto.ModifiedDate)  => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)  : query.OrderBy(x => x.ModifiedDate),
            _                                 => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CustomerDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CustomerDialog>("New customer", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Customer created.", Severity.Success);
    }

    private async Task OpenEditAsync(CustomerDto row)
    {
        var parameters = new DialogParameters<CustomerDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CustomerDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Customer updated.", Severity.Success);
    }

    private async Task DeleteAsync(CustomerDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Customers.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Customer no longer exists.", Severity.Warning); return; }
        db.Customers.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Customer deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
