@page "/engineering"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Engineering</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.Architecture" Color="Color.Primary" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Engineering</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Routings, BOMs, ECOs, drawings, deviations — ECO approval auto-activates new revisions</MudText>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.ChangeCircle" Color="Color.Warning" Value="@ecosUnderReview.ToString("N0")" Label="ECOs under review" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Value="@activeBoms.ToString("N0")" Label="Active BOMs" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" Value="@activeRoutings.ToString("N0")" Label="Active routings" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.RuleFolder" Color="Color.Error" Value="@pendingDeviations.ToString("N0")" Label="Pending deviations" /></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="mt-3">Modules</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Change orders" Subtitle="Draft → UnderReview → Approved/Rejected. Approval auto-activates affected BOM/Routing revisions." Icon="@Icons.Material.Filled.ChangeCircle" Href="engineering/ecos" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Routings" Subtitle="Ordered sequence of stations per product — template used by MES runs." Icon="@Icons.Material.Filled.Timeline" Href="engineering/routings" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Bills of materials" Subtitle="Engineering BOM with revision control — independent of AW's finance BOM." Icon="@Icons.Material.Filled.AccountTree" Href="engineering/boms" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Documents" Subtitle="Drawings, specs, CAD models, procedures — URL refs to external storage." Icon="@Icons.Material.Filled.Description" Href="engineering/documents" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Deviations" Subtitle="Time- and quantity-bounded spec exceptions — temporary, not permanent changes." Icon="@Icons.Material.Filled.RuleFolder" Href="engineering/deviations" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Reference data" Subtitle="Raw AW BOM catalog, illustrations, cultures, units of measure." Icon="@Icons.Material.Filled.TableView" Href="engineering/reference" /></MudItem>
    </MudGrid>
</MudStack>

@code {
    private int ecosUnderReview, activeBoms, activeRoutings, pendingDeviations;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        ecosUnderReview = await db.EngineeringChangeOrders.CountAsync(e => e.Status == EcoStatus.UnderReview);
        activeBoms = await db.BomHeaders.CountAsync(b => b.IsActive);
        activeRoutings = await db.ManufacturingRoutings.CountAsync(r => r.IsActive);
        pendingDeviations = await db.DeviationRequests.CountAsync(d => d.Status == DeviationStatus.Pending);
    }
}
