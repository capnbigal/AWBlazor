@using AWBlazorApp.Features.Engineering.Dtos
@page "/engineering/deviations"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDeviationService DevService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Deviation requests</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Deviation requests</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Time- and quantity-bounded spec exceptions. Pending → Approved / Rejected / Cancelled.</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Submit deviation</MudButton>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterProduct" Label="Product" Variant="Variant.Outlined" Clearable="true" />
            <MudSelect T="DeviationStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="DeviationStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<DeviationStatus>()) { <MudSelectItem T="DeviationStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="DeviationRequestDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.ProductId" Title="Product" />
            <PropertyColumn Property="x => x.Reason" Title="Reason" />
            <PropertyColumn Property="x => x.ValidFrom" Title="From" />
            <PropertyColumn Property="x => x.ValidTo" Title="To" />
            <PropertyColumn Property="x => x.AuthorizedQuantity" Title="Qty" />
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)" Variant="Variant.Filled">@context.Item.Status</MudChip></CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    @if (context.Item.Status == DeviationStatus.Pending)
                    {
                        <MudStack Row="true" Spacing="1">
                            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                                <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" OnClick="@(() => OpenReview(context.Item.Id, true))">Approve</MudButton>
                                <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined" OnClick="@(() => OpenReview(context.Item.Id, false))">Reject</MudButton>
                            </AuthorizeView>
                            <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" OnClick="@(() => Cancel(context.Item.Id))">Cancel</MudButton>
                        </MudStack>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="DeviationRequestDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Submit deviation</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newRow.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int" @bind-Value="newRow.ProductId" Label="Product ID" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Reason" Label="Reason" Required="true" Variant="Variant.Outlined" Lines="3" />
            <MudTextField @bind-Value="newRow.ProposedDisposition" Label="Proposed disposition" Variant="Variant.Outlined" Lines="2" />
            <MudNumericField T="decimal?" @bind-Value="newRow.AuthorizedQuantity" Label="Authorized quantity (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.UnitMeasureCode" Label="UOM (e.g. EA, LB)" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="fromDate" Label="Valid from" Variant="Variant.Outlined" Clearable="true" />
            <MudDatePicker @bind-Date="toDate" Label="Valid to" Variant="Variant.Outlined" Clearable="true" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Submit")</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="reviewOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>@(reviewApprove ? "Approve" : "Reject") deviation</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="reviewNotes" Label="Decision notes" Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => reviewOpen = false">Cancel</MudButton>
        <MudButton Color="@(reviewApprove ? Color.Success : Color.Error)" Variant="Variant.Filled" OnClick="SubmitReview">@(reviewApprove ? "Approve" : "Reject")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<DeviationRequestDto> grid = null!;
    private bool _loading = true;
    private int? filterProduct;
    private DeviationStatus? filterStatus = DeviationStatus.Pending;

    private bool dialogOpen, saving;
    private CreateDeviationRequestRequest newRow = new();
    private DateTime? fromDate, toDate;

    private bool reviewOpen, reviewApprove;
    private int reviewId;
    private string? reviewNotes;

    private static Color StatusColor(DeviationStatus s) => s switch
    {
        DeviationStatus.Pending => Color.Warning,
        DeviationStatus.Approved => Color.Success,
        DeviationStatus.Rejected => Color.Error,
        DeviationStatus.Cancelled => Color.Default,
        DeviationStatus.Expired => Color.Dark,
        _ => Color.Default,
    };

    private async Task<GridData<DeviationRequestDto>> LoadAsync(GridState<DeviationRequestDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.DeviationRequests.AsNoTracking();
            if (filterProduct.HasValue) q = q.Where(x => x.ProductId == filterProduct.Value);
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.RaisedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<DeviationRequestDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateDeviationRequestRequest(); fromDate = DateTime.UtcNow.Date; toDate = DateTime.UtcNow.Date.AddDays(30); dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            if (fromDate.HasValue) newRow.ValidFrom = DateOnly.FromDateTime(fromDate.Value);
            if (toDate.HasValue) newRow.ValidTo = DateOnly.FromDateTime(toDate.Value);
            await using var db = await DbFactory.CreateDbContextAsync();
            var by = await GetUserNameAsync();
            var entity = newRow.ToEntity(by);
            await using var tx = await db.Database.BeginTransactionAsync();
            db.DeviationRequests.Add(entity);
            await db.SaveChangesAsync();
            db.DeviationRequestAuditLogs.Add(DeviationRequestAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add("Submitted.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Submit failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private void OpenReview(int id, bool approve) { reviewId = id; reviewApprove = approve; reviewNotes = null; reviewOpen = true; }

    private async Task SubmitReview()
    {
        try
        {
            var by = await GetUserNameAsync();
            if (reviewApprove) await DevService.ApproveAsync(reviewId, reviewNotes, by, default);
            else await DevService.RejectAsync(reviewId, reviewNotes, by, default);
            Snackbar.Add(reviewApprove ? "Approved." : "Rejected.", Severity.Success);
            reviewOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Decision failed: {ex.Message}", Severity.Error); }
    }

    private async Task Cancel(int id)
    {
        try
        {
            var by = await GetUserNameAsync();
            await DevService.CancelAsync(id, by, default);
            Snackbar.Add("Cancelled.", Severity.Success);
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Cancel failed: {ex.Message}", Severity.Error); }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
