@page "/engineering/ecos"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject AWBlazorApp.Features.Insights.Services.NotificationService NotificationService

<PageTitle>Engineering change orders</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Engineering change orders</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Draft → UnderReview → Approved/Rejected. Approval auto-activates affected BOM/Routing revisions.</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New ECO</MudButton>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="EcoStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="EcoStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<EcoStatus>()) { <MudSelectItem T="EcoStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="EngineeringChangeOrderDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Title" Title="Title" />
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)" Variant="Variant.Filled">@context.Item.Status</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.RaisedAt" Title="Raised" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.DecidedAt" Title="Decided" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate><MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"engineering/ecos/{context.Item.Id}"))" /></CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="EngineeringChangeOrderDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New engineering change order</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newEco.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newEco.Title" Label="Title" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newEco.Description" Label="Description" Variant="Variant.Outlined" Lines="6" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [SupplyParameterFromQuery(Name = "status")] public string? StatusQuery { get; set; }

    private MudDataGrid<EngineeringChangeOrderDto> grid = null!;
    private bool _loading = true;
    private EcoStatus? filterStatus;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(StatusQuery) && Enum.TryParse<EcoStatus>(StatusQuery, ignoreCase: true, out var s))
        {
            filterStatus = s;
        }
    }

    private bool dialogOpen, saving;
    private CreateEngineeringChangeOrderRequest newEco = new();

    private static Color StatusColor(EcoStatus s) => s switch
    {
        EcoStatus.Draft => Color.Default,
        EcoStatus.UnderReview => Color.Warning,
        EcoStatus.Approved => Color.Success,
        EcoStatus.Rejected => Color.Error,
        EcoStatus.Cancelled => Color.Dark,
        _ => Color.Default,
    };

    private async Task<GridData<EngineeringChangeOrderDto>> LoadAsync(GridState<EngineeringChangeOrderDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.EngineeringChangeOrders.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.RaisedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<EngineeringChangeOrderDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newEco = new CreateEngineeringChangeOrderRequest(); dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var by = await GetUserNameAsync();
            var entity = newEco.ToEntity(by);
            await using var tx = await db.Database.BeginTransactionAsync();
            db.EngineeringChangeOrders.Add(entity);
            await db.SaveChangesAsync();
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.Code}.", Severity.Success);
            await NotificationService.NotifyDashboardChangedAsync("Engineering");
            dialogOpen = false;
            Navigation.NavigateTo($"engineering/ecos/{entity.Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
