@page "/aw/illustrations"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Illustrations.Domain
@using AWBlazorApp.Features.Production.Illustrations.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="IllustrationDto"
          @ref="page"
          Title="Illustrations"
          Caption="Production.Illustration · Diagram XML column not exposed"
          NewButtonLabel="New illustration"
          HistoryRoute="aw/illustrations/history"
          IdOf="row => row.Id"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="illustration"
          DeleteConfirmMessage="@(row => $"Permanently delete illustration #{row.Id}?")">
    <Columns>
        <PropertyColumn T="IllustrationDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="Illustration" PropertyName="@nameof(IllustrationDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="IllustrationDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="Illustration" PropertyName="@nameof(IllustrationDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
    Illustration is just an integer surrogate key plus a Diagram XML column. Creating one
    allocates the next id; the Diagram column stays NULL on insert from this app.
</MudText>

@code {
    private CrudPage<IllustrationDto> page = null!;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<IllustrationDto>> LoadServerDataAsync(GridState<IllustrationDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Illustrations.AsNoTracking();
        query = query.ApplyColumnFilters(columnFilters);
        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(IllustrationDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(IllustrationDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                    => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<IllustrationDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Create illustration?",
            "This allocates a new Illustration row with a fresh id. The Diagram XML column stays NULL.",
            yesText: "Create", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = new CreateIllustrationRequest().ToEntity();
        db.Illustrations.Add(entity);
        await db.SaveChangesAsync();
        Snackbar.Add($"Illustration #{entity.Id} created.", Severity.Success);
    }

    private async Task DeleteAsync(IllustrationDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Illustrations.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Illustration no longer exists.", Severity.Warning); return; }
        db.Illustrations.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Illustration deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
