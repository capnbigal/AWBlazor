@page "/aw/illustrations/history"
@page "/aw/illustrations/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Illustration history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/illustrations"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Illustration history" : $"History for Illustration #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Illustration" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
