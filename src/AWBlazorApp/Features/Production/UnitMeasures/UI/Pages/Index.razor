@page "/aw/unit-measures"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.UnitMeasures.Domain
@using AWBlazorApp.Features.Production.UnitMeasures.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="UnitMeasureDto"
          @ref="page"
          Title="Units of measure"
          Caption="Production.UnitMeasure"
          NewButtonLabel="New unit of measure"
          HistoryRoute="aw/unit-measures/history"
          IdOf="row => row.UnitMeasureCode"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="unit of measure"
          DeleteConfirmMessage="@(row => $"Permanently delete {row.UnitMeasureCode} ({row.Name})?")">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="UnitMeasureDto" TProperty="string" Property="x => x.UnitMeasureCode" Title="Code">
            <HeaderTemplate><GridColumnHeader TEntity="UnitMeasure" PropertyName="@nameof(UnitMeasureDto.UnitMeasureCode)" Title="Code" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="UnitMeasureDto" TProperty="string" Property="x => x.Name" Title="Name">
            <HeaderTemplate><GridColumnHeader TEntity="UnitMeasure" PropertyName="@nameof(UnitMeasureDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="UnitMeasureDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="UnitMeasure" PropertyName="@nameof(UnitMeasureDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<UnitMeasureDto> page = null!;
    private string? filterName;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<UnitMeasureDto>> LoadServerDataAsync(GridState<UnitMeasureDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.UnitMeasures.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var needle = filterName.Trim();
            query = query.Where(x => x.Name.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(UnitMeasureDto.UnitMeasureCode) => sort.Descending ? query.OrderByDescending(x => x.UnitMeasureCode) : query.OrderBy(x => x.UnitMeasureCode),
            nameof(UnitMeasureDto.Name)            => sort.Descending ? query.OrderByDescending(x => x.Name)            : query.OrderBy(x => x.Name),
            nameof(UnitMeasureDto.ModifiedDate)    => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)    : query.OrderBy(x => x.ModifiedDate),
            _                                      => query.OrderBy(x => x.UnitMeasureCode),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<UnitMeasureDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<UnitMeasureDialog>("New unit of measure", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Unit of measure created.", Severity.Success);
    }

    private async Task OpenEditAsync(UnitMeasureDto row)
    {
        var parameters = new DialogParameters<UnitMeasureDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<UnitMeasureDialog>($"Edit {row.UnitMeasureCode}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Unit of measure updated.", Severity.Success);
    }

    private async Task DeleteAsync(UnitMeasureDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.UnitMeasures.FirstOrDefaultAsync(t => t.UnitMeasureCode == row.UnitMeasureCode);
        if (entity is null) { Snackbar.Add("Unit of measure no longer exists.", Severity.Warning); return; }
        db.UnitMeasures.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Unit of measure deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
