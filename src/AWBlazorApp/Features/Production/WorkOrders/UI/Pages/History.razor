@page "/aw/work-orders/history"
@page "/aw/work-orders/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Work order history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/work-orders"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Work order history" : $"History for WorkOrder #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="WorkOrder" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
