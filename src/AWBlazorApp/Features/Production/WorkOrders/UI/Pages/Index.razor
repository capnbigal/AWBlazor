@page "/aw/work-orders"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.WorkOrders.Domain
@using AWBlazorApp.Features.Production.WorkOrders.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="WorkOrderDto"
          @ref="page"
          Title="Work orders"
          Caption="Production.WorkOrder"
          NewButtonLabel="New work order"
          HistoryRoute="aw/work-orders/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="work order"
          DeleteConfirmMessage="@(row => $"Permanently delete work order #{row.Id}?")">
    <ExpandedContent Context="row">
        <WorkOrderExpandedRow WorkOrderId="@row.Id" />
    </ExpandedContent>
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <HierarchyColumn T="WorkOrderDto" />
        <PropertyColumn T="WorkOrderDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="int" Property="x => x.ProductId" Title="Product id">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.ProductId)" Title="Product id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="int" Property="x => x.OrderQty" Title="Order qty">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.OrderQty)" Title="Order qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="short" Property="x => x.ScrappedQty" Title="Scrapped">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.ScrappedQty)" Title="Scrapped" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="int" Property="x => x.StockedQty" Title="Stocked">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.StockedQty)" Title="Stocked" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="DateTime" Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.StartDate)" Title="Start" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="DateTime" Property="x => x.DueDate" Title="Due" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.DueDate)" Title="Due" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="DateTime?" Property="x => x.EndDate" Title="End" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.EndDate)" Title="End" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderDto" TProperty="short?" Property="x => x.ScrapReasonId" Title="Scrap reason" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrder" PropertyName="@nameof(WorkOrderDto.ScrapReasonId)" Title="Scrap reason" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<WorkOrderDto> page = null!;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<WorkOrderDto>> LoadServerDataAsync(GridState<WorkOrderDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.WorkOrders.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(WorkOrderDto.Id)            => sort.Descending ? query.OrderByDescending(x => x.Id)            : query.OrderBy(x => x.Id),
            nameof(WorkOrderDto.ProductId)     => sort.Descending ? query.OrderByDescending(x => x.ProductId)     : query.OrderBy(x => x.ProductId),
            nameof(WorkOrderDto.OrderQty)      => sort.Descending ? query.OrderByDescending(x => x.OrderQty)      : query.OrderBy(x => x.OrderQty),
            nameof(WorkOrderDto.StockedQty)    => sort.Descending ? query.OrderByDescending(x => x.StockedQty)    : query.OrderBy(x => x.StockedQty),
            nameof(WorkOrderDto.ScrappedQty)   => sort.Descending ? query.OrderByDescending(x => x.ScrappedQty)   : query.OrderBy(x => x.ScrappedQty),
            nameof(WorkOrderDto.StartDate)     => sort.Descending ? query.OrderByDescending(x => x.StartDate)     : query.OrderBy(x => x.StartDate),
            nameof(WorkOrderDto.EndDate)       => sort.Descending ? query.OrderByDescending(x => x.EndDate)       : query.OrderBy(x => x.EndDate),
            nameof(WorkOrderDto.DueDate)       => sort.Descending ? query.OrderByDescending(x => x.DueDate)       : query.OrderBy(x => x.DueDate),
            nameof(WorkOrderDto.ScrapReasonId) => sort.Descending ? query.OrderByDescending(x => x.ScrapReasonId) : query.OrderBy(x => x.ScrapReasonId),
            _                                  => query.OrderByDescending(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<WorkOrderDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<WorkOrderDialog>("New work order", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Work order created.", Severity.Success);
    }

    private async Task OpenEditAsync(WorkOrderDto row)
    {
        var parameters = new DialogParameters<WorkOrderDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<WorkOrderDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Work order updated.", Severity.Success);
    }

    private async Task DeleteAsync(WorkOrderDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.WorkOrders.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Work order no longer exists.", Severity.Warning); return; }
        db.WorkOrders.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Work order deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
