@page "/aw/work-order-routings"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.WorkOrderRoutings.Domain
@using AWBlazorApp.Features.Production.WorkOrderRoutings.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<CrudPage TDto="WorkOrderRoutingDto"
          @ref="page"
          Title="Work order routings"
          Caption="Production.WorkOrderRouting · 3-col PK"
          NewButtonLabel="New routing"
          HistoryRoute="aw/work-order-routings/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="routing">
    <Filters>
        <MudItem xs="12"><MudNumericField T="int?" @bind-Value="filterWorkOrderId" Label="Work order id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="int" Property="x => x.WorkOrderId" Title="Work order">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.WorkOrderId)" Title="Work order" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="int" Property="x => x.ProductId" Title="Product">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="short" Property="x => x.OperationSequence" Title="Op seq">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.OperationSequence)" Title="Op seq" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="short" Property="x => x.LocationId" Title="Location">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.LocationId)" Title="Location" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="DateTime" Property="x => x.ScheduledStartDate" Title="Sched start" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.ScheduledStartDate)" Title="Sched start" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="DateTime" Property="x => x.ScheduledEndDate" Title="Sched end" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.ScheduledEndDate)" Title="Sched end" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="decimal" Property="x => x.PlannedCost" Title="Planned cost" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.PlannedCost)" Title="Planned cost" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="WorkOrderRoutingDto" TProperty="decimal?" Property="x => x.ActualCost" Title="Actual cost" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="WorkOrderRouting" PropertyName="@nameof(WorkOrderRoutingDto.ActualCost)" Title="Actual cost" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/work-order-routings/history?workOrderId={row.WorkOrderId}&productId={row.ProductId}&operationSequence={row.OperationSequence}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<WorkOrderRoutingDto> page = null!;
    private int? filterWorkOrderId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<WorkOrderRoutingDto>> LoadServerDataAsync(GridState<WorkOrderRoutingDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.WorkOrderRoutings.AsNoTracking();
        if (filterWorkOrderId.HasValue) query = query.Where(x => x.WorkOrderId == filterWorkOrderId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(WorkOrderRoutingDto.WorkOrderId)        => sort.Descending ? query.OrderByDescending(x => x.WorkOrderId)        : query.OrderBy(x => x.WorkOrderId),
            nameof(WorkOrderRoutingDto.ProductId)          => sort.Descending ? query.OrderByDescending(x => x.ProductId)          : query.OrderBy(x => x.ProductId),
            nameof(WorkOrderRoutingDto.OperationSequence)  => sort.Descending ? query.OrderByDescending(x => x.OperationSequence)  : query.OrderBy(x => x.OperationSequence),
            nameof(WorkOrderRoutingDto.LocationId)         => sort.Descending ? query.OrderByDescending(x => x.LocationId)         : query.OrderBy(x => x.LocationId),
            nameof(WorkOrderRoutingDto.ScheduledStartDate) => sort.Descending ? query.OrderByDescending(x => x.ScheduledStartDate) : query.OrderBy(x => x.ScheduledStartDate),
            nameof(WorkOrderRoutingDto.ScheduledEndDate)   => sort.Descending ? query.OrderByDescending(x => x.ScheduledEndDate)   : query.OrderBy(x => x.ScheduledEndDate),
            nameof(WorkOrderRoutingDto.PlannedCost)        => sort.Descending ? query.OrderByDescending(x => x.PlannedCost)        : query.OrderBy(x => x.PlannedCost),
            nameof(WorkOrderRoutingDto.ActualCost)         => sort.Descending ? query.OrderByDescending(x => x.ActualCost)         : query.OrderBy(x => x.ActualCost),
            _                                              => query.OrderBy(x => x.WorkOrderId).ThenBy(x => x.ProductId).ThenBy(x => x.OperationSequence),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<WorkOrderRoutingDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<WorkOrderRoutingDialog>("New routing", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Routing created.", Severity.Success);
    }

    private async Task OpenEditAsync(WorkOrderRoutingDto row)
    {
        var parameters = new DialogParameters<WorkOrderRoutingDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<WorkOrderRoutingDialog>($"Edit routing ({row.WorkOrderId}, {row.ProductId}, {row.OperationSequence})", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Routing updated.", Severity.Success); await page.ReloadAsync(); }
    }

    private async Task DeleteAsync(WorkOrderRoutingDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete routing?", $"Permanently delete routing ({row.WorkOrderId}, {row.ProductId}, {row.OperationSequence})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.WorkOrderRoutings.FirstOrDefaultAsync(t => t.WorkOrderId == row.WorkOrderId && t.ProductId == row.ProductId && t.OperationSequence == row.OperationSequence);
        if (entity is null) { Snackbar.Add("Routing no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.WorkOrderRoutings.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Routing deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
