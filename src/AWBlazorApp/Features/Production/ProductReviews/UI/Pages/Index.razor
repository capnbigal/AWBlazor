@page "/aw/product-reviews"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.ProductReviews.Domain
@using AWBlazorApp.Features.Production.ProductReviews.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="ProductReviewDto"
          @ref="page"
          Title="Product reviews"
          Caption="Production.ProductReview"
          NewButtonLabel="New review"
          HistoryRoute="aw/product-reviews/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="review"
          DeleteConfirmMessage="@(row => $"Permanently delete review #{row.Id}?")">
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><MudNumericField T="int?" @bind-Value="filterMinRating" Label="Minimum rating" Variant="Variant.Outlined" Clearable="true" Min="1" Max="5" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductReviewDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductReview" PropertyName="@nameof(ProductReviewDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductReviewDto" TProperty="int" Property="x => x.ProductId" Title="Product id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductReview" PropertyName="@nameof(ProductReviewDto.ProductId)" Title="Product id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductReviewDto" TProperty="string" Property="x => x.ReviewerName" Title="Reviewer">
            <HeaderTemplate><GridColumnHeader TEntity="ProductReview" PropertyName="@nameof(ProductReviewDto.ReviewerName)" Title="Reviewer" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductReviewDto" TProperty="int" Property="x => x.Rating" Title="Rating">
            <HeaderTemplate><GridColumnHeader TEntity="ProductReview" PropertyName="@nameof(ProductReviewDto.Rating)" Title="Rating" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductReviewDto" TProperty="DateTime" Property="x => x.ReviewDate" Title="Date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="ProductReview" PropertyName="@nameof(ProductReviewDto.ReviewDate)" Title="Date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductReviewDto" TProperty="string" Property="x => x.EmailAddress" Title="Email">
            <HeaderTemplate><GridColumnHeader TEntity="ProductReview" PropertyName="@nameof(ProductReviewDto.EmailAddress)" Title="Email" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<ProductReviewDto> page = null!;
    private int? filterProductId;
    private int? filterMinRating;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductReviewDto>> LoadServerDataAsync(GridState<ProductReviewDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductReviews.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        if (filterMinRating.HasValue) query = query.Where(x => x.Rating >= filterMinRating.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductReviewDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(ProductReviewDto.ProductId)    => sort.Descending ? query.OrderByDescending(x => x.ProductId)    : query.OrderBy(x => x.ProductId),
            nameof(ProductReviewDto.ReviewerName) => sort.Descending ? query.OrderByDescending(x => x.ReviewerName) : query.OrderBy(x => x.ReviewerName),
            nameof(ProductReviewDto.EmailAddress) => sort.Descending ? query.OrderByDescending(x => x.EmailAddress) : query.OrderBy(x => x.EmailAddress),
            nameof(ProductReviewDto.Rating)       => sort.Descending ? query.OrderByDescending(x => x.Rating)       : query.OrderBy(x => x.Rating),
            nameof(ProductReviewDto.ReviewDate)   => sort.Descending ? query.OrderByDescending(x => x.ReviewDate)   : query.OrderBy(x => x.ReviewDate),
            _                                     => query.OrderByDescending(x => x.ReviewDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductReviewDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductReviewDialog>("New review", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Review created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductReviewDto row)
    {
        var parameters = new DialogParameters<ProductReviewDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductReviewDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Review updated.", Severity.Success);
    }

    private async Task DeleteAsync(ProductReviewDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductReviews.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Review no longer exists.", Severity.Warning); return; }
        db.ProductReviews.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Review deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
