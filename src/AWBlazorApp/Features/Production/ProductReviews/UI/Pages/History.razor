@page "/aw/product-reviews/history"
@page "/aw/product-reviews/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Product review history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-reviews"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Product review history" : $"History for ProductReview #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ProductReview" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
