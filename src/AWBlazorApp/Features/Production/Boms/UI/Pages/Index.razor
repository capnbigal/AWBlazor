@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Bill of materials</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Bill of materials</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.BillOfMaterials</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/bill-of-materials/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New BOM row</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudNumericField T="int?" @bind-Value="filterComponentId" Label="Component id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="BillOfMaterialsDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductAssemblyId" Title="Assembly id">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.ProductAssemblyId)" Title="Assembly id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ComponentId" Title="Component id">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.ComponentId)" Title="Component id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.BomLevel" Title="Level">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.BomLevel)" Title="Level" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PerAssemblyQty" Title="Qty/asm">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.PerAssemblyQty)" Title="Qty/asm" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.UnitMeasureCode" Title="UoM">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.UnitMeasureCode)" Title="UoM" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.StartDate)" Title="Start" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.EndDate" Title="End" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="BillOfMaterials" PropertyName="@nameof(BillOfMaterialsDto.EndDate)" Title="End" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="BillOfMaterialsDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<BillOfMaterialsDto> grid = null!;
    private bool _loading = true;
    private int? filterComponentId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<BillOfMaterialsDto>> LoadServerDataAsync(GridState<BillOfMaterialsDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.BillOfMaterials.AsNoTracking();
            if (filterComponentId.HasValue) query = query.Where(x => x.ComponentId == filterComponentId.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(BillOfMaterialsDto.Id)                 => sort.Descending ? query.OrderByDescending(x => x.Id)                 : query.OrderBy(x => x.Id),
                nameof(BillOfMaterialsDto.ProductAssemblyId)  => sort.Descending ? query.OrderByDescending(x => x.ProductAssemblyId)  : query.OrderBy(x => x.ProductAssemblyId),
                nameof(BillOfMaterialsDto.ComponentId)        => sort.Descending ? query.OrderByDescending(x => x.ComponentId)        : query.OrderBy(x => x.ComponentId),
                nameof(BillOfMaterialsDto.StartDate)          => sort.Descending ? query.OrderByDescending(x => x.StartDate)          : query.OrderBy(x => x.StartDate),
                nameof(BillOfMaterialsDto.EndDate)            => sort.Descending ? query.OrderByDescending(x => x.EndDate)            : query.OrderBy(x => x.EndDate),
                nameof(BillOfMaterialsDto.UnitMeasureCode)    => sort.Descending ? query.OrderByDescending(x => x.UnitMeasureCode)    : query.OrderBy(x => x.UnitMeasureCode),
                nameof(BillOfMaterialsDto.BomLevel)           => sort.Descending ? query.OrderByDescending(x => x.BomLevel)           : query.OrderBy(x => x.BomLevel),
                nameof(BillOfMaterialsDto.PerAssemblyQty)     => sort.Descending ? query.OrderByDescending(x => x.PerAssemblyQty)     : query.OrderBy(x => x.PerAssemblyQty),
                _                                             => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<BillOfMaterialsDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<BillOfMaterialsDialog>("New BOM row", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("BOM row created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(BillOfMaterialsDto row)
    {
        var parameters = new DialogParameters<BillOfMaterialsDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<BillOfMaterialsDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("BOM row updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(BillOfMaterialsDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete BOM row?", $"Permanently delete BOM row #{row.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.BillOfMaterials.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.BillOfMaterialsAuditLogs.Add(BillOfMaterialsAuditService.RecordDelete(entity, changedBy));
        db.BillOfMaterials.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("BOM row deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(BillOfMaterialsDto row) => Navigation.NavigateTo($"aw/bill-of-materials/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
