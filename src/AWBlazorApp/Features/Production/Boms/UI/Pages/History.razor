@page "/aw/bill-of-materials/history"
@page "/aw/bill-of-materials/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>BOM history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/bill-of-materials"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "BOM history" : $"History for BillOfMaterials #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="BillOfMaterials" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
