@page "/aw/scrap-reasons/history"
@page "/aw/scrap-reasons/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Scrap reason history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/scrap-reasons"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Scrap reason history" : $"History for ScrapReason #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ScrapReason" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
