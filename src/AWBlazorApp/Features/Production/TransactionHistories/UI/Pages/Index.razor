@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup

<PageTitle>Transaction history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Transaction history</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Production.TransactionHistory</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/transaction-histories/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New transaction</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => { filterProductId = v == 0 ? null : v; })" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" />
    </MudPaper>

    <MudDataGrid T="TransactionHistoryDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" Virtualize="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductId" Title="Product">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ReferenceOrderId" Title="Ref order">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ReferenceOrderId)" Title="Ref order" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ReferenceOrderLineId" Title="Ref line">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ReferenceOrderLineId)" Title="Ref line" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.TransactionDate" Title="Date" Format="yyyy-MM-dd">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.TransactionDate)" Title="Date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.TransactionType" Title="Type">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.TransactionType)" Title="Type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Quantity" Title="Qty">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.Quantity)" Title="Qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ActualCost" Title="Cost" Format="C2">
                <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ActualCost)" Title="Cost" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History"><MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" /></MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="TransactionHistoryDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<TransactionHistoryDto> grid = null!;
    private bool _loading = true;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<TransactionHistoryDto>> LoadServerDataAsync(GridState<TransactionHistoryDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.TransactionHistories.AsNoTracking();
            if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(TransactionHistoryDto.Id) => sort.Descending ? query.OrderByDescending(x => x.Id) : query.OrderBy(x => x.Id),
                nameof(TransactionHistoryDto.ProductId) => sort.Descending ? query.OrderByDescending(x => x.ProductId) : query.OrderBy(x => x.ProductId),
                nameof(TransactionHistoryDto.ReferenceOrderId) => sort.Descending ? query.OrderByDescending(x => x.ReferenceOrderId) : query.OrderBy(x => x.ReferenceOrderId),
                nameof(TransactionHistoryDto.ReferenceOrderLineId) => sort.Descending ? query.OrderByDescending(x => x.ReferenceOrderLineId) : query.OrderBy(x => x.ReferenceOrderLineId),
                nameof(TransactionHistoryDto.TransactionDate) => sort.Descending ? query.OrderByDescending(x => x.TransactionDate) : query.OrderBy(x => x.TransactionDate),
                nameof(TransactionHistoryDto.TransactionType) => sort.Descending ? query.OrderByDescending(x => x.TransactionType) : query.OrderBy(x => x.TransactionType),
                nameof(TransactionHistoryDto.Quantity) => sort.Descending ? query.OrderByDescending(x => x.Quantity) : query.OrderBy(x => x.Quantity),
                nameof(TransactionHistoryDto.ActualCost) => sort.Descending ? query.OrderByDescending(x => x.ActualCost) : query.OrderBy(x => x.ActualCost),
                _ => query.OrderByDescending(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<TransactionHistoryDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<TransactionHistoryDialog>("New transaction", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Transaction created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(TransactionHistoryDto row)
    {
        var parameters = new DialogParameters<TransactionHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<TransactionHistoryDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Transaction updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(TransactionHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete transaction?", $"Permanently delete transaction #{row.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.TransactionHistories.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Transaction no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.TransactionHistoryAuditLogs.Add(TransactionHistoryAuditService.RecordDelete(entity, changedBy));
        db.TransactionHistories.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Transaction deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(TransactionHistoryDto row) => Navigation.NavigateTo($"aw/transaction-histories/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
