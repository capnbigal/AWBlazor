@page "/aw/transaction-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.TransactionHistories.Domain
@using AWBlazorApp.Features.Production.TransactionHistories.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="TransactionHistoryDto"
          @ref="page"
          Title="Transaction history"
          Caption="Production.TransactionHistory"
          NewButtonLabel="New transaction"
          HistoryRoute="aw/transaction-histories/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="transaction"
          DeleteConfirmMessage="@(row => $"Permanently delete transaction #{row.Id}?")">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="TransactionHistoryDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryDto" TProperty="int" Property="x => x.ProductId" Title="Product">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryDto" TProperty="int" Property="x => x.ReferenceOrderId" Title="Ref order">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ReferenceOrderId)" Title="Ref order" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryDto" TProperty="int" Property="x => x.ReferenceOrderLineId" Title="Ref line">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ReferenceOrderLineId)" Title="Ref line" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryDto" TProperty="DateTime" Property="x => x.TransactionDate" Title="Date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.TransactionDate)" Title="Date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryDto" TProperty="string" Property="x => x.TransactionType" Title="Type">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.TransactionType)" Title="Type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryDto" TProperty="int" Property="x => x.Quantity" Title="Qty">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.Quantity)" Title="Qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryDto" TProperty="decimal" Property="x => x.ActualCost" Title="Cost" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistory" PropertyName="@nameof(TransactionHistoryDto.ActualCost)" Title="Cost" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<TransactionHistoryDto> page = null!;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<TransactionHistoryDto>> LoadServerDataAsync(GridState<TransactionHistoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.TransactionHistories.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(TransactionHistoryDto.Id)                   => sort.Descending ? query.OrderByDescending(x => x.Id)                   : query.OrderBy(x => x.Id),
            nameof(TransactionHistoryDto.ProductId)            => sort.Descending ? query.OrderByDescending(x => x.ProductId)            : query.OrderBy(x => x.ProductId),
            nameof(TransactionHistoryDto.ReferenceOrderId)     => sort.Descending ? query.OrderByDescending(x => x.ReferenceOrderId)     : query.OrderBy(x => x.ReferenceOrderId),
            nameof(TransactionHistoryDto.ReferenceOrderLineId) => sort.Descending ? query.OrderByDescending(x => x.ReferenceOrderLineId) : query.OrderBy(x => x.ReferenceOrderLineId),
            nameof(TransactionHistoryDto.TransactionDate)      => sort.Descending ? query.OrderByDescending(x => x.TransactionDate)      : query.OrderBy(x => x.TransactionDate),
            nameof(TransactionHistoryDto.TransactionType)      => sort.Descending ? query.OrderByDescending(x => x.TransactionType)      : query.OrderBy(x => x.TransactionType),
            nameof(TransactionHistoryDto.Quantity)             => sort.Descending ? query.OrderByDescending(x => x.Quantity)             : query.OrderBy(x => x.Quantity),
            nameof(TransactionHistoryDto.ActualCost)           => sort.Descending ? query.OrderByDescending(x => x.ActualCost)           : query.OrderBy(x => x.ActualCost),
            _                                                  => query.OrderByDescending(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<TransactionHistoryDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<TransactionHistoryDialog>("New transaction", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Transaction created.", Severity.Success);
    }

    private async Task OpenEditAsync(TransactionHistoryDto row)
    {
        var parameters = new DialogParameters<TransactionHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<TransactionHistoryDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Transaction updated.", Severity.Success);
    }

    private async Task DeleteAsync(TransactionHistoryDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.TransactionHistories.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Transaction no longer exists.", Severity.Warning); return; }
        db.TransactionHistories.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Transaction deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
