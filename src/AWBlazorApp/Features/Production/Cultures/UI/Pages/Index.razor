@page "/aw/cultures"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Cultures.Domain
@using AWBlazorApp.Features.Production.Cultures.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="CultureDto"
          @ref="page"
          Title="Cultures"
          Caption="Production.Culture"
          NewButtonLabel="New culture"
          HistoryRoute="aw/cultures/history"
          IdOf="row => row.CultureId"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="culture"
          DeleteConfirmMessage="@(row => $"Permanently delete culture {row.CultureId} ({row.Name})?")">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="CultureDto" TProperty="string" Property="x => x.CultureId" Title="Culture ID">
            <HeaderTemplate><GridColumnHeader TEntity="Culture" PropertyName="@nameof(CultureDto.CultureId)" Title="Culture ID" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CultureDto" TProperty="string" Property="x => x.Name" Title="Name">
            <HeaderTemplate><GridColumnHeader TEntity="Culture" PropertyName="@nameof(CultureDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="CultureDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="Culture" PropertyName="@nameof(CultureDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<CultureDto> page = null!;
    private string? filterName;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<CultureDto>> LoadServerDataAsync(GridState<CultureDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Cultures.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var needle = filterName.Trim();
            query = query.Where(x => x.Name.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(CultureDto.CultureId)    => sort.Descending ? query.OrderByDescending(x => x.CultureId)    : query.OrderBy(x => x.CultureId),
            nameof(CultureDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
            nameof(CultureDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                               => query.OrderBy(x => x.CultureId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<CultureDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CultureDialog>("New culture", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Culture created.", Severity.Success);
    }

    private async Task OpenEditAsync(CultureDto row)
    {
        var parameters = new DialogParameters<CultureDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<CultureDialog>($"Edit {row.CultureId}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Culture updated.", Severity.Success);
    }

    private async Task DeleteAsync(CultureDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Cultures.FirstOrDefaultAsync(t => t.CultureId == row.CultureId);
        if (entity is null) { Snackbar.Add("Culture no longer exists.", Severity.Warning); return; }
        db.Cultures.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Culture deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
