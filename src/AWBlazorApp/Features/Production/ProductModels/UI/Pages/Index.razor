@page "/aw/product-models"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.ProductModels.Domain
@using AWBlazorApp.Features.Production.ProductModels.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="ProductModelDto"
          @ref="page"
          Title="Product models"
          Caption="Production.ProductModel"
          NewButtonLabel="New product model"
          HistoryRoute="aw/product-models/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="product model"
          DeleteConfirmMessage="@(row => $"Permanently delete model #{row.Id} ({row.Name})?")">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductModelDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModel" PropertyName="@nameof(ProductModelDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductModelDto" TProperty="string" Property="x => x.Name" Title="Name">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModel" PropertyName="@nameof(ProductModelDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductModelDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModel" PropertyName="@nameof(ProductModelDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<ProductModelDto> page = null!;
    private string? filterName;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductModelDto>> LoadServerDataAsync(GridState<ProductModelDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductModels.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var n = filterName.Trim();
            query = query.Where(x => x.Name.Contains(n));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductModelDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(ProductModelDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
            nameof(ProductModelDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                    => query.OrderBy(x => x.Name),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductModelDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductModelDialog>("New product model", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Product model created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductModelDto row)
    {
        var parameters = new DialogParameters<ProductModelDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductModelDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Product model updated.", Severity.Success);
    }

    private async Task DeleteAsync(ProductModelDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductModels.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Model no longer exists.", Severity.Warning); return; }
        db.ProductModels.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Product model deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
