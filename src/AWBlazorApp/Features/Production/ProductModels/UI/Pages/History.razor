@page "/aw/product-models/history"
@page "/aw/product-models/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Product model history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-models"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Product model history" : $"History for ProductModel #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ProductModel" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
