@page "/aw/product-model-product-description-cultures"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.ProductModelProductDescriptionCultures.Domain
@using AWBlazorApp.Features.Production.ProductModelProductDescriptionCultures.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<CrudPage TDto="ProductModelProductDescriptionCultureDto"
          @ref="page"
          Title="Model ↔ description ↔ culture"
          Caption="Production.ProductModelProductDescriptionCulture · 3-col PK"
          NewButtonLabel="New link"
          HistoryRoute="aw/product-model-product-description-cultures/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12"><MudNumericField T="int?" @bind-Value="filterProductModelId" Label="Product model id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductModelProductDescriptionCultureDto" TProperty="int" Property="x => x.ProductModelId" Title="Model id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModelProductDescriptionCulture" PropertyName="@nameof(ProductModelProductDescriptionCultureDto.ProductModelId)" Title="Model id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductModelProductDescriptionCultureDto" TProperty="int" Property="x => x.ProductDescriptionId" Title="Description id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModelProductDescriptionCulture" PropertyName="@nameof(ProductModelProductDescriptionCultureDto.ProductDescriptionId)" Title="Description id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductModelProductDescriptionCultureDto" TProperty="string" Property="x => x.CultureId" Title="Culture">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModelProductDescriptionCulture" PropertyName="@nameof(ProductModelProductDescriptionCultureDto.CultureId)" Title="Culture" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductModelProductDescriptionCultureDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModelProductDescriptionCulture" PropertyName="@nameof(ProductModelProductDescriptionCultureDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/product-model-product-description-cultures/history?productModelId={row.ProductModelId}&productDescriptionId={row.ProductDescriptionId}&cultureId={row.CultureId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<ProductModelProductDescriptionCultureDto> page = null!;
    private int? filterProductModelId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductModelProductDescriptionCultureDto>> LoadServerDataAsync(GridState<ProductModelProductDescriptionCultureDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductModelProductDescriptionCultures.AsNoTracking();
        if (filterProductModelId.HasValue) query = query.Where(x => x.ProductModelId == filterProductModelId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductModelProductDescriptionCultureDto.ProductModelId)       => sort.Descending ? query.OrderByDescending(x => x.ProductModelId)       : query.OrderBy(x => x.ProductModelId),
            nameof(ProductModelProductDescriptionCultureDto.ProductDescriptionId) => sort.Descending ? query.OrderByDescending(x => x.ProductDescriptionId) : query.OrderBy(x => x.ProductDescriptionId),
            nameof(ProductModelProductDescriptionCultureDto.CultureId)            => sort.Descending ? query.OrderByDescending(x => x.CultureId)            : query.OrderBy(x => x.CultureId),
            nameof(ProductModelProductDescriptionCultureDto.ModifiedDate)         => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)         : query.OrderBy(x => x.ModifiedDate),
            _                                                                     => query.OrderBy(x => x.ProductModelId).ThenBy(x => x.ProductDescriptionId).ThenBy(x => x.CultureId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductModelProductDescriptionCultureDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductModelProductDescriptionCultureDialog>("Link model ↔ description ↔ culture", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(ProductModelProductDescriptionCultureDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.ProductModelId}, {row.ProductDescriptionId}, {row.CultureId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductModelProductDescriptionCultures.FirstOrDefaultAsync(t => t.ProductModelId == row.ProductModelId && t.ProductDescriptionId == row.ProductDescriptionId && t.CultureId == row.CultureId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.ProductModelProductDescriptionCultures.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
