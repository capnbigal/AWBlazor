@page "/aw/product-categories/history"
@page "/aw/product-categories/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Product category history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-categories"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Product category history" : $"History for ProductCategory #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ProductCategory" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
