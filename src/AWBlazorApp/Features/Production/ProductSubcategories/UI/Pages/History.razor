@page "/aw/product-subcategories/history"
@page "/aw/product-subcategories/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Subcategory history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-subcategories"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Subcategory history" : $"History for ProductSubcategory #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ProductSubcategory" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
