@using AWBlazorApp.Features.Production.WorkOrderRoutings.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="ProductSubcategoryDto"
          Title="Product subcategories"
          Caption="Production.ProductSubcategory"
          NewButtonLabel="New subcategory"
          HistoryRoute="aw/product-subcategories/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="subcategory">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6"><MudNumericField T="int?" @bind-Value="filterCategoryId" Label="Category id" Variant="Variant.Outlined" Clearable="true" /></MudItem>
    </Filters>
    <Columns>

            <PropertyColumn T="ProductSubcategoryDto" TProperty="int" Property="x => x.Id" Title="Id" />
            <PropertyColumn T="ProductSubcategoryDto" TProperty="int" Property="x => x.ProductCategoryId" Title="Category id" />
            <PropertyColumn T="ProductSubcategoryDto" TProperty="string" Property="x => x.Name" Title="Name" />
            <PropertyColumn T="ProductSubcategoryDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            
    </Columns>
</CrudPage>

@code {
    private string? filterName;
    private int? filterCategoryId;

    private async Task<GridData<ProductSubcategoryDto>> LoadServerDataAsync(GridState<ProductSubcategoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.ProductSubcategories.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName))
            {
                var needle = filterName.Trim();
                query = query.Where(x => x.Name.Contains(needle));
            }
            if (filterCategoryId.HasValue) query = query.Where(x => x.ProductCategoryId == filterCategoryId.Value);var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(ProductSubcategoryDto.Id)                => sort.Descending ? query.OrderByDescending(x => x.Id)                : query.OrderBy(x => x.Id),
                nameof(ProductSubcategoryDto.ProductCategoryId) => sort.Descending ? query.OrderByDescending(x => x.ProductCategoryId) : query.OrderBy(x => x.ProductCategoryId),
                nameof(ProductSubcategoryDto.Name)              => sort.Descending ? query.OrderByDescending(x => x.Name)              : query.OrderBy(x => x.Name),
                nameof(ProductSubcategoryDto.ModifiedDate)      => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)      : query.OrderBy(x => x.ModifiedDate),
                _                                               => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ProductSubcategoryDto> { Items = rows, TotalItems = total };
        }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductSubcategoryDialog>("New subcategory", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Subcategory created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductSubcategoryDto row)
    {
        var parameters = new DialogParameters<ProductSubcategoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductSubcategoryDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Subcategory updated.", Severity.Success);
    }

    private async Task DeleteAsync(ProductSubcategoryDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductSubcategories.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.ProductSubcategories.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Subcategory deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
