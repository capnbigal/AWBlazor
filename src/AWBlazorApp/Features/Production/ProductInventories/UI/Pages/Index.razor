@page "/aw/product-inventories"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.ProductInventories.Domain
@using AWBlazorApp.Features.Production.ProductInventories.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="ProductInventoryDto"
          @ref="page"
          Title="Product inventories"
          Caption="Production.ProductInventory · composite PK (ProductID, LocationID)"
          NewButtonLabel="New inventory row"
          HistoryRoute="aw/product-inventories/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="inventory row">
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><FkSelect TValue="short" Value="@(filterLocationId ?? 0)" ValueChanged="@(v => filterLocationId = v == 0 ? null : v)" Label="Location" Items="_locations" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductInventoryDto" TProperty="int" Property="x => x.ProductId" Title="Product id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductInventory" PropertyName="@nameof(ProductInventoryDto.ProductId)" Title="Product id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductInventoryDto" TProperty="short" Property="x => x.LocationId" Title="Location id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductInventory" PropertyName="@nameof(ProductInventoryDto.LocationId)" Title="Location id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductInventoryDto" TProperty="string" Property="x => x.Shelf" Title="Shelf">
            <HeaderTemplate><GridColumnHeader TEntity="ProductInventory" PropertyName="@nameof(ProductInventoryDto.Shelf)" Title="Shelf" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductInventoryDto" TProperty="byte" Property="x => x.Bin" Title="Bin">
            <HeaderTemplate><GridColumnHeader TEntity="ProductInventory" PropertyName="@nameof(ProductInventoryDto.Bin)" Title="Bin" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductInventoryDto" TProperty="short" Property="x => x.Quantity" Title="Quantity">
            <HeaderTemplate><GridColumnHeader TEntity="ProductInventory" PropertyName="@nameof(ProductInventoryDto.Quantity)" Title="Quantity" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductInventoryDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductInventory" PropertyName="@nameof(ProductInventoryDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/product-inventories/history?productId={row.ProductId}&locationId={row.LocationId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<ProductInventoryDto> page = null!;
    private int? filterProductId;
    private short? filterLocationId;
    private List<LookupItem<short>> _locations = [];
    private readonly ColumnFilterState columnFilters = new();

    protected override async Task OnInitializedAsync()
    {
        _locations = await Lookup.GetLocationsAsync();
    }

    private async Task<GridData<ProductInventoryDto>> LoadServerDataAsync(GridState<ProductInventoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductInventories.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        if (filterLocationId.HasValue) query = query.Where(x => x.LocationId == filterLocationId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductInventoryDto.ProductId)    => sort.Descending ? query.OrderByDescending(x => x.ProductId)    : query.OrderBy(x => x.ProductId),
            nameof(ProductInventoryDto.LocationId)   => sort.Descending ? query.OrderByDescending(x => x.LocationId)   : query.OrderBy(x => x.LocationId),
            nameof(ProductInventoryDto.Shelf)        => sort.Descending ? query.OrderByDescending(x => x.Shelf)        : query.OrderBy(x => x.Shelf),
            nameof(ProductInventoryDto.Bin)          => sort.Descending ? query.OrderByDescending(x => x.Bin)          : query.OrderBy(x => x.Bin),
            nameof(ProductInventoryDto.Quantity)     => sort.Descending ? query.OrderByDescending(x => x.Quantity)     : query.OrderBy(x => x.Quantity),
            nameof(ProductInventoryDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                        => query.OrderBy(x => x.ProductId).ThenBy(x => x.LocationId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductInventoryDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductInventoryDialog>("New inventory row", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Inventory row created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductInventoryDto row)
    {
        var parameters = new DialogParameters<ProductInventoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductInventoryDialog>($"Edit ({row.ProductId}, {row.LocationId})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Inventory row updated.", Severity.Success); await page.ReloadAsync(); }
    }

    private async Task DeleteAsync(ProductInventoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete inventory row?", $"Permanently delete ({row.ProductId}, {row.LocationId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductInventories.FirstOrDefaultAsync(t => t.ProductId == row.ProductId && t.LocationId == row.LocationId);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.ProductInventories.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Inventory row deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
