@page "/aw/product-documents"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using AWBlazorApp.Features.Production.ProductDocuments.Domain
@using AWBlazorApp.Features.Production.ProductDocuments.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="ProductDocumentDto"
          @ref="page"
          Title="Product ↔ document"
          Caption="Production.ProductDocument · composite PK (ProductID, DocumentNode hierarchyid)"
          NewButtonLabel="New link"
          HistoryRoute="aw/product-documents/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductDocumentDto" TProperty="int" Property="x => x.ProductId" Title="Product id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductDocument" PropertyName="@nameof(ProductDocumentDto.ProductId)" Title="Product id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDocumentDto" TProperty="string" Property="x => x.DocumentNode" Title="Document node">
            <HeaderTemplate><GridColumnHeader TEntity="ProductDocument" PropertyName="@nameof(ProductDocumentDto.DocumentNode)" Title="Document node" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDocumentDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductDocument" PropertyName="@nameof(ProductDocumentDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/product-documents/history?productId={row.ProductId}&documentNode={Uri.EscapeDataString(row.DocumentNode)}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<ProductDocumentDto> page = null!;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductDocumentDto>> LoadServerDataAsync(GridState<ProductDocumentDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductDocuments.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductDocumentDto.ProductId)    => sort.Descending ? query.OrderByDescending(x => x.ProductId)    : query.OrderBy(x => x.ProductId),
            nameof(ProductDocumentDto.DocumentNode) => sort.Descending ? query.OrderByDescending(x => x.DocumentNode) : query.OrderBy(x => x.DocumentNode),
            nameof(ProductDocumentDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                       => query.OrderBy(x => x.ProductId).ThenBy(x => x.DocumentNode),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize)
            .Select(x => new ProductDocumentDto(x.ProductId, x.DocumentNode.ToString()!, x.ModifiedDate))
            .ToListAsync(ct);
        return new GridData<ProductDocumentDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductDocumentDialog>("Link a product to a document", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(ProductDocumentDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.ProductId}, {row.DocumentNode})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var node = HierarchyId.Parse(row.DocumentNode);
        var entity = await db.ProductDocuments.FirstOrDefaultAsync(t => t.ProductId == row.ProductId && t.DocumentNode == node);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.ProductDocuments.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
