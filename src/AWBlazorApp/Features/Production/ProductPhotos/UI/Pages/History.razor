@page "/aw/product-photos/history"
@page "/aw/product-photos/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Product photo history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-photos"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Product photo history" : $"History for ProductPhoto #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ProductPhoto" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
