@page "/aw/product-photos"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.ProductPhotos.Domain
@using AWBlazorApp.Features.Production.ProductPhotos.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="ProductPhotoDto"
          @ref="page"
          Title="Product photos"
          Caption="Production.ProductPhoto · image bytes not editable"
          NewButtonLabel="New photo"
          HistoryRoute="aw/product-photos/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="photo"
          DeleteConfirmMessage="@(row => $"Permanently delete photo #{row.Id}?")">
    <Columns>
        <PropertyColumn T="ProductPhotoDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductPhoto" PropertyName="@nameof(ProductPhotoDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductPhotoDto" TProperty="string" Property="x => x.ThumbnailPhotoFileName" Title="Thumbnail file">
            <HeaderTemplate><GridColumnHeader TEntity="ProductPhoto" PropertyName="@nameof(ProductPhotoDto.ThumbnailPhotoFileName)" Title="Thumbnail file" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductPhotoDto" TProperty="bool" Property="x => x.HasThumbnail" Title="Has thumb?" />
        <PropertyColumn T="ProductPhotoDto" TProperty="string" Property="x => x.LargePhotoFileName" Title="Large file">
            <HeaderTemplate><GridColumnHeader TEntity="ProductPhoto" PropertyName="@nameof(ProductPhotoDto.LargePhotoFileName)" Title="Large file" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductPhotoDto" TProperty="bool" Property="x => x.HasLargePhoto" Title="Has large?" />
        <PropertyColumn T="ProductPhotoDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductPhoto" PropertyName="@nameof(ProductPhotoDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<ProductPhotoDto> page = null!;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductPhotoDto>> LoadServerDataAsync(GridState<ProductPhotoDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductPhotos.AsNoTracking();
        query = query.ApplyColumnFilters(columnFilters);
        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductPhotoDto.Id)                     => sort.Descending ? query.OrderByDescending(x => x.Id)                     : query.OrderBy(x => x.Id),
            nameof(ProductPhotoDto.ThumbnailPhotoFileName) => sort.Descending ? query.OrderByDescending(x => x.ThumbnailPhotoFileName) : query.OrderBy(x => x.ThumbnailPhotoFileName),
            nameof(ProductPhotoDto.HasThumbnail)           => sort.Descending ? query.OrderByDescending(x => x.ThumbNailPhoto != null && x.ThumbNailPhoto.Length > 0) : query.OrderBy(x => x.ThumbNailPhoto != null && x.ThumbNailPhoto.Length > 0),
            nameof(ProductPhotoDto.LargePhotoFileName)     => sort.Descending ? query.OrderByDescending(x => x.LargePhotoFileName)     : query.OrderBy(x => x.LargePhotoFileName),
            nameof(ProductPhotoDto.HasLargePhoto)          => sort.Descending ? query.OrderByDescending(x => x.LargePhoto != null && x.LargePhoto.Length > 0) : query.OrderBy(x => x.LargePhoto != null && x.LargePhoto.Length > 0),
            nameof(ProductPhotoDto.ModifiedDate)           => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)           : query.OrderBy(x => x.ModifiedDate),
            _                                              => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize)
            .Select(x => new ProductPhotoDto(
                x.Id, x.ThumbnailPhotoFileName, x.LargePhotoFileName,
                x.ThumbNailPhoto != null && x.ThumbNailPhoto.Length > 0,
                x.LargePhoto != null && x.LargePhoto.Length > 0,
                x.ModifiedDate))
            .ToListAsync(ct);
        return new GridData<ProductPhotoDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductPhotoDialog>("New product photo", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Photo created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductPhotoDto row)
    {
        var parameters = new DialogParameters<ProductPhotoDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductPhotoDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Photo updated.", Severity.Success);
    }

    private async Task DeleteAsync(ProductPhotoDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductPhotos.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Photo no longer exists.", Severity.Warning); return; }
        db.ProductPhotos.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Photo deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
