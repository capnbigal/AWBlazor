@page "/aw/products/history"
@page "/aw/products/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Product history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/products"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Product history" : $"History for Product #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Product" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
