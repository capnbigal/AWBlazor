@page "/aw/products"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Products.Domain
@using AWBlazorApp.Features.Production.Products.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="ProductDto"
          @ref="page"
          Title="Products"
          Caption="Production.Product"
          NewButtonLabel="New product"
          HistoryRoute="aw/products/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="product"
          DeleteConfirmMessage="@(row => $"Permanently delete product #{row.Id} ({row.Name})?")">
    <ExpandedContent Context="row">
        <ProductExpandedRow ProductId="@row.Id" />
    </ExpandedContent>
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><FkSelect TValue="int" Value="@(filterSubcategoryId ?? 0)" ValueChanged="@(v => filterSubcategoryId = v == 0 ? null : v)" Label="Subcategory" Items="_subcategories" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <HierarchyColumn T="ProductDto" />
        <PropertyColumn T="ProductDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Id" PropertyName="@nameof(ProductDto.Id)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="string" Property="x => x.Name" Title="Name">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Name" PropertyName="@nameof(ProductDto.Name)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="string" Property="x => x.ProductNumber" Title="Number">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Number" PropertyName="@nameof(ProductDto.ProductNumber)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="string" Property="x => x.Color" Title="Color">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Color" PropertyName="@nameof(ProductDto.Color)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="string" Property="x => x.Size" Title="Size">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Size" PropertyName="@nameof(ProductDto.Size)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="decimal" Property="x => x.StandardCost" Title="Cost" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Cost" PropertyName="@nameof(ProductDto.StandardCost)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="decimal" Property="x => x.ListPrice" Title="List price" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="List price" PropertyName="@nameof(ProductDto.ListPrice)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="string" Property="x => x.ProductLine" Title="Line">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Line" PropertyName="@nameof(ProductDto.ProductLine)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="string" Property="x => x.Class" Title="Class">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Class" PropertyName="@nameof(ProductDto.Class)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
            <HeaderTemplate><GridColumnHeader TEntity="Product" Title="Modified" PropertyName="@nameof(ProductDto.ModifiedDate)" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<ProductDto> page = null!;
    private string? filterName;
    private int? filterSubcategoryId;
    private List<LookupItem<int>> _subcategories = [];
    private readonly ColumnFilterState columnFilters = new();

    protected override async Task OnInitializedAsync()
    {
        _subcategories = await Lookup.GetProductSubcategoriesAsync();
    }

    private async Task<GridData<ProductDto>> LoadServerDataAsync(GridState<ProductDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.Products.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(filterName))
        {
            var n = filterName.Trim();
            query = query.Where(x => x.Name.Contains(n));
        }
        if (filterSubcategoryId.HasValue) query = query.Where(x => x.ProductSubcategoryId == filterSubcategoryId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductDto.Id)            => sort.Descending ? query.OrderByDescending(x => x.Id)            : query.OrderBy(x => x.Id),
            nameof(ProductDto.Name)          => sort.Descending ? query.OrderByDescending(x => x.Name)          : query.OrderBy(x => x.Name),
            nameof(ProductDto.ProductNumber) => sort.Descending ? query.OrderByDescending(x => x.ProductNumber) : query.OrderBy(x => x.ProductNumber),
            nameof(ProductDto.Color)         => sort.Descending ? query.OrderByDescending(x => x.Color)         : query.OrderBy(x => x.Color),
            nameof(ProductDto.Size)          => sort.Descending ? query.OrderByDescending(x => x.Size)          : query.OrderBy(x => x.Size),
            nameof(ProductDto.Class)         => sort.Descending ? query.OrderByDescending(x => x.Class)         : query.OrderBy(x => x.Class),
            nameof(ProductDto.ProductLine)   => sort.Descending ? query.OrderByDescending(x => x.ProductLine)   : query.OrderBy(x => x.ProductLine),
            nameof(ProductDto.ListPrice)     => sort.Descending ? query.OrderByDescending(x => x.ListPrice)     : query.OrderBy(x => x.ListPrice),
            nameof(ProductDto.StandardCost)  => sort.Descending ? query.OrderByDescending(x => x.StandardCost)  : query.OrderBy(x => x.StandardCost),
            nameof(ProductDto.ModifiedDate)  => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)  : query.OrderBy(x => x.ModifiedDate),
            _                                => query.OrderBy(x => x.Name),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductDialog>("New product", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Product created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductDto row)
    {
        var parameters = new DialogParameters<ProductDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Product updated.", Severity.Success);
    }

    private async Task DeleteAsync(ProductDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Products.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Product no longer exists.", Severity.Warning); return; }
        db.Products.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Product deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
