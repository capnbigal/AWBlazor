@page "/aw/product-cost-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.ProductCostHistories.Domain
@using AWBlazorApp.Features.Production.ProductCostHistories.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="ProductCostHistoryDto"
          @ref="page"
          Title="Product cost history"
          Caption="Production.ProductCostHistory · composite PK (ProductID, StartDate)"
          NewButtonLabel="New cost row"
          HistoryRoute="aw/product-cost-histories/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="cost row">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductCostHistoryDto" TProperty="int" Property="x => x.ProductId" Title="Product id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductCostHistory" PropertyName="@nameof(ProductCostHistoryDto.ProductId)" Title="Product id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductCostHistoryDto" TProperty="DateTime" Property="x => x.StartDate" Title="Start date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="ProductCostHistory" PropertyName="@nameof(ProductCostHistoryDto.StartDate)" Title="Start date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductCostHistoryDto" TProperty="DateTime?" Property="x => x.EndDate" Title="End date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="ProductCostHistory" PropertyName="@nameof(ProductCostHistoryDto.EndDate)" Title="End date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductCostHistoryDto" TProperty="decimal" Property="x => x.StandardCost" Title="Cost" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="ProductCostHistory" PropertyName="@nameof(ProductCostHistoryDto.StandardCost)" Title="Cost" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductCostHistoryDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductCostHistory" PropertyName="@nameof(ProductCostHistoryDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/product-cost-histories/history?productId={row.ProductId}&startDate={row.StartDate:yyyy-MM-dd}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<ProductCostHistoryDto> page = null!;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductCostHistoryDto>> LoadServerDataAsync(GridState<ProductCostHistoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductCostHistories.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductCostHistoryDto.ProductId)    => sort.Descending ? query.OrderByDescending(x => x.ProductId)    : query.OrderBy(x => x.ProductId),
            nameof(ProductCostHistoryDto.StartDate)    => sort.Descending ? query.OrderByDescending(x => x.StartDate)    : query.OrderBy(x => x.StartDate),
            nameof(ProductCostHistoryDto.EndDate)      => sort.Descending ? query.OrderByDescending(x => x.EndDate)      : query.OrderBy(x => x.EndDate),
            nameof(ProductCostHistoryDto.StandardCost) => sort.Descending ? query.OrderByDescending(x => x.StandardCost) : query.OrderBy(x => x.StandardCost),
            nameof(ProductCostHistoryDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                          => query.OrderBy(x => x.ProductId).ThenByDescending(x => x.StartDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductCostHistoryDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductCostHistoryDialog>("New cost row", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Cost row created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductCostHistoryDto row)
    {
        var parameters = new DialogParameters<ProductCostHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductCostHistoryDialog>($"Edit ({row.ProductId}, {row.StartDate:yyyy-MM-dd})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Cost row updated.", Severity.Success); await page.ReloadAsync(); }
    }

    private async Task DeleteAsync(ProductCostHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete cost row?", $"Permanently delete cost row ({row.ProductId}, {row.StartDate:yyyy-MM-dd})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductCostHistories.FirstOrDefaultAsync(t => t.ProductId == row.ProductId && t.StartDate == row.StartDate);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.ProductCostHistories.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Cost row deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
