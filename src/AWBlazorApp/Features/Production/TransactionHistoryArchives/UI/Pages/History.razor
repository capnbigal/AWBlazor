@page "/aw/transaction-history-archives/history"
@page "/aw/transaction-history-archives/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Transaction history archive audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/transaction-history-archives"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Transaction history archive audit" : $"History for TransactionHistoryArchive #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="TransactionHistoryArchive" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
