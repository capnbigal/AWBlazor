@page "/aw/transaction-history-archives"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.TransactionHistoryArchives.Domain
@using AWBlazorApp.Features.Production.TransactionHistoryArchives.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="TransactionHistoryArchiveDto"
          @ref="page"
          Title="Transaction history archive"
          Caption="Production.TransactionHistoryArchive"
          NewButtonLabel="New archive entry"
          HistoryRoute="aw/transaction-history-archives/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="archive entry"
          DeleteConfirmMessage="@(row => $"Permanently delete archive entry #{row.Id}?")">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="int" Property="x => x.ProductId" Title="Product">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="int" Property="x => x.ReferenceOrderId" Title="Ref order">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.ReferenceOrderId)" Title="Ref order" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="int" Property="x => x.ReferenceOrderLineId" Title="Ref line">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.ReferenceOrderLineId)" Title="Ref line" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="DateTime" Property="x => x.TransactionDate" Title="Date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.TransactionDate)" Title="Date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="string" Property="x => x.TransactionType" Title="Type">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.TransactionType)" Title="Type" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="int" Property="x => x.Quantity" Title="Qty">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.Quantity)" Title="Qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="TransactionHistoryArchiveDto" TProperty="decimal" Property="x => x.ActualCost" Title="Cost" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="TransactionHistoryArchive" PropertyName="@nameof(TransactionHistoryArchiveDto.ActualCost)" Title="Cost" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<TransactionHistoryArchiveDto> page = null!;
    private int? filterProductId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<TransactionHistoryArchiveDto>> LoadServerDataAsync(GridState<TransactionHistoryArchiveDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.TransactionHistoryArchives.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(TransactionHistoryArchiveDto.Id)                   => sort.Descending ? query.OrderByDescending(x => x.Id)                   : query.OrderBy(x => x.Id),
            nameof(TransactionHistoryArchiveDto.ProductId)            => sort.Descending ? query.OrderByDescending(x => x.ProductId)            : query.OrderBy(x => x.ProductId),
            nameof(TransactionHistoryArchiveDto.ReferenceOrderId)     => sort.Descending ? query.OrderByDescending(x => x.ReferenceOrderId)     : query.OrderBy(x => x.ReferenceOrderId),
            nameof(TransactionHistoryArchiveDto.ReferenceOrderLineId) => sort.Descending ? query.OrderByDescending(x => x.ReferenceOrderLineId) : query.OrderBy(x => x.ReferenceOrderLineId),
            nameof(TransactionHistoryArchiveDto.TransactionDate)      => sort.Descending ? query.OrderByDescending(x => x.TransactionDate)      : query.OrderBy(x => x.TransactionDate),
            nameof(TransactionHistoryArchiveDto.TransactionType)      => sort.Descending ? query.OrderByDescending(x => x.TransactionType)      : query.OrderBy(x => x.TransactionType),
            nameof(TransactionHistoryArchiveDto.Quantity)             => sort.Descending ? query.OrderByDescending(x => x.Quantity)             : query.OrderBy(x => x.Quantity),
            nameof(TransactionHistoryArchiveDto.ActualCost)           => sort.Descending ? query.OrderByDescending(x => x.ActualCost)           : query.OrderBy(x => x.ActualCost),
            _                                                         => query.OrderByDescending(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<TransactionHistoryArchiveDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<TransactionHistoryArchiveDialog>("New archive entry", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Archive entry created.", Severity.Success);
    }

    private async Task OpenEditAsync(TransactionHistoryArchiveDto row)
    {
        var parameters = new DialogParameters<TransactionHistoryArchiveDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<TransactionHistoryArchiveDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Archive entry updated.", Severity.Success);
    }

    private async Task DeleteAsync(TransactionHistoryArchiveDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.TransactionHistoryArchives.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Entry no longer exists.", Severity.Warning); return; }
        db.TransactionHistoryArchives.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Archive entry deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
