@page "/aw/product-descriptions/history"
@page "/aw/product-descriptions/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Description history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-descriptions"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Description history" : $"History for ProductDescription #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ProductDescription" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
