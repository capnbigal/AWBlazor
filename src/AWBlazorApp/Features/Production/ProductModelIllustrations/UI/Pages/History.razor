@page "/aw/product-model-illustrations/history"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.Cultures.Dtos
@using AWBlazorApp.Features.Production.Documents.Dtos
@using AWBlazorApp.Features.Production.Illustrations.Dtos
@using AWBlazorApp.Features.Production.Locations.Dtos
@using AWBlazorApp.Features.Production.ProductCategories.Dtos
@using AWBlazorApp.Features.Production.ProductCostHistories.Dtos
@using AWBlazorApp.Features.Production.ProductDescriptions.Dtos
@using AWBlazorApp.Features.Production.ProductDocuments.Dtos
@using AWBlazorApp.Features.Production.ProductInventories.Dtos
@using AWBlazorApp.Features.Production.ProductListPriceHistories.Dtos
@using AWBlazorApp.Features.Production.ProductModels.Dtos
@using AWBlazorApp.Features.Production.ProductModelIllustrations.Dtos
@using AWBlazorApp.Features.Production.ProductModelProductDescriptionCultures.Dtos
@using AWBlazorApp.Features.Production.ProductPhotos.Dtos
@using AWBlazorApp.Features.Production.ProductProductPhotos.Dtos
@using AWBlazorApp.Features.Production.ProductReviews.Dtos
@using AWBlazorApp.Features.Production.Products.Dtos
@using AWBlazorApp.Features.Production.ProductSubcategories.Dtos
@using AWBlazorApp.Features.Production.ScrapReasons.Dtos
@using AWBlazorApp.Features.Production.TransactionHistories.Dtos
@using AWBlazorApp.Features.Production.TransactionHistoryArchives.Dtos
@using AWBlazorApp.Features.Production.UnitMeasures.Dtos
@using AWBlazorApp.Features.Production.WorkOrders.Dtos
@using AWBlazorApp.Features.Production.WorkOrderRoutings.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Model ↔ illustration audit</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/product-model-illustrations"))" />
        <MudText Typo="Typo.h4">Model ↔ illustration audit</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="ProductModelId" Label="Product model id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudNumericField T="int?" @bind-Value="IllustrationId" Label="Illustration id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3"><MudTextField @bind-Value="filterChangedBy" Label="Changed by" Variant="Variant.Outlined" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" @bind-Value="filterAction" Label="Action" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter">
                    <MudSelectItem T="string?" Value="@null">(any)</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Created")">Created</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Updated")">Updated</MudSelectItem>
                    <MudSelectItem T="string?" Value="@("Deleted")">Deleted</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="ProductModelIllustrationAuditLogDto" ServerData="LoadServerDataAsync" @ref="grid" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss">
                <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustrationAuditLog" PropertyName="@nameof(ProductModelIllustrationAuditLogDto.ChangedDate)" Title="When" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ProductModelId" Title="Model">
                <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustrationAuditLog" PropertyName="@nameof(ProductModelIllustrationAuditLogDto.ProductModelId)" Title="Model" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.IllustrationId" Title="Illustration">
                <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustrationAuditLog" PropertyName="@nameof(ProductModelIllustrationAuditLogDto.IllustrationId)" Title="Illustration" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@ActionColor(context.Item.Action)" Variant="Variant.Filled">@context.Item.Action</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ChangedBy" Title="By">
                <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustrationAuditLog" PropertyName="@nameof(ProductModelIllustrationAuditLogDto.ChangedBy)" Title="By" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ChangeSummary" Title="Change summary">
                <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustrationAuditLog" PropertyName="@nameof(ProductModelIllustrationAuditLogDto.ChangeSummary)" Title="Change summary" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ProductModelIllustrationAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? ProductModelId { get; set; }
    [SupplyParameterFromQuery] public int? IllustrationId { get; set; }

    private MudDataGrid<ProductModelIllustrationAuditLogDto> grid = null!;
    private string? filterChangedBy;
    private string? filterAction;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductModelIllustrationAuditLogDto>> LoadServerDataAsync(GridState<ProductModelIllustrationAuditLogDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductModelIllustrationAuditLogs.AsNoTracking();

        if (ProductModelId.HasValue) query = query.Where(a => a.ProductModelId == ProductModelId.Value);
        if (IllustrationId.HasValue) query = query.Where(a => a.IllustrationId == IllustrationId.Value);
        if (!string.IsNullOrWhiteSpace(filterAction)) query = query.Where(a => a.Action == filterAction);
        if (!string.IsNullOrWhiteSpace(filterChangedBy))
        {
            var needle = filterChangedBy.Trim();
            query = query.Where(a => a.ChangedBy != null && a.ChangedBy.Contains(needle));
        }
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);

        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductModelIllustrationAuditLogDto.ChangedDate) => sort.Descending ? query.OrderByDescending(a => a.ChangedDate) : query.OrderBy(a => a.ChangedDate),
            nameof(ProductModelIllustrationAuditLogDto.ProductModelId) => sort.Descending ? query.OrderByDescending(a => a.ProductModelId) : query.OrderBy(a => a.ProductModelId),
            nameof(ProductModelIllustrationAuditLogDto.IllustrationId) => sort.Descending ? query.OrderByDescending(a => a.IllustrationId) : query.OrderBy(a => a.IllustrationId),
            nameof(ProductModelIllustrationAuditLogDto.ChangedBy) => sort.Descending ? query.OrderByDescending(a => a.ChangedBy) : query.OrderBy(a => a.ChangedBy),
            nameof(ProductModelIllustrationAuditLogDto.ChangeSummary) => sort.Descending ? query.OrderByDescending(a => a.ChangeSummary) : query.OrderBy(a => a.ChangeSummary),
            _ => query.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id),
        };

        var rows = await query
            .Skip(state.Page * state.PageSize).Take(state.PageSize).Select(a => a.ToDto()).ToListAsync(ct);
        return new GridData<ProductModelIllustrationAuditLogDto> { Items = rows, TotalItems = total };
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private static Color ActionColor(string action) => action switch
    {
        "Created" => Color.Success, "Updated" => Color.Info, "Deleted" => Color.Error, _ => Color.Default,
    };
}
