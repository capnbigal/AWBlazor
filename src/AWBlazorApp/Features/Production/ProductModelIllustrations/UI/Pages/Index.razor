@page "/aw/product-model-illustrations"
@attribute [Authorize]
@using AWBlazorApp.Features.Production.ProductModelIllustrations.Domain
@using AWBlazorApp.Features.Production.ProductModelIllustrations.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<CrudPage TDto="ProductModelIllustrationDto"
          @ref="page"
          Title="Model ↔ illustration"
          Caption="Production.ProductModelIllustration · composite PK (ProductModelID, IllustrationID)"
          NewButtonLabel="New link"
          HistoryRoute="aw/product-model-illustrations/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="link">
    <Filters>
        <MudItem xs="12"><MudNumericField T="int?" @bind-Value="filterProductModelId" Label="Product model id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductModelIllustrationDto" TProperty="int" Property="x => x.ProductModelId" Title="Product model id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustration" PropertyName="@nameof(ProductModelIllustrationDto.ProductModelId)" Title="Product model id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductModelIllustrationDto" TProperty="int" Property="x => x.IllustrationId" Title="Illustration id">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustration" PropertyName="@nameof(ProductModelIllustrationDto.IllustrationId)" Title="Illustration id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductModelIllustrationDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductModelIllustration" PropertyName="@nameof(ProductModelIllustrationDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/product-model-illustrations/history?productModelId={row.ProductModelId}&illustrationId={row.IllustrationId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<ProductModelIllustrationDto> page = null!;
    private int? filterProductModelId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductModelIllustrationDto>> LoadServerDataAsync(GridState<ProductModelIllustrationDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductModelIllustrations.AsNoTracking();
        if (filterProductModelId.HasValue) query = query.Where(x => x.ProductModelId == filterProductModelId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductModelIllustrationDto.ProductModelId) => sort.Descending ? query.OrderByDescending(x => x.ProductModelId) : query.OrderBy(x => x.ProductModelId),
            nameof(ProductModelIllustrationDto.IllustrationId) => sort.Descending ? query.OrderByDescending(x => x.IllustrationId) : query.OrderBy(x => x.IllustrationId),
            nameof(ProductModelIllustrationDto.ModifiedDate)   => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)   : query.OrderBy(x => x.ModifiedDate),
            _                                                  => query.OrderBy(x => x.ProductModelId).ThenBy(x => x.IllustrationId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductModelIllustrationDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductModelIllustrationDialog>("Link a model to an illustration", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Link created.", Severity.Success);
    }

    private async Task DeleteAsync(ProductModelIllustrationDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete link?", $"Permanently delete link ({row.ProductModelId}, {row.IllustrationId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductModelIllustrations.FirstOrDefaultAsync(t => t.ProductModelId == row.ProductModelId && t.IllustrationId == row.IllustrationId);
        if (entity is null) { Snackbar.Add("Link no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.ProductModelIllustrations.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Link deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
