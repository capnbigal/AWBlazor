@using AWBlazorApp.Features.Production.TransactionHistories.Dtos
@using AWBlazorApp.Features.Production.TransactionHistoryArchives.Dtos
@using AWBlazorApp.Features.Production.UnitMeasures.Dtos
@using AWBlazorApp.Features.Production.WorkOrders.Dtos
@using AWBlazorApp.Features.Production.WorkOrderRoutings.Dtos
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateProductListPriceHistoryRequest> CreateValidator
@inject MudFormValidator<UpdateProductListPriceHistoryRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject LookupService Lookup

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create price row" : $"Edit price ({Model!.ProductId}, {Model.StartDate:yyyy-MM-dd})")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.ProductId" ValueChanged="@((int v) => createModel = createModel with { ProductId = v })" Label="Product" SearchFunc="Lookup.SearchProductsAsync" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@createModel.StartDate" DateChanged="@((DateTime? v) => createModel = createModel with { StartDate = v ?? DateTime.UtcNow.Date })" Label="Start date" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@createModel.EndDate" DateChanged="@((DateTime? v) => createModel = createModel with { EndDate = v })" Label="End date" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal" Value="@createModel.ListPrice" ValueChanged="@((decimal v) => createModel = createModel with { ListPrice = v })" Label="List price" Variant="Variant.Outlined" Required="true" Min="0" Step="0.01M" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="@updateModel.EndDate" DateChanged="@((DateTime? v) => updateModel = updateModel with { EndDate = v })" Label="End date" Variant="Variant.Outlined" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Value="@updateModel.ListPrice" ValueChanged="@((decimal? v) => updateModel = updateModel with { ListPrice = v })" Label="List price" Variant="Variant.Outlined" Clearable="true" Min="0" Step="0.01M" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ProductListPriceHistoryDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateProductListPriceHistoryRequest createModel = new() { StartDate = DateTime.UtcNow.Date };
    private UpdateProductListPriceHistoryRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
        {
            updateModel = new UpdateProductListPriceHistoryRequest
            {
                EndDate = Model.EndDate,
                ListPrice = Model.ListPrice,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.ProductListPriceHistories.AnyAsync(x =>
                        x.ProductId == createModel.ProductId && x.StartDate == createModel.StartDate))
                {
                    Snackbar.Add("Price row for that product + start date already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.ProductListPriceHistories.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.ProductListPriceHistories.FirstOrDefaultAsync(t =>
                    t.ProductId == Model!.ProductId && t.StartDate == Model.StartDate);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                updateModel.ApplyTo(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
