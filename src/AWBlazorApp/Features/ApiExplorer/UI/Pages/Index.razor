@page "/api-explorer"
@attribute [Authorize]
@using System.Text
@using System.Text.Json
@using AWBlazorApp.Features.ApiExplorer.Domain
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>API explorer</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4">API explorer</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Hit live endpoints with your current session. Results render as a data grid when the
            response looks tabular, otherwise as formatted JSON. A friendlier front door than Swagger.
        </MudText>
    </div>

    <MudGrid Spacing="3">
        @* ── Catalog ─────────────────────────────────────────────────────────── *@
        <MudItem xs="12" md="4" lg="3">
            <MudPaper Elevation="1" Class="pa-2">
                <MudTextField T="string" @bind-Value="filter" Placeholder="Filter endpoints..."
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                @foreach (var group in FilteredEndpoints.GroupBy(e => e.Category).OrderBy(g => g.Key))
                {
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Class="px-2 pt-2">@group.Key</MudText>
                    @foreach (var ep in group)
                    {
                        <MudListItem T="string" OnClick="@(() => SelectEndpoint(ep))"
                                     Class="@(selected?.Id == ep.Id ? "api-endpoint-row selected" : "api-endpoint-row")">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="@MethodColor(ep.Method)" Variant="Variant.Filled"
                                         Class="api-method-chip">@ep.Method</MudChip>
                                <MudText Typo="Typo.body2" Class="api-endpoint-path">@ep.Path</MudText>
                            </MudStack>
                        </MudListItem>
                    }
                }
            </MudPaper>
        </MudItem>

        @* ── Request / response panel ──────────────────────────────────────── *@
        <MudItem xs="12" md="8" lg="9">
            <MudPaper Elevation="1" Class="pa-4">
                @if (selected is null)
                {
                    <MudAlert Severity="Severity.Info">Select an endpoint on the left to begin.</MudAlert>
                }
                else
                {
                    <MudStack Spacing="3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudChip T="string" Color="@MethodColor(selected.Method)" Variant="Variant.Filled">@selected.Method</MudChip>
                            <MudText Typo="Typo.h6" Class="api-endpoint-path">@selected.Path</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@selected.Summary</MudText>

                        @if (selected.Parameters.Count > 0)
                        {
                            <MudDivider />
                            <MudText Typo="Typo.subtitle2">Parameters</MudText>
                            <MudGrid Spacing="2">
                                @foreach (var p in selected.Parameters)
                                {
                                    <MudItem xs="12" sm="6">
                                        <MudTextField T="string" Label="@p.Name" HelperText="@p.Description"
                                                      Value="@(paramValues.GetValueOrDefault(p.Name, p.DefaultValue ?? ""))"
                                                      ValueChanged="@(v => paramValues[p.Name] = v ?? "")"
                                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                                      Immediate="true" />
                                    </MudItem>
                                }
                            </MudGrid>
                        }

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton StartIcon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary"
                                       Variant="Variant.Filled" OnClick="SendAsync" Disabled="@sending">
                                @(sending ? "Sending..." : "Send request")
                            </MudButton>
                            @if (!string.IsNullOrEmpty(builtUrl))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">@builtUrl</MudText>
                            }
                        </MudStack>

                        @if (response is not null)
                        {
                            <MudDivider />
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Color="@(response.Ok ? Color.Success : Color.Error)" Variant="Variant.Filled">
                                    @response.Status @response.StatusText
                                </MudChip>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@response.ElapsedMs ms · @response.ContentType</MudText>
                                <MudSpacer />
                                <MudToggleGroup T="string" @bind-Value="viewMode" Color="Color.Primary" Size="Size.Small" SelectionMode="SelectionMode.SingleSelection">
                                    <MudToggleItem T="string" Value="@("grid")"  Text="Grid"  />
                                    <MudToggleItem T="string" Value="@("json")"  Text="JSON" />
                                </MudToggleGroup>
                            </MudStack>

                            @if (viewMode == "grid" && gridRows is { Count: > 0 })
                            {
                                <MudTextField T="string" @bind-Value="gridFilter" Placeholder="Filter rows (matches any column)..."
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList"
                                              Class="mb-2" />
                                <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="overflow-x: auto;">
                                    <thead>
                                        <tr>
                                            @foreach (var col in gridColumns!)
                                            {
                                                <th>@col</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in FilteredGridRows)
                                        {
                                            <tr>
                                                @foreach (var col in gridColumns!)
                                                {
                                                    <td>@FormatCell(row.GetValueOrDefault(col))</td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Showing @FilteredGridRows.Count of @gridRows.Count row@(gridRows.Count == 1 ? "" : "s")@(totalCount.HasValue && totalCount.Value != gridRows.Count ? $" (total on server: {totalCount.Value:N0})" : "")@(string.IsNullOrEmpty(gridFilter) ? "" : $" · filter: \"{gridFilter}\"").
                                </MudText>
                            }
                            else
                            {
                                <pre class="api-explorer-json">@response.Body</pre>
                            }
                        }
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private ApiEndpoint? selected;
    private string filter = "";
    private string viewMode = "grid";
    private bool sending;
    private string builtUrl = "";

    private readonly Dictionary<string, string> paramValues = new();

    private ApiResponse? response;
    private List<Dictionary<string, object?>>? gridRows;
    private List<string>? gridColumns;
    private long? totalCount;
    private string gridFilter = "";

    private IEnumerable<ApiEndpoint> FilteredEndpoints =>
        string.IsNullOrWhiteSpace(filter)
            ? ApiEndpointCatalog.Endpoints
            : ApiEndpointCatalog.Endpoints.Where(e =>
                e.Path.Contains(filter, StringComparison.OrdinalIgnoreCase)
                || e.Summary.Contains(filter, StringComparison.OrdinalIgnoreCase)
                || e.Category.Contains(filter, StringComparison.OrdinalIgnoreCase));

    private void SelectEndpoint(ApiEndpoint ep)
    {
        selected = ep;
        paramValues.Clear();
        foreach (var p in ep.Parameters)
            paramValues[p.Name] = p.DefaultValue ?? "";
        response = null;
        gridRows = null;
        gridColumns = null;
        totalCount = null;
        gridFilter = "";
        builtUrl = BuildUrl(ep);
    }

    /// <summary>Case-insensitive substring match across every cell in a row. Empty needle = no filter.</summary>
    private IReadOnlyList<Dictionary<string, object?>> FilteredGridRows
    {
        get
        {
            if (gridRows is null) return Array.Empty<Dictionary<string, object?>>();
            if (string.IsNullOrWhiteSpace(gridFilter)) return gridRows;
            var n = gridFilter.Trim();
            return gridRows.Where(r => r.Values.Any(v => v?.ToString()?.Contains(n, StringComparison.OrdinalIgnoreCase) == true)).ToList();
        }
    }

    private string BuildUrl(ApiEndpoint ep)
    {
        var qs = ep.Parameters
            .Where(p => !string.IsNullOrWhiteSpace(paramValues.GetValueOrDefault(p.Name)))
            .Select(p => $"{Uri.EscapeDataString(p.Name)}={Uri.EscapeDataString(paramValues[p.Name])}")
            .ToArray();
        return qs.Length == 0 ? ep.Path : ep.Path + "?" + string.Join("&", qs);
    }

    private async Task SendAsync()
    {
        if (selected is null) return;
        sending = true;
        builtUrl = BuildUrl(selected);
        try
        {
            response = await JS.InvokeAsync<ApiResponse>("awApiExplorer.send", selected.Method, builtUrl);
            ParseGrid(response);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Request failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            sending = false;
        }
    }

    /// <summary>
    /// Inspect the parsed JSON to decide if it's tabular: either a JSON array of objects, or a
    /// paging envelope {results:[], total, ...} (PagedResult shape from Shared/Models/Common.cs).
    /// Also tolerates legacy {items:[], totalCount, ...} for any caller still using that shape.
    /// Populates gridColumns/gridRows when yes.
    /// </summary>
    private void ParseGrid(ApiResponse res)
    {
        gridRows = null;
        gridColumns = null;
        totalCount = null;

        if (string.IsNullOrWhiteSpace(res.Body)) return;

        try
        {
            using var doc = JsonDocument.Parse(res.Body);
            var root = doc.RootElement;

            JsonElement items;
            if (root.ValueKind == JsonValueKind.Array)
            {
                items = root;
            }
            else if (root.ValueKind == JsonValueKind.Object
                     && TryGetArrayProperty(root, out items, out var totalProp))
            {
                if (totalProp is { } tc && tc.TryGetInt64(out var tcVal))
                    totalCount = tcVal;
            }
            else
            {
                return;
            }

            var rows = new List<Dictionary<string, object?>>();
            var columns = new List<string>();
            var seen = new HashSet<string>();
            foreach (var el in items.EnumerateArray())
            {
                if (el.ValueKind != JsonValueKind.Object) return; // not tabular
                var row = new Dictionary<string, object?>();
                foreach (var prop in el.EnumerateObject())
                {
                    if (seen.Add(prop.Name)) columns.Add(prop.Name);
                    row[prop.Name] = ExtractValue(prop.Value);
                }
                rows.Add(row);
                if (rows.Count >= 500) break; // safety cap
            }

            if (rows.Count == 0) return;
            gridRows = rows;
            gridColumns = columns;
            viewMode = "grid";
        }
        catch
        {
            // Non-tabular response — stay in JSON view.
        }
    }

    /// <summary>
    /// Resolves which property on the response object holds the row array and which (if any)
    /// holds the total-count scalar. Tries the current PagedResult shape first
    /// (<c>results</c>/<c>total</c>), then the legacy shape (<c>items</c>/<c>totalCount</c>).
    /// </summary>
    private static bool TryGetArrayProperty(JsonElement root, out JsonElement array, out JsonElement? total)
    {
        foreach (var (arrayName, totalName) in new[] { ("results", "total"), ("items", "totalCount") })
        {
            if (root.TryGetProperty(arrayName, out var arr) && arr.ValueKind == JsonValueKind.Array)
            {
                array = arr;
                total = root.TryGetProperty(totalName, out var tc) ? tc : null;
                return true;
            }
        }
        array = default;
        total = null;
        return false;
    }

    private static object? ExtractValue(JsonElement el) => el.ValueKind switch
    {
        JsonValueKind.String => el.GetString(),
        JsonValueKind.Number => el.TryGetInt64(out var i) ? i : el.GetDouble(),
        JsonValueKind.True   => true,
        JsonValueKind.False  => false,
        JsonValueKind.Null   => null,
        JsonValueKind.Object => el.GetRawText(),
        JsonValueKind.Array  => el.GetRawText(),
        _                    => el.GetRawText(),
    };

    private static string FormatCell(object? val) => val switch
    {
        null => "",
        bool b => b ? "true" : "false",
        double d => d.ToString("G"),
        _ => val.ToString() ?? "",
    };

    private static Color MethodColor(string method) => method.ToUpperInvariant() switch
    {
        "GET"    => Color.Success,
        "POST"   => Color.Primary,
        "PATCH"  => Color.Warning,
        "PUT"    => Color.Warning,
        "DELETE" => Color.Error,
        _        => Color.Default,
    };

    public sealed record ApiResponse(bool Ok, int Status, string StatusText, int ElapsedMs, string ContentType, string Body, JsonElement? Parsed);
}
