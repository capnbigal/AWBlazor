@page "/aw/product-vendors"
@attribute [Authorize]
@using AWBlazorApp.Features.Purchasing.ProductVendors.Domain
@using AWBlazorApp.Features.Purchasing.ProductVendors.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="ProductVendorDto"
          @ref="page"
          Title="Product vendors"
          Caption="Purchasing.ProductVendor · composite PK (ProductID, BusinessEntityID)"
          NewButtonLabel="New product vendor"
          HistoryRoute="aw/product-vendors/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="product vendor">
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterProductId ?? 0)" ValueChanged="@(v => filterProductId = v == 0 ? null : v)" Label="Product" SearchFunc="@(q => Lookup.SearchProductsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Vendor" SearchFunc="@(q => Lookup.SearchVendorsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="ProductVendorDto" TProperty="int" Property="x => x.ProductId" Title="Product">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductVendorDto" TProperty="int" Property="x => x.BusinessEntityId" Title="Vendor">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.BusinessEntityId)" Title="Vendor" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductVendorDto" TProperty="int" Property="x => x.AverageLeadTime" Title="Lead time">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.AverageLeadTime)" Title="Lead time" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductVendorDto" TProperty="decimal" Property="x => x.StandardPrice" Title="Std price" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.StandardPrice)" Title="Std price" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductVendorDto" TProperty="int" Property="x => x.MinOrderQty" Title="Min qty">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.MinOrderQty)" Title="Min qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductVendorDto" TProperty="int" Property="x => x.MaxOrderQty" Title="Max qty">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.MaxOrderQty)" Title="Max qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductVendorDto" TProperty="string" Property="x => x.UnitMeasureCode" Title="UoM">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.UnitMeasureCode)" Title="UoM" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="ProductVendorDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="ProductVendor" PropertyName="@nameof(ProductVendorDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/product-vendors/history?productId={row.ProductId}&businessEntityId={row.BusinessEntityId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<ProductVendorDto> page = null!;
    private int? filterProductId;
    private int? filterBusinessEntityId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<ProductVendorDto>> LoadServerDataAsync(GridState<ProductVendorDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.ProductVendors.AsNoTracking();
        if (filterProductId.HasValue) query = query.Where(x => x.ProductId == filterProductId.Value);
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(ProductVendorDto.ProductId)        => sort.Descending ? query.OrderByDescending(x => x.ProductId)        : query.OrderBy(x => x.ProductId),
            nameof(ProductVendorDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(ProductVendorDto.AverageLeadTime)  => sort.Descending ? query.OrderByDescending(x => x.AverageLeadTime)  : query.OrderBy(x => x.AverageLeadTime),
            nameof(ProductVendorDto.StandardPrice)    => sort.Descending ? query.OrderByDescending(x => x.StandardPrice)    : query.OrderBy(x => x.StandardPrice),
            nameof(ProductVendorDto.MinOrderQty)      => sort.Descending ? query.OrderByDescending(x => x.MinOrderQty)      : query.OrderBy(x => x.MinOrderQty),
            nameof(ProductVendorDto.MaxOrderQty)      => sort.Descending ? query.OrderByDescending(x => x.MaxOrderQty)      : query.OrderBy(x => x.MaxOrderQty),
            nameof(ProductVendorDto.UnitMeasureCode)  => sort.Descending ? query.OrderByDescending(x => x.UnitMeasureCode)  : query.OrderBy(x => x.UnitMeasureCode),
            nameof(ProductVendorDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _                                         => query.OrderBy(x => x.ProductId).ThenBy(x => x.BusinessEntityId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<ProductVendorDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ProductVendorDialog>("New product vendor", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Product vendor created.", Severity.Success);
    }

    private async Task OpenEditAsync(ProductVendorDto row)
    {
        var parameters = new DialogParameters<ProductVendorDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ProductVendorDialog>($"Edit ({row.ProductId}, {row.BusinessEntityId})", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Product vendor updated.", Severity.Success); await page.ReloadAsync(); }
    }

    private async Task DeleteAsync(ProductVendorDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete product vendor?", $"Permanently delete product vendor ({row.ProductId}, {row.BusinessEntityId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ProductVendors.FirstOrDefaultAsync(t => t.ProductId == row.ProductId && t.BusinessEntityId == row.BusinessEntityId);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.ProductVendors.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Product vendor deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
