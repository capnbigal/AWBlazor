@page "/aw/purchase-order-details"
@attribute [Authorize]
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<CrudPage TDto="PurchaseOrderDetailDto"
          @ref="page"
          Title="Purchase order details"
          Caption="Purchasing.PurchaseOrderDetail · composite PK (PurchaseOrderID, PurchaseOrderDetailID)"
          NewButtonLabel="New line item"
          HistoryRoute="aw/purchase-order-details/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="line item">
    <Filters>
        <MudItem xs="12"><MudNumericField T="int?" @bind-Value="filterPurchaseOrderId" Label="PO id" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="int" Property="x => x.PurchaseOrderId" Title="PO #">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.PurchaseOrderId)" Title="PO #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="int" Property="x => x.PurchaseOrderDetailId" Title="Line #">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.PurchaseOrderDetailId)" Title="Line #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="int" Property="x => x.ProductId" Title="Product">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.ProductId)" Title="Product" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="short" Property="x => x.OrderQty" Title="Qty">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.OrderQty)" Title="Qty" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="decimal" Property="x => x.UnitPrice" Title="Unit price" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.UnitPrice)" Title="Unit price" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="decimal" Property="x => x.LineTotal" Title="Line total" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.LineTotal)" Title="Line total" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="decimal" Property="x => x.ReceivedQty" Title="Received">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.ReceivedQty)" Title="Received" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="decimal" Property="x => x.StockedQty" Title="Stocked">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.StockedQty)" Title="Stocked" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderDetailDto" TProperty="DateTime" Property="x => x.DueDate" Title="Due" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderDetail" PropertyName="@nameof(PurchaseOrderDetailDto.DueDate)" Title="Due" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/purchase-order-details/history?purchaseOrderId={row.PurchaseOrderId}&purchaseOrderDetailId={row.PurchaseOrderDetailId}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<PurchaseOrderDetailDto> page = null!;
    private int? filterPurchaseOrderId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<PurchaseOrderDetailDto>> LoadServerDataAsync(GridState<PurchaseOrderDetailDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.PurchaseOrderDetails.AsNoTracking();
        if (filterPurchaseOrderId.HasValue) query = query.Where(x => x.PurchaseOrderId == filterPurchaseOrderId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(PurchaseOrderDetailDto.PurchaseOrderId)       => sort.Descending ? query.OrderByDescending(x => x.PurchaseOrderId)       : query.OrderBy(x => x.PurchaseOrderId),
            nameof(PurchaseOrderDetailDto.PurchaseOrderDetailId) => sort.Descending ? query.OrderByDescending(x => x.PurchaseOrderDetailId) : query.OrderBy(x => x.PurchaseOrderDetailId),
            nameof(PurchaseOrderDetailDto.ProductId)             => sort.Descending ? query.OrderByDescending(x => x.ProductId)             : query.OrderBy(x => x.ProductId),
            nameof(PurchaseOrderDetailDto.OrderQty)              => sort.Descending ? query.OrderByDescending(x => x.OrderQty)              : query.OrderBy(x => x.OrderQty),
            nameof(PurchaseOrderDetailDto.UnitPrice)             => sort.Descending ? query.OrderByDescending(x => x.UnitPrice)             : query.OrderBy(x => x.UnitPrice),
            nameof(PurchaseOrderDetailDto.LineTotal)             => sort.Descending ? query.OrderByDescending(x => x.LineTotal)             : query.OrderBy(x => x.LineTotal),
            nameof(PurchaseOrderDetailDto.ReceivedQty)           => sort.Descending ? query.OrderByDescending(x => x.ReceivedQty)           : query.OrderBy(x => x.ReceivedQty),
            nameof(PurchaseOrderDetailDto.StockedQty)            => sort.Descending ? query.OrderByDescending(x => x.StockedQty)            : query.OrderBy(x => x.StockedQty),
            nameof(PurchaseOrderDetailDto.DueDate)               => sort.Descending ? query.OrderByDescending(x => x.DueDate)               : query.OrderBy(x => x.DueDate),
            _                                                    => query.OrderBy(x => x.PurchaseOrderId).ThenBy(x => x.PurchaseOrderDetailId),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<PurchaseOrderDetailDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<PurchaseOrderDetailDialog>("New line item", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Line item created.", Severity.Success);
    }

    private async Task OpenEditAsync(PurchaseOrderDetailDto row)
    {
        var parameters = new DialogParameters<PurchaseOrderDetailDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<PurchaseOrderDetailDialog>($"Edit ({row.PurchaseOrderId}, {row.PurchaseOrderDetailId})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Line item updated.", Severity.Success); await page.ReloadAsync(); }
    }

    private async Task DeleteAsync(PurchaseOrderDetailDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete line item?", $"Permanently delete line ({row.PurchaseOrderId}, {row.PurchaseOrderDetailId})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.PurchaseOrderDetails.FirstOrDefaultAsync(t => t.PurchaseOrderId == row.PurchaseOrderId && t.PurchaseOrderDetailId == row.PurchaseOrderDetailId);
        if (entity is null) { Snackbar.Add("Row no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.PurchaseOrderDetails.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Line item deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
