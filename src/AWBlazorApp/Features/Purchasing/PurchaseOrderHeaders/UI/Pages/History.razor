@page "/aw/purchase-order-headers/history"
@page "/aw/purchase-order-headers/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>PO header history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/purchase-order-headers"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "PO header history" : $"History for PurchaseOrderHeader #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="PurchaseOrderHeader" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
