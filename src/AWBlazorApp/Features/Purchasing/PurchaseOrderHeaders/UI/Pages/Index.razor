@page "/aw/purchase-order-headers"
@attribute [Authorize]
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="PurchaseOrderHeaderDto"
          @ref="page"
          Title="Purchase order headers"
          Caption="Purchasing.PurchaseOrderHeader"
          NewButtonLabel="New PO"
          HistoryRoute="aw/purchase-order-headers/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="PO"
          DeleteConfirmMessage="@(row => $"Permanently delete PO #{row.Id}?")">
    <ExpandedContent Context="row">
        <PurchaseOrderExpandedRow PurchaseOrderId="@row.Id" />
    </ExpandedContent>
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterVendorId ?? 0)" ValueChanged="@(v => filterVendorId = v == 0 ? null : v)" Label="Vendor" SearchFunc="@(q => Lookup.SearchVendorsAsync(q))" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><MudNumericField T="byte?" @bind-Value="filterStatus" Label="Status (1-4)" Variant="Variant.Outlined" Clearable="true" OnBlur="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <HierarchyColumn T="PurchaseOrderHeaderDto" />
        <PropertyColumn T="PurchaseOrderHeaderDto" TProperty="int" Property="x => x.Id" Title="PO #">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderHeader" PropertyName="@nameof(PurchaseOrderHeaderDto.Id)" Title="PO #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <TemplateColumn T="PurchaseOrderHeaderDto" Title="Status" Sortable="false">
            <CellTemplate>
                @{ var (label, color) = StatusHelper.PurchaseOrderStatus(context.Item.Status); }
                <MudChip T="string" Size="Size.Small" Color="@color" Variant="Variant.Filled">@label</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn T="PurchaseOrderHeaderDto" TProperty="int" Property="x => x.VendorId" Title="Vendor">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderHeader" PropertyName="@nameof(PurchaseOrderHeaderDto.VendorId)" Title="Vendor" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderHeaderDto" TProperty="int" Property="x => x.EmployeeId" Title="Employee">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderHeader" PropertyName="@nameof(PurchaseOrderHeaderDto.EmployeeId)" Title="Employee" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderHeaderDto" TProperty="DateTime" Property="x => x.OrderDate" Title="Order date" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderHeader" PropertyName="@nameof(PurchaseOrderHeaderDto.OrderDate)" Title="Order date" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderHeaderDto" TProperty="decimal" Property="x => x.SubTotal" Title="Subtotal" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderHeader" PropertyName="@nameof(PurchaseOrderHeaderDto.SubTotal)" Title="Subtotal" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderHeaderDto" TProperty="decimal" Property="x => x.TotalDue" Title="Total due" Format="C2">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderHeader" PropertyName="@nameof(PurchaseOrderHeaderDto.TotalDue)" Title="Total due" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="PurchaseOrderHeaderDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" HeaderClass="d-none d-md-table-cell" CellClass="d-none d-md-table-cell">
            <HeaderTemplate><GridColumnHeader TEntity="PurchaseOrderHeader" PropertyName="@nameof(PurchaseOrderHeaderDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<PurchaseOrderHeaderDto> page = null!;
    private int? filterVendorId;
    private byte? filterStatus;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<PurchaseOrderHeaderDto>> LoadServerDataAsync(GridState<PurchaseOrderHeaderDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.PurchaseOrderHeaders.AsNoTracking();
        if (filterVendorId.HasValue) query = query.Where(x => x.VendorId == filterVendorId.Value);
        if (filterStatus.HasValue) query = query.Where(x => x.Status == filterStatus.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(PurchaseOrderHeaderDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
            nameof(PurchaseOrderHeaderDto.EmployeeId)   => sort.Descending ? query.OrderByDescending(x => x.EmployeeId)   : query.OrderBy(x => x.EmployeeId),
            nameof(PurchaseOrderHeaderDto.VendorId)     => sort.Descending ? query.OrderByDescending(x => x.VendorId)     : query.OrderBy(x => x.VendorId),
            nameof(PurchaseOrderHeaderDto.OrderDate)    => sort.Descending ? query.OrderByDescending(x => x.OrderDate)    : query.OrderBy(x => x.OrderDate),
            nameof(PurchaseOrderHeaderDto.SubTotal)     => sort.Descending ? query.OrderByDescending(x => x.SubTotal)     : query.OrderBy(x => x.SubTotal),
            nameof(PurchaseOrderHeaderDto.TotalDue)     => sort.Descending ? query.OrderByDescending(x => x.TotalDue)     : query.OrderBy(x => x.TotalDue),
            nameof(PurchaseOrderHeaderDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
            _                                           => query.OrderByDescending(x => x.OrderDate).ThenBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<PurchaseOrderHeaderDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<PurchaseOrderHeaderDialog>("New PO", new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("PO created.", Severity.Success);
    }

    private async Task OpenEditAsync(PurchaseOrderHeaderDto row)
    {
        var parameters = new DialogParameters<PurchaseOrderHeaderDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<PurchaseOrderHeaderDialog>($"Edit PO #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("PO updated.", Severity.Success);
    }

    private async Task DeleteAsync(PurchaseOrderHeaderDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.PurchaseOrderHeaders.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("PO no longer exists.", Severity.Warning); return; }
        db.PurchaseOrderHeaders.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("PO deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
