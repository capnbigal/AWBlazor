@page "/aw/ship-methods/history"
@page "/aw/ship-methods/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Ship method history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/ship-methods"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Ship method history" : $"History for ShipMethod #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="ShipMethod" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
