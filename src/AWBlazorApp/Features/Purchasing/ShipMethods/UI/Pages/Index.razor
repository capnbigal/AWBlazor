@page "/aw/ship-methods"
@attribute [Authorize]
@using AWBlazorApp.Features.Purchasing.ProductVendors.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Domain
@using AWBlazorApp.Features.Purchasing.ShipMethods.Domain
@using AWBlazorApp.Features.Purchasing.Vendors.Domain
@using AWBlazorApp.Features.Purchasing.ProductVendors.Dtos
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Dtos
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Dtos
@using AWBlazorApp.Features.Purchasing.ShipMethods.Dtos
@using AWBlazorApp.Features.Purchasing.Vendors.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="ShipMethodDto"
          Title="Ship methods"
          Caption="Purchasing.ShipMethod"
          NewButtonLabel="New ship method"
          HistoryRoute="aw/ship-methods/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="ship method">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
    </Filters>
    <Columns>

            <PropertyColumn T="ShipMethodDto" TProperty="int" Property="x => x.Id" Title="Id" />
            <PropertyColumn T="ShipMethodDto" TProperty="string" Property="x => x.Name" Title="Name" />
            <PropertyColumn T="ShipMethodDto" TProperty="decimal" Property="x => x.ShipBase" Title="Base" Format="C" />
            <PropertyColumn T="ShipMethodDto" TProperty="decimal" Property="x => x.ShipRate" Title="Rate" Format="C" />
            <PropertyColumn T="ShipMethodDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            
    </Columns>
</CrudPage>

@code {
    private string? filterName;

    private async Task<GridData<ShipMethodDto>> LoadServerDataAsync(GridState<ShipMethodDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.ShipMethods.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName))
            {
                var needle = filterName.Trim();
                query = query.Where(x => x.Name.Contains(needle));
            }var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(ShipMethodDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
                nameof(ShipMethodDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
                nameof(ShipMethodDto.ShipBase)     => sort.Descending ? query.OrderByDescending(x => x.ShipBase)     : query.OrderBy(x => x.ShipBase),
                nameof(ShipMethodDto.ShipRate)     => sort.Descending ? query.OrderByDescending(x => x.ShipRate)     : query.OrderBy(x => x.ShipRate),
                nameof(ShipMethodDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _                                  => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ShipMethodDto> { Items = rows, TotalItems = total };
        }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ShipMethodDialog>("New ship method", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Ship method created.", Severity.Success);
    }

    private async Task OpenEditAsync(ShipMethodDto row)
    {
        var parameters = new DialogParameters<ShipMethodDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ShipMethodDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Ship method updated.", Severity.Success);
    }

    private async Task DeleteAsync(ShipMethodDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ShipMethods.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.ShipMethods.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Ship method deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
