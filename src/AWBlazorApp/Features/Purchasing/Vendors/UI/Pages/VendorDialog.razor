@using AWBlazorApp.Features.Purchasing.ProductVendors.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Domain
@using AWBlazorApp.Features.Purchasing.ShipMethods.Domain
@using AWBlazorApp.Features.Purchasing.Vendors.Domain
@using AWBlazorApp.Features.Purchasing.ProductVendors.Dtos
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Dtos
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Dtos
@using AWBlazorApp.Features.Purchasing.ShipMethods.Dtos
@using AWBlazorApp.Features.Purchasing.Vendors.Dtos
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateVendorRequest> CreateValidator
@inject MudFormValidator<UpdateVendorRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject LookupService Lookup
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create vendor" : $"Edit vendor #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <FkAutocomplete TValue="int" Value="@createModel.Id" ValueChanged="@((int v) => createModel = createModel with { Id = v })" SearchFunc="@(q => Lookup.SearchPersonsAsync(q))" Label="Business entity (person)" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@createModel.AccountNumber" ValueChanged="@((string? v) => createModel = createModel with { AccountNumber = v })" Label="Account #" Variant="Variant.Outlined" Required="true" MaxLength="15" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="byte" Value="@createModel.CreditRating" ValueChanged="@((byte v) => createModel = createModel with { CreditRating = v })" Label="Credit rating (1-5)" Variant="Variant.Outlined" Min="1" Max="5" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox T="bool" Value="@createModel.PreferredVendorStatus" ValueChanged="@((bool v) => createModel = createModel with { PreferredVendorStatus = v })" Label="Preferred" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox T="bool" Value="@createModel.ActiveFlag" ValueChanged="@((bool v) => createModel = createModel with { ActiveFlag = v })" Label="Active" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@createModel.PurchasingWebServiceUrl" ValueChanged="@((string? v) => createModel = createModel with { PurchasingWebServiceUrl = v })" Label="Web service URL" Variant="Variant.Outlined" MaxLength="1024" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.AccountNumber" ValueChanged="@((string? v) => updateModel = updateModel with { AccountNumber = v })" Label="Account #" Variant="Variant.Outlined" MaxLength="15" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" MaxLength="50" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="byte?" Value="@updateModel.CreditRating" ValueChanged="@((byte? v) => updateModel = updateModel with { CreditRating = v })" Label="Credit rating (1-5)" Variant="Variant.Outlined" Min="1" Max="5" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox T="bool?" Value="@updateModel.PreferredVendorStatus" ValueChanged="@((bool? v) => updateModel = updateModel with { PreferredVendorStatus = v })" Label="Preferred" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox T="bool?" Value="@updateModel.ActiveFlag" ValueChanged="@((bool? v) => updateModel = updateModel with { ActiveFlag = v })" Label="Active" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Value="@updateModel.PurchasingWebServiceUrl" ValueChanged="@((string? v) => updateModel = updateModel with { PurchasingWebServiceUrl = v })" Label="Web service URL" Variant="Variant.Outlined" MaxLength="1024" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public VendorDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateVendorRequest createModel = new() { CreditRating = 1, PreferredVendorStatus = true, ActiveFlag = true };
    private UpdateVendorRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null)
            updateModel = new UpdateVendorRequest
            {
                AccountNumber = Model.AccountNumber,
                Name = Model.Name,
                CreditRating = Model.CreditRating,
                PreferredVendorStatus = Model.PreferredVendorStatus,
                ActiveFlag = Model.ActiveFlag,
                PurchasingWebServiceUrl = Model.PurchasingWebServiceUrl,
            };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                if (await db.Vendors.AnyAsync(x => x.Id == createModel.Id))
                {
                    Snackbar.Add($"Vendor #{createModel.Id} already exists.", Severity.Error);
                    return;
                }
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.Vendors.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Vendors.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                updateModel.ApplyTo(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
