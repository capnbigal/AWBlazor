@page "/aw/vendors/history"
@page "/aw/vendors/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Vendor history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/vendors"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Vendor history" : $"History for Vendor #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Vendor" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
