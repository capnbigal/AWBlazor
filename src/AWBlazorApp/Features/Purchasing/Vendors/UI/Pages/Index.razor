@page "/aw/vendors"
@attribute [Authorize]
@using AWBlazorApp.Features.Purchasing.ProductVendors.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Domain
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Domain
@using AWBlazorApp.Features.Purchasing.ShipMethods.Domain
@using AWBlazorApp.Features.Purchasing.Vendors.Domain
@using AWBlazorApp.Features.Purchasing.ProductVendors.Dtos
@using AWBlazorApp.Features.Purchasing.PurchaseOrderDetails.Dtos
@using AWBlazorApp.Features.Purchasing.PurchaseOrderHeaders.Dtos
@using AWBlazorApp.Features.Purchasing.ShipMethods.Dtos
@using AWBlazorApp.Features.Purchasing.Vendors.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Vendors</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Vendors</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Purchasing.Vendor</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="aw/vendors/history">View history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">New vendor</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterAccountNumber" Label="Account # contains" Variant="Variant.Outlined" Immediate="false" OnBlur="ApplyFilter" /></MudItem>
        </MudGrid>
    </MudPaper>

    <MudDataGrid T="VendorDto" ServerData="LoadServerDataAsync" @ref="grid" Loading="@_loading" LoadingProgressColor="Color.Primary" Dense="true" Hover="true" Striped="true" SortMode="SortMode.Single" RowsPerPage="25">
        <Columns>
            <HierarchyColumn T="VendorDto" />
            <PropertyColumn Property="x => x.Id" Title="Id">
                <HeaderTemplate><GridColumnHeader TEntity="Vendor" PropertyName="@nameof(VendorDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.AccountNumber" Title="Account #">
                <HeaderTemplate><GridColumnHeader TEntity="Vendor" PropertyName="@nameof(VendorDto.AccountNumber)" Title="Account #" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Name" Title="Name">
                <HeaderTemplate><GridColumnHeader TEntity="Vendor" PropertyName="@nameof(VendorDto.Name)" Title="Name" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CreditRating" Title="Credit">
                <HeaderTemplate><GridColumnHeader TEntity="Vendor" PropertyName="@nameof(VendorDto.CreditRating)" Title="Credit" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PreferredVendorStatus" Title="Preferred">
                <HeaderTemplate><GridColumnHeader TEntity="Vendor" PropertyName="@nameof(VendorDto.PreferredVendorStatus)" Title="Preferred" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ActiveFlag" Title="Active">
                <HeaderTemplate><GridColumnHeader TEntity="Vendor" PropertyName="@nameof(VendorDto.ActiveFlag)" Title="Active" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
                <HeaderTemplate><GridColumnHeader TEntity="Vendor" PropertyName="@nameof(VendorDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="History">
                            <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small" OnClick="@(() => OpenHistory(context.Item))" />
                        </MudTooltip>
                        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(context.Item))" />
                        </AuthorizeView>
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Item))" />
                        </AuthorizeView>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <ChildRowContent><VendorExpandedRow VendorId="@context.Item.Id" /></ChildRowContent>
        <PagerContent><MudDataGridPager T="VendorDto" /></PagerContent>
        <NoRecordsContent>
            <EmptyState />
        </NoRecordsContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<VendorDto> grid = null!;
    private bool _loading = true;
    private string? filterName;
    private string? filterAccountNumber;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<VendorDto>> LoadServerDataAsync(GridState<VendorDto> state, CancellationToken ct)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.Vendors.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName)) query = query.Where(x => x.Name.Contains(filterName.Trim()));
            if (!string.IsNullOrWhiteSpace(filterAccountNumber)) query = query.Where(x => x.AccountNumber.Contains(filterAccountNumber.Trim()));
            query = query.ApplyColumnFilters(columnFilters);

            var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(VendorDto.Id)                    => sort.Descending ? query.OrderByDescending(x => x.Id)                    : query.OrderBy(x => x.Id),
                nameof(VendorDto.Name)                  => sort.Descending ? query.OrderByDescending(x => x.Name)                  : query.OrderBy(x => x.Name),
                nameof(VendorDto.AccountNumber)         => sort.Descending ? query.OrderByDescending(x => x.AccountNumber)         : query.OrderBy(x => x.AccountNumber),
                nameof(VendorDto.CreditRating)          => sort.Descending ? query.OrderByDescending(x => x.CreditRating)          : query.OrderBy(x => x.CreditRating),
                nameof(VendorDto.PreferredVendorStatus) => sort.Descending ? query.OrderByDescending(x => x.PreferredVendorStatus) : query.OrderBy(x => x.PreferredVendorStatus),
                nameof(VendorDto.ActiveFlag)            => sort.Descending ? query.OrderByDescending(x => x.ActiveFlag)            : query.OrderBy(x => x.ActiveFlag),
                nameof(VendorDto.ModifiedDate)          => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)          : query.OrderBy(x => x.ModifiedDate),
                _                                       => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<VendorDto> { Items = rows, TotalItems = total };
            }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }}

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<VendorDialog>("New vendor", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Vendor created.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task OpenEditAsync(VendorDto row)
    {
        var parameters = new DialogParameters<VendorDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<VendorDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Vendor updated.", Severity.Success); await grid.ReloadServerData(); }
    }

    private async Task DeleteAsync(VendorDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete vendor?", $"Permanently delete vendor #{row.Id} \"{row.Name}\"?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Vendors.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Vendor no longer exists.", Severity.Warning); await grid.ReloadServerData(); return; }

        var changedBy = await GetCurrentUserNameAsync();
        db.Vendors.Remove(entity);
        try
        {
            await db.SaveChangesAsync();
            Snackbar.Add("Vendor deleted.", Severity.Success);
        }
        catch (DbUpdateException ex)
        {
            Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error);
        }
        await grid.ReloadServerData();
    }

    private void OpenHistory(VendorDto row) => Navigation.NavigateTo($"aw/vendors/history/{row.Id}");

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
