@page "/aw/employee-department-histories"
@attribute [Authorize]
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Domain
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LookupService Lookup

<CrudPage TDto="EmployeeDepartmentHistoryDto"
          @ref="page"
          Title="Employee department history"
          Caption="HumanResources.EmployeeDepartmentHistory · 4-column composite PK"
          NewButtonLabel="New assignment"
          HistoryRoute="aw/employee-department-histories/history"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          EntityNameSingular="assignment">
    <Filters>
        <MudItem xs="12" sm="6"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Employee" Clearable="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" OnSelectionChanged="ApplyFilter" /></MudItem>
        <MudItem xs="12" sm="6"><FkSelect TValue="short" Value="@(filterDepartmentId ?? 0)" ValueChanged="@(v => filterDepartmentId = v == 0 ? null : v)" Label="Department" Items="_departments" Clearable="true" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="EmployeeDepartmentHistoryDto" TProperty="int" Property="x => x.BusinessEntityId" Title="Employee">
            <HeaderTemplate><GridColumnHeader TEntity="EmployeeDepartmentHistory" PropertyName="@nameof(EmployeeDepartmentHistoryDto.BusinessEntityId)" Title="Employee" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmployeeDepartmentHistoryDto" TProperty="short" Property="x => x.DepartmentId" Title="Dept">
            <HeaderTemplate><GridColumnHeader TEntity="EmployeeDepartmentHistory" PropertyName="@nameof(EmployeeDepartmentHistoryDto.DepartmentId)" Title="Dept" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmployeeDepartmentHistoryDto" TProperty="byte" Property="x => x.ShiftId" Title="Shift">
            <HeaderTemplate><GridColumnHeader TEntity="EmployeeDepartmentHistory" PropertyName="@nameof(EmployeeDepartmentHistoryDto.ShiftId)" Title="Shift" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmployeeDepartmentHistoryDto" TProperty="DateTime" Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="EmployeeDepartmentHistory" PropertyName="@nameof(EmployeeDepartmentHistoryDto.StartDate)" Title="Start" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmployeeDepartmentHistoryDto" TProperty="DateTime?" Property="x => x.EndDate" Title="End" Format="yyyy-MM-dd">
            <HeaderTemplate><GridColumnHeader TEntity="EmployeeDepartmentHistory" PropertyName="@nameof(EmployeeDepartmentHistoryDto.EndDate)" Title="End" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="EmployeeDepartmentHistoryDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="EmployeeDepartmentHistory" PropertyName="@nameof(EmployeeDepartmentHistoryDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
    <Actions Context="row">
        <MudStack Row="true" Spacing="1">
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" aria-label="View history" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"aw/employee-department-histories/history?businessEntityId={row.BusinessEntityId}&departmentId={row.DepartmentId}&shiftId={row.ShiftId}&startDate={row.StartDate:yyyy-MM-dd}"))" />
            </MudTooltip>
            <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="Edit" Size="Size.Small" OnClick="@(() => OpenEditAsync(row))" />
            </AuthorizeView>
            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(row))" />
            </AuthorizeView>
        </MudStack>
    </Actions>
</CrudPage>

@code {
    private CrudPage<EmployeeDepartmentHistoryDto> page = null!;
    private int? filterBusinessEntityId;
    private short? filterDepartmentId;
    private List<LookupItem<short>> _departments = [];
    private readonly ColumnFilterState columnFilters = new();

    protected override async Task OnInitializedAsync()
    {
        _departments = await Lookup.GetDepartmentsAsync();
    }

    private async Task<GridData<EmployeeDepartmentHistoryDto>> LoadServerDataAsync(GridState<EmployeeDepartmentHistoryDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.EmployeeDepartmentHistories.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        if (filterDepartmentId.HasValue) query = query.Where(x => x.DepartmentId == filterDepartmentId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(EmployeeDepartmentHistoryDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(EmployeeDepartmentHistoryDto.DepartmentId)     => sort.Descending ? query.OrderByDescending(x => x.DepartmentId)     : query.OrderBy(x => x.DepartmentId),
            nameof(EmployeeDepartmentHistoryDto.ShiftId)          => sort.Descending ? query.OrderByDescending(x => x.ShiftId)          : query.OrderBy(x => x.ShiftId),
            nameof(EmployeeDepartmentHistoryDto.StartDate)        => sort.Descending ? query.OrderByDescending(x => x.StartDate)        : query.OrderBy(x => x.StartDate),
            nameof(EmployeeDepartmentHistoryDto.EndDate)          => sort.Descending ? query.OrderByDescending(x => x.EndDate)          : query.OrderBy(x => x.EndDate),
            nameof(EmployeeDepartmentHistoryDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _                                                     => query.OrderBy(x => x.BusinessEntityId).ThenBy(x => x.DepartmentId).ThenBy(x => x.ShiftId).ThenByDescending(x => x.StartDate),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<EmployeeDepartmentHistoryDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<EmployeeDepartmentHistoryDialog>("New assignment", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Assignment created.", Severity.Success);
    }

    private async Task OpenEditAsync(EmployeeDepartmentHistoryDto row)
    {
        var parameters = new DialogParameters<EmployeeDepartmentHistoryDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<EmployeeDepartmentHistoryDialog>($"Edit assignment ({row.BusinessEntityId}/{row.DepartmentId}/{row.ShiftId}/{row.StartDate:yyyy-MM-dd})", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) { Snackbar.Add("Assignment updated.", Severity.Success); await page.ReloadAsync(); }
    }

    private async Task DeleteAsync(EmployeeDepartmentHistoryDto row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Delete assignment?", $"Permanently delete assignment ({row.BusinessEntityId}/{row.DepartmentId}/{row.ShiftId}/{row.StartDate:yyyy-MM-dd})?", yesText: "Delete", cancelText: "Cancel");
        if (confirm != true) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.EmployeeDepartmentHistories.FirstOrDefaultAsync(t => t.BusinessEntityId == row.BusinessEntityId && t.DepartmentId == row.DepartmentId && t.ShiftId == row.ShiftId && t.StartDate == row.StartDate);
        if (entity is null) { Snackbar.Add("Assignment no longer exists.", Severity.Warning); await page.ReloadAsync(); return; }
        db.EmployeeDepartmentHistories.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Assignment deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
        await page.ReloadAsync();
    }
}
