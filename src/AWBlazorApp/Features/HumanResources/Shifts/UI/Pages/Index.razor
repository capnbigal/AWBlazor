@page "/aw/shifts"
@attribute [Authorize]
@using AWBlazorApp.Features.HumanResources.Departments.Domain
@using AWBlazorApp.Features.HumanResources.Employees.Domain
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Domain
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Domain
@using AWBlazorApp.Features.HumanResources.JobCandidates.Domain
@using AWBlazorApp.Features.HumanResources.Shifts.Domain
@using AWBlazorApp.Features.HumanResources.Departments.Dtos
@using AWBlazorApp.Features.HumanResources.Employees.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Dtos
@using AWBlazorApp.Features.HumanResources.JobCandidates.Dtos
@using AWBlazorApp.Features.HumanResources.Shifts.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="ShiftDto"
          Title="Shifts"
          Caption="HumanResources.Shift"
          NewButtonLabel="New shift"
          HistoryRoute="aw/shifts/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="shift">
    <Filters>
        <MudItem xs="12"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
    </Filters>
    <Columns>

            <PropertyColumn T="ShiftDto" TProperty="int" Property="x => x.Id" Title="Id" />
            <PropertyColumn T="ShiftDto" TProperty="string" Property="x => x.Name" Title="Name" />
            <TemplateColumn T="ShiftDto" Title="Start" Sortable="false">
                <CellTemplate>@context.Item.StartTime.ToString(@"hh\:mm")</CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="ShiftDto" Title="End" Sortable="false">
                <CellTemplate>@context.Item.EndTime.ToString(@"hh\:mm")</CellTemplate>
            </TemplateColumn>
            <PropertyColumn T="ShiftDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            
    </Columns>
</CrudPage>

@code {
    private string? filterName;

    private async Task<GridData<ShiftDto>> LoadServerDataAsync(GridState<ShiftDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.Shifts.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName))
            {
                var needle = filterName.Trim();
                query = query.Where(x => x.Name.Contains(needle));
            }var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(ShiftDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
                nameof(ShiftDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
                nameof(ShiftDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _                             => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ShiftDto> { Items = rows, TotalItems = total };
        }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<ShiftDialog>("New shift", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Shift created.", Severity.Success);
    }

    private async Task OpenEditAsync(ShiftDto row)
    {
        var parameters = new DialogParameters<ShiftDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<ShiftDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Shift updated.", Severity.Success);
    }

    private async Task DeleteAsync(ShiftDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Shifts.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.Shifts.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Shift deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
