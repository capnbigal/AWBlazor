@page "/aw/shifts/history"
@page "/aw/shifts/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Shift history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/shifts"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Shift history" : $"History for Shift #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Shift" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
