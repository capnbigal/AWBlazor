@page "/aw/employees/history"
@page "/aw/employees/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Employee history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/employees"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Employee history" : $"History for Employee #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Employee" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
