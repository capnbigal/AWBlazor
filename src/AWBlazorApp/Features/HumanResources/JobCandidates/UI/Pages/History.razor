@page "/aw/job-candidates/history"
@page "/aw/job-candidates/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Job candidate history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/job-candidates"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Job candidate history" : $"History for JobCandidate #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="JobCandidate" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
