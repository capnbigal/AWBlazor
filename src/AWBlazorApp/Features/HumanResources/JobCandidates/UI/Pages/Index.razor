@page "/aw/job-candidates"
@attribute [Authorize]
@using AWBlazorApp.Features.HumanResources.JobCandidates.Domain
@using AWBlazorApp.Features.HumanResources.JobCandidates.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LookupService Lookup

<CrudPage TDto="JobCandidateDto"
          @ref="page"
          Title="Job candidates"
          Caption="HumanResources.JobCandidate"
          NewButtonLabel="New candidate"
          HistoryRoute="aw/job-candidates/history"
          IdOf="row => row.Id"
          LoadData="LoadServerDataAsync"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="candidate"
          DeleteConfirmMessage="@(row => $"Permanently delete job candidate #{row.Id}?")">
    <Filters>
        <MudItem xs="12"><FkAutocomplete TValue="int" Value="@(filterBusinessEntityId ?? 0)" ValueChanged="@(v => filterBusinessEntityId = v == 0 ? null : v)" Label="Employee" Clearable="true" SearchFunc="@(q => Lookup.SearchEmployeesAsync(q))" OnSelectionChanged="ApplyFilter" /></MudItem>
    </Filters>
    <Columns>
        <PropertyColumn T="JobCandidateDto" TProperty="int" Property="x => x.Id" Title="Id">
            <HeaderTemplate><GridColumnHeader TEntity="JobCandidate" PropertyName="@nameof(JobCandidateDto.Id)" Title="Id" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="JobCandidateDto" TProperty="int?" Property="x => x.BusinessEntityId" Title="Employee">
            <HeaderTemplate><GridColumnHeader TEntity="JobCandidate" PropertyName="@nameof(JobCandidateDto.BusinessEntityId)" Title="Employee" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
        <PropertyColumn T="JobCandidateDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm">
            <HeaderTemplate><GridColumnHeader TEntity="JobCandidate" PropertyName="@nameof(JobCandidateDto.ModifiedDate)" Title="Modified" State="columnFilters" OnChanged="ApplyFilter" /></HeaderTemplate>
        </PropertyColumn>
    </Columns>
</CrudPage>

@code {
    private CrudPage<JobCandidateDto> page = null!;
    private int? filterBusinessEntityId;
    private readonly ColumnFilterState columnFilters = new();

    private async Task<GridData<JobCandidateDto>> LoadServerDataAsync(GridState<JobCandidateDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        var query = db.JobCandidates.AsNoTracking();
        if (filterBusinessEntityId.HasValue) query = query.Where(x => x.BusinessEntityId == filterBusinessEntityId.Value);
        query = query.ApplyColumnFilters(columnFilters);

        var total = await query.CountAsync(ct);
        var sort = state.SortDefinitions.FirstOrDefault();
        query = sort?.SortBy switch
        {
            nameof(JobCandidateDto.Id)               => sort.Descending ? query.OrderByDescending(x => x.Id)               : query.OrderBy(x => x.Id),
            nameof(JobCandidateDto.BusinessEntityId) => sort.Descending ? query.OrderByDescending(x => x.BusinessEntityId) : query.OrderBy(x => x.BusinessEntityId),
            nameof(JobCandidateDto.ModifiedDate)     => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate)     : query.OrderBy(x => x.ModifiedDate),
            _                                        => query.OrderBy(x => x.Id),
        };

        var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
        return new GridData<JobCandidateDto> { Items = rows, TotalItems = total };
    }

    private Task ApplyFilter() => page.ReloadAsync();

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<JobCandidateDialog>("New candidate", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Job candidate created.", Severity.Success);
    }

    private async Task OpenEditAsync(JobCandidateDto row)
    {
        var parameters = new DialogParameters<JobCandidateDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<JobCandidateDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Job candidate updated.", Severity.Success);
    }

    private async Task DeleteAsync(JobCandidateDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.JobCandidates.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Candidate no longer exists.", Severity.Warning); return; }
        db.JobCandidates.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Job candidate deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
