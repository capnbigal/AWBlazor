@page "/aw/departments/history"
@page "/aw/departments/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Department history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back" Size="Size.Medium" OnClick="@(() => Navigation.NavigateTo("aw/departments"))" />

        <MudText Typo="Typo.h4">@(SlotId is null ? "Department history" : $"History for Department #{SlotId}")</MudText>
    </MudStack>

    <AuditHistoryGrid EntityType="Department" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
