@using AWBlazorApp.Features.HumanResources.Departments.Domain
@using AWBlazorApp.Features.HumanResources.Employees.Domain
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Domain
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Domain
@using AWBlazorApp.Features.HumanResources.JobCandidates.Domain
@using AWBlazorApp.Features.HumanResources.Shifts.Domain
@using AWBlazorApp.Features.HumanResources.Departments.Dtos
@using AWBlazorApp.Features.HumanResources.Employees.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Dtos
@using AWBlazorApp.Features.HumanResources.JobCandidates.Dtos
@using AWBlazorApp.Features.HumanResources.Shifts.Dtos
@using AWBlazorApp.Features.HumanResources.Departments.Application.Services
@using AWBlazorApp.Features.HumanResources.Employees.Application.Services
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Application.Services
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Application.Services
@using AWBlazorApp.Features.HumanResources.JobCandidates.Application.Services
@using AWBlazorApp.Features.HumanResources.Shifts.Application.Services
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateDepartmentRequest> CreateValidator
@inject MudFormValidator<UpdateDepartmentRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">@(IsNew ? "Create department" : $"Edit department #{Model!.Id}")</MudText></TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><MudTextField Value="@createModel.Name" ValueChanged="@((string? v) => createModel = createModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" /></MudItem>
                    <MudItem xs="12" sm="6"><MudTextField Value="@createModel.GroupName" ValueChanged="@((string? v) => createModel = createModel with { GroupName = v })" Label="Group" Variant="Variant.Outlined" Required="true" MaxLength="50" /></MudItem>
                </MudGrid>
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6"><MudTextField Value="@updateModel.Name" ValueChanged="@((string? v) => updateModel = updateModel with { Name = v })" Label="Name" Variant="Variant.Outlined" Required="true" MaxLength="50" /></MudItem>
                    <MudItem xs="12" sm="6"><MudTextField Value="@updateModel.GroupName" ValueChanged="@((string? v) => updateModel = updateModel with { GroupName = v })" Label="Group" Variant="Variant.Outlined" Required="true" MaxLength="50" /></MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">@(saving ? "Saving..." : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DepartmentDto? Model { get; set; }

    private bool IsNew => Model is null;
    private MudForm form = null!;
    private CreateDepartmentRequest createModel = new();
    private UpdateDepartmentRequest updateModel = new();
    private bool saving;

    protected override void OnInitialized()
    {
        if (Model is not null) updateModel = new UpdateDepartmentRequest { Name = Model.Name, GroupName = Model.GroupName };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();
            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                await using var tx = await db.Database.BeginTransactionAsync();
                db.Departments.Add(entity);
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                db.DepartmentAuditLogs.Add(DepartmentAuditService.RecordCreate(entity, changedBy));
                await db.SaveChangesAsync();
                await tx.CommitAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel)) { Snackbar.Add("Please fix the errors in the form.", Severity.Error); return; }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.Departments.FirstOrDefaultAsync(t => t.Id == Model!.Id);
                if (entity is null) { MudDialog.Close(DialogResult.Cancel()); return; }
                var before = DepartmentAuditService.CaptureSnapshot(entity);
                updateModel.ApplyTo(entity);
                db.DepartmentAuditLogs.Add(DepartmentAuditService.RecordUpdate(before, entity, changedBy));
                try
                {
                    await db.SaveChangesAsync();
                }
                catch (DbUpdateException ex) when (ex.InnerException?.Message.Contains("FOREIGN KEY") == true)
                {
                    Snackbar.Add($"A referenced record does not exist: {ex.InnerException.Message}", Severity.Error);
                    return;
                }
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally { saving = false; }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
