@page "/aw/departments"
@attribute [Authorize]
@using AWBlazorApp.Features.HumanResources.Departments.Domain
@using AWBlazorApp.Features.HumanResources.Employees.Domain
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Domain
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Domain
@using AWBlazorApp.Features.HumanResources.JobCandidates.Domain
@using AWBlazorApp.Features.HumanResources.Shifts.Domain
@using AWBlazorApp.Features.HumanResources.Departments.Dtos
@using AWBlazorApp.Features.HumanResources.Employees.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeeDepartmentHistories.Dtos
@using AWBlazorApp.Features.HumanResources.EmployeePayHistories.Dtos
@using AWBlazorApp.Features.HumanResources.JobCandidates.Dtos
@using AWBlazorApp.Features.HumanResources.Shifts.Dtos
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<CrudPage TDto="DepartmentDto"
          Title="Departments"
          Caption="HumanResources.Department"
          NewButtonLabel="New department"
          HistoryRoute="aw/departments/history"
          EditRoles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")"
          DeleteRoles="@($"{AppRoles.Manager},{AppRoles.Admin}")"
          LoadData="LoadServerDataAsync"
          IdOf="row => row.Id"
          OnCreate="OpenCreateAsync"
          OnEdit="OpenEditAsync"
          OnDelete="DeleteAsync"
          EntityNameSingular="department">
    <Filters>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterName" Label="Name contains" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="filterGroupName" Label="Group" Variant="Variant.Outlined" /></MudItem>
    </Filters>
    <Columns>

            <PropertyColumn T="DepartmentDto" TProperty="int" Property="x => x.Id" Title="Id" />
            <PropertyColumn T="DepartmentDto" TProperty="string" Property="x => x.Name" Title="Name" />
            <PropertyColumn T="DepartmentDto" TProperty="string" Property="x => x.GroupName" Title="Group" />
            <PropertyColumn T="DepartmentDto" TProperty="DateTime" Property="x => x.ModifiedDate" Title="Modified" Format="yyyy-MM-dd HH:mm" />
            
    </Columns>
</CrudPage>

@code {
    private string? filterName;
    private string? filterGroupName;

    private async Task<GridData<DepartmentDto>> LoadServerDataAsync(GridState<DepartmentDto> state, CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.Departments.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(filterName))
            {
                var needle = filterName.Trim();
                query = query.Where(x => x.Name.Contains(needle));
            }
            if (!string.IsNullOrWhiteSpace(filterGroupName))
            {
                var needle = filterGroupName.Trim();
                query = query.Where(x => x.GroupName == needle);
            }var total = await query.CountAsync(ct);
            var sort = state.SortDefinitions.FirstOrDefault();
            query = sort?.SortBy switch
            {
                nameof(DepartmentDto.Id)           => sort.Descending ? query.OrderByDescending(x => x.Id)           : query.OrderBy(x => x.Id),
                nameof(DepartmentDto.Name)         => sort.Descending ? query.OrderByDescending(x => x.Name)         : query.OrderBy(x => x.Name),
                nameof(DepartmentDto.GroupName)    => sort.Descending ? query.OrderByDescending(x => x.GroupName)    : query.OrderBy(x => x.GroupName),
                nameof(DepartmentDto.ModifiedDate) => sort.Descending ? query.OrderByDescending(x => x.ModifiedDate) : query.OrderBy(x => x.ModifiedDate),
                _                                  => query.OrderBy(x => x.Id),
            };

            var rows = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<DepartmentDto> { Items = rows, TotalItems = total };
        }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<DepartmentDialog>("New department", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Department created.", Severity.Success);
    }

    private async Task OpenEditAsync(DepartmentDto row)
    {
        var parameters = new DialogParameters<DepartmentDialog> { { x => x.Model, row } };
        var dialog = await DialogService.ShowAsync<DepartmentDialog>($"Edit #{row.Id}", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if ((await dialog.Result) is { Canceled: false }) Snackbar.Add("Department updated.", Severity.Success);
    }

    private async Task DeleteAsync(DepartmentDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Departments.FirstOrDefaultAsync(t => t.Id == row.Id);
        if (entity is null) { Snackbar.Add("Already gone.", Severity.Warning); return; }
        db.Departments.Remove(entity);
        try { await db.SaveChangesAsync(); Snackbar.Add("Department deleted.", Severity.Success); }
        catch (DbUpdateException ex) { Snackbar.Add($"Cannot delete: {ex.InnerException?.Message ?? ex.Message}", Severity.Error); }
    }
}
