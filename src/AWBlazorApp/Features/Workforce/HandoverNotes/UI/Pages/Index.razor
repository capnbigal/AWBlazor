@page "/workforce/handover-notes"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Shift handover</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Shift handover notes</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Per-station messages between outgoing and incoming crew</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New note</MudButton>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterStation" Label="Station" Variant="Variant.Outlined" Clearable="true" />
            <MudDatePicker @bind-Date="filterDate" Label="Shift date" Variant="Variant.Outlined" Clearable="true" />
            <MudCheckBox T="bool" @bind-Value="unackOnly" Label="Unacknowledged only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="ShiftHandoverNoteDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="#" />
            <PropertyColumn Property="x => x.StationId" Title="Station" />
            <PropertyColumn Property="x => x.ShiftDate" Title="Date" />
            <PropertyColumn Property="x => x.FromShiftId" Title="From" />
            <PropertyColumn Property="x => x.ToShiftId" Title="To" />
            <TemplateColumn Title="Note" Sortable="false">
                <CellTemplate><MudText Typo="Typo.body2" Style="max-width: 400px; white-space: pre-wrap">@context.Item.Note</MudText></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.AuthoredAt" Title="Authored" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Acknowledged" Sortable="false">
                <CellTemplate>
                    @if (!context.Item.RequiresAcknowledgment)
                    { <MudText Typo="Typo.body2" Color="Color.Secondary">n/a</MudText> }
                    else if (context.Item.AcknowledgedAt.HasValue)
                    { <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Check">@context.Item.AcknowledgedAt:yyyy-MM-dd HH:mm</MudChip> }
                    else
                    { <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@(() => Acknowledge(context.Item.Id))">Acknowledge</MudButton> }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ShiftHandoverNoteDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New handover note</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newRow.StationId" Label="Station ID" Required="true" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="shiftDate" Label="Shift date" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRow.FromShiftId" Label="From shift (HumanResources.Shift.ID)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRow.ToShiftId" Label="To shift" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Note" Label="Note" Required="true" Variant="Variant.Outlined" Lines="4" />
            <MudCheckBox T="bool" @bind-Value="newRow.RequiresAcknowledgment" Label="Requires acknowledgment" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Post")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<ShiftHandoverNoteDto> grid = null!;
    private bool _loading = true;
    private int? filterStation;
    private DateTime? filterDate;
    private bool unackOnly;

    private bool dialogOpen, saving;
    private CreateShiftHandoverNoteRequest newRow = new();
    private DateTime? shiftDate = DateTime.UtcNow.Date;

    private async Task<GridData<ShiftHandoverNoteDto>> LoadAsync(GridState<ShiftHandoverNoteDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.ShiftHandoverNotes.AsNoTracking();
            if (filterStation.HasValue) q = q.Where(x => x.StationId == filterStation.Value);
            if (filterDate.HasValue) { var d = DateOnly.FromDateTime(filterDate.Value); q = q.Where(x => x.ShiftDate == d); }
            if (unackOnly) q = q.Where(x => x.RequiresAcknowledgment && x.AcknowledgedAt == null);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.ShiftDate).ThenByDescending(x => x.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ShiftHandoverNoteDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateShiftHandoverNoteRequest(); shiftDate = DateTime.UtcNow.Date; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            if (shiftDate.HasValue) newRow.ShiftDate = DateOnly.FromDateTime(shiftDate.Value);
            var by = await GetUserNameAsync();
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRow.ToEntity(by);
            db.ShiftHandoverNotes.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add("Posted.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Post failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task Acknowledge(int id)
    {
        try
        {
            var by = await GetUserNameAsync();
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.ShiftHandoverNotes.FirstOrDefaultAsync(x => x.Id == id);
            if (entity is null) return;
            entity.AcknowledgedAt = DateTime.UtcNow;
            entity.AcknowledgedByUserId = by;
            entity.ModifiedDate = DateTime.UtcNow;
            await db.SaveChangesAsync();
            Snackbar.Add("Acknowledged.", Severity.Success);
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Acknowledge failed: {ex.Message}", Severity.Error); }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
