@page "/workforce/qualifications"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Qualifications</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Qualifications</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">wf.Qualification — skills, certifications, safety, compliance</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New qualification</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="search" Label="Search code / name" Variant="Variant.Outlined" Clearable="true" />
            <MudSelect T="QualificationCategory?" @bind-Value="filterCategory" Label="Category" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="QualificationCategory?" Value="@null">(any)</MudSelectItem>
                @foreach (var c in Enum.GetValues<QualificationCategory>()) { <MudSelectItem T="QualificationCategory?" Value="@c">@c</MudSelectItem> }
            </MudSelect>
            <MudCheckBox T="bool" @bind-Value="filterActive" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="QualificationDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Category" Title="Category" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="QualificationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New qualification</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newQ.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newQ.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newQ.Description" Label="Description" Variant="Variant.Outlined" Lines="2" />
            <MudSelect T="QualificationCategory" @bind-Value="newQ.Category" Label="Category" Variant="Variant.Outlined">
                @foreach (var c in Enum.GetValues<QualificationCategory>()) { <MudSelectItem T="QualificationCategory" Value="@c">@c</MudSelectItem> }
            </MudSelect>
            <MudCheckBox T="bool" @bind-Value="newQ.IsActive" Label="Active" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<QualificationDto> grid = null!;
    private bool _loading = true;
    private string? search;
    private QualificationCategory? filterCategory;
    private bool filterActive = true;

    private bool dialogOpen, saving;
    private CreateQualificationRequest newQ = new();

    private async Task<GridData<QualificationDto>> LoadAsync(GridState<QualificationDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.Qualifications.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(x => x.Code.Contains(s) || x.Name.Contains(s));
            }
            if (filterCategory.HasValue) q = q.Where(x => x.Category == filterCategory.Value);
            if (filterActive) q = q.Where(x => x.IsActive);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.Code)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<QualificationDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newQ = new CreateQualificationRequest { IsActive = true, Category = QualificationCategory.Skill }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newQ.ToEntity();
            var by = await GetUserNameAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            db.Qualifications.Add(entity);
            await db.SaveChangesAsync();
            db.QualificationAuditLogs.Add(QualificationAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.Code}.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
