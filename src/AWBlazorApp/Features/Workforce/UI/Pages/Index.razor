@page "/workforce"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Workforce</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Workforce</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Training, qualifications, attendance, leave, shift communication</MudText>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.NotificationsActive" Color="Color.Error" Value="@openAlerts.ToString("N0")" Label="Open qual alerts" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.AccessTime" Color="Color.Warning" Value="@expiringQuals.ToString("N0")" Label="Quals expiring ≤30d" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.EventBusy" Color="Color.Info" Value="@pendingLeaves.ToString("N0")" Label="Pending leave" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.EditNote" Color="Color.Primary" Value="@unackHandovers.ToString("N0")" Label="Unack handover notes" /></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="mt-3">Modules</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="HR analytics" Subtitle="Headcount, tenure, gender distribution, salaried vs hourly." Icon="@Icons.Material.Filled.Analytics" Href="analytics/hr" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Alert inbox" Subtitle="Operator qualification issues from clock-in." Icon="@Icons.Material.Filled.NotificationsActive" Href="workforce/qualification-alerts" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Training courses" Subtitle="wf.TrainingCourse — recurring cert tracking." Icon="@Icons.Material.Filled.School" Href="workforce/training-courses" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Training records" Subtitle="Completion history per employee." Icon="@Icons.Material.Filled.History" Href="workforce/training-records" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Qualifications" Subtitle="wf.Qualification — skills, certs, safety, compliance." Icon="@Icons.Material.Filled.Badge" Href="workforce/qualifications" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Employee quals" Subtitle="Per-employee grant, expiry, evidence." Icon="@Icons.Material.Filled.CardMembership" Href="workforce/employee-qualifications" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Station requirements" Subtitle="Required quals per station." Icon="@Icons.Material.Filled.WorkspacePremium" Href="workforce/station-qualifications" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Attendance" Subtitle="Per-shift clock in / out, status." Icon="@Icons.Material.Filled.HowToReg" Href="workforce/attendance" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Leave requests" Subtitle="Pending → Approved/Rejected workflow." Icon="@Icons.Material.Filled.EventBusy" Href="workforce/leave-requests" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Shift handover" Subtitle="Per-station handover notes." Icon="@Icons.Material.Filled.EditNote" Href="workforce/handover-notes" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Announcements" Subtitle="Broadcast messages across org / org unit." Icon="@Icons.Material.Filled.Campaign" Href="workforce/announcements" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Reference data" Subtitle="AW employees, pay history, job candidates, departments, shifts." Icon="@Icons.Material.Filled.TableView" Href="workforce/reference" /></MudItem>
    </MudGrid>
</MudStack>

@code {
    private int openAlerts, expiringQuals, pendingLeaves, unackHandovers;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        openAlerts = await db.QualificationAlerts.CountAsync(a => a.Status == QualificationAlertStatus.Open);
        var cutoff = DateTime.UtcNow.AddDays(30);
        expiringQuals = await db.EmployeeQualifications.CountAsync(q => q.ExpiresOn != null && q.ExpiresOn <= cutoff);
        pendingLeaves = await db.LeaveRequests.CountAsync(l => l.Status == LeaveStatus.Pending);
        unackHandovers = await db.ShiftHandoverNotes.CountAsync(h => h.RequiresAcknowledgment && h.AcknowledgedAt == null);
    }
}
