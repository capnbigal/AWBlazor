@page "/workforce/leave-requests"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ILeaveRequestService LeaveService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Leave requests</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Leave requests</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Pending → Approved / Rejected. Anyone can submit; Manager/Admin reviews.</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Submit request</MudButton>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterEmployee" Label="Employee" Variant="Variant.Outlined" Clearable="true" />
            <MudSelect T="LeaveStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 180px">
                <MudSelectItem T="LeaveStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<LeaveStatus>()) { <MudSelectItem T="LeaveStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudSelect T="LeaveType?" @bind-Value="filterType" Label="Type" Variant="Variant.Outlined" Clearable="true" Style="max-width: 180px">
                <MudSelectItem T="LeaveType?" Value="@null">(any)</MudSelectItem>
                @foreach (var t in Enum.GetValues<LeaveType>()) { <MudSelectItem T="LeaveType?" Value="@t">@t</MudSelectItem> }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="LeaveRequestDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="#" />
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Employee" />
            <PropertyColumn Property="x => x.LeaveType" Title="Type" />
            <PropertyColumn Property="x => x.StartDate" Title="Start" />
            <PropertyColumn Property="x => x.EndDate" Title="End" />
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)" Variant="Variant.Filled">@context.Item.Status</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    @if (context.Item.Status == LeaveStatus.Pending)
                    {
                        <MudStack Row="true" Spacing="1">
                            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                                <Authorized>
                                    <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" OnClick="@(() => Approve(context.Item.Id))">Approve</MudButton>
                                    <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined" OnClick="@(() => Reject(context.Item.Id))">Reject</MudButton>
                                </Authorized>
                            </AuthorizeView>
                            <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" OnClick="@(() => Cancel(context.Item.Id))">Cancel</MudButton>
                        </MudStack>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="LeaveRequestDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Submit leave request</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newRow.BusinessEntityId" Label="Employee (BusinessEntityId)" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="LeaveType" @bind-Value="newRow.LeaveType" Label="Type" Variant="Variant.Outlined">
                @foreach (var t in Enum.GetValues<LeaveType>()) { <MudSelectItem T="LeaveType" Value="@t">@t</MudSelectItem> }
            </MudSelect>
            <MudDatePicker @bind-Date="startDate" Label="Start date" Required="true" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="endDate" Label="End date" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Reason" Label="Reason" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Submit")</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="reviewDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>@(reviewIsApprove ? "Approve" : "Reject") leave #@reviewId</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="reviewNotes" Label="Review notes" Variant="Variant.Outlined" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => reviewDialogOpen = false">Cancel</MudButton>
        <MudButton Color="@(reviewIsApprove ? Color.Success : Color.Error)" Variant="Variant.Filled" OnClick="SubmitReview">@(reviewIsApprove ? "Approve" : "Reject")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<LeaveRequestDto> grid = null!;
    private bool _loading = true;
    private int? filterEmployee;
    private LeaveStatus? filterStatus = LeaveStatus.Pending;
    private LeaveType? filterType;

    private bool dialogOpen, saving;
    private CreateLeaveRequestRequest newRow = new();
    private DateTime? startDate = DateTime.UtcNow.Date, endDate = DateTime.UtcNow.Date;

    private bool reviewDialogOpen, reviewIsApprove;
    private int reviewId;
    private string? reviewNotes;

    private static Color StatusColor(LeaveStatus s) => s switch
    {
        LeaveStatus.Pending => Color.Warning,
        LeaveStatus.Approved => Color.Success,
        LeaveStatus.Rejected => Color.Error,
        LeaveStatus.Cancelled => Color.Default,
        _ => Color.Default,
    };

    private async Task<GridData<LeaveRequestDto>> LoadAsync(GridState<LeaveRequestDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.LeaveRequests.AsNoTracking();
            if (filterEmployee.HasValue) q = q.Where(x => x.BusinessEntityId == filterEmployee.Value);
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            if (filterType.HasValue) q = q.Where(x => x.LeaveType == filterType.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.RequestedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<LeaveRequestDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateLeaveRequestRequest { LeaveType = LeaveType.Vacation }; startDate = DateTime.UtcNow.Date; endDate = DateTime.UtcNow.Date; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            if (!startDate.HasValue || !endDate.HasValue) { Snackbar.Add("Start and end are required.", Severity.Error); return; }
            newRow.StartDate = DateOnly.FromDateTime(startDate.Value);
            newRow.EndDate = DateOnly.FromDateTime(endDate.Value);
            if (newRow.EndDate < newRow.StartDate) { Snackbar.Add("End must be on or after start.", Severity.Error); return; }

            var by = await GetUserNameAsync();
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRow.ToEntity(by);
            db.LeaveRequests.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add("Submitted.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Submit failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private void Approve(int id) { reviewId = id; reviewIsApprove = true; reviewNotes = null; reviewDialogOpen = true; }
    private void Reject(int id) { reviewId = id; reviewIsApprove = false; reviewNotes = null; reviewDialogOpen = true; }

    private async Task SubmitReview()
    {
        try
        {
            var by = await GetUserNameAsync();
            if (reviewIsApprove) await LeaveService.ApproveAsync(reviewId, reviewNotes, by, default);
            else await LeaveService.RejectAsync(reviewId, reviewNotes, by, default);
            Snackbar.Add(reviewIsApprove ? "Approved." : "Rejected.", Severity.Success);
            reviewDialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Review failed: {ex.Message}", Severity.Error); }
    }

    private async Task Cancel(int id)
    {
        try
        {
            var by = await GetUserNameAsync();
            await LeaveService.CancelAsync(id, by, default);
            Snackbar.Add("Cancelled.", Severity.Success);
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Cancel failed: {ex.Message}", Severity.Error); }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
