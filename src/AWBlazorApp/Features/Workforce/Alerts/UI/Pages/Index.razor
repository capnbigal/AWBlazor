@page "/workforce/qualification-alerts"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Qualification alert inbox</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Color="Color.Error" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Qualification alert inbox</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Operator clocked in to a station missing a required qualification. Clock-in was not blocked — review and acknowledge.</MudText>
        </MudStack>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="QualificationAlertStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="QualificationAlertStatus?" Value="@null">(all)</MudSelectItem>
                @foreach (var s in Enum.GetValues<QualificationAlertStatus>()) { <MudSelectItem T="QualificationAlertStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterStation" Label="Station" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterEmployee" Label="Employee (BusinessEntityId)" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="QualificationAlertDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="#" />
            <PropertyColumn Property="x => x.RaisedAt" Title="Raised" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.BusinessEntityId" Title="Employee" />
            <PropertyColumn Property="x => x.StationId" Title="Station" />
            <PropertyColumn Property="x => x.QualificationId" Title="Qualification" />
            <TemplateColumn Title="Reason" Sortable="false">
                <CellTemplate>
                    @if (context.Item.Reason == QualificationAlertReason.Missing)
                    { <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">Missing</MudChip> }
                    else
                    { <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Expired</MudChip> }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)" Variant="Variant.Filled">@context.Item.Status</MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    @if (context.Item.Status == QualificationAlertStatus.Open)
                    {
                        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                            <MudStack Row="true" Spacing="1">
                                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@(() => Acknowledge(context.Item.Id, QualificationAlertStatus.Acknowledged))">Ack</MudButton>
                                <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" OnClick="@(() => Acknowledge(context.Item.Id, QualificationAlertStatus.Resolved))">Resolve</MudButton>
                                <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" OnClick="@(() => Acknowledge(context.Item.Id, QualificationAlertStatus.Dismissed))">Dismiss</MudButton>
                            </MudStack>
                        </AuthorizeView>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="QualificationAlertDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<QualificationAlertDto> grid = null!;
    private bool _loading = true;
    private QualificationAlertStatus? filterStatus = QualificationAlertStatus.Open;
    private int? filterStation;
    private int? filterEmployee;

    private static Color StatusColor(QualificationAlertStatus s) => s switch
    {
        QualificationAlertStatus.Open => Color.Error,
        QualificationAlertStatus.Acknowledged => Color.Warning,
        QualificationAlertStatus.Resolved => Color.Success,
        QualificationAlertStatus.Dismissed => Color.Default,
        _ => Color.Default,
    };

    private async Task<GridData<QualificationAlertDto>> LoadAsync(GridState<QualificationAlertDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.QualificationAlerts.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(a => a.Status == filterStatus.Value);
            if (filterStation.HasValue) q = q.Where(a => a.StationId == filterStation.Value);
            if (filterEmployee.HasValue) q = q.Where(a => a.BusinessEntityId == filterEmployee.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(a => a.RaisedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(a => a.ToDto()).ToListAsync(ct);
            return new GridData<QualificationAlertDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task Acknowledge(long id, QualificationAlertStatus target)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.QualificationAlerts.FirstOrDefaultAsync(a => a.Id == id);
            if (entity is null) { Snackbar.Add("Alert not found.", Severity.Error); return; }
            var by = await GetUserNameAsync();
            entity.Status = target;
            entity.AcknowledgedAt = DateTime.UtcNow;
            entity.AcknowledgedByUserId = by;
            entity.ModifiedDate = DateTime.UtcNow;
            await db.SaveChangesAsync();
            Snackbar.Add($"Alert {target}.", Severity.Success);
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Update failed: {ex.Message}", Severity.Error); }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
