@page "/performance/reports"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Performance reports</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Performance reports</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Saved report queries + run history</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New report</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudCheckBox T="bool" @bind-Value="activeOnly" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="PerformanceReportDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Kind" Title="Kind" />
            <PropertyColumn Property="x => x.RangePreset" Title="Range" />
            <PropertyColumn Property="x => x.LastRunAt" Title="Last run" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate>@(context.Item.IsActive ? "✓" : "")</CellTemplate></TemplateColumn>
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudTooltip Text="Run report"><MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"performance/reports/{context.Item.Id}/run"))" /></MudTooltip>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="PerformanceReportDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>New performance report</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newRow.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Description" Label="Description" Variant="Variant.Outlined" Lines="2" />
            <MudSelect T="PerformanceReportKind" @bind-Value="newRow.Kind" Label="Kind" Variant="Variant.Outlined">
                @foreach (var k in Enum.GetValues<PerformanceReportKind>()) { <MudSelectItem T="PerformanceReportKind" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudSelect T="ReportRangePreset" @bind-Value="newRow.RangePreset" Label="Date range" Variant="Variant.Outlined" HelperText="Resolved at run time so the report stays rolling.">
                @foreach (var r in Enum.GetValues<ReportRangePreset>()) { <MudSelectItem T="ReportRangePreset" Value="@r">@r</MudSelectItem> }
            </MudSelect>
            @if (newRow.Kind == PerformanceReportKind.OeeSummary || newRow.Kind == PerformanceReportKind.ProductionTrend)
            {
                <MudNumericField T="int?" @bind-Value="newRow.StationId" Label="Station ID (optional)" Variant="Variant.Outlined" Clearable="true" HelperText="Empty = all stations" />
            }
            @if (newRow.Kind == PerformanceReportKind.MaintenanceScorecard)
            {
                <MudNumericField T="int?" @bind-Value="newRow.AssetId" Label="Asset ID (optional)" Variant="Variant.Outlined" Clearable="true" HelperText="Empty = all assets" />
            }
            @if (newRow.Kind == PerformanceReportKind.KpiRollup || newRow.Kind == PerformanceReportKind.Custom)
            {
                <MudTextField @bind-Value="newRow.DefinitionJson" Label="Definition (JSON)" Variant="Variant.Outlined" Lines="4" HelperText="Free-form spec — runner does not yet interpret these kinds." />
            }
            <MudCheckBox T="bool" @bind-Value="newRow.IsActive" Label="Active" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<PerformanceReportDto> grid = null!;
    private bool _loading = true;
    private bool activeOnly = true;

    private bool dialogOpen, saving;
    private CreatePerformanceReportRequest newRow = new();

    private async Task<GridData<PerformanceReportDto>> LoadAsync(GridState<PerformanceReportDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.PerformanceReports.AsNoTracking();
            if (activeOnly) q = q.Where(x => x.IsActive);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.Code)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<PerformanceReportDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreatePerformanceReportRequest { Kind = PerformanceReportKind.OeeSummary, RangePreset = ReportRangePreset.Last7Days, DefinitionJson = "{}", IsActive = true }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRow.ToEntity();
            var by = await GetUserNameAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            db.PerformanceReports.Add(entity);
            await db.SaveChangesAsync();
            db.PerformanceReportAuditLogs.Add(PerformanceReportAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.Code}.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
