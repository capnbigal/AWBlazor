@page "/mes/runs/history"
@attribute [Authorize]

<PageTitle>Run history</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h5">Production run audit history</MudText>
        @if (Id.HasValue) { <MudChip T="string" Variant="Variant.Outlined">Filtering: run #@Id</MudChip> }
    </MudStack>

    <AuditHistoryGrid EntityType="ProductionRun" EntityId="@(Id?.ToString())" />
</MudStack>

@code {
    [SupplyParameterFromQuery] public int? Id { get; set; }
}
