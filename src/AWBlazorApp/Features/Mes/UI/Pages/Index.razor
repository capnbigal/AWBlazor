@page "/mes"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Production execution</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.Engineering" Color="Color.Primary" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Production execution</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Runs, downtime, operator clock-ins — OEE rolls up live from the event tables</MudText>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Success" Value="@inProgressRuns.ToString("N0")" Label="Runs in progress" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Pause" Color="Color.Warning" Value="@pausedRuns.ToString("N0")" Label="Runs paused" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Value="@completedToday.ToString("N0")" Label="Completed today" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Error" Value="@openDowntime.ToString("N0")" Label="Open downtime events" /></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="mt-3">Modules</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Production analytics" Subtitle="Time-series charts for units produced, scrap, throughput." Icon="@Icons.Material.Filled.Analytics" Href="analytics/production" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Production runs" Subtitle="Start, pause, resume, complete production runs." Icon="@Icons.Material.Filled.PlayCircle" Href="mes/runs" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Downtime events" Subtitle="Track reasons and durations against OEE." Icon="@Icons.Material.Filled.Timer" Href="mes/downtime" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Downtime reason codes" Subtitle="Seeded catalog used when logging downtime events." Icon="@Icons.Material.Filled.Rule" Href="mes/downtime/reasons" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Work instructions" Subtitle="Versioned content keyed to WorkOrderRouting steps." Icon="@Icons.Material.Filled.MenuBook" Href="mes/instructions" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="OEE rollup" Subtitle="Live Availability × Performance × Quality by station." Icon="@Icons.Material.Filled.Speed" Href="mes/oee" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Reference data" Subtitle="AW manufacturing work orders, WO routings, transaction history, scrap reasons, product documents." Icon="@Icons.Material.Filled.TableView" Href="mes/reference" /></MudItem>
    </MudGrid>
</MudStack>

@code {
    private int inProgressRuns, pausedRuns, completedToday, openDowntime;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var todayStart = DateTime.UtcNow.Date;
        inProgressRuns = await db.ProductionRuns.CountAsync(r => r.Status == ProductionRunStatus.InProgress);
        pausedRuns = await db.ProductionRuns.CountAsync(r => r.Status == ProductionRunStatus.Paused);
        completedToday = await db.ProductionRuns.CountAsync(r => r.Status == ProductionRunStatus.Completed && r.ActualEndAt >= todayStart);
        openDowntime = await db.DowntimeEvents.CountAsync(d => d.EndAt == null);
    }
}
