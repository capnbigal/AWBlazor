@using AWBlazorApp.Shared.Dtos
@using AWBlazorApp.Shared.Services
@using AWBlazorApp.Shared.Validation
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject MudFormValidator<CreateToolSlotConfigurationRequest> CreateValidator
@inject MudFormValidator<UpdateToolSlotConfigurationRequest> UpdateValidator
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsNew ? "Create tool slot configuration" : $"Edit tool slot #{Slot?.Id}")</MudText>
    </TitleContent>
    <DialogContent>
        @if (IsNew)
        {
            <MudForm @ref="form" Model="@createModel" Validation="@CreateValidator.ValidateField" ValidationDelay="0">
                @RenderCreateFields()
            </MudForm>
        }
        else
        {
            <MudForm @ref="form" Model="@updateModel" Validation="@UpdateValidator.ValidateField" ValidationDelay="0">
                @RenderUpdateFields()
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="@saving">
            @(saving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ToolSlotConfigurationDto? Slot { get; set; }

    private bool IsNew => Slot is null;

    private MudForm form = null!;
    private CreateToolSlotConfigurationRequest createModel = new();
    private UpdateToolSlotConfigurationRequest updateModel = new();
    private bool saving;

    private static readonly (string Field, string Label)[] SlotFields =
    [
        ("Fcl1", "Front Center Left 1"),
        ("Fcl2", "Front Center Left 2"),
        ("Fcr1", "Front Center Right 1"),
        ("Ffl1", "Front Far Left 1"),
        ("Ffl2", "Front Far Left 2"),
        ("Ffr1", "Front Far Right 1"),
        ("Ffr2", "Front Far Right 2"),
        ("Ffr3", "Front Far Right 3"),
        ("Ffr4", "Front Far Right 4"),
        ("Rcl1", "Rear Center Left 1"),
        ("Rcr1", "Rear Center Right 1"),
        ("Rcr2", "Rear Center Right 2"),
        ("Rfl1", "Rear Far Left 1"),
        ("Rfr1", "Rear Far Right 1"),
        ("Rfr2", "Rear Far Right 2"),
    ];

    protected override void OnInitialized()
    {
        if (Slot is not null)
        {
            updateModel = new UpdateToolSlotConfigurationRequest
            {
                Family = Slot.Family,
                MtCode = Slot.MtCode,
                Destination = Slot.Destination,
                Fcl1 = Slot.Fcl1, Fcl2 = Slot.Fcl2, Fcr1 = Slot.Fcr1,
                Ffl1 = Slot.Ffl1, Ffl2 = Slot.Ffl2,
                Ffr1 = Slot.Ffr1, Ffr2 = Slot.Ffr2, Ffr3 = Slot.Ffr3, Ffr4 = Slot.Ffr4,
                Rcl1 = Slot.Rcl1,
                Rcr1 = Slot.Rcr1, Rcr2 = Slot.Rcr2,
                Rfl1 = Slot.Rfl1,
                Rfr1 = Slot.Rfr1, Rfr2 = Slot.Rfr2,
                IsActive = Slot.IsActive,
            };
        }
    }

    private RenderFragment RenderCreateFields() => __builder =>
    {
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="createModel.Family" Label="Family" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="createModel.MtCode" Label="Machine type code" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="createModel.Destination" Label="Destination" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle1">Slots</MudText>
            </MudItem>

            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Fcl1" ValueChanged="@((string? v) => createModel = createModel with { Fcl1 = v })" Label="Front Center Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Fcl2" ValueChanged="@((string? v) => createModel = createModel with { Fcl2 = v })" Label="Front Center Left 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Fcr1" ValueChanged="@((string? v) => createModel = createModel with { Fcr1 = v })" Label="Front Center Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Ffl1" ValueChanged="@((string? v) => createModel = createModel with { Ffl1 = v })" Label="Front Far Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Ffl2" ValueChanged="@((string? v) => createModel = createModel with { Ffl2 = v })" Label="Front Far Left 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Ffr1" ValueChanged="@((string? v) => createModel = createModel with { Ffr1 = v })" Label="Front Far Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Ffr2" ValueChanged="@((string? v) => createModel = createModel with { Ffr2 = v })" Label="Front Far Right 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Ffr3" ValueChanged="@((string? v) => createModel = createModel with { Ffr3 = v })" Label="Front Far Right 3" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Ffr4" ValueChanged="@((string? v) => createModel = createModel with { Ffr4 = v })" Label="Front Far Right 4" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Rcl1" ValueChanged="@((string? v) => createModel = createModel with { Rcl1 = v })" Label="Rear Center Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Rcr1" ValueChanged="@((string? v) => createModel = createModel with { Rcr1 = v })" Label="Rear Center Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Rcr2" ValueChanged="@((string? v) => createModel = createModel with { Rcr2 = v })" Label="Rear Center Right 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Rfl1" ValueChanged="@((string? v) => createModel = createModel with { Rfl1 = v })" Label="Rear Far Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Rfr1" ValueChanged="@((string? v) => createModel = createModel with { Rfr1 = v })" Label="Rear Far Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@createModel.Rfr2" ValueChanged="@((string? v) => createModel = createModel with { Rfr2 = v })" Label="Rear Far Right 2" Variant="Variant.Outlined" /></MudItem>

            <MudItem xs="12">
                <MudSwitch T="bool" Value="@createModel.IsActive"
                           ValueChanged="@((bool v) => createModel = createModel with { IsActive = v })"
                           Label="Active" Color="Color.Primary" />
            </MudItem>
        </MudGrid>
    };

    private RenderFragment RenderUpdateFields() => __builder =>
    {
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4">
                <MudTextField Value="@updateModel.Family" ValueChanged="@((string? v) => updateModel = updateModel with { Family = v })" Label="Family" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField Value="@updateModel.MtCode" ValueChanged="@((string? v) => updateModel = updateModel with { MtCode = v })" Label="Machine type code" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField Value="@updateModel.Destination" ValueChanged="@((string? v) => updateModel = updateModel with { Destination = v })" Label="Destination" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle1">Slots</MudText>
            </MudItem>

            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Fcl1" ValueChanged="@((string? v) => updateModel = updateModel with { Fcl1 = v })" Label="Front Center Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Fcl2" ValueChanged="@((string? v) => updateModel = updateModel with { Fcl2 = v })" Label="Front Center Left 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Fcr1" ValueChanged="@((string? v) => updateModel = updateModel with { Fcr1 = v })" Label="Front Center Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Ffl1" ValueChanged="@((string? v) => updateModel = updateModel with { Ffl1 = v })" Label="Front Far Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Ffl2" ValueChanged="@((string? v) => updateModel = updateModel with { Ffl2 = v })" Label="Front Far Left 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Ffr1" ValueChanged="@((string? v) => updateModel = updateModel with { Ffr1 = v })" Label="Front Far Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Ffr2" ValueChanged="@((string? v) => updateModel = updateModel with { Ffr2 = v })" Label="Front Far Right 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Ffr3" ValueChanged="@((string? v) => updateModel = updateModel with { Ffr3 = v })" Label="Front Far Right 3" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Ffr4" ValueChanged="@((string? v) => updateModel = updateModel with { Ffr4 = v })" Label="Front Far Right 4" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Rcl1" ValueChanged="@((string? v) => updateModel = updateModel with { Rcl1 = v })" Label="Rear Center Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Rcr1" ValueChanged="@((string? v) => updateModel = updateModel with { Rcr1 = v })" Label="Rear Center Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Rcr2" ValueChanged="@((string? v) => updateModel = updateModel with { Rcr2 = v })" Label="Rear Center Right 2" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Rfl1" ValueChanged="@((string? v) => updateModel = updateModel with { Rfl1 = v })" Label="Rear Far Left 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Rfr1" ValueChanged="@((string? v) => updateModel = updateModel with { Rfr1 = v })" Label="Rear Far Right 1" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="6" md="4"><MudTextField Value="@updateModel.Rfr2" ValueChanged="@((string? v) => updateModel = updateModel with { Rfr2 = v })" Label="Rear Far Right 2" Variant="Variant.Outlined" /></MudItem>

            <MudItem xs="12">
                <MudSwitch T="bool" Value="@(updateModel.IsActive ?? false)"
                           ValueChanged="@((bool v) => updateModel = updateModel with { IsActive = v })"
                           Label="Active" Color="Color.Primary" />
            </MudItem>
        </MudGrid>
    };

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var changedBy = await GetCurrentUserNameAsync();

            if (IsNew)
            {
                if (!await CreateValidator.ValidateAllAsync(createModel))
                {
                    Snackbar.Add("Set at least one of Family, Machine type code, or Destination.", Severity.Error);
                    return;
                }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = createModel.ToEntity();
                db.ToolSlotConfigurations.Add(entity);
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
            else
            {
                if (!await UpdateValidator.ValidateAllAsync(updateModel))
                {
                    return;
                }
                await using var db = await DbFactory.CreateDbContextAsync();
                var entity = await db.ToolSlotConfigurations.FirstOrDefaultAsync(t => t.Id == Slot!.Id);
                if (entity is null)
                {
                    MudDialog.Close(DialogResult.Cancel());
                    return;
                }
                updateModel.ApplyTo(entity);
                await db.SaveChangesAsync();
                MudDialog.Close(DialogResult.Ok(entity.Id));
            }
        }
        finally
        {
            saving = false;
        }
    }

    private async Task<string?> GetCurrentUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
