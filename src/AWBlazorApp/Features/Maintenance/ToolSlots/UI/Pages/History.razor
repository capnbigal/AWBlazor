@page "/maintenance/tool-slots/history"
@page "/maintenance/tool-slots/history/{SlotId:int}"
@* Legacy aliases. Preserved for existing bookmarks; new code should use /maintenance/tool-slots/*. *@
@page "/tool-slots/history"
@page "/tool-slots/history/{SlotId:int}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Tool slot history@(SlotId is null ? "" : $" — #{SlotId}")</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back"
                       Size="Size.Medium"
                       OnClick="@(() => Navigation.NavigateTo("maintenance/tool-slots"))" />
        <MudText Typo="Typo.h4">
            @(SlotId is null ? "Tool slot history" : $"History for tool slot #{SlotId}")
        </MudText>
        <MudSpacer />
        @if (SlotId is not null)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.List"
                       Href="maintenance/tool-slots/history">
                All history
            </MudButton>
        }
    </MudStack>

    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Every create, update, and delete of a tool slot configuration is recorded here.
    </MudText>

    <AuditHistoryGrid EntityType="ToolSlotConfiguration" EntityId="@(SlotId?.ToString())" />
</MudStack>

@code {
    [Parameter] public int? SlotId { get; set; }
}
