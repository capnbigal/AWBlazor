@page "/maintenance/work-orders/{Id:int}"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IWorkOrderService WoService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>WO @(wo?.WorkOrderNumber ?? "—")</PageTitle>

@if (wo is null)
{
    <MudText Typo="Typo.body1">Loading…</MudText>
}
else
{
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("maintenance/work-orders"))" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h4">@wo.WorkOrderNumber</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@wo.Title · Asset @wo.AssetId · @wo.Type</MudText>
            </MudStack>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@PriorityColor(wo.Priority)" Variant="Variant.Outlined">@wo.Priority</MudChip>
            <MudChip T="string" Size="Size.Medium" Color="@StatusColor(wo.Status)" Variant="Variant.Filled">@wo.Status</MudChip>
        </MudStack>

        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                @if (wo.Status == WorkOrderStatus.Draft)
                {
                    <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
                        <MudButton Color="Color.Info" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Schedule" OnClick="OpenSchedule">Schedule</MudButton>
                    </AuthorizeView>
                    <MudButton Color="Color.Default" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Cancel" OnClick="@(() => Cancel("Cancelled from Draft"))">Cancel</MudButton>
                }
                else if (wo.Status == WorkOrderStatus.Scheduled)
                {
                    <MudButton Color="Color.Warning" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="Start">Start</MudButton>
                    <MudButton Color="Color.Default" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Cancel" OnClick="@(() => Cancel("Cancelled from Scheduled"))">Cancel</MudButton>
                }
                else if (wo.Status == WorkOrderStatus.InProgress)
                {
                    <MudButton Color="Color.Success" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Check" OnClick="OpenComplete">Complete</MudButton>
                    <MudButton Color="Color.Tertiary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Pause" OnClick="OpenHold">Hold</MudButton>
                    <MudButton Color="Color.Default" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Cancel" OnClick="@(() => Cancel("Cancelled from InProgress"))">Cancel</MudButton>
                }
                else if (wo.Status == WorkOrderStatus.OnHold)
                {
                    <MudButton Color="Color.Warning" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="Resume">Resume</MudButton>
                    <MudButton Color="Color.Default" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Cancel" OnClick="@(() => Cancel("Cancelled from OnHold"))">Cancel</MudButton>
                }
                <MudSpacer />
                @if (wo.AssignedBusinessEntityId.HasValue)
                { <MudText Typo="Typo.caption" Color="Color.Secondary">Assignee @wo.AssignedBusinessEntityId</MudText> }
                @if (wo.ScheduledFor.HasValue)
                { <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-3">Scheduled @wo.ScheduledFor.Value.ToString("yyyy-MM-dd HH:mm")</MudText> }
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(wo.Description))
            {
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.body2" Style="white-space: pre-wrap">@wo.Description</MudText>
            }
            @if (!string.IsNullOrWhiteSpace(wo.CompletionNotes))
            {
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2">Completion / state notes</MudText>
                <MudText Typo="Typo.body2" Style="white-space: pre-wrap">@wo.CompletionNotes</MudText>
            }
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Tasks</MudText>
                <MudSpacer />
                @if (wo.Status is WorkOrderStatus.Draft or WorkOrderStatus.Scheduled or WorkOrderStatus.InProgress)
                {
                    <MudButton Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddTask">Add task</MudButton>
                }
            </MudStack>
            <MudDataGrid T="MaintenanceWorkOrderTaskDto" Items="tasks" Dense="true" Hover="true" Striped="true">
                <Columns>
                    <PropertyColumn Property="x => x.SequenceNumber" Title="#" />
                    <PropertyColumn Property="x => x.TaskName" Title="Task" />
                    <PropertyColumn Property="x => x.EstimatedMinutes" Title="Est min" />
                    <PropertyColumn Property="x => x.ActualMinutes" Title="Actual min" />
                    <TemplateColumn Title="Signoff" Sortable="false">
                        <CellTemplate>
                            @if (context.Item.RequiresSignoff)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Warning" />
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Done" Sortable="false">
                        <CellTemplate>
                            @if (context.Item.IsComplete)
                            { <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Check">@context.Item.CompletedByUserId</MudChip> }
                            else if (wo.Status == WorkOrderStatus.InProgress)
                            { <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@(() => OpenCompleteTask(context.Item.Id))">Complete</MudButton> }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Parts used</MudText>
                <MudSpacer />
                @if (wo.Status == WorkOrderStatus.InProgress)
                {
                    <MudButton Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddPart">Record part usage</MudButton>
                }
            </MudStack>
            <MudDataGrid T="WorkOrderPartUsageDto" Items="parts" Dense="true" Hover="true" Striped="true">
                <Columns>
                    <PropertyColumn Property="x => x.SparePartId" Title="Part ID" />
                    <PropertyColumn Property="x => x.Quantity" Title="Qty" />
                    <PropertyColumn Property="x => x.UnitCost" Title="Unit cost" />
                    <PropertyColumn Property="x => x.UsedAt" Title="Used" Format="yyyy-MM-dd HH:mm" />
                    <PropertyColumn Property="x => x.Notes" Title="Notes" />
                </Columns>
            </MudDataGrid>
        </MudPaper>
    </MudStack>
}

<MudDialog @bind-Visible="scheduleOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Schedule WO</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudDatePicker @bind-Date="scheduleDate" Label="Scheduled date" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="scheduleAssignee" Label="Assignee (BusinessEntityId)" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => scheduleOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitSchedule">Schedule</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="completeOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Complete WO</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="completeNotes" Label="Completion notes" Variant="Variant.Outlined" Lines="3" />
            <MudNumericField T="decimal?" @bind-Value="completeMeter" Label="Meter value at completion (optional)" Variant="Variant.Outlined" HelperText="Used for meter-based PM schedules — updates the triggering schedule's last-completed stamp." />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => completeOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="SubmitComplete">Complete</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="holdOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Put WO on hold</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="holdReason" Label="Reason" Variant="Variant.Outlined" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => holdOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Tertiary" Variant="Variant.Filled" OnClick="SubmitHold">Hold</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="addTaskOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Add task</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newTask.SequenceNumber" Label="Sequence" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newTask.TaskName" Label="Task name" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newTask.Instructions" Label="Instructions" Variant="Variant.Outlined" Lines="3" />
            <MudNumericField T="int?" @bind-Value="newTask.EstimatedMinutes" Label="Estimated minutes" Variant="Variant.Outlined" />
            <MudCheckBox T="bool" @bind-Value="newTask.RequiresSignoff" Label="Requires signoff" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => addTaskOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddTaskAsync">Add</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="completeTaskOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Complete task</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int?" @bind-Value="taskActualMinutes" Label="Actual minutes" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="taskSignoffNotes" Label="Signoff notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => completeTaskOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="SubmitCompleteTask">Done</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="addPartOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>Record part usage</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newUsage.SparePartId" Label="Spare part ID" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="decimal" @bind-Value="newUsage.Quantity" Label="Quantity" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="decimal?" @bind-Value="newUsage.UnitCost" Label="Unit cost (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newUsage.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => addPartOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddPartAsync">Record</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int Id { get; set; }

    private MaintenanceWorkOrderDto? wo;
    private List<MaintenanceWorkOrderTaskDto> tasks = new();
    private List<WorkOrderPartUsageDto> parts = new();

    private bool scheduleOpen;
    private DateTime? scheduleDate = DateTime.UtcNow.Date.AddDays(1);
    private int? scheduleAssignee;

    private bool completeOpen;
    private string? completeNotes;
    private decimal? completeMeter;

    private bool holdOpen;
    private string? holdReason;

    private bool addTaskOpen;
    private CreateWorkOrderTaskRequest newTask = new();

    private bool completeTaskOpen;
    private int completeTaskId;
    private int? taskActualMinutes;
    private string? taskSignoffNotes;

    private bool addPartOpen;
    private CreateWorkOrderPartUsageRequest newUsage = new();

    private static Color StatusColor(WorkOrderStatus s) => s switch
    {
        WorkOrderStatus.Draft => Color.Default,
        WorkOrderStatus.Scheduled => Color.Info,
        WorkOrderStatus.InProgress => Color.Warning,
        WorkOrderStatus.OnHold => Color.Tertiary,
        WorkOrderStatus.Completed => Color.Success,
        WorkOrderStatus.Cancelled => Color.Dark,
        _ => Color.Default,
    };

    private static Color PriorityColor(WorkOrderPriority p) => p switch
    {
        WorkOrderPriority.Critical => Color.Error,
        WorkOrderPriority.High => Color.Warning,
        WorkOrderPriority.Medium => Color.Info,
        WorkOrderPriority.Low => Color.Default,
        _ => Color.Default,
    };

    protected override async Task OnParametersSetAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var row = await db.MaintenanceWorkOrders.AsNoTracking().FirstOrDefaultAsync(w => w.Id == Id);
        wo = row?.ToDto();
        tasks = await db.MaintenanceWorkOrderTasks.AsNoTracking()
            .Where(t => t.MaintenanceWorkOrderId == Id)
            .OrderBy(t => t.SequenceNumber)
            .Select(t => t.ToDto()).ToListAsync();
        parts = await db.WorkOrderPartUsages.AsNoTracking()
            .Where(u => u.MaintenanceWorkOrderId == Id)
            .OrderByDescending(u => u.UsedAt)
            .Select(u => u.ToDto()).ToListAsync();
    }

    private void OpenSchedule() { scheduleDate = DateTime.UtcNow.Date.AddDays(1); scheduleAssignee = null; scheduleOpen = true; }

    private async Task SubmitSchedule()
    {
        try
        {
            var by = await GetUserNameAsync();
            await WoService.ScheduleAsync(Id, scheduleDate ?? DateTime.UtcNow, scheduleAssignee, by, default);
            Snackbar.Add("Scheduled.", Severity.Success);
            scheduleOpen = false;
            await ReloadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Schedule failed: {ex.Message}", Severity.Error); }
    }

    private async Task Start()
    {
        try { await WoService.StartAsync(Id, await GetUserNameAsync(), default); Snackbar.Add("Started.", Severity.Success); await ReloadAsync(); }
        catch (Exception ex) { Snackbar.Add($"Start failed: {ex.Message}", Severity.Error); }
    }

    private void OpenHold() { holdReason = null; holdOpen = true; }
    private async Task SubmitHold()
    {
        try { await WoService.HoldAsync(Id, holdReason, await GetUserNameAsync(), default); Snackbar.Add("On hold.", Severity.Success); holdOpen = false; await ReloadAsync(); }
        catch (Exception ex) { Snackbar.Add($"Hold failed: {ex.Message}", Severity.Error); }
    }

    private async Task Resume()
    {
        try { await WoService.ResumeAsync(Id, await GetUserNameAsync(), default); Snackbar.Add("Resumed.", Severity.Success); await ReloadAsync(); }
        catch (Exception ex) { Snackbar.Add($"Resume failed: {ex.Message}", Severity.Error); }
    }

    private void OpenComplete() { completeNotes = null; completeMeter = null; completeOpen = true; }
    private async Task SubmitComplete()
    {
        try { await WoService.CompleteAsync(Id, completeNotes, completeMeter, await GetUserNameAsync(), default); Snackbar.Add("Completed.", Severity.Success); completeOpen = false; await ReloadAsync(); }
        catch (Exception ex) { Snackbar.Add($"Complete failed: {ex.Message}", Severity.Error); }
    }

    private async Task Cancel(string reason)
    {
        try { await WoService.CancelAsync(Id, reason, await GetUserNameAsync(), default); Snackbar.Add("Cancelled.", Severity.Success); await ReloadAsync(); }
        catch (Exception ex) { Snackbar.Add($"Cancel failed: {ex.Message}", Severity.Error); }
    }

    private void OpenAddTask()
    {
        var next = tasks.Count == 0 ? 10 : tasks.Max(t => t.SequenceNumber) + 10;
        newTask = new CreateWorkOrderTaskRequest { MaintenanceWorkOrderId = Id, SequenceNumber = next };
        addTaskOpen = true;
    }

    private async Task AddTaskAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            newTask.MaintenanceWorkOrderId = Id;
            var entity = newTask.ToEntity();
            db.MaintenanceWorkOrderTasks.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add("Task added.", Severity.Success);
            addTaskOpen = false;
            await ReloadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Add failed: {ex.Message}", Severity.Error); }
    }

    private void OpenCompleteTask(int taskId) { completeTaskId = taskId; taskActualMinutes = null; taskSignoffNotes = null; completeTaskOpen = true; }

    private async Task SubmitCompleteTask()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var t = await db.MaintenanceWorkOrderTasks.FirstOrDefaultAsync(x => x.Id == completeTaskId);
            if (t is null) return;
            var by = await GetUserNameAsync();
            t.IsComplete = true;
            t.CompletedAt = DateTime.UtcNow;
            t.CompletedByUserId = by;
            t.ActualMinutes = taskActualMinutes;
            t.SignoffNotes = taskSignoffNotes?.Trim();
            t.ModifiedDate = DateTime.UtcNow;
            await db.SaveChangesAsync();
            Snackbar.Add("Task completed.", Severity.Success);
            completeTaskOpen = false;
            await ReloadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Complete task failed: {ex.Message}", Severity.Error); }
    }

    private void OpenAddPart() { newUsage = new CreateWorkOrderPartUsageRequest { MaintenanceWorkOrderId = Id, Quantity = 1 }; addPartOpen = true; }

    private async Task AddPartAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            newUsage.MaintenanceWorkOrderId = Id;
            var by = await GetUserNameAsync();
            var entity = newUsage.ToEntity(by);
            db.WorkOrderPartUsages.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add("Part usage recorded.", Severity.Success);
            addPartOpen = false;
            await ReloadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Record failed: {ex.Message}", Severity.Error); }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
