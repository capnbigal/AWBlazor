@page "/maintenance"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Maintenance</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Primary" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Maintenance</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">PM schedules, work orders, spare parts, meter-based due detection</MudText>
        </MudStack>
    </MudStack>

    @* ── Headline KPIs ─────────────────────────────────────────────── *@
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Assignment" Color="Color.Warning" Value="@openWorkOrders.ToString("N0")" Label="Open work orders" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Info" Value="@inProgressWorkOrders.ToString("N0")" Label="In progress" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Schedule" Color="Color.Primary" Value="@activeSchedules.ToString("N0")" Label="Active PM schedules" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Value="@criticalAssets.ToString("N0")" Label="Critical assets" /></MudItem>
    </MudGrid>

    @* ── Modules ───────────────────────────────────────────────────── *@
    <MudText Typo="Typo.h5" Class="mt-3">Modules</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Work orders" Subtitle="Draft → Scheduled → InProgress → Completed with OnHold/Cancelled side paths." Icon="@Icons.Material.Filled.Assignment" Href="maintenance/work-orders" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="PM schedules" Subtitle="Time- or meter-based preventive maintenance. Generate due WOs on demand." Icon="@Icons.Material.Filled.Schedule" Href="maintenance/pm-schedules" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Asset profiles" Subtitle="Criticality, owner, target MTBF per asset. 1:1 sidecar on org.Asset." Icon="@Icons.Material.Filled.PrecisionManufacturing" Href="maintenance/asset-profiles" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Spare parts" Subtitle="Standalone catalog with optional link to AW Production.Product." Icon="@Icons.Material.Filled.Inventory" Href="maintenance/spare-parts" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Meter readings" Subtitle="Runtime hours / cycles / kWh. Drives usage-based PM due checks." Icon="@Icons.Material.Filled.Speed" Href="maintenance/meter-readings" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Maintenance log" Subtitle="Free-form observations not yet escalated to a work order." Icon="@Icons.Material.Filled.EventNote" Href="maintenance/logs" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Tool slots" Subtitle="Externally-managed tool slot configurations keyed by family / MT code." Icon="@Icons.Material.Filled.Build" Href="maintenance/tool-slots" /></MudItem>
    </MudGrid>

    @* ── Recent activity ───────────────────────────────────────────── *@
    <MudText Typo="Typo.h5" Class="mt-3">Recent work orders</MudText>
    <MudPaper Class="pa-4" Elevation="2">
        @if (recentWorkOrders.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No work orders yet.</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true">
                <thead>
                    <tr>
                        <th>WO #</th>
                        <th>Title</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var wo in recentWorkOrders)
                    {
                        <tr>
                            <td><strong>@wo.Number</strong></td>
                            <td>@wo.Title</td>
                            <td><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@PriorityColor(wo.Priority)">@wo.Priority</MudChip></td>
                            <td><MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@StatusColor(wo.Status)">@wo.Status</MudChip></td>
                            <td>@wo.ModifiedDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"maintenance/work-orders/{wo.Id}"))" /></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>
</MudStack>

@code {
    private int openWorkOrders, inProgressWorkOrders, activeSchedules, criticalAssets;
    private List<RecentWo> recentWorkOrders = [];

    private record RecentWo(int Id, string Number, string Title, WorkOrderStatus Status, WorkOrderPriority Priority, DateTime ModifiedDate);

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        openWorkOrders = await db.MaintenanceWorkOrders.CountAsync(w =>
            w.Status != WorkOrderStatus.Completed && w.Status != WorkOrderStatus.Cancelled);
        inProgressWorkOrders = await db.MaintenanceWorkOrders.CountAsync(w => w.Status == WorkOrderStatus.InProgress);
        activeSchedules = await db.PmSchedules.CountAsync(s => s.IsActive);
        criticalAssets = await db.AssetMaintenanceProfiles.CountAsync(p => p.Criticality == AssetCriticality.Critical);

        recentWorkOrders = await db.MaintenanceWorkOrders.AsNoTracking()
            .OrderByDescending(w => w.ModifiedDate)
            .Take(5)
            .Select(w => new RecentWo(w.Id, w.WorkOrderNumber, w.Title, w.Status, w.Priority, w.ModifiedDate))
            .ToListAsync();
    }

    private static Color StatusColor(WorkOrderStatus s) => s switch
    {
        WorkOrderStatus.Draft      => Color.Default,
        WorkOrderStatus.Scheduled  => Color.Info,
        WorkOrderStatus.InProgress => Color.Warning,
        WorkOrderStatus.OnHold     => Color.Secondary,
        WorkOrderStatus.Completed  => Color.Success,
        WorkOrderStatus.Cancelled  => Color.Error,
        _                          => Color.Default,
    };

    private static Color PriorityColor(WorkOrderPriority p) => p switch
    {
        WorkOrderPriority.Critical => Color.Error,
        WorkOrderPriority.High     => Color.Warning,
        WorkOrderPriority.Medium   => Color.Info,
        WorkOrderPriority.Low      => Color.Default,
        _                          => Color.Default,
    };
}
