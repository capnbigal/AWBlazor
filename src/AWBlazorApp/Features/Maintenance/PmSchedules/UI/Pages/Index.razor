@page "/maintenance/pm-schedules"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IPmScheduleService PmService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>PM schedules</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">PM schedules</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">maint.PmSchedule — time-based (days) or meter-based (runtime hours / cycles)</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="GenerateDueAll" Disabled="generating">@(generating ? "Generating…" : "Generate all due")</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New schedule</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField T="int?" @bind-Value="filterAsset" Label="Asset ID" Variant="Variant.Outlined" Clearable="true" />
            <MudCheckBox T="bool" @bind-Value="activeOnly" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="PmScheduleDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.AssetId" Title="Asset" />
            <PropertyColumn Property="x => x.IntervalKind" Title="Kind" />
            <PropertyColumn Property="x => x.IntervalValue" Title="Interval" />
            <PropertyColumn Property="x => x.LastCompletedAt" Title="Last run" Format="yyyy-MM-dd" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate></TemplateColumn>
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate><MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"maintenance/pm-schedules/{context.Item.Id}"))" /></CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="PmScheduleDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New PM schedule</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newRow.Code" Label="Code (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Description" Label="Description" Variant="Variant.Outlined" Lines="2" />
            <MudNumericField T="int" @bind-Value="newRow.AssetId" Label="Asset ID" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="PmIntervalKind" @bind-Value="newRow.IntervalKind" Label="Interval kind" Variant="Variant.Outlined">
                @foreach (var k in Enum.GetValues<PmIntervalKind>()) { <MudSelectItem T="PmIntervalKind" Value="@k">@k</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int" @bind-Value="newRow.IntervalValue" Label="Interval value (days / hours / cycles)" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="WorkOrderPriority" @bind-Value="newRow.DefaultPriority" Label="Default priority" Variant="Variant.Outlined">
                @foreach (var p in Enum.GetValues<WorkOrderPriority>()) { <MudSelectItem T="WorkOrderPriority" Value="@p">@p</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int" @bind-Value="newRow.EstimatedMinutes" Label="Estimated minutes" Variant="Variant.Outlined" />
            <MudCheckBox T="bool" @bind-Value="newRow.IsActive" Label="Active" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<PmScheduleDto> grid = null!;
    private bool _loading = true;
    private int? filterAsset;
    private bool activeOnly = true;
    private bool generating;

    private bool dialogOpen, saving;
    private CreatePmScheduleRequest newRow = new();

    private async Task<GridData<PmScheduleDto>> LoadAsync(GridState<PmScheduleDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.PmSchedules.AsNoTracking();
            if (filterAsset.HasValue) q = q.Where(x => x.AssetId == filterAsset.Value);
            if (activeOnly) q = q.Where(x => x.IsActive);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.Code)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<PmScheduleDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreatePmScheduleRequest { IntervalKind = PmIntervalKind.Days, DefaultPriority = WorkOrderPriority.Medium, IsActive = true }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRow.ToEntity();
            db.PmSchedules.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add($"Created {entity.Code}.", Severity.Success);
            dialogOpen = false;
            Navigation.NavigateTo($"maintenance/pm-schedules/{entity.Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task GenerateDueAll()
    {
        generating = true;
        try
        {
            var by = await GetUserNameAsync();
            var count = await PmService.GenerateDueWorkOrdersAsync(null, by, default);
            Snackbar.Add($"Generated {count} work order(s).", count > 0 ? Severity.Success : Severity.Info);
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Generate failed: {ex.Message}", Severity.Error); }
        finally { generating = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
