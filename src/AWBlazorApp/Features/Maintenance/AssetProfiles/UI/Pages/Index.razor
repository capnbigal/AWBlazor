@page "/maintenance/asset-profiles"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>Asset maintenance profiles</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Asset maintenance profiles</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">1:1 sidecar on org.Asset — criticality, owner, target MTBF</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New profile</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="AssetCriticality?" @bind-Value="filterCriticality" Label="Criticality" Variant="Variant.Outlined" Clearable="true" Style="max-width: 200px">
                <MudSelectItem T="AssetCriticality?" Value="@null">(any)</MudSelectItem>
                @foreach (var c in Enum.GetValues<AssetCriticality>()) { <MudSelectItem T="AssetCriticality?" Value="@c">@c</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterAsset" Label="Asset ID" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="AssetMaintenanceProfileDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.AssetId" Title="Asset" />
            <TemplateColumn Title="Criticality" Sortable="false">
                <CellTemplate><MudChip T="string" Size="Size.Small" Color="@CriticalityColor(context.Item.Criticality)" Variant="Variant.Filled">@context.Item.Criticality</MudChip></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.OwnerBusinessEntityId" Title="Owner" />
            <PropertyColumn Property="x => x.TargetMtbfHours" Title="Target MTBF (hrs)" />
            <PropertyColumn Property="x => x.NextPmDueAt" Title="Next PM due" Format="yyyy-MM-dd" />
        </Columns>
        <PagerContent><MudDataGridPager T="AssetMaintenanceProfileDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New asset maintenance profile</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newRow.AssetId" Label="Asset ID" Required="true" Variant="Variant.Outlined" />
            <MudSelect T="AssetCriticality" @bind-Value="newRow.Criticality" Label="Criticality" Variant="Variant.Outlined">
                @foreach (var c in Enum.GetValues<AssetCriticality>()) { <MudSelectItem T="AssetCriticality" Value="@c">@c</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="newRow.OwnerBusinessEntityId" Label="Owner (BusinessEntityId)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRow.TargetMtbfHours" Label="Target MTBF (hours)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<AssetMaintenanceProfileDto> grid = null!;
    private bool _loading = true;
    private AssetCriticality? filterCriticality;
    private int? filterAsset;

    private bool dialogOpen, saving;
    private CreateAssetMaintenanceProfileRequest newRow = new();

    private static Color CriticalityColor(AssetCriticality c) => c switch
    {
        AssetCriticality.Critical => Color.Error,
        AssetCriticality.High => Color.Warning,
        AssetCriticality.Medium => Color.Info,
        AssetCriticality.Low => Color.Default,
        _ => Color.Default,
    };

    private async Task<GridData<AssetMaintenanceProfileDto>> LoadAsync(GridState<AssetMaintenanceProfileDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.AssetMaintenanceProfiles.AsNoTracking();
            if (filterCriticality.HasValue) q = q.Where(x => x.Criticality == filterCriticality.Value);
            if (filterAsset.HasValue) q = q.Where(x => x.AssetId == filterAsset.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.AssetId)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<AssetMaintenanceProfileDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateAssetMaintenanceProfileRequest { Criticality = AssetCriticality.Medium }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (await db.AssetMaintenanceProfiles.AnyAsync(p => p.AssetId == newRow.AssetId))
            {
                Snackbar.Add("This asset already has a profile.", Severity.Error);
                return;
            }
            var entity = newRow.ToEntity();
            db.AssetMaintenanceProfiles.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add("Created.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

}
