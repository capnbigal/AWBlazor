@page "/maintenance/spare-parts"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Spare parts</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Spare parts</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">maint.SparePart — catalog with optional link to AW Production.Product</MudText>
        <MudSpacer />
        <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New part</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="search" Label="Search part number / name" Variant="Variant.Outlined" Clearable="true" />
            <MudCheckBox T="bool" @bind-Value="activeOnly" Label="Active only" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="SparePartDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.PartNumber" Title="Part #" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.UnitMeasureCode" Title="UOM" />
            <PropertyColumn Property="x => x.StandardCost" Title="Std cost" />
            <PropertyColumn Property="x => x.ReorderPoint" Title="Reorder pt" />
            <PropertyColumn Property="x => x.ProductId" Title="Product link" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="SparePartDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New spare part</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="newRow.PartNumber" Label="Part number (UPPER)" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.Description" Label="Description" Variant="Variant.Outlined" Lines="2" />
            <MudNumericField T="int?" @bind-Value="newRow.ProductId" Label="AW Product ID (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newRow.UnitMeasureCode" Label="UOM (3 chars)" Variant="Variant.Outlined" />
            <MudNumericField T="decimal?" @bind-Value="newRow.StandardCost" Label="Standard cost" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRow.ReorderPoint" Label="Reorder point" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newRow.ReorderQuantity" Label="Reorder quantity" Variant="Variant.Outlined" />
            <MudCheckBox T="bool" @bind-Value="newRow.IsActive" Label="Active" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<SparePartDto> grid = null!;
    private bool _loading = true;
    private string? search;
    private bool activeOnly = true;

    private bool dialogOpen, saving;
    private CreateSparePartRequest newRow = new();

    private async Task<GridData<SparePartDto>> LoadAsync(GridState<SparePartDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.SpareParts.AsNoTracking();
            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(x => x.PartNumber.Contains(s) || x.Name.Contains(s));
            }
            if (activeOnly) q = q.Where(x => x.IsActive);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderBy(x => x.PartNumber)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<SparePartDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newRow = new CreateSparePartRequest { UnitMeasureCode = "EA", IsActive = true }; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newRow.ToEntity();
            var by = await GetUserNameAsync();
            await using var tx = await db.Database.BeginTransactionAsync();
            db.SpareParts.Add(entity);
            await db.SaveChangesAsync();
            db.SparePartAuditLogs.Add(SparePartAuditService.RecordCreate(entity, by));
            await db.SaveChangesAsync();
            await tx.CommitAsync();
            Snackbar.Add($"Created {entity.PartNumber}.", Severity.Success);
            dialogOpen = false;
            await grid.ReloadServerData();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
