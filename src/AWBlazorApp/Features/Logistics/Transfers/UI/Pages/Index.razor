@page "/logistics/transfers"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Stock transfers</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Stock transfers</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">lgx.StockTransfer — paired TRANSFER_OUT + TRANSFER_IN ledger events</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="logistics/transfers/history">All history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New transfer</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="StockTransferStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 220px">
                <MudSelectItem T="StockTransferStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<StockTransferStatus>()) { <MudSelectItem T="StockTransferStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterFrom" Label="From location" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterTo" Label="To location" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="StockTransferDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.TransferNumber" Title="Number" />
            <PropertyColumn Property="x => x.Status" Title="Status" />
            <PropertyColumn Property="x => x.FromLocationId" Title="From" />
            <PropertyColumn Property="x => x.ToLocationId" Title="To" />
            <PropertyColumn Property="x => x.FromOrganizationId" Title="From org" />
            <PropertyColumn Property="x => x.ToOrganizationId" Title="To org" />
            <PropertyColumn Property="x => x.InitiatedAt" Title="Initiated" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.CompletedAt" Title="Completed" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"logistics/transfers/{context.Item.Id}"))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="StockTransferDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New stock transfer</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newTransfer.FromLocationId" Label="From location id" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int" @bind-Value="newTransfer.ToLocationId" Label="To location id" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newTransfer.FromOrganizationId" Label="From org (optional, for inter-org)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newTransfer.ToOrganizationId" Label="To org (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newTransfer.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create draft")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<StockTransferDto> grid = null!;
    private bool _loading = true;
    private StockTransferStatus? filterStatus;
    private int? filterFrom, filterTo;

    private bool dialogOpen, saving;
    private CreateStockTransferRequest newTransfer = new();

    private async Task<GridData<StockTransferDto>> LoadAsync(GridState<StockTransferDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.StockTransfers.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            if (filterFrom.HasValue) q = q.Where(x => x.FromLocationId == filterFrom.Value);
            if (filterTo.HasValue) q = q.Where(x => x.ToLocationId == filterTo.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.InitiatedAt).ThenByDescending(x => x.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<StockTransferDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newTransfer = new CreateStockTransferRequest(); dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newTransfer.ToEntity();
            db.StockTransfers.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add($"Created {entity.TransferNumber}.", Severity.Success);
            dialogOpen = false;
            Navigation.NavigateTo($"logistics/transfers/{entity.Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
