@page "/logistics/shipments"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Shipments</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Shipments</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">lgx.Shipment — outbound to customers, Pick → Pack → Ship → Delivered on one row</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="logistics/shipments/history">All history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New shipment</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="ShipmentStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 220px">
                <MudSelectItem T="ShipmentStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<ShipmentStatus>()) { <MudSelectItem T="ShipmentStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterSo" Label="SO id" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="ShipmentDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.ShipmentNumber" Title="Number" />
            <PropertyColumn Property="x => x.Status" Title="Status" />
            <PropertyColumn Property="x => x.SalesOrderId" Title="SO" />
            <PropertyColumn Property="x => x.CustomerBusinessEntityId" Title="Customer" />
            <PropertyColumn Property="x => x.ShippedFromLocationId" Title="From" />
            <PropertyColumn Property="x => x.ShipMethodId" Title="Method" />
            <PropertyColumn Property="x => x.TrackingNumber" Title="Tracking" />
            <PropertyColumn Property="x => x.ShippedAt" Title="Shipped" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"logistics/shipments/{context.Item.Id}"))" />
                        @if (context.Item.SalesOrderId != null)
                        {
                            <MudTooltip Text="Open process timeline">
                                <MudIconButton Icon="@Icons.Material.Filled.Timeline"
                                               aria-label="Timeline"
                                               Size="Size.Small"
                                               Href="@($"/processes/timeline?chain=sales-to-ship&root={context.Item.SalesOrderId}")" />
                            </MudTooltip>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="ShipmentDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New shipment</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newShipment.ShippedFromLocationId" Label="From location id" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newShipment.SalesOrderId" Label="SalesOrderId (optional)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newShipment.CustomerBusinessEntityId" Label="Customer (BusinessEntityId, optional)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newShipment.ShipMethodId" Label="ShipMethodId (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newShipment.TrackingNumber" Label="Tracking number (optional)" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newShipment.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create draft")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<ShipmentDto> grid = null!;
    private bool _loading = true;
    private ShipmentStatus? filterStatus;
    private int? filterSo;

    private bool dialogOpen, saving;
    private CreateShipmentRequest newShipment = new();

    private async Task<GridData<ShipmentDto>> LoadAsync(GridState<ShipmentDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.Shipments.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            if (filterSo.HasValue) q = q.Where(x => x.SalesOrderId == filterSo.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.ModifiedDate).ThenByDescending(x => x.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<ShipmentDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newShipment = new CreateShipmentRequest(); dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newShipment.ToEntity();
            db.Shipments.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add($"Created {entity.ShipmentNumber}.", Severity.Success);
            dialogOpen = false;
            Navigation.NavigateTo($"logistics/shipments/{entity.Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
