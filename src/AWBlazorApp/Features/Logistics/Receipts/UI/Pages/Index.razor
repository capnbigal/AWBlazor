@page "/logistics/receipts"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Goods receipts</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Goods receipts</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">lgx.GoodsReceipt — inbound from POs and ad-hoc</MudText>
        <MudSpacer />
        <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.History" Href="logistics/receipts/history">All history</MudButton>
        <AuthorizeView Roles="@($"{AppRoles.Employee},{AppRoles.Manager},{AppRoles.Admin}")">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">New receipt</MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="GoodsReceiptStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 220px">
                <MudSelectItem T="GoodsReceiptStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<GoodsReceiptStatus>()) { <MudSelectItem T="GoodsReceiptStatus?" Value="@s">@s</MudSelectItem> }
            </MudSelect>
            <MudNumericField T="int?" @bind-Value="filterPo" Label="PO id" Variant="Variant.Outlined" Clearable="true" />
            <MudNumericField T="int?" @bind-Value="filterLocation" Label="Location" Variant="Variant.Outlined" Clearable="true" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="GoodsReceiptDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.ReceiptNumber" Title="Number" />
            <PropertyColumn Property="x => x.Status" Title="Status" />
            <PropertyColumn Property="x => x.PurchaseOrderId" Title="PO" />
            <PropertyColumn Property="x => x.VendorBusinessEntityId" Title="Vendor" />
            <PropertyColumn Property="x => x.ReceivedLocationId" Title="Location" />
            <PropertyColumn Property="x => x.ReceivedAt" Title="Received" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.PostedAt" Title="Posted" Format="yyyy-MM-dd HH:mm" />
            <PropertyColumn Property="x => x.PostedByUserId" Title="By" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" OnClick="@(() => Navigation.NavigateTo($"logistics/receipts/{context.Item.Id}"))" />
                        @if (context.Item.PurchaseOrderId != null)
                        {
                            <MudTooltip Text="Open process timeline">
                                <MudIconButton Icon="@Icons.Material.Filled.Timeline"
                                               aria-label="Timeline"
                                               Size="Size.Small"
                                               Href="@($"/processes/timeline?chain=purchase-to-receive&root={context.Item.PurchaseOrderId}")" />
                            </MudTooltip>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="GoodsReceiptDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

<MudDialog @bind-Visible="dialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>New goods receipt</TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudNumericField T="int" @bind-Value="newReceipt.ReceivedLocationId" Label="Received location id" Required="true" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newReceipt.PurchaseOrderId" Label="PurchaseOrderId (optional)" Variant="Variant.Outlined" />
            <MudNumericField T="int?" @bind-Value="newReceipt.VendorBusinessEntityId" Label="Vendor (BusinessEntityId, optional)" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="receivedAt" Label="Received at" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="newReceipt.Notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => dialogOpen = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAsync" Disabled="saving">@(saving ? "Saving..." : "Create draft")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudDataGrid<GoodsReceiptDto> grid = null!;
    private bool _loading = true;
    private GoodsReceiptStatus? filterStatus;
    private int? filterPo, filterLocation;

    private bool dialogOpen;
    private bool saving;
    private CreateGoodsReceiptRequest newReceipt = new();
    private DateTime? receivedAt;

    private async Task<GridData<GoodsReceiptDto>> LoadAsync(GridState<GoodsReceiptDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.GoodsReceipts.AsNoTracking();
            if (filterStatus.HasValue) q = q.Where(x => x.Status == filterStatus.Value);
            if (filterPo.HasValue) q = q.Where(x => x.PurchaseOrderId == filterPo.Value);
            if (filterLocation.HasValue) q = q.Where(x => x.ReceivedLocationId == filterLocation.Value);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(x => x.ReceivedAt).ThenByDescending(x => x.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<GoodsReceiptDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private void OpenCreate() { newReceipt = new CreateGoodsReceiptRequest(); receivedAt = DateTime.Today; dialogOpen = true; }

    private async Task CreateAsync()
    {
        saving = true;
        try
        {
            newReceipt.ReceivedAt = receivedAt;
            await using var db = await DbFactory.CreateDbContextAsync();
            var entity = newReceipt.ToEntity();
            db.GoodsReceipts.Add(entity);
            await db.SaveChangesAsync();
            Snackbar.Add($"Created {entity.ReceiptNumber}.", Severity.Success);
            dialogOpen = false;
            Navigation.NavigateTo($"logistics/receipts/{entity.Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { saving = false; }
    }

    private async Task<string?> GetUserNameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.IsAuthenticated == true ? state.User.Identity.Name : null;
    }
}
