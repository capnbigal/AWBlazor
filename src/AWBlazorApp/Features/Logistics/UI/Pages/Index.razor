@page "/logistics"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Logistics</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Logistics</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Receipts, shipments, transfers — every post writes inv.* ledger rows</MudText>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Inbox" Color="Color.Info" Value="@receiptDraftCount.ToString("N0")" Label="Receipt drafts" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Outbox" Color="Color.Warning" Value="@shipmentInProgress.ToString("N0")" Label="Shipments in progress" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.SyncAlt" Color="Color.Primary" Value="@transferInTransit.ToString("N0")" Label="Transfers in transit" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Value="@postedLast30.ToString("N0")" Label="Posted in last 30 days" /></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="mt-3">Modules</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Goods receipts" Subtitle="Inbound from POs and ad-hoc — every Post writes inv.* rows." Icon="@Icons.Material.Filled.Inbox" Href="logistics/receipts" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Shipments" Subtitle="Outbound to customers — pick, pack, ship." Icon="@Icons.Material.Filled.Outbox" Href="logistics/shipments" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Stock transfers" Subtitle="Inter-location, inter-org — two-phase with in-transit state." Icon="@Icons.Material.Filled.SyncAlt" Href="logistics/transfers" /></MudItem>
    </MudGrid>
</MudStack>

@code {
    private int receiptDraftCount, receiptPosted30Count;
    private int shipmentInProgress, shipmentShipped30;
    private int transferInTransit, transferCompleted30;
    private int postedLast30;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var since30 = DateTime.UtcNow.AddDays(-30);

        receiptDraftCount = await db.GoodsReceipts.CountAsync(r => r.Status == GoodsReceiptStatus.Draft);
        receiptPosted30Count = await db.GoodsReceipts.CountAsync(r => r.Status == GoodsReceiptStatus.Posted && r.PostedAt >= since30);

        shipmentInProgress = await db.Shipments.CountAsync(s => s.Status == ShipmentStatus.Draft || s.Status == ShipmentStatus.Picked || s.Status == ShipmentStatus.Packed);
        shipmentShipped30 = await db.Shipments.CountAsync(s => s.ShippedAt >= since30);

        transferInTransit = await db.StockTransfers.CountAsync(t => t.Status == StockTransferStatus.InTransit);
        transferCompleted30 = await db.StockTransfers.CountAsync(t => t.Status == StockTransferStatus.Completed && t.CompletedAt >= since30);

        postedLast30 = receiptPosted30Count + shipmentShipped30 + transferCompleted30;
    }
}
