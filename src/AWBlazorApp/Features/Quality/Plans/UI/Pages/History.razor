@page "/quality/inspection-plans/{Id:int}/history"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Plan history</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h5">Inspection plan #@Id audit history</MudText>
    <MudDataGrid T="InspectionPlanAuditLogDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" RowsPerPage="100">
        <Columns>
            <PropertyColumn Property="x => x.ChangedDate" Title="When" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.PlanCode" Title="Code" />
            <PropertyColumn Property="x => x.Action" Title="Action" />
            <PropertyColumn Property="x => x.ChangedBy" Title="By" />
            <PropertyColumn Property="x => x.ChangeSummary" Title="Summary" />
        </Columns>
        <PagerContent><MudDataGridPager T="InspectionPlanAuditLogDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    [Parameter] public int Id { get; set; }
    private MudDataGrid<InspectionPlanAuditLogDto> grid = null!;
    private bool _loading = true;

    private async Task<GridData<InspectionPlanAuditLogDto>> LoadAsync(GridState<InspectionPlanAuditLogDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var q = db.InspectionPlanAuditLogs.AsNoTracking().Where(a => a.InspectionPlanId == Id);
            var total = await q.CountAsync(ct);
            var rows = await q.OrderByDescending(a => a.ChangedDate).ThenByDescending(a => a.Id)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(a => a.ToDto()).ToListAsync(ct);
            return new GridData<InspectionPlanAuditLogDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }
}
