@page "/quality"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Quality</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Quality</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Plans, inspections, NCRs, CAPA — auto-triggered from Receipt / Shipment / Run posts</MudText>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Pending" Color="Color.Warning" Value="@pendingInspections.ToString("N0")" Label="Pending inspections" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Info" Value="@inProgressInspections.ToString("N0")" Label="In-progress" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Error" Value="@openNcrs.ToString("N0")" Label="Open NCRs" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Build" Color="Color.Primary" Value="@activeCapas.ToString("N0")" Label="Active CAPA cases" /></MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Rule" Color="Color.Primary" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6">Inspection plans</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Templates with characteristics + auto-trigger flags</MudText>
                    </MudStack>
                    <MudSpacer />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.List" Href="quality/inspection-plans">Open</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Info" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6">Inspections</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Record results, complete, auto-open NCR on Fail</MudText>
                    </MudStack>
                    <MudSpacer />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.List" Href="quality/inspections">Open</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6">Non-conformances</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Disposition: Scrap / Quarantine auto-post to inv ledger</MudText>
                    </MudStack>
                    <MudSpacer />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.List" Href="quality/ncrs">Open</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Engineering" Color="Color.Primary" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6">CAPA cases</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Investigation → CorrectiveAction → Verification → Closed</MudText>
                    </MudStack>
                    <MudSpacer />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.List" Href="quality/capa">Open</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private int pendingInspections, inProgressInspections, openNcrs, activeCapas;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        pendingInspections = await db.Inspections.CountAsync(i => i.Status == InspectionStatus.Pending);
        inProgressInspections = await db.Inspections.CountAsync(i => i.Status == InspectionStatus.InProgress);
        openNcrs = await db.NonConformances.CountAsync(n => n.Status != NonConformanceStatus.Closed);
        activeCapas = await db.CapaCases.CountAsync(c => c.Status != CapaStatus.Closed);
    }
}
