@page "/quality"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Quality</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Primary" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Quality</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Plans, inspections, NCRs, CAPA — auto-triggered from Receipt / Shipment / Run posts</MudText>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Pending" Color="Color.Warning" Value="@pendingInspections.ToString("N0")" Label="Pending inspections" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Info" Value="@inProgressInspections.ToString("N0")" Label="In-progress" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Error" Value="@openNcrs.ToString("N0")" Label="Open NCRs" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><KpiCard Icon="@Icons.Material.Filled.Build" Color="Color.Primary" Value="@activeCapas.ToString("N0")" Label="Active CAPA cases" /></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" Class="mt-3">Modules</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Inspection plans" Subtitle="Templates with characteristics + auto-trigger flags." Icon="@Icons.Material.Filled.Rule" Href="quality/inspection-plans" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Inspections" Subtitle="Record results, complete, auto-open NCR on Fail." Icon="@Icons.Material.Filled.FactCheck" Href="quality/inspections" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="Non-conformances" Subtitle="Disposition: Scrap / Quarantine auto-post to inv ledger." Icon="@Icons.Material.Filled.Warning" Href="quality/ncrs" /></MudItem>
        <MudItem xs="12" sm="6" md="4"><ModuleCard Title="CAPA cases" Subtitle="Investigation → CorrectiveAction → Verification → Closed." Icon="@Icons.Material.Filled.Engineering" Href="quality/capa" /></MudItem>
    </MudGrid>
</MudStack>

@code {
    private int pendingInspections, inProgressInspections, openNcrs, activeCapas;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        pendingInspections = await db.Inspections.CountAsync(i => i.Status == InspectionStatus.Pending);
        inProgressInspections = await db.Inspections.CountAsync(i => i.Status == InspectionStatus.InProgress);
        openNcrs = await db.NonConformances.CountAsync(n => n.Status != NonConformanceStatus.Closed);
        activeCapas = await db.CapaCases.CountAsync(c => c.Status != CapaStatus.Closed);
    }
}
