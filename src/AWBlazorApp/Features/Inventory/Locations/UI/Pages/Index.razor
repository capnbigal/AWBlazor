@page "/inventory/locations"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Inventory locations</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Inventory locations</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">inv.InventoryLocation — Warehouse → Zone → Bin tree</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="InventoryLocationKind?" @bind-Value="filterKind" Label="Kind" Variant="Variant.Outlined" Clearable="true" Style="max-width: 220px">
                <MudSelectItem T="InventoryLocationKind?" Value="@null">(any)</MudSelectItem>
                @foreach (var k in Enum.GetValues<InventoryLocationKind>())
                {
                    <MudSelectItem T="InventoryLocationKind?" Value="@k">@k</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="filterCode" Label="Code contains" Variant="Variant.Outlined" />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="InventoryLocationDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" Striped="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.Path" Title="Path" />
            <PropertyColumn Property="x => x.Code" Title="Code" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Kind" Title="Kind" />
            <PropertyColumn Property="x => x.Depth" Title="Depth" />
            <PropertyColumn Property="x => x.ParentLocationId" Title="Parent" />
            <PropertyColumn Property="x => x.OrgUnitId" Title="OrgUnit" />
            <TemplateColumn Title="Active" Sortable="false"><CellTemplate><BoolIndicator Value="context.Item.IsActive" /></CellTemplate></TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="InventoryLocationDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<InventoryLocationDto> grid = null!;
    private bool _loading = true;
    private InventoryLocationKind? filterKind;
    private string? filterCode;

    private async Task<GridData<InventoryLocationDto>> LoadAsync(GridState<InventoryLocationDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.InventoryLocations.AsNoTracking();
            if (filterKind.HasValue) query = query.Where(x => x.Kind == filterKind.Value);
            if (!string.IsNullOrWhiteSpace(filterCode)) { var n = filterCode.Trim(); query = query.Where(x => x.Code.Contains(n)); }
            var total = await query.CountAsync(ct);
            var rows = await query.OrderBy(x => x.Path).ThenBy(x => x.Code)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<InventoryLocationDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();
}
