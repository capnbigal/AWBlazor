@using AWBlazorApp.Features.Inventory.Dtos
@page "/inventory/transaction-types"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Transaction types</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Transaction types</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">inv.InventoryTransactionType — 20 seeded codes governing balance arithmetic and JSON emission</MudText>
    </MudStack>

    <MudSimpleTable Dense="true" Striped="true" Hover="true">
        <thead>
            <tr><th>Id</th><th>Code</th><th>Name</th><th>Sign</th><th>Approval</th><th>Emits JSON</th><th>Active</th></tr>
        </thead>
        <tbody>
            @foreach (var t in types)
            {
                <tr>
                    <td>@t.Id</td>
                    <td><strong>@t.Code</strong></td>
                    <td>@t.Name</td>
                    <td>@(t.Sign switch { > 0 => "+1", < 0 => "-1", _ => "0" })</td>
                    <td>@(t.RequiresApproval ? "✓" : "")</td>
                    <td>@(t.EmitsJson ? "✓" : "")</td>
                    <td>@(t.IsActive ? "✓" : "")</td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
</MudStack>

@code {
    private List<InventoryTransactionTypeDto> types = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        types = await db.InventoryTransactionTypes.AsNoTracking()
            .OrderBy(t => t.Id).Select(t => t.ToDto()).ToListAsync();
    }
}
