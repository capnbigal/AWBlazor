@using AWBlazorApp.Features.Inventory.Dtos
@page "/inventory/outbox"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Inventory outbox</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Outbox</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">inv.InventoryTransactionOutbox — JSON emission queue drained every minute by Hangfire</MudText>
    </MudStack>

    <MudPaper Class="pa-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="OutboxStatus?" @bind-Value="filterStatus" Label="Status" Variant="Variant.Outlined" Clearable="true" Style="max-width: 220px">
                <MudSelectItem T="OutboxStatus?" Value="@null">(any)</MudSelectItem>
                @foreach (var s in Enum.GetValues<OutboxStatus>())
                {
                    <MudSelectItem T="OutboxStatus?" Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ApplyFilter">Apply</MudButton>
        </MudStack>
    </MudPaper>

    <MudDataGrid T="InventoryOutboxDto" ServerData="LoadAsync" @ref="grid" Loading="@_loading" Dense="true" Hover="true" RowsPerPage="50">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="Id" />
            <PropertyColumn Property="x => x.InventoryTransactionId" Title="Transaction" />
            <PropertyColumn Property="x => x.Status" Title="Status" />
            <PropertyColumn Property="x => x.Attempts" Title="Attempts" />
            <PropertyColumn Property="x => x.NextAttemptAt" Title="Next" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.PublishedAt" Title="Published" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.CreatedAt" Title="Created" Format="yyyy-MM-dd HH:mm:ss" />
            <PropertyColumn Property="x => x.LastError" Title="Error" />
            <TemplateColumn Title="Actions" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="View payload"><MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ShowPayloadAsync(context.Item))" /></MudTooltip>
                        @if (context.Item.Status is OutboxStatus.Failed or OutboxStatus.DeadLetter)
                        {
                            <AuthorizeView Roles="@($"{AppRoles.Manager},{AppRoles.Admin}")" Context="auth">
                                <MudTooltip Text="Retry now"><MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Color="Color.Warning" OnClick="@(() => RetryAsync(context.Item))" /></MudTooltip>
                            </AuthorizeView>
                        }
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="InventoryOutboxDto" /></PagerContent>
    </MudDataGrid>
</MudStack>

@code {
    private MudDataGrid<InventoryOutboxDto> grid = null!;
    private bool _loading = true;
    private OutboxStatus? filterStatus;

    private async Task<GridData<InventoryOutboxDto>> LoadAsync(GridState<InventoryOutboxDto> state, CancellationToken ct)
    {
        _loading = true; await InvokeAsync(StateHasChanged);
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync(ct);
            var query = db.InventoryTransactionOutbox.AsNoTracking();
            if (filterStatus.HasValue) query = query.Where(x => x.Status == filterStatus.Value);
            var total = await query.CountAsync(ct);
            var rows = await query.OrderByDescending(x => x.CreatedAt)
                .Skip(state.Page * state.PageSize).Take(state.PageSize)
                .Select(x => x.ToDto()).ToListAsync(ct);
            return new GridData<InventoryOutboxDto> { Items = rows, TotalItems = total };
        }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplyFilter() => await grid.ReloadServerData();

    private async Task ShowPayloadAsync(InventoryOutboxDto row)
    {
        string pretty;
        try { pretty = System.Text.Json.JsonSerializer.Serialize(System.Text.Json.JsonDocument.Parse(row.Payload), new System.Text.Json.JsonSerializerOptions { WriteIndented = true }); }
        catch { pretty = row.Payload; }
        await DialogService.ShowMessageBoxAsync($"Outbox {row.Id} payload",
            (MarkupString)($"<pre style='white-space:pre-wrap;font-size:12px;'>{System.Net.WebUtility.HtmlEncode(pretty)}</pre>"),
            yesText: "Close");
    }

    private async Task RetryAsync(InventoryOutboxDto row)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.InventoryTransactionOutbox.FirstOrDefaultAsync(x => x.Id == row.Id);
        if (entity is null) return;
        entity.Status = OutboxStatus.Pending;
        entity.NextAttemptAt = DateTime.UtcNow;
        entity.LastError = null;
        await db.SaveChangesAsync();
        Snackbar.Add("Queued for retry.", Severity.Success);
        await grid.ReloadServerData();
    }
}
