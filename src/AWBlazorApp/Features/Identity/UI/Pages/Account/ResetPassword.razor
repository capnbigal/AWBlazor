@page "/Account/ResetPassword"

@attribute [ExcludeFromInteractiveRouting]
@attribute [Microsoft.AspNetCore.RateLimiting.EnableRateLimiting("auth")]

@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject NavigationManager NavigationManager

<PageTitle>Reset password</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" GutterBottom="true">Reset password</MudText>

        <StatusMessage Message="@Message" />

        <EditForm Model="Input" method="post" OnValidSubmit="OnValidSubmitAsync" FormName="reset-password">
            <DataAnnotationsValidator />
            <ValidationSummary class="form-validation-summary" role="alert" />

            @* Code is set from the query string in OnInitialized; round-trip it via a hidden input. *@
            <input type="hidden" name="Input.Code" value="@Input.Code" />

            <div class="form-field">
                <label for="reset-email" class="form-label">Email</label>
                <InputText id="reset-email"
                           @bind-Value="Input.Email"
                           type="email"
                           autocomplete="username"
                           class="form-control" />
                <ValidationMessage For="@(() => Input.Email)" class="form-error" />
            </div>

            <div class="form-field">
                <label for="reset-password" class="form-label">New password</label>
                <InputText id="reset-password"
                           @bind-Value="Input.Password"
                           type="password"
                           autocomplete="new-password"
                           class="form-control" />
                <ValidationMessage For="@(() => Input.Password)" class="form-error" />
            </div>

            <div class="form-field">
                <label for="reset-confirm" class="form-label">Confirm password</label>
                <InputText id="reset-confirm"
                           @bind-Value="Input.ConfirmPassword"
                           type="password"
                           autocomplete="new-password"
                           class="form-control" />
                <ValidationMessage For="@(() => Input.ConfirmPassword)" class="form-error" />
            </div>

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-2">
                Reset password
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private IEnumerable<IdentityError>? identityErrors;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    private string? Message =>
        identityErrors is null ? null : $"Error: {string.Join(", ", identityErrors.Select(e => e.Description))}";

    protected override void OnInitialized()
    {
        // The static-SSR form binder can null out Input on GET; restore it before any use.
        Input ??= new();

        if (Code is null)
        {
            RedirectManager.RedirectTo("Account/InvalidPasswordReset");
            return;
        }
        Input.Code = Code;
    }

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Input.Code));
        var result = await UserManager.ResetPasswordAsync(user, code, Input.Password);
        if (result.Succeeded)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        identityErrors = result.Errors;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare(nameof(Password), ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";

        public string Code { get; set; } = "";
    }
}
