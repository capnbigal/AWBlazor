@page "/Account/Manage/Disable2fa"

@attribute [ExcludeFromInteractiveRouting]

@using Microsoft.AspNetCore.Identity

@inject UserManager<ApplicationUser> UserManager
@inject IdentityUserAccessor UserAccessor
@inject IdentityRedirectManager RedirectManager
@inject ILogger<Disable2fa> Logger

<PageTitle>Disable 2FA</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" GutterBottom="true">Disable two-factor authentication</MudText>

        <ManageNavMenu />

        <MudAlert Severity="Severity.Warning" Class="my-3">
            Disabling 2FA does not change the keys used in authenticator apps. To change the
            key used in an authenticator app you should reset the authenticator key.
        </MudAlert>

        <EditForm Model="dummy" method="post" OnValidSubmit="OnSubmitAsync" FormName="disable-2fa">
            <AntiforgeryToken />
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Error">
                Disable 2FA
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private object? dummy { get; set; }

    protected override void OnInitialized() => dummy ??= new();

    protected override async Task OnInitializedAsync()
    {
        var user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        if (!await UserManager.GetTwoFactorEnabledAsync(user))
        {
            throw new InvalidOperationException("Cannot disable 2FA: it is not currently enabled for this user.");
        }
    }

    private async Task OnSubmitAsync()
    {
        var user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        var result = await UserManager.SetTwoFactorEnabledAsync(user, false);
        if (!result.Succeeded)
        {
            throw new InvalidOperationException("Unexpected error disabling 2FA.");
        }

        Logger.LogInformation("User has disabled 2FA.");
        RedirectManager.RedirectToWithStatus(
            "Account/Manage/TwoFactorAuthentication",
            "2FA has been disabled. You can re-enable it by setting up an authenticator app.",
            HttpContext);
    }
}
