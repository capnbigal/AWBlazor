# Copy this file to `.env` in /opt/awblazor on the droplet and fill in real values.
# `chmod 600 .env` after creating.
# NEVER COMMIT THE .env FILE.

# --- SQL Server ---------------------------------------------------------------
# Must be at least 8 chars, contain 3 of: uppercase, lowercase, digit, symbol.
SA_PASSWORD=CHANGE_ME_a_strong_password_here

# --- App image tag (optional) ------------------------------------------------
# If pulling from GHCR, this is the tag to pull. Defaults to "latest".
APP_TAG=latest

# --- SMTP (optional) ----------------------------------------------------------
# Leave blank to use an SMTP host that accepts localhost/no auth.
# For production, use a relay (SendGrid, Mailgun, SES).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@alibalib.com
SMTP_FROM_NAME=AWBlazor

# --- Demo / POC toggles ------------------------------------------------------
# When true, /Account/Login prefills admin@email.com / p@55wOrd. Flip and run
# `sudo docker compose up -d app` to apply (no rebuild needed).
DEMO_AUTOFILL_LOGIN=false

# --- External auth (optional) ------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
